# Copy this to the project root .env and fill in the values.
# The payment service reads the root .env directly — no separate file needed.

# ─── Stripe ──────────────────────────────────────────────────────────────────

# Real Stripe keys (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_example
STRIPE_PUBLISHABLE_KEY=pk_test_example
STRIPE_WEBHOOK_SECRET=whsec_example

# ─── Fake Stripe (local development) ────────────────────────────────────────
#
# Set USE_FAKE_STRIPE=true to route all Stripe calls to a local fake server.
# STRIPE_API_BASE must match the URL where localstripe / stripe-mock is running.
#
#   Option 1 — localstripe (recommended, default port 8420):
#     pip install localstripe && localstripe
#
#   Option 2 — stripe-mock (Docker, port 12111):
#     docker run --rm -p 12111:12111 stripe/stripe-mock
#
USE_FAKE_STRIPE=true
STRIPE_API_BASE=http://localhost:8420

# ─── Payment service ─────────────────────────────────────────────────────────
PAYMENT_SERVICE_PORT=3001
PAYMENT_SERVICE_URL=http://localhost:3001
