{% extends 'layout_admin.html.twig' %}

{% block title %}Admin - New Ticket Category{% endblock %}

{% block main %}
<div class="min-h-screen bg-[#020617] py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-4xl mx-auto space-y-8">
        <!-- Header -->
        <div class="flex items-center justify-between">
            <div>
                <h1 class="text-3xl font-bold text-white tracking-tight">New Ticket Category</h1>
                <p class="text-slate-400 mt-2">Add a new ticket category to the system</p>
            </div>
            <a href="{{ path('admin_category_ticket_index') }}" class="inline-flex items-center gap-2 px-4 py-2 bg-slate-800/50 hover:bg-slate-800 text-slate-300 border border-slate-700 rounded-lg font-medium transition-all text-sm">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
                </svg>
                Back
            </a>
        </div>

        <!-- Form Card -->
        <div class="bg-[#0f172a] rounded-2xl border border-slate-800 shadow-2xl overflow-hidden">
            <div class="bg-slate-800/30 px-8 py-5 border-b border-slate-800 flex items-center gap-3">
                <svg class="w-5 h-5 text-[#0FAF7A]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7"/>
                </svg>
                <h2 class="text-lg font-bold text-white">Category details</h2>
            </div>
            
            <div class="p-8">
                {% include 'admin/category/_form.html.twig' with { form: form } %}
            </div>
        </div>
    </div>
</div>
{% endblock %}
