{% extends 'layout_admin.html.twig' %}

{% block title %}Admin - Create Ticket{% endblock %}

{% block head %}
{{ parent() }}
<meta name="turbo-cache-control" content="no-cache">
{% endblock %}

{% block main %}
<div class="max-w-4xl mx-auto space-y-6">
    <!-- Header -->
    <div class="bg-gradient-to-br from-white to-slate-50 dark:from-slate-900 dark:to-slate-800 rounded-xl border border-slate-200 dark:border-slate-700 shadow-lg p-6">
        <div class="flex items-center justify-between">
            <div class="flex items-center gap-4">
                <div class="w-14 h-14 rounded-xl bg-gradient-to-br from-emerald-600 to-teal-600 flex items-center justify-center shadow-lg">
                    <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                    </svg>
                </div>
                <div>
                    <h1 class="text-2xl font-bold text-slate-900 dark:text-white">Create Ticket (Admin)</h1>
                    <p class="text-sm text-slate-600 dark:text-slate-400 mt-1">Create a ticket on behalf of a user</p>
                </div>
            </div>
            <a href="{{ path('admin_ticket_list') }}" class="inline-flex items-center gap-2 px-4 py-2 bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 text-slate-700 dark:text-slate-200 rounded-lg font-medium transition-all">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
                </svg>
                Back
            </a>
        </div>
    </div>

    <!-- Form -->
    <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 shadow-lg overflow-hidden">
        <div class="bg-gradient-to-r from-emerald-600 to-teal-600 px-6 py-4">

            <h2 class="text-lg font-bold text-white flex items-center gap-2">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                </svg>
                Ticket Details
            </h2>
        </div>

        <div class="p-6">
            {{ form_start(form, {'attr': {'class': 'space-y-6', 'data-turbo': 'false', 'novalidate': 'novalidate', 'data-validate': 'admin-ticket-create'}}) }}

                <div class="bg-slate-50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700 rounded-lg p-5">
                    <div class="flex items-center gap-2 mb-3">
                        <svg class="w-5 h-5 text-emerald-600 dark:text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">

                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                        </svg>
                        {{ form_label(form.createdBy, 'User (Client/Worker)', {'label_attr': {'class': 'text-sm font-semibold text-slate-700 dark:text-slate-300'}}) }}
                    </div>
                    
                    {# Search Input #}
                    <div class="mb-3">
                        <div class="relative">
                            <input 
                                type="text" 
                                id="user-search" 
                                placeholder="Search by username, name, or email..." 
                                class="block w-full rounded-lg border-slate-300 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-100 shadow-sm focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500 transition-all pl-10"

                                autocomplete="off"
                            />
                            <svg class="w-5 h-5 absolute left-3 top-1/2 transform -translate-y-1/2 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                            </svg>
                            
                            {# Search results dropdown #}
                            <div id="search-results" style="display: none; position: absolute; top: 100%; left: 0; right: 0; margin-top: 0.5rem; background: white; border: 1px solid #cbd5e1; border-radius: 0.5rem; box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04); max-height: 15rem; overflow-y: auto; z-index: 9999;" class="dark:bg-slate-800 dark:border-slate-700">
                                {# Search results will be populated here #}
                            </div>
                        </div>
                        
                        {# Selected user display #}
                        <div id="selected-user" class="mt-2 p-3 bg-emerald-50 dark:bg-emerald-900/20 border border-emerald-200 dark:border-emerald-700 rounded-lg" style="display: none;">
                            <div class="flex items-center justify-between">
                                <div class="flex items-center gap-2">
                                    <svg class="w-4 h-4 text-emerald-600 dark:text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                    </svg>
                                    <span class="text-sm font-medium text-emerald-900 dark:text-emerald-100" id="selected-user-text"></span>
                                </div>
                                <button type="button" id="clear-selection" class="text-emerald-600 hover:text-emerald-800 dark:text-emerald-400 dark:hover:text-emerald-200">

                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                                    </svg>
                                </button>
                            </div>
                        </div>
                    </div>
                    
                    {# Hidden select - visually hidden but still accessible for form validation #}
                    <div style="position: absolute; left: -9999px; width: 1px; height: 1px; overflow: hidden;">
                        {{ form_widget(form.createdBy) }}
                    </div>
                    {{ form_errors(form.createdBy) }}
                    <p class="mt-2 text-xs text-slate-500 dark:text-slate-400">Select the user for whom you're creating this ticket</p>
                </div>

                <div class="bg-slate-50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700 rounded-lg p-5">
                    <div class="flex items-center gap-2 mb-3">
                        <svg class="w-5 h-5 text-emerald-600 dark:text-teal-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">

                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 20l4-16m2 16l4-16M6 9h14M4 15h14"/>
                        </svg>
                        {{ form_label(form.subject, 'Subject', {'label_attr': {'class': 'text-sm font-semibold text-slate-700 dark:text-slate-300'}}) }}
                    </div>
                    {{ form_widget(form.subject, {'attr': {'class': 'block w-full rounded-lg border-slate-300 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-100 shadow-sm focus:border-emerald-500 focus:ring-2 focus:ring-teal-500 transition-all', 'placeholder': 'Brief description of the issue'}}) }}

                    {{ form_errors(form.subject) }}
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div class="bg-slate-50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700 rounded-lg p-5">
                        <div class="flex items-center gap-2 mb-3">
                            <svg class="w-5 h-5 text-emerald-600 dark:text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/>
                            </svg>
                            {{ form_label(form.category, 'Category', {'label_attr': {'class': 'text-sm font-semibold text-slate-700 dark:text-slate-300'}}) }}
                        </div>
                        {{ form_widget(form.category, {'attr': {'class': 'block w-full rounded-lg border-slate-300 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-100 shadow-sm focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500 transition-all'}}) }}
                        {{ form_errors(form.category) }}
                    </div>

                    <div class="bg-slate-50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700 rounded-lg p-5">
                        <div class="flex items-center gap-2 mb-3">
                            <svg class="w-5 h-5 text-amber-600 dark:text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
                            </svg>
                            {{ form_label(form.priority, 'Priority', {'label_attr': {'class': 'text-sm font-semibold text-slate-700 dark:text-slate-300'}}) }}
                        </div>
                        {{ form_widget(form.priority, {'attr': {'class': 'block w-full rounded-lg border-slate-300 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-100 shadow-sm focus:border-amber-500 focus:ring-2 focus:ring-amber-500 transition-all'}}) }}
                        {{ form_errors(form.priority) }}
                    </div>
                </div>

                <div class="bg-slate-50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700 rounded-lg p-5">
                    <div class="flex items-center gap-2 mb-3">
                        <svg class="w-5 h-5 text-emerald-600 dark:text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">

                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/>
                        </svg>
                        {{ form_label(form.message, 'Message', {'label_attr': {'class': 'text-sm font-semibold text-slate-700 dark:text-slate-300'}}) }}
                    </div>
                    {{ form_widget(form.message, {'attr': {'class': 'block w-full rounded-lg border-slate-300 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-100 shadow-sm focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500 transition-all resize-none', 'rows': 6, 'placeholder': 'Describe the issue in detail...'}}) }}

                    {{ form_errors(form.message) }}
                </div>

                <div class="bg-slate-50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700 rounded-lg p-5">
                    {{ form_label(form.attachment, 'Attachment (optional)', {'label_attr': {'class': 'block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-3'}}) }}
                    {{ form_widget(form.attachment, {'attr': {'class': 'block w-full text-sm text-slate-500 dark:text-slate-300 file:mr-4 file:py-2.5 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-gradient-to-r file:from-emerald-50 file:to-teal-50 file:text-emerald-700 hover:file:from-emerald-100 hover:file:to-teal-100 file:transition-all file:cursor-pointer dark:file:from-emerald-900/50 dark:file:to-teal-900/50 dark:file:text-emerald-300'}}) }}

                    {{ form_errors(form.attachment) }}
                    <p class="mt-2 text-xs text-slate-500 dark:text-slate-400">Max 10MB. Allowed: PDF, Word, images, ZIP/RAR</p>
                </div>

                {{ form_widget(form._token) }}

                <div class="flex items-center justify-end gap-3 pt-6 border-t border-slate-200 dark:border-slate-800">
                    <a href="{{ path('admin_ticket_list') }}" class="inline-flex items-center gap-2 px-6 py-2.5 bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 text-slate-700 dark:text-slate-200 rounded-lg font-medium transition-all">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                        </svg>
                        Cancel
                    </a>
                    <button type="submit" class="inline-flex items-center gap-2 px-6 py-2.5 bg-gradient-to-r from-emerald-600 to-teal-600 hover:from-emerald-700 hover:to-teal-700 text-white rounded-lg font-semibold transition-all shadow-lg shadow-emerald-500/30 hover:shadow-emerald-500/50">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
                        </svg>
                        Create Ticket
                    </button>
                </div>

            {{ form_end(form, {'render_rest': false}) }}
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
// Track if click handler is already attached (to prevent duplicates)
let clickHandlerAttached = false;

// Function to initialize the search
function initializeUserSearch() {
    console.log('Initializing user search...');
    
    const searchInput = document.getElementById('user-search');
    const searchResults = document.getElementById('search-results');
    
    // Check if already initialized to prevent duplicate event listeners
    if (searchInput && searchInput.dataset.initialized === 'true') {
        console.log('Search already initialized, skipping...');
        return;
    }
    // Try both possible IDs for the select element
    let userSelect = document.getElementById('user-select');
    if (!userSelect) {
        userSelect = document.getElementById('admin_ticket_createdBy');
        console.log('Using auto-generated ID: admin_ticket_createdBy');
    } else {
        console.log('Using custom ID: user-select');
    }
    
    // Also try to find it by name if ID doesn't work
    if (!userSelect) {
        userSelect = document.querySelector('select[name="admin_ticket[createdBy]"]');
        if (userSelect) {
            console.log('Found select by name attribute');
        }
    }
    
    let searchTimeout;

    console.log('Elements found:', {
        searchInput: !!searchInput,
        searchResults: !!searchResults,
        userSelect: !!userSelect,
        userSelectId: userSelect ? userSelect.id : 'NOT FOUND'
    });

    if (!searchInput || !searchResults || !userSelect) {
        console.error('Search elements not found - Debug info:', {
            searchInput: searchInput,
            searchResults: searchResults,
            userSelect: userSelect,
            allSelects: document.querySelectorAll('select'),
            pageHTML: document.body.innerHTML.substring(0, 500)
        });
        // Try to find ANY select on the page
        const anySelect = document.querySelector('select');
        if (anySelect) {
            console.log('Found a select element:', anySelect);
            console.log('Select attributes:', {
                id: anySelect.id,
                name: anySelect.name,
                className: anySelect.className
            });
        }
        return;
    }
    
    console.log('Search initialized successfully!');
    
    // Mark as initialized to prevent duplicate event listeners
    searchInput.dataset.initialized = 'true';

    // Prevent form submission when pressing Enter in search
    searchInput.addEventListener('keydown', function(e) {
        if (e.key === 'Enter') {
            e.preventDefault();
            return false;
        }
    });

    // Helper function to escape HTML
    function escapeHtml(text) {
        const map = {
            '&': '&amp;',
            '<': '&lt;',
            '>': '&gt;',
            '"': '&quot;',
            "'": '&#039;'
        };
        return text.replace(/[&<>"']/g, m => map[m]);
    }

    // Get selected user elements
    const selectedUserDiv = document.getElementById('selected-user');
    const selectedUserText = document.getElementById('selected-user-text');
    const clearSelectionBtn = document.getElementById('clear-selection');

    // Clear selection handler
    if (clearSelectionBtn) {
        clearSelectionBtn.addEventListener('click', function(e) {
            e.preventDefault();
            userSelect.value = '';
            searchInput.value = '';
            selectedUserDiv.style.display = 'none';
            searchInput.focus();
        });
    }

    // Handle search input
    searchInput.addEventListener('input', function(e) {
        e.preventDefault();
        clearTimeout(searchTimeout);
        const query = this.value.trim();

        if (query.length < 2) {
            searchResults.style.display = 'none';
            searchResults.innerHTML = '';
            return;
        }

        // Show loading state immediately
        searchResults.innerHTML = '<div class="p-3 text-sm text-slate-500 dark:text-slate-400">Searching...</div>';
        searchResults.style.display = 'block';
        console.log('Search results shown');

        searchTimeout = setTimeout(() => {
            console.log('Searching for:', query);
            fetch(`{{ path('admin_ticket_search_users') }}?q=${encodeURIComponent(query)}`)
                .then(response => {
                    if (!response.ok) {
                        throw new Error('Network response was not ok');
                    }
                    return response.json();
                })
                .then(users => {
                    console.log('Found users:', users);
                    
                    if (users.length === 0) {
                        searchResults.innerHTML = '<div class="p-3 text-sm text-slate-500 dark:text-slate-400">No users found</div>';
                        searchResults.style.display = 'block';
                        return;
                    }

                    let resultsHTML = '<div class="divide-y divide-slate-200 dark:divide-slate-700">';
                    users.forEach(user => {
                        resultsHTML += `
                            <div class="p-3 hover:bg-slate-100 dark:hover:bg-slate-700 cursor-pointer transition-colors user-result" data-user-id="${user.id}" data-username="${escapeHtml(user.username)}">
                                <div class="flex items-center gap-3">
                                    <div class="flex-shrink-0 w-8 h-8 rounded-full bg-gradient-to-br from-emerald-500 to-teal-500 flex items-center justify-center text-white font-semibold text-sm">

                                        ${user.username.charAt(0).toUpperCase()}
                                    </div>
                                    <div class="flex-1 min-w-0">
                                        <div class="text-sm font-semibold text-slate-900 dark:text-white truncate">
                                            ${escapeHtml(user.username)}
                                        </div>
                                        <div class="text-xs text-slate-500 dark:text-slate-400 truncate">
                                            ${escapeHtml(user.fullName)} - ${escapeHtml(user.email)}
                                        </div>
                                    </div>
                                    <span class="inline-flex items-center px-2 py-1 rounded text-xs font-medium ${user.role === 'CLIENT' ? 'bg-emerald-100 text-emerald-700 dark:bg-emerald-900/50 dark:text-emerald-300' : 'bg-emerald-100 text-emerald-700 dark:bg-emerald-900/50 dark:text-emerald-300'}">

                                        ${user.role}
                                    </span>
                                </div>
                            </div>
                        `;
                    });
                    resultsHTML += '</div>';

                    searchResults.innerHTML = resultsHTML;
                    searchResults.style.display = 'block';

                    // Add click handlers to results
                    document.querySelectorAll('.user-result').forEach(result => {
                        result.addEventListener('click', function(e) {
                            e.preventDefault();
                            const userId = this.dataset.userId;
                            const username = this.dataset.username;
                            const userInfo = this.querySelector('.text-xs').textContent.trim();
                            
                            console.log('Selected user:', userId, username);
                            
                            // Set the hidden select value
                            userSelect.value = userId;
                            
                            // Update UI
                            searchInput.value = '';
                            searchResults.style.display = 'none';
                            
                            // Show selected user
                            selectedUserText.textContent = `${username} - ${userInfo}`;
                            selectedUserDiv.style.display = 'block';
                            
                            // Trigger change event on select
                            userSelect.dispatchEvent(new Event('change', { bubbles: true }));
                        });
                    });
                })
                .catch(error => {
                    console.error('Search error:', error);
                    searchResults.innerHTML = '<div class="p-3 text-sm text-red-500">Error searching users. Please try again.</div>';
                    searchResults.style.display = 'block';
                });
        }, 200);
    });

    // Close search results when clicking outside (only attach once globally)
    if (!clickHandlerAttached) {
        document.addEventListener('click', function(e) {
            const currentSearchInput = document.getElementById('user-search');
            const currentSearchResults = document.getElementById('search-results');
            
            if (currentSearchInput && currentSearchResults) {
                if (!currentSearchInput.contains(e.target) && !currentSearchResults.contains(e.target)) {
                    currentSearchResults.style.display = 'none';
                }
            }
        });
        clickHandlerAttached = true;
    }

    // Focus search input when clicking on it
    searchInput.addEventListener('focus', function() {
        if (this.value.trim().length >= 2 && searchResults.innerHTML.trim() !== '') {
            searchResults.style.display = 'block';
        }
    });
}

// Initialize on both DOMContentLoaded and Turbo events
document.addEventListener('DOMContentLoaded', initializeUserSearch);

// Turbo Drive events (for when navigating with Turbo)
document.addEventListener('turbo:load', initializeUserSearch);
document.addEventListener('turbo:render', initializeUserSearch);

// Also run immediately if DOM is already loaded
if (document.readyState === 'loading') {
    // Still loading, wait for DOMContentLoaded
} else {
    // DOM already loaded, initialize now
    initializeUserSearch();
}
</script>
{% endblock %}
