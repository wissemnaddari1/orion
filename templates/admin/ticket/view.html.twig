{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('vendor/frappe-gantt/frappe-gantt.umd.js') }}"></script>

    {# أ”أ¶أ‡أ”أ¶أ‡ Sidebar collapsible toggle أ”أ¶أ‡أ”أ¶أ‡ #}
    <script>
    function toggleSidebarSection(id) {
        const el = document.getElementById(id);
        const chevron = document.getElementById(id + '-chevron');
        if (!el) return;
        el.classList.toggle('expanded');
        if (chevron) chevron.classList.toggle('rotated');
    }
    </script>

    {# أ”أ¶أ‡أ”أ¶أ‡ Collapsible messages أ”أ¶أ‡أ”أ¶أ‡ #}
    <script>
    document.addEventListener('DOMContentLoaded', function() {
        const LINE_HEIGHT = 20;
        const MAX_LINES = 5;
        const THRESHOLD = LINE_HEIGHT * MAX_LINES;

        document.querySelectorAll('[data-msg-body]').forEach(function(body) {
            if (body.scrollHeight > THRESHOLD + 20) {
                body.classList.add('msg-body-collapsed');
                const toggle = body.parentElement.querySelector('[data-msg-toggle]');
                if (toggle) {
                    toggle.classList.remove('hidden');
                    toggle.addEventListener('click', function() {
                        const isCollapsed = body.classList.contains('msg-body-collapsed');
                        body.classList.toggle('msg-body-collapsed');
                        toggle.textContent = isCollapsed ? 'Show less أ”أ»â”¤' : 'Show more أ”أ»آ¥';
                    });
                }
            }
        });

        {# أ”أ¶أ‡أ”أ¶أ‡ Attachment file label أ”أ¶أ‡أ”أ¶أ‡ #}
        const attachInput = document.getElementById('admin-reply-attachment');
        const attachLabel = document.getElementById('admin-attachment-label');
        if (attachInput && attachLabel) {
            attachInput.addEventListener('change', function() {
                attachLabel.textContent = this.files.length ? this.files[0].name : 'Attach file';
            });
        }
    });
    </script>

    {# أ”أ¶أ‡أ”أ¶أ‡ Gantt Chart أ”أ¶أ‡أ”أ¶أ‡ #}
    <script>
        function printTicketTimeline() {
            const ganttSection = document.getElementById('gantt-section');
            const chevron = document.getElementById('gantt-section-chevron');
            if (ganttSection && !ganttSection.classList.contains('expanded')) {
                ganttSection.classList.add('expanded');
            }
            if (chevron && !chevron.classList.contains('rotated')) {
                chevron.classList.add('rotated');
            }

            const weekBtn = document.querySelector('[data-ticket-gantt-view="Week"]');
            if (weekBtn) weekBtn.click();

            document.body.classList.add('printing-ticket-timeline');
            setTimeout(() => {
                window.print();
                setTimeout(() => {
                    document.body.classList.remove('printing-ticket-timeline');
                }, 300);
            }, 120);
        }

        (function () {
            function initTicketLifecycleGantt() {
                const container = document.getElementById('ticket-lifecycle-gantt');
                if (!container) return;

                if (typeof Gantt === 'undefined') {
                    container.innerHTML = '<p class="text-sm text-slate-500 dark:text-slate-400">Loading timeline...</p>';
                    setTimeout(initTicketLifecycleGantt, 150);
                    return;
                }

                const now = new Date();
                const nowStr = now.toISOString().split('T')[0];

                const createdAt = '{{ ticket.createdAt ? ticket.createdAt|date("Y-m-d") : "" }}';
                const acknowledgedAt = '{{ ticket.acknowledgedAt ? ticket.acknowledgedAt|date("Y-m-d") : "" }}';
                const closedAt = '{{ ticket.closedAt ? ticket.closedAt|date("Y-m-d") : "" }}';
                const status = '{{ ticket.status }}';

                if (!createdAt) {
                    container.innerHTML = '<p class="text-sm text-slate-500 dark:text-slate-400">No date information available.</p>';
                    return;
                }

                const tasks = [];

                const openEnd = acknowledgedAt || closedAt || nowStr;
                let openEndDate = new Date(openEnd);
                const openStartDate = new Date(createdAt);
                if (openEndDate <= openStartDate) openEndDate = new Date(openStartDate.getTime() + 86400000);
                tasks.push({
                    id: 'phase-created',
                    name: 'Open / Created',
                    start: createdAt,
                    end: openEndDate.toISOString().split('T')[0],
                    progress: 100,
                    custom_class: 'bar-phase-created'
                });

                if (acknowledgedAt) {
                    const ackEnd = closedAt || nowStr;
                    let ackEndDate = new Date(ackEnd);
                    const ackStartDate = new Date(acknowledgedAt);
                    if (ackEndDate <= ackStartDate) ackEndDate = new Date(ackStartDate.getTime() + 86400000);

                    const inProgressProgress = status === 'CLOSED' ? 100 : (status === 'IN_PROGRESS' ? 60 : 40);
                    tasks.push({
                        id: 'phase-in-progress',
                        name: 'In Progress',
                        start: acknowledgedAt,
                        end: ackEndDate.toISOString().split('T')[0],
                        progress: inProgressProgress,
                        custom_class: 'bar-phase-in_progress',
                        dependencies: 'phase-created'
                    });
                }

                if (status === 'WAITING_USER') {
                    const wuStart = acknowledgedAt || createdAt;
                    const wuStartDate = new Date(wuStart);
                    let wuEndDate = new Date(nowStr);
                    if (wuEndDate <= wuStartDate) wuEndDate = new Date(wuStartDate.getTime() + 86400000);
                    tasks.push({
                        id: 'phase-waiting',
                        name: 'Waiting User',
                        start: wuStartDate.toISOString().split('T')[0],
                        end: wuEndDate.toISOString().split('T')[0],
                        progress: 50,
                        custom_class: 'bar-phase-waiting_user',
                        dependencies: acknowledgedAt ? 'phase-in-progress' : 'phase-created'
                    });
                }

                if (closedAt) {
                    const closedStartDate = new Date(closedAt);
                    const closedEndDate = new Date(closedStartDate.getTime() + 86400000);
                    tasks.push({
                        id: 'phase-closed',
                        name: 'Closed / Resolved',
                        start: closedAt,
                        end: closedEndDate.toISOString().split('T')[0],
                        progress: 100,
                        custom_class: 'bar-phase-closed',
                        dependencies: acknowledgedAt ? 'phase-in-progress' : 'phase-created'
                    });
                }

                if (tasks.length === 0) return;

                container.style.overflowX = 'auto';
                container.style.overflowY = 'hidden';

                const columnWidths = { Day: 24, Week: 80, Month: 60 };
                const defaultMode = container.dataset.viewMode || 'Day';

                const renderGantt = (mode) => {
                    container.innerHTML = '';
                    container.dataset.viewMode = mode;
                    new Gantt(container, tasks, {
                        view_mode: mode,
                        bar_height: 22,
                        bar_corner_radius: 4,
                        column_width: columnWidths[mode] || 30,
                        padding: 18,
                        infinite_padding: false,
                        scroll_to: 'start',
                        today_button: false,
                        readonly: true,
                        readonly_dates: true,
                        readonly_progress: true,
                        popup: ({ task, set_title, set_subtitle, set_details }) => {
                            set_title(task.name);
                            set_subtitle('From ' + task.start + ' to ' + task.end);
                            set_details('Progress: ' + task.progress + '%');
                        }
                    });
                };

                renderGantt(defaultMode);

                const viewButtons = document.querySelectorAll('[data-ticket-gantt-view]');
                viewButtons.forEach((btn) => {
                    if (btn.dataset.ganttBound === '1') return;
                    btn.dataset.ganttBound = '1';
                    btn.addEventListener('click', () => {
                        const mode = btn.dataset.ticketGanttView;
                        renderGantt(mode);

                        viewButtons.forEach((b) => {
                            b.classList.remove('bg-emerald-600', 'text-white');
                            b.classList.add('text-slate-600', 'dark:text-slate-300');
                        });
                        btn.classList.add('bg-emerald-600', 'text-white');
                        btn.classList.remove('text-slate-600', 'dark:text-slate-300');
                    });
                });

                const activeMode = container.dataset.viewMode || 'Day';
                viewButtons.forEach((b) => {
                    const isActive = b.dataset.ticketGanttView === activeMode;
                    b.classList.toggle('bg-emerald-600', isActive);
                    b.classList.toggle('text-white', isActive);
                    if (!isActive) {
                        b.classList.add('text-slate-600', 'dark:text-slate-300');
                    } else {
                        b.classList.remove('text-slate-600', 'dark:text-slate-300');
                    }
                });
            }

            initTicketLifecycleGantt();
            document.addEventListener('DOMContentLoaded', initTicketLifecycleGantt);
            document.addEventListener('turbo:load', initTicketLifecycleGantt);
            document.addEventListener('turbo:render', initTicketLifecycleGantt);
            window.addEventListener('pageshow', initTicketLifecycleGantt);
        })();
    </script>

    {# أ”أ¶أ‡أ”أ¶أ‡ AJAX Reply + Moderation أ”أ¶أ‡أ”أ¶أ‡ #}
    <script>
    document.addEventListener('DOMContentLoaded', function() {
        const replyForm = document.querySelector('form[data-validate="admin-ticket-reply"]');
        if (!replyForm) return;

        const textarea = replyForm.querySelector('textarea');
        const errorBox = document.getElementById('admin-moderation-error');
        const errorText = document.getElementById('admin-moderation-error-text');
        const submitBtn = replyForm.querySelector('button[type="submit"]');

        replyForm.addEventListener('submit', function(e) {
            e.preventDefault();

            // Hide previous error
            if (errorBox) {
                errorBox.classList.add('hidden');
                errorBox.classList.remove('animate-shake-admin');
            }
            if (textarea) {
                textarea.classList.remove('border-red-500', 'ring-2', 'ring-red-300');
            }

            // Disable button, show loading
            const originalBtnHTML = submitBtn.innerHTML;
            submitBtn.disabled = true;
            submitBtn.innerHTML = `
                <svg class="w-4 h-4 animate-spin mr-1.5" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
                Sending...
            `;

            // Send via AJAX
            const formData = new FormData(replyForm);

            fetch(replyForm.action, {
                method: 'POST',
                body: formData,
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                }
            })
            .then(async response => {
                const data = await response.json().catch(() => null);

                if (!response.ok || (data && data.success === false)) {
                    const errorMessage = (data && (data.error || data.message)) || 'Your message contains inappropriate content and cannot be sent. Please revise your message.';

                    if (errorBox) {
                        errorText.textContent = errorMessage;
                        errorBox.classList.remove('hidden');
                        void errorBox.offsetWidth;
                        errorBox.classList.add('animate-shake-admin');
                    }
                    if (textarea) {
                        textarea.classList.add('border-red-500', 'ring-2', 'ring-red-300');
                        textarea.focus();
                    }

                    submitBtn.disabled = false;
                    submitBtn.innerHTML = originalBtnHTML;
                    return;
                }

                // Success أ”أ‡أ¶ reload page
                window.location.reload();
            })
            .catch(error => {
                console.error('Error:', error);
                replyForm.removeEventListener('submit', arguments.callee);
                replyForm.submit();
            });
        });

        // Clear error when typing
        if (textarea) {
            textarea.addEventListener('input', function() {
                if (errorBox && !errorBox.classList.contains('hidden')) {
                    errorBox.classList.add('hidden');
                    textarea.classList.remove('border-red-500', 'ring-2', 'ring-red-300');
                }
            });
        }
    });
    </script>
