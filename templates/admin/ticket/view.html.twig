{% extends 'layout_admin.html.twig' %}

{% block title %}Admin - Ticket #{{ ticket.id }} - {{ ticket.subject }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('vendor/frappe-gantt/frappe-gantt.css') }}">
    <style>
        .gantt .bar-wrapper.bar-phase-created .bar { fill: #3b82f6; }
        .gantt .bar-wrapper.bar-phase-created .bar-progress { fill: #2563eb; }
        .gantt .bar-wrapper.bar-phase-in_progress .bar { fill: #f59e0b; }
        .gantt .bar-wrapper.bar-phase-in_progress .bar-progress { fill: #d97706; }
        .gantt .bar-wrapper.bar-phase-acknowledged .bar { fill: #10b981; }
        .gantt .bar-wrapper.bar-phase-acknowledged .bar-progress { fill: #059669; }
        .gantt .bar-wrapper.bar-phase-closed .bar { fill: #64748b; }
        .gantt .bar-wrapper.bar-phase-closed .bar-progress { fill: #475569; }
        .gantt .bar-wrapper.bar-phase-waiting_user .bar { fill: #a855f7; }
        .gantt .bar-wrapper.bar-phase-waiting_user .bar-progress { fill: #9333ea; }
        .gantt-container { border-radius: 8px; overflow-x: auto !important; }
        .gantt .bar-label { font-size: 11px; font-weight: 500; }
        #ticket-lifecycle-gantt .gantt-container { max-width: 100%; }
        #ticket-lifecycle-gantt svg.gantt { max-width: none; }
        #ticket-lifecycle-gantt .lower-text, #ticket-lifecycle-gantt .upper-text { font-size: 10px !important; }
        #ticket-lifecycle-gantt .gantt .grid-header { overflow: visible; }

        /* Collapsible message body */
        .msg-body-collapsed {
            max-height: 6rem;
            overflow: hidden;
            position: relative;
        }
        .msg-body-collapsed::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 2rem;
            background: linear-gradient(transparent, var(--msg-fade, #ffffff));
        }
        .dark .msg-body-collapsed::after {
            --msg-fade: #0f172a;
        }

        /* Sidebar sticky */
        .ticket-sidebar {
            position: sticky;
            top: 1rem;
            max-height: calc(100vh - 2rem);
            overflow-y: auto;
        }
        .ticket-sidebar::-webkit-scrollbar { width: 4px; }
        .ticket-sidebar::-webkit-scrollbar-thumb { background: #94a3b8; border-radius: 4px; }

        /* Smooth expand animation */
        .sidebar-collapsible-content {
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.3s ease-out;
        }
        .sidebar-collapsible-content.expanded {
            max-height: 600px;
        }
        .collapse-chevron {
            transition: transform 0.2s ease;
        }
        .collapse-chevron.rotated {
            transform: rotate(180deg);
        }

        /* Message hover */
        .msg-card:hover {
            border-color: #10b981;
        }

        @keyframes shake-admin {
            0%, 100% { transform: translateX(0); }
            10%, 30%, 50%, 70%, 90% { transform: translateX(-4px); }
            20%, 40%, 60%, 80% { transform: translateX(4px); }
        }
        .animate-shake-admin {
            animation: shake-admin 0.5s ease-in-out;
        }

        /* Print enhancements for ticket timeline */
        @media print {
            @page {
                size: A4 landscape;
                margin: 10mm;
            }

            .no-print {
                display: none !important;
            }

            .ticket-sidebar {
                position: static !important;
                max-height: none !important;
                overflow: visible !important;
            }

            .sidebar-collapsible-content {
                max-height: none !important;
                overflow: visible !important;
            }

            body.printing-ticket-timeline .ticket-sidebar > :not(.print-gantt-card) {
                display: none !important;
            }

            body.printing-ticket-timeline .print-gantt-card {
                border: 1px solid #cbd5e1 !important;
                box-shadow: none !important;
                break-inside: avoid;
                page-break-inside: avoid;
                background: #ffffff !important;
            }

            body.printing-ticket-timeline #ticket-lifecycle-gantt {
                overflow: visible !important;
            }

            body.printing-ticket-timeline #ticket-lifecycle-gantt .gantt-container {
                overflow: visible !important;
            }

            body.printing-ticket-timeline #ticket-lifecycle-gantt svg.gantt {
                width: 100% !important;
                height: auto !important;
            }

            body.printing-ticket-timeline .gantt .bar-label,
            body.printing-ticket-timeline .gantt .lower-text,
            body.printing-ticket-timeline .gantt .upper-text {
                fill: #0f172a !important;
                color: #0f172a !important;
                font-weight: 600 !important;
            }
        }
    </style>
{% endblock %}

{% block main %}
<div class="max-w-[1400px] mx-auto">

    {# أ”أ²أ‰أ”أ²أ‰أ”أ²أ‰ TOP HEADER BAR أ”أ²أ‰أ”أ²أ‰أ”أ²أ‰ #}
    <div class="bg-gradient-to-r from-emerald-600 to-teal-600 rounded-xl px-6 py-4 mb-6 shadow-lg">
        <div class="flex items-center justify-between flex-wrap gap-3">
            <div class="flex-1 min-w-0">
                <div class="flex items-center gap-3">
                    <a href="{{ path('admin_ticket_list') }}" class="text-white/70 hover:text-white transition-colors flex-shrink-0" title="Back to tickets">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
                        </svg>
                    </a>
                    <div class="min-w-0">
                        <h1 class="text-xl font-bold text-white truncate">{{ ticket.subject }}</h1>
                        <p class="text-sm text-emerald-100 mt-0.5">
                            <span class="font-semibold">Ticket #{{ ticket.id }}</span>
                            أ”أ‡أ³ {{ ticket.createdAt|date('M d, Y H:i') }}
                            أ”أ‡أ³ {{ ticket.createdBy.firstName ~ ' ' ~ ticket.createdBy.lastName }}
                        </p>
                    </div>
                </div>
            </div>
            <div class="flex items-center gap-3 flex-shrink-0">
                {# Status Badge #}
                {% if ticket.status == 'OPEN' %}
                    <span class="px-3 py-1 text-xs font-bold rounded-full bg-blue-500 text-white">آ­ئ’أ¶أپ OPEN</span>
                {% elseif ticket.status == 'IN_PROGRESS' %}
                    <span class="px-3 py-1 text-xs font-bold rounded-full bg-amber-500 text-white">آ­ئ’ئ’أ، IN PROGRESS</span>
                {% elseif ticket.status == 'WAITING_USER' %}
                    <span class="px-3 py-1 text-xs font-bold rounded-full bg-purple-500 text-white">آ­ئ’ئ’أ؛ WAITING USER</span>
                {% elseif ticket.status == 'CLOSED' %}
                    <span class="px-3 py-1 text-xs font-bold rounded-full bg-slate-500 text-white">أ”آ£أ  CLOSED</span>
                {% endif %}
                {# Acknowledge Button #}
                {% if not ticket.acknowledgedByAd %}
                    <form method="POST" action="{{ path('admin_ticket_acknowledge', {'id': ticket.id}) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('acknowledge' ~ ticket.id) }}">
                        <button type="submit" class="inline-flex items-center px-3 py-1.5 bg-white/20 hover:bg-white/30 backdrop-blur-sm text-white rounded-lg text-sm font-medium transition-all border border-white/30">
                            <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                            </svg>
                            Acknowledge
                        </button>
                    </form>
                {% else %}
                    <div class="px-3 py-1.5 bg-white/20 backdrop-blur-sm text-white rounded-lg text-sm border border-white/30 flex items-center gap-1.5">
                        <svg class="w-4 h-4 text-green-300" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"/>
                        </svg>
                        <span class="font-semibold">Acknowledged</span>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>

    {# أ”أ²أ‰أ”أ²أ‰أ”أ²أ‰ SPLIT PANE LAYOUT أ”أ²أ‰أ”أ²أ‰أ”أ²أ‰ #}
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_380px] gap-6 items-start">

        {# أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡ #}
        {#  LEFT COLUMN أ”أ‡أ¶ Conversation Thread + Reply Form        #}
        {# أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡ #}
        <div class="space-y-0">

            {# أ”أ¶أ‡أ”أ¶أ‡ Conversation Header أ”أ¶أ‡أ”أ¶أ‡ #}
            <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-t-xl px-5 py-3 flex items-center justify-between">
                <h2 class="text-sm font-bold text-slate-700 dark:text-slate-200 flex items-center gap-2">
                    <svg class="w-4 h-4 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/>
                    </svg>
                    Conversation
                </h2>
                <span class="text-xs text-slate-500 dark:text-slate-400">{{ messages|length }} message{{ messages|length != 1 ? 's' : '' }}</span>
            </div>

            {# أ”أ¶أ‡أ”أ¶أ‡ Message Thread أ”أ¶أ‡أ”أ¶أ‡ #}
            <div class="bg-slate-50 dark:bg-slate-950 border-x border-slate-200 dark:border-slate-800 divide-y divide-slate-200 dark:divide-slate-800">
                {% for message in messages %}
                    {% set isAdmin = message.senderRole == 'ADMIN' %}
                    {% set isInternal = message.isInternal %}

                    <div class="msg-card px-5 py-4 transition-colors duration-150 {% if isInternal %}bg-amber-50/60 dark:bg-amber-900/10{% elseif isAdmin %}bg-emerald-50/30 dark:bg-emerald-900/5{% else %}bg-white dark:bg-slate-900{% endif %}">
                        {# Message header: avatar + name + badge + timestamp #}
                        <div class="flex items-center gap-3 mb-2">
                            <div class="w-8 h-8 rounded-full flex items-center justify-center text-white text-xs font-bold flex-shrink-0 shadow-sm
                                {% if isInternal %}bg-amber-500
                                {% elseif isAdmin %}bg-gradient-to-br from-emerald-500 to-teal-600
                                {% else %}bg-gradient-to-br from-slate-500 to-slate-600{% endif %}">
                                {% if isInternal %}
                                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z"/></svg>
                                {% else %}
                                    {{ message.sender.firstName|first }}{{ message.sender.lastName|first }}
                                {% endif %}
                            </div>
                            <div class="flex items-center gap-2 flex-wrap flex-1 min-w-0">
                                <span class="font-semibold text-sm text-slate-800 dark:text-slate-200">{{ message.sender.firstName ~ ' ' ~ message.sender.lastName }}</span>
                                {% if isInternal %}
                                    <span class="px-1.5 py-0.5 text-[10px] font-bold uppercase rounded bg-amber-500 text-white leading-none">Internal Note</span>
                                {% elseif isAdmin %}
                                    <span class="px-1.5 py-0.5 text-[10px] font-bold uppercase rounded bg-gradient-to-r from-emerald-500 to-teal-600 text-white leading-none">Admin</span>
                                {% elseif message.senderRole == 'WORKER' %}
                                    <span class="px-1.5 py-0.5 text-[10px] font-bold uppercase rounded bg-gradient-to-r from-green-500 to-emerald-600 text-white leading-none">Worker</span>
                                {% else %}
                                    <span class="px-1.5 py-0.5 text-[10px] font-bold uppercase rounded bg-slate-500 text-white leading-none">Client</span>
                                {% endif %}
                            </div>
                            <span class="text-xs text-slate-400 dark:text-slate-500 flex-shrink-0 tabular-nums">
                                {{ message.createdAt|date('M d, H:i') }}
                                {% if message.isEdited %}<span class="italic ml-1">(edited)</span>{% endif %}
                            </span>
                        </div>

                        {# Message body أ”أ‡أ¶ collapsible #}
                        <div class="pl-11">
                            <div class="msg-body text-sm text-slate-700 dark:text-slate-300 whitespace-pre-line break-words" data-msg-body>{{ message.message }}</div>
                            <button type="button" class="msg-toggle hidden text-xs text-emerald-600 dark:text-emerald-400 hover:text-emerald-800 dark:hover:text-emerald-300 font-medium mt-1 cursor-pointer" data-msg-toggle>
                                Show more أ”أ»آ¥
                            </button>

                            {# Attachment #}
                            {% if message.fileName %}
                                <div class="mt-3 pt-3 border-t border-slate-200 dark:border-slate-700">
                                    {% set fileExtension = message.fileName|split('.')|last|lower %}
                                    {% if fileExtension in ['jpg', 'jpeg', 'png', 'gif', 'webp', 'svg'] %}
                                        <a href="{{ message.filePath }}" target="_blank" class="block group">
                                            <img src="{{ message.filePath }}" alt="{{ message.fileName }}" class="max-w-xs max-h-48 rounded-lg border border-slate-300 dark:border-slate-600 group-hover:opacity-90 transition-opacity">
                                            <span class="text-xs text-slate-500 dark:text-slate-400 mt-1 inline-block">{{ message.fileName }} ({{ (message.fileSize / 1024)|round(2) }} KB)</span>
                                        </a>
                                    {% else %}
                                        <a href="{{ message.filePath }}" target="_blank" class="inline-flex items-center text-sm text-emerald-600 dark:text-emerald-400 hover:text-emerald-800 dark:hover:text-emerald-300 font-medium">
                                            <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13"></path>
                                            </svg>
                                            {{ message.fileName }} <span class="text-xs opacity-75 ml-1">({{ (message.fileSize / 1024)|round(2) }} KB)</span>
                                        </a>
                                    {% endif %}
                                </div>
                            {% endif %}
                        </div>
                    </div>
                {% else %}
                    <div class="px-5 py-12 text-center text-slate-400 dark:text-slate-500">
                        <svg class="w-12 h-12 mx-auto mb-3 opacity-30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/>
                        </svg>
                        <p class="text-sm">No messages yet</p>
                    </div>
                {% endfor %}
            </div>

            {# أ”أ¶أ‡أ”أ¶أ‡ Reply Form (pinned at bottom of conversation) أ”أ¶أ‡أ”أ¶أ‡ #}
            <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-b-xl shadow-sm">
                <div class="px-5 py-3 border-b border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-800/50">
                    <h3 class="text-sm font-bold text-slate-700 dark:text-slate-200 flex items-center gap-2">
                        <svg class="w-4 h-4 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
                        </svg>
                        Reply
                    </h3>
                </div>
                <div class="p-5">
                    {{ form_start(replyForm, {'action': path('admin_ticket_reply', {'id': ticket.id}), 'attr': {'class': 'space-y-3', 'data-validate': 'admin-ticket-reply', 'novalidate': 'novalidate'}}) }}
                        {# Textarea #}
                        <div>
                            {{ form_widget(replyForm.message, {'attr': {'class': 'block w-full rounded-lg border-slate-300 dark:border-slate-700 dark:bg-slate-950 dark:text-slate-100 shadow-sm focus:border-emerald-500 focus:ring-emerald-500 transition-all text-sm', 'rows': 3, 'placeholder': 'Type your reply...'}}) }}
                            {{ form_errors(replyForm.message) }}
                            <div id="admin-moderation-error" class="hidden mt-3 p-3 rounded-lg bg-red-50 dark:bg-red-900/20 border border-red-300 dark:border-red-700 animate-shake-admin">
                                <div class="flex items-center gap-2">
                                    <svg class="w-5 h-5 text-red-600 dark:text-red-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.732 16.5c-.77.833.192 2.5 1.732 2.5z"/>
                                    </svg>
                                    <div>
                                        <p class="font-semibold text-sm text-red-800 dark:text-red-300">Message Blocked</p>
                                        <p id="admin-moderation-error-text" class="text-xs text-red-700 dark:text-red-400 mt-0.5">Your message contains inappropriate content and cannot be sent.</p>
                                    </div>
                                </div>
                            </div>
                        </div>

                        {# Bottom row: internal note + attachment + send button #}
                        <div class="flex items-center justify-between gap-3 flex-wrap">
                            <div class="flex items-center gap-4">
                                {% if replyForm.isInternal is defined %}
                                    <label class="flex items-center gap-2 cursor-pointer px-3 py-1.5 bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-700 rounded-lg hover:bg-amber-100 dark:hover:bg-amber-900/30 transition-colors">
                                        {{ form_widget(replyForm.isInternal, {'attr': {'class': 'h-3.5 w-3.5 text-amber-600 focus:ring-amber-500 border-amber-300 dark:border-amber-700 rounded cursor-pointer'}}) }}
                                        <span class="text-xs font-medium text-amber-800 dark:text-amber-300">Internal Note</span>
                                    </label>
                                {% endif %}
                                <label class="flex items-center gap-1.5 cursor-pointer text-xs text-slate-500 dark:text-slate-400 hover:text-emerald-600 dark:hover:text-emerald-400 transition-colors">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13"></path>
                                    </svg>
                                    {{ form_widget(replyForm.attachment, {'attr': {'class': 'hidden', 'id': 'admin-reply-attachment'}}) }}
                                    <span id="admin-attachment-label">Attach file</span>
                                </label>
                            </div>
                            {{ form_widget(replyForm._token) }}
                            <button type="submit" class="inline-flex items-center px-5 py-2 bg-gradient-to-r from-emerald-600 to-teal-600 hover:from-emerald-700 hover:to-teal-700 text-white rounded-lg text-sm font-medium transition-all shadow-md shadow-emerald-500/25 hover:shadow-emerald-500/40">
                                <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
                                </svg>
                                Send
                            </button>
                        </div>
                    {{ form_end(replyForm, {'render_rest': false}) }}
                </div>
            </div>
        </div>


        {# أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡أ”أ¶أ‡ #}
        {#  RIGHT COLUMN أ”أ‡أ¶ Sticky Sidebar                         #}
