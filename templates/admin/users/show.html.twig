{% extends 'layout_admin.html.twig' %}

{% block title %}{{ user.fullName }} - User Details - Orion{% endblock %}

{% block main %}
<div class="max-w-4xl mx-auto space-y-6">
    <div class="flex items-center justify-between">
        <a href="{{ path('admin_users_index') }}"
           class="inline-flex items-center gap-2 text-slate-600 hover:text-slate-900 dark:text-slate-400 dark:hover:text-white">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
            </svg>
            Back to Users
        </a>
        <div class="flex gap-2">
            {% if not user.emailVerified %}
                <form method="post" action="{{ path('admin_users_verify_email', {id: user.id}) }}">

                    <button type="submit"
                            class="px-4 py-2 bg-emerald-600 text-white rounded-lg hover:bg-emerald-700 transition">
                        Verify Email
                    </button>
                </form>
            {% endif %}
            <a href="{{ path('admin_users_edit', {id: user.id}) }}"
               class="px-4 py-2 bg-emerald-600 text-white rounded-lg hover:bg-emerald-700 transition">

                Edit User
            </a>
            <form method="post" action="{{ path('admin_users_delete', {id: user.id}) }}"
                  onsubmit="return confirm('Are you sure you want to delete this user?');">

                <button type="submit"
                        class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition">
                    Delete
                </button>
            </form>
        </div>
    </div>

    <div class="bg-white dark:bg-slate-900 rounded-lg border border-slate-200 dark:border-slate-800 p-6">
        <div class="flex items-start gap-6">
            <div class="flex-shrink-0">
                {% if user.profilePicture %}
                    <img src="{{ asset(user.profilePicture) }}"
                         alt="{{ user.fullName }}"
                         class="w-24 h-24 rounded-full object-cover">
                {% else %}
                    <div class="w-24 h-24 rounded-full bg-emerald-600 flex items-center justify-center text-white text-2xl font-bold">
                        {{ user.firstName|first|upper }}{{ user.lastName|first|upper }}
                    </div>
                {% endif %}
            </div>
            <div class="flex-1">
                <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-1">{{ user.fullName }}</h2>
                <p class="text-slate-500 dark:text-slate-400">@{{ user.username }}</p>
                <div class="mt-3 flex flex-wrap gap-2">
                    <span class="px-2 py-1 text-xs font-semibold rounded-full bg-slate-100 text-slate-800 dark:bg-slate-800 dark:text-slate-400">
                        {{ user.role ? user.role.value : 'N/A' }}
                    </span>
                    <span class="px-2 py-1 text-xs font-semibold rounded-full bg-slate-100 text-slate-800 dark:bg-slate-800 dark:text-slate-400">
                        {{ user.status ? user.status.value : 'N/A' }}
                    </span>
                </div>
            </div>
        </div>
    </div>

    <div class="bg-white dark:bg-slate-900 rounded-lg border border-slate-200 dark:border-slate-800 p-6">
        <h3 class="text-lg font-semibold text-slate-900 dark:text-white mb-4">Account Details</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm text-slate-700 dark:text-slate-300">
            <div><span class="text-slate-500">Email:</span> {{ user.email }}</div>
            <div><span class="text-slate-500">Phone:</span> {{ user.phone ?: '-' }}</div>
            <div><span class="text-slate-500">Email Verified:</span> {{ user.emailVerified ? 'Yes' : 'No' }}</div>
            <div><span class="text-slate-500">Phone Verified:</span> {{ user.phoneVerified ? 'Yes' : 'No' }}</div>
            <div><span class="text-slate-500">Two Factor Enabled:</span> {{ user.twoFactorEnabled ? 'Yes' : 'No' }}</div>
            <div><span class="text-slate-500">Account Balance:</span> {{ user.accountBalance }} {{ user.walletCurrency }}</div>
        </div>
    </div>

    <div class="bg-white dark:bg-slate-900 rounded-lg border border-slate-200 dark:border-slate-800 p-6">
        <h3 class="text-lg font-semibold text-slate-900 dark:text-white mb-4">Location</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm text-slate-700 dark:text-slate-300">
            <div><span class="text-slate-500">Country:</span> {{ user.country ?: '-' }}</div>
            <div><span class="text-slate-500">City:</span> {{ user.city ?: '-' }}</div>
            <div><span class="text-slate-500">Timezone:</span> {{ user.timezone ?: '-' }}</div>
        </div>
    </div>

    <div class="bg-white dark:bg-slate-900 rounded-lg border border-slate-200 dark:border-slate-800 p-6">
        <h3 class="text-lg font-semibold text-slate-900 dark:text-white mb-4">Timestamps</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm text-slate-700 dark:text-slate-300">
            <div><span class="text-slate-500">Created At:</span> {{ user.createdAt ? user.createdAt|date('Y-m-d H:i') : '-' }}</div>
            <div><span class="text-slate-500">Updated At:</span> {{ user.updatedAt ? user.updatedAt|date('Y-m-d H:i') : '-' }}</div>
        </div>
    </div>
</div>
{% endblock %}
