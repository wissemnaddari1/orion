{# templates/components/_admin_topbar.html.twig
   Admin-only topbar: NO navigation links.
   Contains only:
   - Mobile sidebar toggle (hamburger)
   - Notifications icon
   - Theme toggle
   - User profile dropdown #}

{% set _current_route = app.request.attributes.get('_route') ?? '' %}

{# Profile / role state, reusing the same logic as the main topbar #}
{% set _has_client = is_granted('ROLE_CLIENT') %}
{% set _has_freelancer = is_granted('ROLE_WORKER') %}
{% set _has_both_roles = _has_client and _has_freelancer %}
{% set _session_state = (app.session is defined and app.session is not null) ? app.session.get('orion_active_state') : null %}

{% if is_granted('ROLE_ADMIN') %}
    {% set _profile_state = 'ADMIN' %}
{% elseif _has_both_roles and _session_state == 'client' %}
    {% set _profile_state = 'CLIENT' %}
{% elseif _has_both_roles and _session_state == 'freelancer' %}
    {% set _profile_state = 'FREELANCER' %}
{% elseif _current_route starts with 'admin_' %}
    {% set _profile_state = 'ADMIN' %}
{% elseif _current_route starts with 'worker_' %}
    {% set _profile_state = 'FREELANCER' %}
{% elseif _current_route starts with 'client_' or _current_route starts with 'request_' %}
    {% set _profile_state = 'CLIENT' %}
{% elseif _session_state == 'client' and _has_client %}
    {% set _profile_state = 'CLIENT' %}
{% elseif _session_state == 'freelancer' and _has_freelancer %}
    {% set _profile_state = 'FREELANCER' %}
{% else %}
    {% set _profile_state = app.user ? (app.user.role.value == 'WORKER' ? 'FREELANCER' : (app.user.role.value == 'CLIENT' ? 'CLIENT' : app.user.role.value)) : 'CLIENT' %}
{% endif %}

{% set _profile_state_label = _profile_state ~ ' • Admin' %}

<header class="admin-topbar sticky top-0 z-30 shrink-0 w-full bg-white/95 backdrop-blur dark:bg-slate-950/85">
    <div class="flex h-full min-h-[var(--admin-header-height,72px)] items-center justify-between gap-3 px-3 sm:px-4 lg:px-6">

        {# Left: mobile sidebar toggle #}
        <div class="flex items-center gap-2">
            <button type="button"
                    class="inline-flex lg:hidden h-10 w-10 items-center justify-center rounded-xl
                           border border-slate-200 bg-white text-slate-700
                           dark:border-slate-800 dark:bg-slate-950 dark:text-slate-200"
                    aria-label="Open admin navigation"
                    @click="sidebarOpen = true">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
                </svg>
            </button>

            <div class="hidden sm:flex flex-col">
                <span class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-400 dark:text-slate-600">
                    Admin
                </span>
                <span class="text-sm font-semibold text-slate-900 dark:text-slate-100 truncate max-w-[12rem] md:max-w-xs">
                    {{ title|default('Dashboard') }}
                </span>
            </div>
        </div>

        {# Right: notifications, theme toggle, user profile dropdown #}
        <div class="flex flex-shrink-0 items-center gap-2 sm:gap-3">

            {# 🔔 Notifications dropdown #}
            <div class="relative" x-data="{ open: false }" @click.away="open = false" data-notification-bell-wrap>
                <button type="button"
                        @click="open = !open; if (open) window.NotificationDropdown && window.NotificationDropdown.load()"
                        :aria-expanded="open"
                        aria-label="Notifications"
                        aria-haspopup="true"
                        data-notification-bell
                        class="relative inline-flex h-10 w-10 items-center justify-center rounded-xl
                               border border-slate-200 bg-white text-slate-700 transition hover:bg-slate-50
                               dark:border-slate-800 dark:bg-slate-950 dark:text-slate-200 dark:hover:bg-slate-900/40">

                    <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none"
                         viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11
                                 a6 6 0 10-12 0v3.159c0 .538-.214 1.055-.595 1.436L4 17h5
                                 m6 0a3 3 0 11-6 0m6 0H9" />
                    </svg>

                    <span id="notification-badge"
                          class="absolute -top-1.5 -right-1.5 inline-flex h-5 min-w-[20px]
                                 items-center justify-center rounded-full bg-emerald-600 px-1
                                 text-[11px] font-extrabold text-white"
                          {% if (notification_count|default(0)) == 0 %} style="display: none;"{% endif %}>
                        {{ notification_count|default(0) }}
                    </span>
                </button>

                <div x-show="open"
                     x-transition:enter="transition ease-out duration-200"
                     x-transition:enter-start="opacity-0 scale-95"
                     x-transition:enter-end="opacity-100 scale-100"
                     x-transition:leave="transition ease-in duration-150"
                     x-transition:leave-start="opacity-100 scale-100"
                     x-transition:leave-end="opacity-0 scale-95"
                     class="absolute right-0 mt-2 w-[380px] max-w-[calc(100vw-2rem)] origin-top-right rounded-2xl
                            border border-slate-200 bg-white shadow-xl
                            dark:border-slate-800 dark:bg-slate-900 z-50"
                     style="display: none;"
                     id="notification-dropdown-panel"
                     @keydown.escape.window="open = false"
                     role="dialog"
                     aria-label="Notifications">
                    <div id="notification-dropdown-content" class="rounded-2xl overflow-hidden">
                        <div class="flex items-center justify-center py-8 text-slate-400">
                            <span class="text-sm">Loading…</span>
                        </div>
                    </div>
                </div>
            </div>

            {# 🌙 / ☀️ Theme Toggle #}
            <button type="button"
                    onclick="window.toggleTheme()"
                    aria-label="Toggle theme"
                    class="inline-flex h-10 w-10 items-center justify-center rounded-xl
                           border border-slate-200 bg-white text-slate-700 transition hover:bg-slate-50
                           dark:border-slate-800 dark:bg-slate-950 dark:text-slate-200 dark:hover:bg-slate-900/40">

                {# Moon (shown in LIGHT mode) #}
                <svg class="h-5 w-5 dark:hidden" xmlns="http://www.w3.org/2000/svg" fill="none"
                     viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M21 12.79A9 9 0 1111.21 3
                             a7 7 0 009.79 9.79z" />
                </svg>

                {# Sun (shown in DARK mode) #}
                <svg class="hidden h-5 w-5 dark:block" xmlns="http://www.w3.org/2000/svg" fill="none"
                     viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M12 3v2m0 14v2m9-9h-2M5 12H3
                             m15.364-6.364l-1.414 1.414
                             M6.05 17.95l-1.414 1.414
                             M17.95 17.95l-1.414-1.414
                             M6.05 6.05L4.636 4.636
                             M12 8a4 4 0 100 8 4 4 0 000-8z" />
                </svg>
            </button>

            {# User Profile Dropdown (copied from main topbar, without dashboard shortcuts) #}
            <div class="relative" x-data="{ open: false }" @click.away="open = false">
                <button @click="open = !open"
                        type="button"
                        class="inline-flex h-10 items-center gap-2 rounded-xl
                               border border-slate-200 bg-white px-3 text-sm font-semibold text-slate-900
                               transition hover:bg-slate-50
                               dark:border-slate-800 dark:bg-slate-950 dark:text-white dark:hover:bg-slate-900/70">

                    {% if app.user %}
                        {% if app.user.profilePicture %}
                            {% set profilePicPath = app.user.profilePicture starts with '/'
                                ? app.user.profilePicture
                                : 'uploads/profile/' ~ app.user.profilePicture %}
                            <img src="{{ asset(profilePicPath) }}"
                                 alt="{{ app.user.fullName }}"
                                 class="h-7 w-7 rounded-full object-cover border-2 border-emerald-500"
                                 onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
                            <div class="h-7 w-7 items-center justify-center rounded-full bg-emerald-600 text-xs font-bold text-white hidden" style="display: none;">
                                {{ app.user.firstName[0]|default('U') }}{{ app.user.lastName[0]|default('') }}
                            </div>
                        {% else %}
                            <div class="flex h-7 w-7 items-center justify-center rounded-full bg-emerald-600 text-xs font-bold text-white">
                                {{ app.user.firstName[0]|default('U') }}{{ app.user.lastName[0]|default('') }}
                            </div>
                        {% endif %}

                        <span class="hidden sm:inline">{{ app.user.fullName|default(app.user.username) }}</span>

                        <svg class="h-4 w-4 transition-transform duration-200"
                             :class="{ 'rotate-180': open }"
                             fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                        </svg>
                    {% else %}
                        <span>{{ user_name|default('Guest') }}</span>
                    {% endif %}
                </button>

                <div x-show="open"
                     x-transition:enter="transition ease-out duration-200"
                     x-transition:enter-start="opacity-0 scale-95"
                     x-transition:enter-end="opacity-100 scale-100"
                     x-transition:leave="transition ease-in duration-150"
                     x-transition:leave-start="opacity-100 scale-100"
                     x-transition:leave-end="opacity-0 scale-95"
                     class="absolute right-0 mt-2 w-80 origin-top-right rounded-2xl
                            border border-slate-200 bg-white shadow-xl
                            dark:border-slate-800 dark:bg-slate-900"
                     style="display: none;">

                    {% if app.user %}
                        <div class="border-b border-slate-100 p-4 dark:border-slate-800">
                            <div class="flex items-start gap-3">
                                {% if app.user.profilePicture %}
                                    {% set profilePicPath = app.user.profilePicture starts with '/'
                                        ? app.user.profilePicture
                                        : 'uploads/profile/' ~ app.user.profilePicture %}
                                    <img src="{{ asset(profilePicPath) }}"
                                         alt="{{ app.user.fullName }}"
                                         class="h-14 w-14 rounded-full object-cover border-2 border-emerald-500"
                                         onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
                                    <div class="h-14 w-14 items-center justify-center rounded-full bg-gradient-to-br from-emerald-500 to-emerald-600 text-xl font-bold text-white shadow-lg hidden" style="display: none;">
                                        {{ app.user.firstName[0]|default('U') }}{{ app.user.lastName[0]|default('') }}
                                    </div>
                                {% else %}
                                    <div class="flex h-14 w-14 items-center justify-center rounded-full bg-gradient-to-br from-emerald-500 to-emerald-600 text-xl font-bold text-white shadow-lg">
                                        {{ app.user.firstName[0]|default('U') }}{{ app.user.lastName[0]|default('') }}
                                    </div>
                                {% endif %}

                                <div class="flex-1 min-w-0">
                                    <p class="text-sm font-bold text-slate-900 dark:text-white truncate">
                                        {{ app.user.fullName|default(app.user.username) }}
                                    </p>
                                    <p class="text-xs text-slate-500 dark:text-slate-400 truncate">
                                        {{ app.user.email }}
                                    </p>
                                    <div class="mt-1 inline-flex items-center gap-1.5">
                                        <span class="inline-flex items-center gap-1.5 rounded-full px-2 py-0.5 text-xs font-semibold
                                                     {% if _profile_state == 'ADMIN' %}
                                                        bg-purple-100 text-purple-700 dark:bg-purple-900/30 dark:text-purple-300
                                                     {% elseif _profile_state == 'CLIENT' %}
                                                        bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-300
                                                     {% else %}
                                                        bg-emerald-100 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-300
                                                     {% endif %}">
                                            {% if app.user.status.value == 'ACTIVE' %}
                                                <span class="flex h-1.5 w-1.5 rounded-full bg-current opacity-80" aria-hidden="true"></span>
                                            {% endif %}
                                            {{ _profile_state_label }}
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="p-2">
                            <a href="{{ path('profile_show') }}"
                               class="flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium text-slate-700
                                      transition hover:bg-slate-100 dark:text-slate-300 dark:hover:bg-slate-800">
                                <svg class="h-5 w-5 text-slate-500 dark:text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                          d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                                </svg>
                                <span>View Profile</span>
                            </a>

                            <a href="{{ path('profile_edit') }}"
                               class="flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium text-slate-700
                                      transition hover:bg-slate-100 dark:text-slate-300 dark:hover:bg-slate-800">
                                <svg class="h-5 w-5 text-slate-500 dark:text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                          d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                                </svg>
                                <span>Edit Profile</span>
                            </a>

                            <button @click="document.getElementById('profile-picture-modal').showModal(); open = false"
                                    type="button"
                                    class="flex w-full items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium text-slate-700
                                           transition hover:bg-slate-100 dark:text-slate-300 dark:hover:bg-slate-800">
                                <svg class="h-5 w-5 text-slate-500 dark:text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                          d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/>
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/>
                                </svg>
                                <span>Change Picture</span>
                            </button>

                            <div class="my-2 border-t border-slate-200 dark:border-slate-800"></div>

                            <a href="{{ path('settings_privacy_security') }}"
                               class="flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium text-slate-700
                                      transition hover:bg-slate-100 dark:text-slate-300 dark:hover:bg-slate-800">
                                <svg class="h-5 w-5 text-slate-500 dark:text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                          d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
                                </svg>
                                <span>Privacy & Security</span>
                            </a>

                            <div class="my-2 border-t border-slate-200 dark:border-slate-800"></div>

                            <a href="{{ path('app_logout') }}"
                               onclick="(function(e) {
                                 e.preventDefault();
                                 if (this.dataset.loggingOut === 'true') return false;
                                 this.dataset.loggingOut = 'true';
                                 try { localStorage.removeItem('token'); } catch (err) {}
                                 window.location.href = '{{ path('app_logout') }}';
                                 return false;
                               }).call(this, event);"
                               class="flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium text-red-600
                                      transition hover:bg-red-50 dark:text-red-400 dark:hover:bg-red-900/20">
                                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                          d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                                </svg>
                                <span>Sign Out</span>
                            </a>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</header>

