{# _badge.html.twig
   Parameters: text (string), variant (success|warning|danger|info|neutral), size (sm|md), pill (bool) #}
{% set variant_classes = {
    success: 'bg-emerald-100 text-[#008F6A] border-emerald-200',
    warning: 'bg-[#FFF1A8]/80 text-[#3F3F3F] border-amber-200',
    danger: 'bg-red-100 text-red-700 border-red-200',
    info: 'bg-blue-100 text-blue-700 border-blue-200',
    neutral: 'bg-gray-100 text-[#3F3F3F] border-gray-200'
} %}
{% set size_classes = (size|default('md')) == 'sm' ? 'px-2 py-0.5 text-xs' : 'px-2.5 py-1 text-sm' %}
<span class="inline-flex items-center font-medium border rounded-full {{ variant_classes[variant|default('neutral')] }} {{ size_classes }} {{ pill|default(true) ? 'rounded-full' : 'rounded-md' }}"
      role="status">{{ text|default('—') }}</span>
