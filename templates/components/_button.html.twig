{# _button.html.twig
   Parameters: label (string), variant (primary|secondary|outline|ghost), size (sm|md|lg), type (button|submit|reset), href (optional, renders as <a>), disabled (bool), icon (optional), full_width (bool) #}
{% set variant_classes = {
    primary: 'bg-gradient-to-r from-[#0FAF7A] to-[#008F6A] text-white shadow-md hover:shadow-lg hover:opacity-95 focus:ring-2 focus:ring-[#0FAF7A] focus:ring-offset-2',
    secondary: 'bg-[#3F3F3F] text-white hover:bg-[#2d2d2d] focus:ring-2 focus:ring-[#3F3F3F] focus:ring-offset-2',
    outline: 'border-2 border-[#0FAF7A] text-[#0FAF7A] bg-transparent hover:bg-[#0FAF7A]/10 focus:ring-2 focus:ring-[#0FAF7A] focus:ring-offset-2',
    ghost: 'text-[#3F3F3F] hover:bg-gray-100 focus:ring-2 focus:ring-gray-200'
} %}
{% set size_classes = {
    sm: 'px-3 py-1.5 text-sm',
    md: 'px-4 py-2 text-sm',
    lg: 'px-6 py-3 text-base'
} %}
{% set base = 'inline-flex items-center justify-center gap-2 font-medium rounded-lg transition-all duration-200 disabled:opacity-50 disabled:cursor-not-allowed ' ~ variant_classes[variant|default('primary')] ~ ' ' ~ size_classes[size|default('md')] %}
{% if full_width|default(false) %}{% set base = base ~ ' w-full' %}{% endif %}

{% if href is defined and href %}
    <a href="{{ href }}" class="{{ base }}" role="button">
        {% if icon is defined %}<span aria-hidden="true">{{ icon }}</span>{% endif %}
        {{ label|default('Button') }}
    </a>
{% else %}
    <button type="{{ type|default('button') }}" class="{{ base }}" {{ disabled|default(false) ? 'disabled' : '' }}>
        {% if icon is defined %}<span aria-hidden="true">{{ icon }}</span>{% endif %}
        {{ label|default('Button') }}
    </button>
{% endif %}
