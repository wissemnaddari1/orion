{# _empty_state.html.twig
   Parameters: title (string), description (string), icon (optional), action_label (optional), action_path (optional) #}
<div class="flex flex-col items-center justify-center rounded-xl border-2 border-dashed border-gray-200 bg-gray-50/50 py-12 px-6 text-center">
    {% if icon is defined and icon %}
        <div class="mb-4 text-4xl text-[#3F3F3F]/60" aria-hidden="true">{{ icon }}</div>
    {% else %}
        <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"/>
        </svg>
    {% endif %}
    <h3 class="text-base font-semibold text-[#000000]">{{ title|default('No items yet') }}</h3>
    <p class="mt-2 max-w-sm text-sm text-[#3F3F3F]">{{ description|default('Get started by creating your first item.') }}</p>
    {% if action_label is defined and action_label %}
        <div class="mt-6">
            {% include 'components/_button.html.twig' with { label: action_label, href: action_path|default('#'), variant: 'primary' } %}
        </div>
    {% endif %}
</div>
