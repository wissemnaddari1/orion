{# _footer.html.twig
   Parameters: links (array of { label, path }), copyright_text (string) #}
<footer class="mt-auto border-t border-gray-200 bg-[#3F3F3F] text-white" role="contentinfo">
    <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
        <div class="flex flex-col gap-6 sm:flex-row sm:items-center sm:justify-between">
            <p class="text-sm text-gray-300">{{ copyright_text|default('© ' ~ "now"|date('Y') ~ ' Orion. All rights reserved.') }}</p>
            <nav class="flex flex-wrap gap-6" aria-label="Footer navigation">
                {% for link in links|default([{ label: 'Privacy', path: '#' }, { label: 'Terms', path: '#' }, { label: 'Contact', path: '#' }]) %}
                    <a href="{{ link.path }}" class="text-sm text-gray-300 transition hover:text-white">{{ link.label }}</a>
                {% endfor %}
            </nav>
        </div>
    </div>
</footer>
