{# Rendered by NotificationController for format=html, or included with passed vars #}
<div class="notification-dropdown-content" data-notification-dropdown data-unread-count="{{ unread_count|default(0) }}">
  <div class="flex items-center justify-between border-b border-slate-200 px-4 py-3 dark:border-slate-800">
    <h3 class="text-sm font-bold text-slate-900 dark:text-white">Offers</h3>
    {% if unread_count|default(0) > 0 %}
      <span class="inline-flex h-6 min-w-[24px] items-center justify-center rounded-full bg-emerald-600 px-2 text-xs font-bold text-white">
        {{ unread_count }}
      </span>
    {% endif %}
  </div>
  <div class="max-h-[min(70vh,400px)] overflow-y-auto">
    {% set rows = notification_rows|default([]) %}
    {% if rows|length == 0 %}
      <p class="px-4 py-6 text-center text-sm text-slate-500 dark:text-slate-400">No offer notifications.</p>
    {% else %}
      <ul class="divide-y divide-slate-100 dark:divide-slate-800" role="list">
        {% for row in rows %}
          {% set n = row.notification %}
          {% set is_client_offer = row.is_client_offer|default(true) %}
          <li class="notification-item group border-0"
              data-notification-id="{{ n.id }}"
              data-notification-type="{{ n.type }}"
              data-payload="{{ n.payload|default({})|json_encode|e('html_attr') }}">
            <div class="flex flex-col gap-1 px-4 py-3 transition {{ n.isRead ? 'bg-transparent' : 'bg-slate-50 dark:bg-slate-800/50' }}">
              <p class="text-sm font-semibold text-slate-900 dark:text-white">{{ n.title }}</p>
              {% if n.body %}
                <p class="text-xs text-slate-600 dark:text-slate-300 line-clamp-2">{{ n.body }}</p>
              {% endif %}
              <p class="text-xs text-slate-400 dark:text-slate-500" data-relative-time="{{ n.createdAt|date('c') }}">
                {{ n.createdAt|date('M j, g:i A') }}
              </p>
              {# Client: Accept / Decline / Negotiate. Freelancer: Accept / Decline only #}
              {% if n.payload.offer_id is defined and n.payload.request_id is defined %}
                <div class="mt-2 flex flex-wrap gap-2 offer-actions" data-offer-id="{{ n.payload.offer_id }}">
                  <button type="button" class="offer-accept inline-flex items-center rounded-lg bg-emerald-600 px-2.5 py-1.5 text-xs font-semibold text-white hover:bg-emerald-700">
                    Accept
                  </button>
                  <button type="button" class="offer-decline inline-flex items-center rounded-lg bg-red-600 px-2.5 py-1.5 text-xs font-semibold text-white hover:bg-red-700">
                    Decline
                  </button>
                  {% if is_client_offer %}
                    <button type="button" class="offer-negotiate inline-flex items-center rounded-lg bg-amber-500 px-2.5 py-1.5 text-xs font-semibold text-white hover:bg-amber-600">
                      Negotiate
                    </button>
                  {% endif %}
                </div>
                {% if is_client_offer %}
                  <div class="negotiate-form hidden mt-2 space-y-2 rounded-lg border border-slate-200 bg-slate-50 p-2 dark:border-slate-700 dark:bg-slate-800">
                    <input type="number" name="budget" placeholder="Budget" step="0.01" class="w-full rounded border border-slate-300 px-2 py-1 text-sm dark:border-slate-600 dark:bg-slate-900 dark:text-white"/>
                    <input type="date" name="deadline" class="w-full rounded border border-slate-300 px-2 py-1 text-sm dark:border-slate-600 dark:bg-slate-900 dark:text-white"/>
                    <textarea name="message" rows="2" placeholder="Message" class="w-full rounded border border-slate-300 px-2 py-1 text-sm dark:border-slate-600 dark:bg-slate-900 dark:text-white"></textarea>
                    <button type="button" class="negotiate-submit rounded bg-amber-500 px-2 py-1 text-xs font-semibold text-white hover:bg-amber-600">Send</button>
                  </div>
                {% endif %}
              {% endif %}
            </div>
          </li>
        {% endfor %}
      </ul>
    {% endif %}
  </div>
</div>
