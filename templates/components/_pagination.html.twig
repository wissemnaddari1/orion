{# _pagination.html.twig
   Parameters: current_page (int), total_pages (int), base_path (string, e.g. "?page="), show_prev_next (bool) #}
{% set current = current_page|default(1) %}
{% set total = total_pages|default(1) %}
{% set base = base_path|default('?page=') %}
<nav class="flex items-center justify-between border-t border-gray-200 px-4 py-3 sm:px-0" aria-label="Pagination">
    <div class="flex flex-1 justify-between gap-2 sm:justify-end">
        <a href="{{ current > 1 ? base ~ (current - 1) : '#' }}"
           class="relative inline-flex items-center rounded-lg border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-[#3F3F3F] hover:bg-gray-50 disabled:pointer-events-none disabled:opacity-50 {{ current <= 1 ? 'opacity-50 cursor-not-allowed' : '' }}">
            Previous
        </a>
        <div class="hidden sm:flex items-center gap-1">
            {% for p in 1..min(total, 5) %}
                <a href="{{ base ~ p }}"
                   class="relative inline-flex items-center rounded-lg px-3 py-2 text-sm font-medium {{ p == current ? 'bg-gradient-to-r from-[#0FAF7A] to-[#008F6A] text-white' : 'text-[#3F3F3F] hover:bg-gray-100' }}">
                    {{ p }}
                </a>
            {% endfor %}
        </div>
        <a href="{{ current < total ? base ~ (current + 1) : '#' }}"
           class="relative inline-flex items-center rounded-lg border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-[#3F3F3F] hover:bg-gray-50 disabled:pointer-events-none disabled:opacity-50 {{ current >= total ? 'opacity-50 cursor-not-allowed' : '' }}">
            Next
        </a>
    </div>
</nav>
