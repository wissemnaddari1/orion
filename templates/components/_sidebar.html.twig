    { label: 'Service Requests',    route: 'worker_service_requests', route_prefix: 'worker_service_requests', icon: '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>' },
    { label: 'My Offers',           route: 'worker_offers_list',      route_prefix: 'worker_offers',        icon: '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/></svg>' },
    { label: 'Contracts',           route: 'worker_contracts_list',    route_prefix: 'worker_contracts',     icon: '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>' },
    { label: 'Worker Profile',      route: 'worker_profiles_index',    route_prefix: 'worker_profiles',     icon: '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>' },
] %}

{# Choose menu by role (admin takes precedence over client/worker) #}
{% if is_granted('ROLE_ADMIN') %}
    {% set _items = _admin_menu %}
    {% set _dashboard_route = 'admin_dashboard' %}
{% elseif is_granted('ROLE_WORKER') %}
    {% set _items = _worker_menu %}
    {% set _dashboard_route = 'worker_dashboard' %}
{% elseif is_granted('ROLE_CLIENT') %}
    {% set _items = _client_menu %}
    {% set _dashboard_route = 'client_dashboard' %}
{% else %}
    {% set _items = [] %}
    {% set _dashboard_route = 'admin_dashboard' %}
{% endif %}

<div class="flex flex-col h-full">
    {# Logo / Brand — exact height for clean corner with topbar #}
    <div class="flex items-center justify-center border-b border-slate-200 dark:border-slate-800 h-[var(--admin-header-height,72px)] min-h-[var(--admin-header-height,72px)] px-4 shrink-0 box-border">
        <a href="{{ _items|length > 0 ? path(_dashboard_route) : path('admin_dashboard') }}" class="inline-flex items-center">
            <img src="{{ asset('images/orion_light_mode.png') }}" alt="Orion" class="h-[100px] w-auto opacity-90 hover:opacity-100 transition">
        </a>
    </div>

    {# Navigation — active by route prefix #}
    <nav class="flex-1 overflow-y-auto p-4 pt-6 space-y-2">
        {% for item in _items %}
            {% set _is_active = _current_route starts with item.route_prefix %}
            <a href="{{ path(item.route) }}"
               class="flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-medium transition
                      {% if _is_active %}
                          bg-emerald-50 text-emerald-700 dark:bg-emerald-900/20 dark:text-emerald-400
                      {% else %}
                          text-slate-700 hover:bg-slate-100 dark:text-slate-300 dark:hover:bg-slate-800
                      {% endif %}">
                {{ item.icon|raw }}
                <span>{{ item.label }}</span>
            </a>
        {% endfor %}
    </nav>

    {# Footer / Logout #}
    <div class="p-4 border-t border-slate-200 dark:border-slate-800">
        <a href="{{ path('app_logout') }}"
           onclick="(function(e) { 
             e.preventDefault(); 
             if (this.dataset.loggingOut === 'true') return false;
             this.dataset.loggingOut = 'true';
             try { localStorage.removeItem('token'); } catch (err) {}
             window.location.href = '{{ path('app_logout') }}';
             return false;
           }).call(this, event);"
           class="flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-medium text-red-600 hover:bg-red-50 dark:text-red-400 dark:hover:bg-red-900/20 transition">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
            </svg>
            <span>Logout</span>
        </a>
    </div>
</div>
