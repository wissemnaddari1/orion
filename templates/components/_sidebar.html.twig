    { label: 'Ticket Categories',   route: 'admin_category_ticket_index', route_prefix: 'admin_category_ticket', icon: '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>' },
