{# templates/components/_topbar.html.twig — Topbar with integrated nav (no sidebar). Dashboard hidden for client/freelancer. #}
{% set _current_route = app.request.attributes.get('_route') ?? '' %}
{# Menu config: same as sidebar; for frontoffice (client/worker) we exclude Dashboard from nav #}
{% set _admin_nav = [
    { label: 'Dashboard',           route: 'admin_dashboard',           route_prefix: 'admin_dashboard' },
    { label: 'Users',              route: 'admin_users_index',         route_prefix: 'admin_users' },
    { label: 'Offers',             route: 'admin_offers_index',       route_prefix: 'admin_offers' },
    { label: 'Services',           route: 'admin_services_index',     route_prefix: 'admin_services' },
    { label: 'Contracts',          route: 'admin_contracts_index',    route_prefix: 'admin_contracts' },
    { label: 'Tickets',            route: 'admin_ticket_list',        route_prefix: 'admin_ticket' },
    { label: 'Worker Categories',  route: 'admin_categories_index',   route_prefix: 'admin_categories' },
    { label: 'Ticket Categories',  route: 'admin_category_ticket_index', route_prefix: 'admin_category_ticket' },
    { label: 'Certificates',       route: 'admin_certificates_index',  route_prefix: 'admin_certificates' },
    { label: 'Face Auth Logs',     route: 'admin_face_logs',          route_prefix: 'admin_face_logs' },
] %}
{% set _client_nav = [
    { label: 'Dashboard',           route: 'client_dashboard',          route_prefix: 'client_dashboard' },
    { label: 'Services',            route: 'request_list',             route_prefix: 'request' },
    { label: 'Contracts',          route: 'client_contracts_list',   route_prefix: 'client_contracts' },
    { label: 'Offers',             route: 'client_offers_index',      route_prefix: 'client_offers' },
    { label: 'Categories',         route: 'client_categories_index',  route_prefix: 'client_categories' },
    { label: 'Apply as Freelancer', route: 'client_apply_freelancer',  route_prefix: 'client_apply' },
] %}
{% set _worker_nav = [
    { label: 'Service Requests',    route: 'worker_service_requests',  route_prefix: 'worker_service_requests' },
    { label: 'My Offers',           route: 'worker_offers_list',        route_prefix: 'worker_offers' },
    { label: 'Contracts',          route: 'worker_contracts_list',    route_prefix: 'worker_contracts' },
    { label: 'Worker Profile',     route: 'worker_profiles_index',    route_prefix: 'worker_profiles' },
] %}
{% if is_granted('ROLE_ADMIN') %}
    {% set _nav_items = _admin_nav %}
    {% set _logo_route = 'admin_dashboard' %}
{% elseif is_granted('ROLE_WORKER') %}
    {% set _nav_items = _worker_nav %}
    {% set _logo_route = 'worker_service_requests' %}
{% elseif is_granted('ROLE_CLIENT') %}
    {% set _nav_items = _client_nav %}
    {% set _logo_route = 'request_list' %}
{% else %}
    {% set _nav_items = [] %}
    {% set _logo_route = 'admin_dashboard' %}
{% endif %}
{# Profile state: session (when user has both roles), else route, else role. Used for dropdown label and switcher. #}
{% set _has_client = is_granted('ROLE_CLIENT') %}
{% set _has_freelancer = is_granted('ROLE_WORKER') %}
{% set _has_both_roles = _has_client and _has_freelancer %}
{% set _session_state = (app.session is defined and app.session is not null) ? app.session.get('orion_active_state') : null %}
{% if is_granted('ROLE_ADMIN') %}
    {% set _profile_state = 'ADMIN' %}
{% elseif _has_both_roles and _session_state == 'client' %}
    {% set _profile_state = 'CLIENT' %}
{% elseif _has_both_roles and _session_state == 'freelancer' %}
    {% set _profile_state = 'FREELANCER' %}
{% elseif _current_route starts with 'admin_' %}
    {% set _profile_state = 'ADMIN' %}
{% elseif _current_route starts with 'worker_' %}
    {% set _profile_state = 'FREELANCER' %}
{% elseif _current_route starts with 'client_' or _current_route starts with 'request_' %}
    {% set _profile_state = 'CLIENT' %}
{% elseif _session_state == 'client' and _has_client %}
    {% set _profile_state = 'CLIENT' %}
{% elseif _session_state == 'freelancer' and _has_freelancer %}
    {% set _profile_state = 'FREELANCER' %}
{% else %}
    {% set _profile_state = app.user ? (app.user.role.value == 'WORKER' ? 'FREELANCER' : (app.user.role.value == 'CLIENT' ? 'CLIENT' : app.user.role.value)) : 'CLIENT' %}
{% endif %}
{# State label for dropdown header: "CLIENT • Dashboard" / "FREELANCER • Dashboard" / "ADMIN • Dashboard" #}
{% set _profile_state_label = _profile_state ~ ' • Dashboard' %}

<header class="sticky top-0 z-[120]
               border-b border-slate-200 bg-white/95 backdrop-blur
               dark:border-slate-800 dark:bg-slate-950/85"
        x-data="{ mobileNavOpen: false }">
  <div class="flex h-[4rem] sm:h-[5rem] items-center justify-between gap-4 px-4 sm:px-6 lg:px-8 py-2">

    {# Left: Logo + Desktop nav #}
    <div class="flex min-w-0 flex-1 items-center gap-4 lg:gap-6">
      <a href="{{ _nav_items|length > 0 ? path(_logo_route) : path('admin_dashboard') }}"
         class="flex-shrink-0 inline-flex items-center">
        <img src="{{ asset('images/orion_light_mode.png') }}" alt="Orion" class="h-14 sm:h-16 md:h-[72px] w-auto opacity-90 hover:opacity-100 transition object-contain">
      </a>

      {# Desktop: horizontal nav #}
      {% if _nav_items|length > 0 %}
      <nav class="hidden lg:flex items-center gap-1" aria-label="Main navigation">
        {% for item in _nav_items %}
          {% set _is_active = _current_route starts with item.route_prefix %}
          <a href="{{ path(item.route) }}"
             class="rounded-lg px-3 py-2 text-sm font-medium transition whitespace-nowrap
                    {% if _is_active %}
                      bg-emerald-50 text-emerald-700 dark:bg-emerald-900/20 dark:text-emerald-400
                    {% else %}
                      text-slate-700 hover:bg-slate-100 dark:text-slate-300 dark:hover:bg-slate-800
                    {% endif %}">
            {{ item.label }}
          </a>
        {% endfor %}
      </nav>
      {% endif %}

      {# Mobile: hamburger #}
      {% if _nav_items|length > 0 %}
      <button type="button"
              @click="mobileNavOpen = !mobileNavOpen"
              :aria-expanded="mobileNavOpen"
              aria-label="Open menu"
              class="lg:hidden flex-shrink-0 inline-flex h-10 w-10 items-center justify-center rounded-xl
                     border border-slate-200 bg-white text-slate-700 dark:border-slate-800 dark:bg-slate-950 dark:text-slate-200">
        <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" x-show="!mobileNavOpen">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" x-show="mobileNavOpen" x-cloak style="display: none;">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
      {% endif %}
    </div>

    <div class="flex flex-shrink-0 items-center gap-2 sm:gap-3">

      {# 🔔 Notifications dropdown #}
      <div class="relative" x-data="{ open: false }" @click.away="open = false" data-notification-bell-wrap>
        <button type="button"
                @click="open = !open; if (open) window.NotificationDropdown && window.NotificationDropdown.load()"
                :aria-expanded="open"
                aria-label="Notifications"
                aria-haspopup="true"
                data-notification-bell
                class="relative inline-flex h-10 w-10 items-center justify-center rounded-xl
                       border border-slate-200 bg-white text-slate-700 transition hover:bg-slate-50
                       dark:border-slate-800 dark:bg-slate-950 dark:text-slate-200 dark:hover:bg-slate-900/40">

          <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none"
               viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11
                     a6 6 0 10-12 0v3.159c0 .538-.214 1.055-.595 1.436L4 17h5
                     m6 0a3 3 0 11-6 0m6 0H9" />
          </svg>

          <span id="notification-badge"
                class="absolute -top-1.5 -right-1.5 inline-flex h-5 min-w-[20px]
                       items-center justify-center rounded-full bg-emerald-600 px-1
                       text-[11px] font-extrabold text-white"
                {% if (notification_count|default(0)) == 0 %} style="display: none;"{% endif %}>
            {{ notification_count|default(0) }}
          </span>
        </button>

        <div x-show="open"
             x-transition:enter="transition ease-out duration-200"
             x-transition:enter-start="opacity-0 scale-95"
             x-transition:enter-end="opacity-100 scale-100"
             x-transition:leave="transition ease-in duration-150"
             x-transition:leave-start="opacity-100 scale-100"
             x-transition:leave-end="opacity-0 scale-95"
             class="absolute right-0 mt-2 w-[380px] max-w-[calc(100vw-2rem)] origin-top-right rounded-2xl
                    border border-slate-200 bg-white shadow-xl
                    dark:border-slate-800 dark:bg-slate-900 z-[130]"
             style="display: none;"
             id="notification-dropdown-panel"
             @keydown.escape.window="open = false"
             role="dialog"
             aria-label="Notifications">
          <div id="notification-dropdown-content" class="rounded-2xl overflow-hidden">
            <div class="flex items-center justify-center py-8 text-slate-400">
              <span class="text-sm">Loading…</span>
            </div>
          </div>
        </div>
      </div>

      {# 🌙 / ☀️ Theme Toggle #}
      <button type="button"
              onclick="window.toggleTheme()"
              aria-label="Toggle theme"
              class="inline-flex h-10 w-10 items-center justify-center rounded-xl
                     border border-slate-200 bg-white text-slate-700 transition hover:bg-slate-50
                     dark:border-slate-800 dark:bg-slate-950 dark:text-slate-200 dark:hover:bg-slate-900/40">

        {# Moon (shown in LIGHT mode) #}
        <svg class="h-5 w-5 dark:hidden" xmlns="http://www.w3.org/2000/svg" fill="none"
             viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M21 12.79A9 9 0 1111.21 3
                   a7 7 0 009.79 9.79z" />
        </svg>

        {# Sun (shown in DARK mode) #}
        <svg class="hidden h-5 w-5 dark:block" xmlns="http://www.w3.org/2000/svg" fill="none"
             viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M12 3v2m0 14v2m9-9h-2M5 12H3
                   m15.364-6.364l-1.414 1.414
                   M6.05 17.95l-1.414 1.414
                   M17.95 17.95l-1.414-1.414
                   M6.05 6.05L4.636 4.636
                   M12 8a4 4 0 100 8 4 4 0 000-8z" />
        </svg>

      </button>

      {# User Profile Dropdown #}
      <div class="relative" x-data="{ open: false }" @click.away="open = false">
        {# Profile Button #}
        <button @click="open = !open"
                type="button"
                class="inline-flex h-10 items-center gap-2 rounded-xl
                       border border-slate-200 bg-white px-3 text-sm font-semibold text-slate-900
                       transition hover:bg-slate-50
                       dark:border-slate-800 dark:bg-slate-950 dark:text-white dark:hover:bg-slate-900/70">
          
          {# Profile Picture #}
          {% if app.user %}
            {% if app.user.profilePicture %}
              {# If profile picture path starts with /, use as-is; otherwise prepend uploads/profile/ #}
              {% set profilePicPath = app.user.profilePicture starts with '/' 
                                       ? app.user.profilePicture 
                                       : 'uploads/profile/' ~ app.user.profilePicture %}
              <img src="{{ asset(profilePicPath) }}" 
                   alt="{{ app.user.fullName }}"
                   class="h-7 w-7 rounded-full object-cover border-2 border-emerald-500"
                   onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
              <div class="h-7 w-7 items-center justify-center rounded-full bg-emerald-600 text-xs font-bold text-white hidden" style="display: none;">
                {{ app.user.firstName[0]|default('U') }}{{ app.user.lastName[0]|default('') }}
              </div>
            {% else %}
              {# Default avatar with user initials #}
              <div class="flex h-7 w-7 items-center justify-center rounded-full bg-emerald-600 text-xs font-bold text-white">
                {{ app.user.firstName[0]|default('U') }}{{ app.user.lastName[0]|default('') }}
              </div>
            {% endif %}
            
            {# User Name #}
            <span class="hidden sm:inline">{{ app.user.fullName|default(app.user.username) }}</span>
            
            {# Chevron Icon #}
            <svg class="h-4 w-4 transition-transform duration-200"
                 :class="{ 'rotate-180': open }"
                 fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          {% else %}
            <span>{{ user_name|default('Guest') }}</span>
          {% endif %}
        </button>

        {# Dropdown Menu #}
        <div x-show="open"
             x-transition:enter="transition ease-out duration-200"
             x-transition:enter-start="opacity-0 scale-95"
             x-transition:enter-end="opacity-100 scale-100"
             x-transition:leave="transition ease-in duration-150"
             x-transition:leave-start="opacity-100 scale-100"
             x-transition:leave-end="opacity-0 scale-95"
             class="absolute right-0 mt-2 w-80 origin-top-right rounded-2xl
                    border border-slate-200 bg-white shadow-xl
                    dark:border-slate-800 dark:bg-slate-900 z-[130]"
             style="display: none;">
          
          {# User Info Header #}
          {% if app.user %}
          <div class="border-b border-slate-100 p-4 dark:border-slate-800">
            <div class="flex items-start gap-3">
              {# Large Profile Picture #}
              {% if app.user.profilePicture %}
                {% set profilePicPath = app.user.profilePicture starts with '/' 
                                         ? app.user.profilePicture 
                                         : 'uploads/profile/' ~ app.user.profilePicture %}
                <img src="{{ asset(profilePicPath) }}" 
                     alt="{{ app.user.fullName }}"
                     class="h-14 w-14 rounded-full object-cover border-2 border-emerald-500"
                     onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
                <div class="h-14 w-14 items-center justify-center rounded-full bg-gradient-to-br from-emerald-500 to-emerald-600 text-xl font-bold text-white shadow-lg hidden" style="display: none;">
                  {{ app.user.firstName[0]|default('U') }}{{ app.user.lastName[0]|default('') }}
                </div>
              {% else %}
                <div class="flex h-14 w-14 items-center justify-center rounded-full bg-gradient-to-br from-emerald-500 to-emerald-600 text-xl font-bold text-white shadow-lg">
                  {{ app.user.firstName[0]|default('U') }}{{ app.user.lastName[0]|default('') }}
                </div>
              {% endif %}

              {# User Details #}
              <div class="flex-1 min-w-0">
                <p class="text-sm font-bold text-slate-900 dark:text-white truncate">
                  {{ app.user.fullName|default(app.user.username) }}
                </p>
                <p class="text-xs text-slate-500 dark:text-slate-400 truncate">
                  {{ app.user.email }}
                </p>
                <div class="mt-1 inline-flex items-center gap-1.5">
                  <span class="inline-flex items-center gap-1.5 rounded-full px-2 py-0.5 text-xs font-semibold
                               {% if _profile_state == 'ADMIN' %}
                                 bg-purple-100 text-purple-700 dark:bg-purple-900/30 dark:text-purple-300
                               {% elseif _profile_state == 'CLIENT' %}
                                 bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-300
                               {% else %}
                                 bg-emerald-100 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-300
                               {% endif %}">
                    {% if app.user.status.value == 'ACTIVE' %}
                      <span class="flex h-1.5 w-1.5 rounded-full bg-current opacity-80" aria-hidden="true"></span>
                    {% endif %}
                    {{ _profile_state_label }}
                  </span>
                </div>
              </div>
            </div>
          </div>

          {# Dashboard shortcuts (only if user has the role) #}
          <div class="border-b border-slate-100 px-2 pb-2 dark:border-slate-800">
            {% if _has_client %}
            <a href="{{ path('client_dashboard') }}"
               class="flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium text-slate-700
                      transition hover:bg-slate-100 dark:text-slate-300 dark:hover:bg-slate-800">
              <svg class="h-5 w-5 text-slate-500 dark:text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
              </svg>
              <span>Open Client Dashboard</span>
            </a>
            {% endif %}
            {% if _has_freelancer %}
            <a href="{{ path('worker_dashboard') }}"
               class="flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium text-slate-700
                      transition hover:bg-slate-100 dark:text-slate-300 dark:hover:bg-slate-800">
              <svg class="h-5 w-5 text-slate-500 dark:text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              <span>Open Freelancer Dashboard</span>
            </a>
            {% endif %}
            {% if _has_both_roles %}
            <div class="my-2 border-t border-slate-200 dark:border-slate-800"></div>
            <p class="px-3 py-1 text-xs font-medium text-slate-500 dark:text-slate-400">Switch view</p>
            {% if _profile_state != 'CLIENT' %}
            <a href="{{ path('app_switch_state', { state: 'client' }) }}"
               class="flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium text-slate-700
                      transition hover:bg-slate-100 dark:text-slate-300 dark:hover:bg-slate-800">
              <span class="flex h-2 w-2 rounded-full bg-blue-500" aria-hidden="true"></span>
              <span>Switch to Client view</span>
            </a>
            {% endif %}
            {% if _profile_state != 'FREELANCER' %}
            <a href="{{ path('app_switch_state', { state: 'freelancer' }) }}"
               class="flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium text-slate-700
                      transition hover:bg-slate-100 dark:text-slate-300 dark:hover:bg-slate-800">
              <span class="flex h-2 w-2 rounded-full bg-emerald-500" aria-hidden="true"></span>
              <span>Switch to Freelancer view</span>
            </a>
            {% endif %}
            {% endif %}
          </div>

          {# Menu Items #}
          <div class="p-2">
            {# View Profile #}
            <a href="{{ path('profile_show') }}"
               class="flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium text-slate-700
                      transition hover:bg-slate-100 dark:text-slate-300 dark:hover:bg-slate-800">
              <svg class="h-5 w-5 text-slate-500 dark:text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                      d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
              </svg>
              <span>View Profile</span>
            </a>

            {# Edit Profile #}
            <a href="{{ path('profile_edit') }}"
               class="flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium text-slate-700
                      transition hover:bg-slate-100 dark:text-slate-300 dark:hover:bg-slate-800">
              <svg class="h-5 w-5 text-slate-500 dark:text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                      d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
              </svg>
              <span>Edit Profile</span>
            </a>

            {# Change Picture #}
            <button @click="document.getElementById('profile-picture-modal').showModal(); open = false"
                    type="button"
                    class="flex w-full items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium text-slate-700
                           transition hover:bg-slate-100 dark:text-slate-300 dark:hover:bg-slate-800">
              <svg class="h-5 w-5 text-slate-500 dark:text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                      d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              <span>Change Picture</span>
            </button>

            <div class="my-2 border-t border-slate-200 dark:border-slate-800"></div>

            {# Account Settings #}
            <a href="{{ path('profile_edit') }}"
               class="flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium text-slate-700
                      transition hover:bg-slate-100 dark:text-slate-300 dark:hover:bg-slate-800">
              <svg class="h-5 w-5 text-slate-500 dark:text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                      d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              <span>Account Settings</span>
            </a>

            {# Privacy & Security #}
            <a href="{{ path('settings_privacy_security') }}"
               class="flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium text-slate-700
                      transition hover:bg-slate-100 dark:text-slate-300 dark:hover:bg-slate-800">
              <svg class="h-5 w-5 text-slate-500 dark:text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                      d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
              </svg>
              <span>Privacy & Security</span>
            </a>

            <div class="my-2 border-t border-slate-200 dark:border-slate-800"></div>

            {# Logout #}
            <a href="{{ path('app_logout') }}"
               onclick="(function(e) { 
                 e.preventDefault(); 
                 if (this.dataset.loggingOut === 'true') return false;
                 this.dataset.loggingOut = 'true';
                 try { localStorage.removeItem('token'); } catch (err) {}
                 window.location.href = '{{ path('app_logout') }}';
                 return false;
               }).call(this, event);"
               class="flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium text-red-600
                      transition hover:bg-red-50 dark:text-red-400 dark:hover:bg-red-900/20">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                      d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
              </svg>
              <span>Sign Out</span>
            </a>
          </div>
          {% endif %}
        </div>
      </div>

    </div>
  </div>

  {# Mobile nav panel #}
  {% if _nav_items|length > 0 %}
  <div x-show="mobileNavOpen"
       x-cloak
       x-transition:enter="transition ease-out duration-200"
       x-transition:enter-start="opacity-0 -translate-y-2"
       x-transition:enter-end="opacity-100 translate-y-0"
       x-transition:leave="transition ease-in duration-150"
       x-transition:leave-start="opacity-100 translate-y-0"
       x-transition:leave-end="opacity-0 -translate-y-2"
       class="lg:hidden border-t border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-950"
       style="display: none;">
    <nav class="flex flex-col p-4 gap-1" aria-label="Mobile navigation">
      {% for item in _nav_items %}
        {% set _is_active = _current_route starts with item.route_prefix %}
        <a href="{{ path(item.route) }}"
           @click="mobileNavOpen = false"
           class="rounded-lg px-4 py-3 text-sm font-medium transition
                  {% if _is_active %}
                    bg-emerald-50 text-emerald-700 dark:bg-emerald-900/20 dark:text-emerald-400
                  {% else %}
                    text-slate-700 hover:bg-slate-100 dark:text-slate-300 dark:hover:bg-slate-800
                  {% endif %}">
          {{ item.label }}
        </a>
      {% endfor %}
    </nav>
  </div>
  {% endif %}
</header>

{# Profile Picture Upload Modal #}
<dialog id="profile-picture-modal" class="rounded-2xl border-none bg-transparent p-0 backdrop:bg-slate-900/50">
  <div class="w-full max-w-md rounded-2xl border border-slate-200 bg-white shadow-2xl dark:border-slate-800 dark:bg-slate-900">
    {# Modal Header #}
    <div class="flex items-center justify-between border-b border-slate-200 px-6 py-4 dark:border-slate-800">
      <h3 class="text-lg font-bold text-slate-900 dark:text-white">Change Profile Picture</h3>
      <button onclick="document.getElementById('profile-picture-modal').close()"
              type="button"
              class="rounded-lg p-1.5 text-slate-400 transition hover:bg-slate-100 hover:text-slate-600 dark:hover:bg-slate-800 dark:hover:text-slate-300">
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    {# Modal Body #}
    <form method="post" action="{{ path('profile_picture_upload') }}" enctype="multipart/form-data" class="p-6" data-validate="profile-picture" novalidate>
      <div class="space-y-4">
        {# Current Picture #}
        {% if app.user and app.user.profilePicture %}
          <div class="text-center">
            <p class="mb-2 text-sm font-medium text-slate-700 dark:text-slate-300">Current Picture</p>
            {% set profilePicPath = app.user.profilePicture starts with '/' 
                                     ? app.user.profilePicture 
                                     : 'uploads/profile/' ~ app.user.profilePicture %}
            <img src="{{ asset(profilePicPath) }}" 
                 alt="Current profile"
                 class="mx-auto h-24 w-24 rounded-full object-cover border-4 border-emerald-500">
          </div>
        {% endif %}

        {# File Input #}
        <div>
          <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">
            Choose New Picture
          </label>
          <input type="file" 
                 name="profile_picture" 
                 accept="image/*"
                 required
                 class="block w-full text-sm text-slate-900 border border-slate-300 rounded-xl cursor-pointer
                        bg-slate-50 focus:outline-none focus:ring-2 focus:ring-emerald-500
                        dark:text-slate-400 dark:bg-slate-900 dark:border-slate-700 dark:placeholder-slate-400
                        file:mr-4 file:py-2 file:px-4 file:rounded-l-xl file:border-0 file:text-sm file:font-semibold
                        file:bg-emerald-50 file:text-emerald-700 hover:file:bg-emerald-100
                        dark:file:bg-emerald-900/30 dark:file:text-emerald-300">
          <p class="mt-1 text-xs text-slate-500 dark:text-slate-400">
            PNG, JPG, GIF up to 5MB
          </p>
        </div>
      </div>

      {# Modal Footer #}
      <div class="mt-6 flex gap-3">
        <button type="button"
                onclick="document.getElementById('profile-picture-modal').close()"
                class="flex-1 rounded-xl border border-slate-300 bg-white px-4 py-2.5 text-sm font-semibold text-slate-900
                       transition hover:bg-slate-50 dark:border-slate-700 dark:bg-slate-800 dark:text-white dark:hover:bg-slate-700">
          Cancel
        </button>
        <button type="submit"
                class="flex-1 rounded-xl bg-emerald-600 px-4 py-2.5 text-sm font-semibold text-white
                       transition hover:bg-emerald-700 focus:outline-none focus:ring-4 focus:ring-emerald-500/30">
          Upload Picture
        </button>
      </div>
    </form>
  </div>
</dialog>
