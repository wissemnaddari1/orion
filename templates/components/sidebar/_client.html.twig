{# templates/components/sidebar/_client.html.twig â€” single source of truth for client menu #}

{% set current = app.request.attributes.get('_route') ?? '' %}
{% set menu = [
    { label: 'Dashboard', route: 'client_dashboard', route_prefix: 'client_dashboard', icon: '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>' },
    { label: 'Services', route: 'request_list', route_prefix: 'request', icon: '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>' },
    { label: 'Contracts', route: 'client_contracts_list', route_prefix: 'client_contracts', icon: '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>' },
    { label: 'Offers', route: 'client_offers_index', route_prefix: 'client_offers', icon: '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/></svg>' },
    { label: 'Categories', route: 'client_categories_index', route_prefix: 'client_categories', icon: '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>' },
    { label: 'Apply as Freelancer', route: 'client_apply_freelancer', route_prefix: 'client_apply', icon: '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/></svg>' },
] %}
<div class="flex flex-col h-full">
    <div class="flex items-center justify-center h-16 border-b border-slate-200 dark:border-slate-800">
        <a href="{{ path('client_dashboard') }}" class="inline-flex items-center gap-2">
            <img src="{{ asset('images/orion_light_mode.png') }}" alt="Orion" class="h-14 w-auto opacity-90 hover:opacity-100 transition">
        </a>
    </div>
    <nav class="flex-1 overflow-y-auto p-4 space-y-2">
        {% for item in menu %}
            {% set active = current starts with item.route_prefix %}
            <a href="{{ path(item.route) }}"
               class="flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-medium transition
                      {% if active %}
                          bg-emerald-50 text-emerald-700 dark:bg-emerald-900/20 dark:text-emerald-400
                      {% else %}
                          text-slate-700 hover:bg-slate-100 dark:text-slate-300 dark:hover:bg-slate-800
                      {% endif %}">
                {{ item.icon|raw }}
                <span>{{ item.label }}</span>
            </a>
        {% endfor %}
    </nav>
    <div class="p-4 border-t border-slate-200 dark:border-slate-800">
        <a href="{{ path('app_logout') }}"
           onclick="(function(e) { 
             e.preventDefault(); 
             if (this.dataset.loggingOut === 'true') return false;
             this.dataset.loggingOut = 'true';
             try { localStorage.removeItem('token'); } catch (err) {}
             window.location.href = '{{ path('app_logout') }}';
             return false;
           }).call(this, event);"
           class="flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-medium text-red-600 hover:bg-red-50 dark:text-red-400 dark:hover:bg-red-900/20 transition">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
            </svg>
            <span>Logout</span>
        </a>
    </div>
</div>
