{% extends 'emails/base.html.twig' %}

{% block body %}
    <h2>New Offer Received</h2>
    <p>Hello {{ client.firstName }},</p>
    <p>
        <strong>{{ offer.worker.fullName }}</strong> has submitted a new offer for your service request:
        <strong>{{ offer.serviceRequest.title }}</strong>.
    </p>

    <div style="background-color: #f3f4f6; padding: 15px; border-radius: 8px; margin: 20px 0;">
        <p><strong>Price:</strong> ${{ offer.price }}</p>
        <p><strong>Estimated Time:</strong> {{ offer.estimatedTimeDays }} days</p>
        <p><strong>Message:</strong></p>
        <blockquote style="font-style: italic; color: #555;">
            {{ offer.message|nl2br }}
        </blockquote>
    </div>

    <p>
        <a href="{{ url('client_offers_show', {id: offer.id}) }}" style="background-color: #10b981; color: white; padding: 10px 20px; text-decoration: none; border-radius: 5px; display: inline-block;">
            View Offer
        </a>
    </p>
    <p>Review the offer details and accept, negotiate, or reject it directly on the platform.</p>
{% endblock %}
