<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Verify your Orion account</title>
</head>
<body style="margin: 0; padding: 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif; background-color: #0f172a;">
    <table width="100%" cellpadding="0" cellspacing="0" style="background-color: #0f172a; padding: 40px 20px;">
        <tr>
            <td align="center">
                <table width="600" cellpadding="0" cellspacing="0" style="background-color: #1e293b; border-radius: 16px; overflow: hidden; box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);">
                    
                    {# Header #}
                    <tr>
                        <td style="background: linear-gradient(135deg, #10b981 0%, #059669 100%); padding: 40px; text-align: center;">
                            <img src="{{ email.image('@email_images/orion_dark_mode.png') }}"
                                 alt="Orion"
                                 width="180"
                                 height="48"
                                 style="display: inline-block; max-width: 180px; height: auto;">
                        </td>
                    </tr>

                    {# Body #}
                    <tr>
                        <td style="padding: 40px;">
                            <h2 style="margin: 0 0 16px; color: #f1f5f9; font-size: 24px; font-weight: bold;">
                                Welcome to Orion, {{ user.firstName }}!
                            </h2>
                            
                            <p style="margin: 0 0 24px; color: #cbd5e1; font-size: 16px; line-height: 1.6;">
                                Thank you for creating an account. To complete your registration and activate your account, please verify your email address using the code below:
                            </p>

                            {# Verification Code #}
                            <table width="100%" cellpadding="0" cellspacing="0" style="margin: 32px 0;">
                                <tr>
                                    <td align="center" style="background-color: #0f172a; border-radius: 12px; padding: 24px;">
                                        <div style="color: #94a3b8; font-size: 14px; font-weight: 500; margin-bottom: 8px; text-transform: uppercase; letter-spacing: 1px;">
                                            Your Verification Code
                                        </div>
                                        <div style="color: #10b981; font-size: 48px; font-weight: bold; letter-spacing: 8px; font-family: 'Courier New', monospace;">
                                            {{ code }}
                                        </div>
                                        <div style="color: #64748b; font-size: 12px; margin-top: 8px;">
                                            Valid for 15 minutes
                                        </div>
                                    </td>
                                </tr>
                            </table>

                            <p style="margin: 24px 0 0; color: #cbd5e1; font-size: 14px; line-height: 1.6;">
                                If you didn't create an account with Orion, please ignore this email.
                            </p>
                        </td>
                    </tr>

                    {# Footer #}
                    <tr>
                        <td style="background-color: #0f172a; padding: 32px; text-align: center;">
                            <p style="margin: 0 0 8px; color: #64748b; font-size: 14px;">
                                <strong style="color: #94a3b8;">Orion Platform</strong>
                            </p>
                            <p style="margin: 0; color: #475569; font-size: 12px;">
                                Connecting clients and freelancers worldwide
                            </p>
                        </td>
                    </tr>
                </table>

                {# Footer Text #}
                <p style="margin: 24px 0 0; color: #64748b; font-size: 12px; text-align: center;">
                    © {{ "now"|date("Y") }} Orion. All rights reserved.
                </p>
            </td>
        </tr>
    </table>
</body>
</html>
