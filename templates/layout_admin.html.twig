{# templates/layout_admin.html.twig — Base layout for all ADMIN pages.
   Uses a permanent left sidebar for navigation (no top nav links).
   Non-admins seeing this template will just get a simple "no access" message. #}

{% extends 'base.html.twig' %}

{% block stylesheets %}
  {{ parent() }}
  <style>
    :root {
      --sidebar-width: 260px;
      --border: rgb(226 232 240);
      --border-color: rgb(226 232 240);
    }
    .dark {
      --border: rgb(30 41 59);
      --border-color: rgb(30 41 59);
    }
    /* Layout: sidebar | main. Topbar inside main — separator line only under main area */
    /* Shared header height: topbar and sidebar logo align on same line; no gap for clean corner */
    :root { --admin-header-height: 72px; }
    .admin-layout {
      display: grid;
      grid-template-columns: var(--sidebar-width) 1fr;
      grid-template-rows: 1fr;
      grid-gap: 0;
      min-height: 100vh;
    }
    .admin-sidebar {
      grid-column: 1;
      grid-row: 1;
      width: var(--sidebar-width);
      border-right: 1px solid var(--border);
    }
    .admin-main {
      grid-column: 2;
      grid-row: 1;
      display: flex;
      flex-direction: column;
      min-width: 0;
      overflow-x: hidden;
    }
    /* Single separator under topbar — exact height for clean corner with sidebar */
    .admin-main .admin-topbar {
      flex-shrink: 0;
      height: var(--admin-header-height);
      min-height: var(--admin-header-height);
      border-bottom: 1px solid var(--border);
      box-sizing: border-box;
    }
    /* Main and content: no border-left — single vertical divider via sidebar only */
    .admin-main { border-left: none; }
    @media (max-width: 1023px) {
      .admin-layout { grid-template-columns: 1fr; }
      .admin-main { grid-column: 1; }
    }
  </style>
{% endblock %}

{% block body %}
    {% if not is_granted('ROLE_ADMIN') %}
        <div class="min-h-screen flex items-center justify-center bg-slate-50 dark:bg-slate-950 px-4">
            <div class="max-w-md text-center">
                <h1 class="text-2xl font-bold text-slate-900 dark:text-white mb-2">
                    Admin area
                </h1>
                <p class="text-slate-600 dark:text-slate-400 text-sm">
                    You do not have permission to access the administration interface.
                </p>
            </div>
        </div>
    {% else %}
        {# Structure: .admin-layout > .admin-sidebar | .admin-main > .admin-topbar | .content #}
        <div class="admin-layout min-h-screen bg-slate-50 dark:bg-slate-950"
             x-data="{ sidebarOpen: false }">

            {# Sidebar: grid column 1; single vertical divider (border-right only) #}
            <aside class="admin-sidebar hidden lg:flex lg:flex-col lg:w-[260px] bg-white dark:bg-slate-950 overflow-y-auto">
                {% include 'components/_admin_sidebar.html.twig' %}
            </aside>

            {# Mobile sidebar (offcanvas) — lg:hidden so it does not participate in grid on desktop #}
            <div class="lg:hidden" x-show="sidebarOpen" x-cloak>
                <div class="fixed inset-0 z-40 flex">
                    <div class="fixed inset-0 bg-black/40 dark:bg-black/60"
                         @click="sidebarOpen = false"
                         x-transition:enter="transition-opacity ease-out duration-200"
                         x-transition:enter-start="opacity-0"
                         x-transition:enter-end="opacity-100"
                         x-transition:leave="transition-opacity ease-in duration-150"
                         x-transition:leave-start="opacity-100"
                         x-transition:leave-end="opacity-0"></div>
                    <div class="relative flex w-full max-w-xs flex-col bg-white dark:bg-slate-950 border-r border-slate-200 dark:border-slate-800 shadow-xl"
                         x-transition:enter="transition ease-out duration-200"
                         x-transition:enter-start="-translate-x-full"
                         x-transition:enter-end="translate-x-0"
                         x-transition:leave="transition ease-in duration-150"
                         x-transition:leave-start="translate-x-0"
                         x-transition:leave-end="-translate-x-full">
                        <div class="flex items-center justify-between px-4 pt-4 pb-2 border-b border-slate-200 dark:border-slate-800">
                            <span class="text-sm font-semibold text-slate-700 dark:text-slate-200">Admin Navigation</span>
                            <button type="button"
                                    class="inline-flex h-9 w-9 items-center justify-center rounded-lg hover:bg-slate-100 dark:hover:bg-slate-900 text-slate-500 dark:text-slate-300"
                                    @click="sidebarOpen = false">
                                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                                </svg>
                            </button>
                        </div>
                        <div class="flex-1 overflow-y-auto p-4">
                            {% include 'components/_admin_sidebar.html.twig' %}
                        </div>
                    </div>
                </div>
            </div>

            {# Main: topbar + content; topbar separator only here — never extends under sidebar #}
            <div class="admin-main flex flex-1 flex-col min-w-0 min-h-screen">

                {# Topbar: inside .main — border-bottom applies ONLY to topbar (main column only) #}
                {% include 'components/_admin_topbar.html.twig' with {
                    title: topbar_title|default('Admin'),
                    notification_count: notification_count|default(notification_unread_count()|default(0))
                } %}

                {# Content area #}
                <div class="flex-1 overflow-auto flex flex-col">

                    {# Flash messages #}
                    {% for type, messages in app.flashes %}
                        {% for message in messages %}
                            <div x-data="{ show: true }"
                                 x-show="show"
                                 x-init="setTimeout(() => show = false, 5000)"
                                 x-transition:enter="transition ease-out duration-300"
                                 x-transition:enter-start="opacity-0 transform translate-y-2"
                                 x-transition:enter-end="opacity-100 transform translate-y-0"
                                 x-transition:leave="transition ease-in duration-200"
                                 x-transition:leave-start="opacity-100 transform translate-y-0"
                                 x-transition:leave-end="opacity-0 transform translate-y-2"
                                 class="mx-4 mt-4 lg:mx-6 rounded-xl border p-4 shadow-lg
                                        {% if type == 'success' %}
                                            bg-emerald-50 border-emerald-200 text-emerald-800 dark:bg-emerald-900/20 dark:border-emerald-800 dark:text-emerald-200
                                        {% elseif type == 'error' %}
                                            bg-red-50 border-red-200 text-red-800 dark:bg-red-900/20 dark:border-red-800 dark:text-red-200
                                        {% elseif type == 'warning' %}
                                            bg-amber-50 border-amber-200 text-amber-800 dark:bg-amber-900/20 dark:border-amber-800 dark:text-amber-200
                                        {% else %}
                                            bg-blue-50 border-blue-200 text-blue-800 dark:bg-blue-900/20 dark:border-blue-800 dark:text-blue-200
                                        {% endif %}"
                                 style="display: none;">
                                <div class="flex items-start gap-3">
                                    <div class="flex-shrink-0">
                                        {% if type == 'success' %}
                                            <svg class="h-5 w-5 text-emerald-600 dark:text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                                        {% elseif type == 'error' %}
                                            <svg class="h-5 w-5 text-red-600 dark:text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                                        {% elseif type == 'warning' %}
                                            <svg class="h-5 w-5 text-amber-600 dark:text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
                                        {% else %}
                                            <svg class="h-5 w-5 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                                        {% endif %}
                                    </div>
                                    <div class="flex-1 text-sm font-medium">{{ message }}</div>
                                    <button @click="show = false" type="button" class="flex-shrink-0 rounded-lg p-1 transition hover:bg-black/5 dark:hover:bg-white/5">
                                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                                    </button>
                                </div>
                            </div>
                        {% endfor %}
                    {% endfor %}

                    {# Page content #}
                    <main class="flex-1 p-4 sm:p-6 lg:p-8">
                        {% block main %}{% endblock %}
                    </main>
                </div>
            </div>
        </div>
    {% endif %}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {% if app.user %}
        <script src="{{ asset('js/notifications.js') }}?v=20260304c" defer></script>
    {% endif %}
{% endblock %}
