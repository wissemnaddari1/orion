{% extends 'layout_admin.html.twig' %}

{% block main %}
<div class="space-y-6">
    {# Page Header #}
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold text-slate-900 dark:text-white">Certificate Applications</h1>
            <p class="text-slate-600 dark:text-slate-400 mt-1">Review and manage freelancer certificate submissions</p>
        </div>
    </div>

    {# Filters #}
    <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm p-4">
        <div class="flex flex-wrap gap-2">
            <a href="{{ path('admin_certificates_index') }}" 
               class="px-4 py-2 rounded-lg text-sm font-medium transition
                      {% if current_status is null %}bg-emerald-100 text-emerald-800 dark:bg-emerald-900/30 dark:text-emerald-400
                      {% else %}text-slate-600 hover:bg-slate-100 dark:text-slate-400 dark:hover:bg-slate-800{% endif %}">
                All
            </a>
            <a href="{{ path('admin_certificates_index', {status: 'pending'}) }}" 
               class="px-4 py-2 rounded-lg text-sm font-medium transition
                      {% if current_status == 'pending' %}bg-amber-100 text-amber-800 dark:bg-amber-900/30 dark:text-amber-400
                      {% else %}text-slate-600 hover:bg-slate-100 dark:text-slate-400 dark:hover:bg-slate-800{% endif %}">
                Pending
            </a>
            <a href="{{ path('admin_certificates_index', {status: 'approved'}) }}" 
               class="px-4 py-2 rounded-lg text-sm font-medium transition
                      {% if current_status == 'approved' %}bg-emerald-100 text-emerald-800 dark:bg-emerald-900/30 dark:text-emerald-400
                      {% else %}text-slate-600 hover:bg-slate-100 dark:text-slate-400 dark:hover:bg-slate-800{% endif %}">
                Approved
            </a>
            <a href="{{ path('admin_certificates_index', {status: 'rejected'}) }}" 
               class="px-4 py-2 rounded-lg text-sm font-medium transition
                      {% if current_status == 'rejected' %}bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-400
                      {% else %}text-slate-600 hover:bg-slate-100 dark:text-slate-400 dark:hover:bg-slate-800{% endif %}">
                Rejected
            </a>
        </div>
    </div>

    {# Users with Certificates Table #}
    <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm overflow-hidden">
        {% if users|length > 0 %}
            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead class="bg-slate-50 dark:bg-slate-800/50">
                        <tr>
                            <th class="px-6 py-4 text-left text-xs font-semibold text-slate-600 dark:text-slate-400 uppercase tracking-wider">
                                User
                            </th>
                            <th class="px-6 py-4 text-left text-xs font-semibold text-slate-600 dark:text-slate-400 uppercase tracking-wider">
                                AI Verdict
                            </th>
                            <th class="px-6 py-4 text-left text-xs font-semibold text-slate-600 dark:text-slate-400 uppercase tracking-wider">
                                AI Score
                            </th>
                            <th class="px-6 py-4 text-left text-xs font-semibold text-slate-600 dark:text-slate-400 uppercase tracking-wider">
                                Status
                            </th>
                            <th class="px-6 py-4 text-left text-xs font-semibold text-slate-600 dark:text-slate-400 uppercase tracking-wider">
                                Submitted
                            </th>
                            <th class="px-6 py-4 text-right text-xs font-semibold text-slate-600 dark:text-slate-400 uppercase tracking-wider">
                                Actions
                            </th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-200 dark:divide-slate-800">
                        {% for user in users %}
                            <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/50 transition">
                                <td class="px-6 py-4">
                                    <div class="flex items-center gap-3">
                                        <div class="w-10 h-10 rounded-full bg-emerald-100 dark:bg-emerald-900/30 flex items-center justify-center">
                                            {% if user.profilePicture %}
                                                <img src="{{ asset(user.profilePicture) }}" alt="" class="w-full h-full rounded-full object-cover">
                                            {% else %}
                                                <span class="text-emerald-600 dark:text-emerald-400 font-medium">
                                                    {{ user.firstName|first }}{{ user.lastName|first }}
                                                </span>
                                            {% endif %}
                                        </div>
                                        <div>
                                            <p class="font-medium text-slate-900 dark:text-white">{{ user.fullName }}</p>
                                            <p class="text-sm text-slate-500 dark:text-slate-400">{{ user.email }}</p>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-4">
                                    {% set verdict = user.certificateAiVerdict|default('pending') %}
                                    <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium
                                        {% if verdict == 'valid' %}bg-emerald-100 text-emerald-800 dark:bg-emerald-900/30 dark:text-emerald-400
                                        {% elseif verdict == 'fake' %}bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-400
                                        {% elseif verdict == 'suspicious' %}bg-amber-100 text-amber-800 dark:bg-amber-900/30 dark:text-amber-400
                                        {% else %}bg-slate-100 text-slate-800 dark:bg-slate-900/30 dark:text-slate-400{% endif %}">
                                        {{ verdict|upper }}
                                    </span>
                                </td>
                                <td class="px-6 py-4">
                                    {% if user.certificateAiScore is not null %}
                                        <div class="flex items-center gap-2">
                                            <div class="w-24 h-2 bg-slate-200 dark:bg-slate-700 rounded-full overflow-hidden">
                                                <div class="h-full rounded-full 
                                                    {% if user.certificateAiScore >= 70 %}bg-emerald-500
                                                    {% elseif user.certificateAiScore >= 40 %}bg-amber-500
                                                    {% else %}bg-red-500{% endif %}"
                                                     style="width: {{ user.certificateAiScore }}%"></div>
                                            </div>
                                            <span class="text-sm text-slate-600 dark:text-slate-400">
                                                {{ user.certificateAiScore }}%
                                            </span>
                                        </div>
                                    {% else %}
                                        <span class="text-sm text-slate-400">N/A</span>
                                    {% endif %}
                                </td>
                                <td class="px-6 py-4">
                                    {% set status = user.certificateStatus|default('pending') %}
                                    <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium
                                        {% if status == 'approved' %}bg-emerald-100 text-emerald-800 dark:bg-emerald-900/30 dark:text-emerald-400
                                        {% elseif status == 'rejected' %}bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-400
                                        {% else %}bg-amber-100 text-amber-800 dark:bg-amber-900/30 dark:text-amber-400{% endif %}">
                                        {{ status|upper }}
                                    </span>
                                </td>
                                <td class="px-6 py-4 text-sm text-slate-600 dark:text-slate-400">
                                    {{ user.certificateUploadedAt ? user.certificateUploadedAt|date('M d, Y') : '-' }}
                                </td>
                                <td class="px-6 py-4 text-right">
                                    <a href="{{ path('admin_certificates_show', {id: user.id}) }}" 
                                       class="inline-flex items-center gap-1 px-3 py-1.5 bg-slate-100 hover:bg-slate-200 dark:bg-slate-800 dark:hover:bg-slate-700 text-slate-700 dark:text-slate-300 rounded-lg text-sm font-medium transition">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                                        </svg>
                                        Review
                                    </a>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% else %}
            <div class="text-center py-16">
                <svg class="w-16 h-16 mx-auto text-slate-300 dark:text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                </svg>
                <h3 class="mt-4 text-lg font-medium text-slate-900 dark:text-white">No certificates found</h3>
                <p class="mt-2 text-slate-500 dark:text-slate-400">
                    {% if current_status %}
                        No {{ current_status|lower }} certificates at this time.
                    {% else %}
                        There are no certificate submissions yet.
                    {% endif %}
                </p>
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}
