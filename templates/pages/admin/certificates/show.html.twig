{% extends 'layout_admin.html.twig' %}

{% block main %}
<div class="space-y-6">
    {# Page Header #}
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div class="flex items-center gap-4">
            <a href="{{ path('admin_certificates_index') }}" 
               class="p-2 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-lg transition">
                <svg class="w-5 h-5 text-slate-600 dark:text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                </svg>
            </a>
            <div>
                <h1 class="text-2xl font-bold text-slate-900 dark:text-white">Review Certificate</h1>
                <p class="text-slate-600 dark:text-slate-400 mt-1">{{ user.fullName }}</p>
            </div>
        </div>
        <div>
            {% set status = user.certificateStatus|default('pending') %}
            <span class="inline-flex items-center px-3 py-1.5 rounded-full text-sm font-medium
                {% if status == 'approved' %}bg-emerald-100 text-emerald-800 dark:bg-emerald-900/30 dark:text-emerald-400
                {% elseif status == 'rejected' %}bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-400
                {% else %}bg-amber-100 text-amber-800 dark:bg-amber-900/30 dark:text-amber-400{% endif %}">
                {{ status|upper }}
            </span>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        {# Left Column - Certificate & AI Analysis #}
        <div class="lg:col-span-2 space-y-6">
            {# Certificate Preview #}
            <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm">
                <div class="p-6 border-b border-slate-200 dark:border-slate-800">
                    <h2 class="text-lg font-semibold text-slate-900 dark:text-white">Certificate Document</h2>
                </div>
                <div class="p-6">
                    {% set extension = user.certificatePath|split('.')|last %}
                    {% if extension == 'pdf' %}
                        <div class="bg-slate-100 dark:bg-slate-800 rounded-lg p-8 text-center">
                            <svg class="w-16 h-16 mx-auto text-red-500" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6zm-1 2l5 5h-5V4zm-3 9.5c0 .828-.448 1.5-1 1.5s-1-.672-1-1.5.448-1.5 1-1.5 1 .672 1 1.5zm4 1.5h-2v-1h2v1zm0-2h-2v-1h2v1z"/>
                            </svg>
                            <p class="mt-4 font-medium text-slate-900 dark:text-white">PDF Document</p>
                            <a href="{{ asset(user.certificatePath) }}" 
                               target="_blank"
                               class="inline-flex items-center gap-2 mt-4 px-4 py-2 bg-emerald-600 hover:bg-emerald-700 text-white rounded-lg font-medium transition">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
                                </svg>
                                Download PDF
                            </a>
                        </div>
                    {% else %}
                        <div class="rounded-lg overflow-hidden border border-slate-200 dark:border-slate-700">
                            <img src="{{ asset(user.certificatePath) }}" 
                                 alt="Certificate" 
                                 class="w-full h-auto">
                        </div>
                        <div class="mt-4 text-center">
                            <a href="{{ asset(user.certificatePath) }}" 
                               target="_blank"
                               class="inline-flex items-center gap-2 px-4 py-2 bg-slate-100 hover:bg-slate-200 dark:bg-slate-800 dark:hover:bg-slate-700 text-slate-700 dark:text-slate-300 rounded-lg font-medium transition">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                                </svg>
                                Open Full Size
                            </a>
                        </div>
                    {% endif %}
                </div>
            </div>

            {# AI Analysis #}
            <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm">
                <div class="p-6 border-b border-slate-200 dark:border-slate-800">
                    <div class="flex items-center justify-between">
                        <h2 class="text-lg font-semibold text-slate-900 dark:text-white">AI Verification Analysis</h2>
                        {% set verdict = user.certificateAiVerdict|default('pending') %}
                        <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium
                            {% if verdict == 'valid' %}bg-emerald-100 text-emerald-800 dark:bg-emerald-900/30 dark:text-emerald-400
                            {% elseif verdict == 'fake' %}bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-400
                            {% elseif verdict == 'suspicious' %}bg-amber-100 text-amber-800 dark:bg-amber-900/30 dark:text-amber-400
                            {% else %}bg-slate-100 text-slate-800 dark:bg-slate-900/30 dark:text-slate-400{% endif %}">
                            {{ verdict|upper }}
                        </span>
                    </div>
                </div>
                <div class="p-6 space-y-6">
                    {# Confidence Score #}
                    <div>
                        <div class="flex items-center justify-between mb-2">
                            <span class="text-sm font-medium text-slate-700 dark:text-slate-300">Confidence Score</span>
                            {% set score = user.certificateAiScore|default(0) %}
                            <span class="text-sm font-bold 
                                {% if score >= 70 %}text-emerald-600 dark:text-emerald-400
                                {% elseif score >= 40 %}text-amber-600 dark:text-amber-400
                                {% else %}text-red-600 dark:text-red-400{% endif %}">
                                {{ score }}%
                            </span>
                        </div>
                        <div class="w-full h-3 bg-slate-200 dark:bg-slate-700 rounded-full overflow-hidden">
                            <div class="h-full rounded-full transition-all duration-500
                                {% if score >= 70 %}bg-emerald-500
                                {% elseif score >= 40 %}bg-amber-500
                                {% else %}bg-red-500{% endif %}"
                                 style="width: {{ score }}%"></div>
                        </div>
                    </div>

                    {# Interpretation Guide #}
                    <div class="bg-emerald-50 dark:bg-emerald-900/20 rounded-lg p-4 border border-emerald-200 dark:border-emerald-800">
                        <h4 class="text-sm font-medium text-emerald-800 dark:text-emerald-200 mb-2">Score Interpretation</h4>
                        <ul class="text-sm text-emerald-700 dark:text-emerald-300 space-y-1">

                            <li class="flex items-center gap-2">
                                <span class="w-3 h-3 rounded-full bg-emerald-500"></span>
                                70-100%: High confidence - Likely valid
                            </li>
                            <li class="flex items-center gap-2">
                                <span class="w-3 h-3 rounded-full bg-amber-500"></span>
                                40-69%: Medium confidence - Needs review
                            </li>
                            <li class="flex items-center gap-2">
                                <span class="w-3 h-3 rounded-full bg-red-500"></span>
                                0-39%: Low confidence - Likely fake
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>

        {# Right Column - User Info & Actions #}
        <div class="space-y-6">
            {# User Info #}
            <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm">
                <div class="p-6 border-b border-slate-200 dark:border-slate-800">
                    <h2 class="text-lg font-semibold text-slate-900 dark:text-white">User Information</h2>
                </div>
                <div class="p-6">
                    <div class="flex items-center gap-4 mb-6">
                        <div class="w-16 h-16 rounded-full bg-emerald-100 dark:bg-emerald-900/30 flex items-center justify-center overflow-hidden">
                            {% if user.profilePicture %}
                                <img src="{{ asset(user.profilePicture) }}" alt="" class="w-full h-full object-cover">
                            {% else %}
                                <span class="text-xl font-bold text-emerald-600 dark:text-emerald-400">
                                    {{ user.firstName|first }}{{ user.lastName|first }}
                                </span>
                            {% endif %}
                        </div>
                        <div>
                            <h3 class="text-lg font-semibold text-slate-900 dark:text-white">{{ user.fullName }}</h3>
                            <p class="text-slate-600 dark:text-slate-400">{{ user.email }}</p>
                        </div>
                    </div>

                    <dl class="space-y-4">
                        <div class="flex justify-between">
                            <dt class="text-slate-600 dark:text-slate-400">Username</dt>
                            <dd class="font-medium text-slate-900 dark:text-white">{{ user.username }}</dd>
                        </div>
                        <div class="flex justify-between">
                            <dt class="text-slate-600 dark:text-slate-400">Current Role</dt>
                            <dd>
                                <span class="px-2 py-1 text-xs font-medium rounded-full 
                                    {% if user.role.value == 'ADMIN' %}bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-400
                                    {% elseif user.role.value == 'WORKER' %}bg-teal-100 text-teal-800 dark:bg-teal-900/30 dark:text-teal-400
                                    {% else %}bg-emerald-100 text-emerald-800 dark:bg-emerald-900/30 dark:text-emerald-400{% endif %}">

                                    {{ user.role.value }}
                                </span>
                            </dd>
                        </div>
                        <div class="flex justify-between">
                            <dt class="text-slate-600 dark:text-slate-400">Submitted</dt>
                            <dd class="font-medium text-slate-900 dark:text-white">{{ user.certificateUploadedAt|date('M d, Y H:i') }}</dd>
                        </div>
                        {% if user.certificateApprovedAt %}
                            <div class="flex justify-between">
                                <dt class="text-slate-600 dark:text-slate-400">Reviewed</dt>
                                <dd class="font-medium text-slate-900 dark:text-white">{{ user.certificateApprovedAt|date('M d, Y H:i') }}</dd>
                            </div>
                        {% endif %}
                    </dl>
                </div>
            </div>

            {# Review Actions #}
            {% if user.isCertificatePending %}
                <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm">
                    <div class="p-6 border-b border-slate-200 dark:border-slate-800">
                        <h2 class="text-lg font-semibold text-slate-900 dark:text-white">Review Decision</h2>
                    </div>
                    <div class="p-6 space-y-4">
                        {# Approve Form #}
                        <form action="{{ path('admin_certificates_approve', {id: user.id}) }}" method="post">

                            <div class="mb-3">
                                <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">
                                    Approval Note (optional)
                                </label>
                                <textarea name="note" rows="2" 
                                          class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-emerald-500 dark:bg-slate-800 dark:border-slate-700 dark:text-white"
                                          placeholder="Add a note for the user..."></textarea>
                            </div>
                            <button type="submit" 
                                    class="w-full py-3 px-4 bg-emerald-600 hover:bg-emerald-700 text-white font-semibold rounded-lg transition flex items-center justify-center gap-2">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                                </svg>
                                Approve Certificate
                            </button>
                        </form>

                        <div class="relative">
                            <div class="absolute inset-0 flex items-center">
                                <div class="w-full border-t border-slate-200 dark:border-slate-700"></div>
                            </div>
                            <div class="relative flex justify-center text-sm">
                                <span class="px-2 bg-white dark:bg-slate-900 text-slate-500">or</span>
                            </div>
                        </div>

                        {# Reject Form #}
                        <form action="{{ path('admin_certificates_reject', {id: user.id}) }}" method="post">

                            <div class="mb-3">
                                <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">
                                    Rejection Reason
                                </label>
                                <textarea name="note" rows="2" 
                                          class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500 dark:bg-slate-800 dark:border-slate-700 dark:text-white"
                                          placeholder="Explain why this certificate is being rejected..."></textarea>
                            </div>
                            <button type="submit" 
                                    class="w-full py-3 px-4 bg-red-600 hover:bg-red-700 text-white font-semibold rounded-lg transition flex items-center justify-center gap-2">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                                </svg>
                                Reject Certificate
                            </button>
                        </form>
                    </div>
                </div>
            {% else %}
                {# Already Reviewed #}
                <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm">
                    <div class="p-6">
                        <div class="text-center">
                            {% if user.isCertificateApproved %}
                                <div class="w-16 h-16 mx-auto rounded-full bg-emerald-100 dark:bg-emerald-900/30 flex items-center justify-center mb-4">
                                    <svg class="w-8 h-8 text-emerald-600 dark:text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                                    </svg>
                                </div>
                                <h3 class="text-lg font-semibold text-slate-900 dark:text-white">Certificate Approved</h3>
                                <p class="mt-2 text-slate-600 dark:text-slate-400">This user is now a freelancer.</p>
                            {% else %}
                                <div class="w-16 h-16 mx-auto rounded-full bg-red-100 dark:bg-red-900/30 flex items-center justify-center mb-4">
                                    <svg class="w-8 h-8 text-red-600 dark:text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                                    </svg>
                                </div>
                                <h3 class="text-lg font-semibold text-slate-900 dark:text-white">Certificate Rejected</h3>
                            {% endif %}

                            {% if user.certificateReviewNote %}
                                <div class="mt-4 p-4 bg-slate-50 dark:bg-slate-800/50 rounded-lg text-left">
                                    <p class="text-sm font-medium text-slate-700 dark:text-slate-300">Review Note:</p>
                                    <p class="text-sm text-slate-600 dark:text-slate-400 mt-1">{{ user.certificateReviewNote }}</p>
                                </div>
                            {% endif %}
                        </div>
                    </div>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
