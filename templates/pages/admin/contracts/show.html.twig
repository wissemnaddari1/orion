{% extends 'layout_admin.html.twig' %}
{% block title %}Contract #{{ contract.id }} - Orion Admin{% endblock %}

{% block main %}
<div class="space-y-6">
    {% for type, messages in app.flashes %}
        {% for message in messages %}
            <div class="rounded-lg px-4 py-3 text-sm font-medium
                {% if type == 'success' %} bg-emerald-50 text-emerald-800 border border-emerald-200 dark:bg-emerald-900/20 dark:text-emerald-400 dark:border-emerald-800
                {% elseif type == 'error' or type == 'danger' %} bg-red-50 text-red-800 border border-red-200 dark:bg-red-900/20 dark:text-red-400 dark:border-red-800
                {% else %} bg-blue-50 text-blue-800 border border-blue-200 dark:bg-blue-900/20 dark:text-blue-400 dark:border-blue-800
                {% endif %}">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div class="flex items-center gap-4">
            <a href="{{ path('admin_contracts_index') }}"
               class="inline-flex items-center gap-1 text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-200 transition text-sm">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                </svg>
                Back
            </a>
            <div>
                <h1 class="text-2xl font-bold text-slate-900 dark:text-white">{{ contract.title }}</h1>
                <p class="text-sm text-slate-500 dark:text-slate-400 mt-0.5">Contract #{{ contract.id }}</p>
            </div>
        </div>

        {% set statusClass = 'bg-slate-100 text-slate-700 dark:bg-slate-700 dark:text-slate-300' %}
        {% if contract.status == 'PENDING_SIGN' %}
            {% set statusClass = 'bg-amber-100 text-amber-800 dark:bg-amber-900/30 dark:text-amber-400' %}
        {% elseif contract.status == 'ACTIVE' %}
            {% set statusClass = 'bg-emerald-100 text-emerald-800 dark:bg-emerald-900/30 dark:text-emerald-400' %}
        {% elseif contract.status == 'IN_PROGRESS' %}
            {% set statusClass = 'bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-400' %}
        {% elseif contract.status == 'COMPLETED' %}
            {% set statusClass = 'bg-indigo-100 text-indigo-800 dark:bg-indigo-900/30 dark:text-indigo-400' %}
        {% elseif contract.status == 'CANCELLED' %}
            {% set statusClass = 'bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-400' %}
        {% elseif contract.status == 'DISPUTED' %}
            {% set statusClass = 'bg-orange-100 text-orange-800 dark:bg-orange-900/30 dark:text-orange-400' %}
        {% endif %}

        <span class="inline-flex items-center rounded-full px-3 py-1 text-sm font-medium {{ statusClass }}">
            {{ contract.status|replace({'_': ' '}) }}
        </span>
    </div>

    <div class="grid gap-6 lg:grid-cols-3">
        <div class="lg:col-span-2 space-y-6">
            <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900">
                <div class="flex items-center justify-between mb-5">
                    <h2 class="text-lg font-semibold text-slate-900 dark:text-white">Contract Details</h2>
                    <span class="text-xs text-slate-400">Created {{ contract.createdAt|date('M d, Y \\a\\t H:i') }}</span>
                </div>
                <dl class="grid gap-x-6 gap-y-4 sm:grid-cols-2">
                    <div>
                        <dt class="text-xs font-medium uppercase tracking-wider text-slate-500 dark:text-slate-400">Title</dt>
                        <dd class="mt-1 text-sm font-semibold text-slate-900 dark:text-white">{{ contract.title }}</dd>
                    </div>
                    <div>
                        <dt class="text-xs font-medium uppercase tracking-wider text-slate-500 dark:text-slate-400">Agreed Price</dt>
                        <dd class="mt-1 text-lg font-bold text-emerald-600 dark:text-emerald-400">{{ contract.agreedPrice|number_format(2) }} {{ contract.currency }}</dd>
                    </div>
                    <div>
                        <dt class="text-xs font-medium uppercase tracking-wider text-slate-500 dark:text-slate-400">Client</dt>
                        <dd class="mt-1 text-sm font-semibold text-slate-900 dark:text-white">
                            {% if contract.client %}
                                {{ contract.client.firstName }} {{ contract.client.lastName }}
                                <span class="block text-xs font-normal text-slate-400">{{ contract.client.email }}</span>
                            {% else %}
                                <span class="text-slate-400 italic">—</span>
                            {% endif %}
                        </dd>
                    </div>
                    <div>
                        <dt class="text-xs font-medium uppercase tracking-wider text-slate-500 dark:text-slate-400">Worker</dt>
                        <dd class="mt-1 text-sm font-semibold text-slate-900 dark:text-white">
                            {% if contract.worker %}
                                {{ contract.worker.firstName }} {{ contract.worker.lastName }}
                                <span class="block text-xs font-normal text-slate-400">{{ contract.worker.email }}</span>
                            {% else %}
                                <span class="text-slate-400 italic">—</span>
                            {% endif %}
                        </dd>
                    </div>
                    <div>
                        <dt class="text-xs font-medium uppercase tracking-wider text-slate-500 dark:text-slate-400">Start Date</dt>
                        <dd class="mt-1 text-sm font-semibold text-slate-900 dark:text-white">{{ contract.startDate ? contract.startDate|date('M d, Y') : '—' }}</dd>
                    </div>
                    <div>
                        <dt class="text-xs font-medium uppercase tracking-wider text-slate-500 dark:text-slate-400">End Date</dt>
                        <dd class="mt-1 text-sm font-semibold text-slate-900 dark:text-white">{{ contract.endDate ? contract.endDate|date('M d, Y') : '—' }}</dd>
                    </div>
                    {% if contract.updatedAt %}
                    <div class="sm:col-span-2">
                        <dt class="text-xs font-medium uppercase tracking-wider text-slate-500 dark:text-slate-400">Last Updated</dt>
                        <dd class="mt-1 text-sm text-slate-600 dark:text-slate-300">{{ contract.updatedAt|date('M d, Y \\a\\t H:i') }}</dd>
                    </div>
                    {% endif %}
                    {% if contract.riskLevel is not null %}
                    <div class="sm:col-span-2">
                        <dt class="text-xs font-medium uppercase tracking-wider text-slate-500 dark:text-slate-400">AI Risk Assessment</dt>
                        <dd class="mt-2 flex items-center gap-3">
                            <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-bold
                                {% if contract.riskLevel == 'LOW' %}bg-emerald-100 text-emerald-700 dark:bg-emerald-500/20 dark:text-emerald-400
                                {% elseif contract.riskLevel == 'MEDIUM' %}bg-amber-100 text-amber-700 dark:bg-amber-500/20 dark:text-amber-400
                                {% else %}bg-red-100 text-red-700 dark:bg-red-500/20 dark:text-red-400{% endif %}">
                                {{ contract.riskLevel }}
                            </span>
                            {% if contract.riskScore is not null %}
                                <span class="text-xs text-slate-500 dark:text-slate-400">Score: {{ (contract.riskScore * 100)|number_format(1) }}%</span>
                            {% endif %}
                        </dd>
                    </div>
                    {% endif %}
                </dl>
            </div>

            <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900">
                <h2 class="text-lg font-semibold text-slate-900 dark:text-white mb-3">Scope of Work</h2>
                <div class="text-sm leading-relaxed text-slate-700 dark:text-slate-300 whitespace-pre-line">{{ contract.scope }}</div>
            </div>

            <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900">
                <div class="flex items-center justify-between mb-4">
                    <h2 class="text-lg font-semibold text-slate-900 dark:text-white">Milestones</h2>
                    <span class="text-xs text-slate-500 dark:text-slate-400">{{ contract.milestones|length }} total</span>
                </div>

                {% if contract.milestones is empty %}
                    <p class="text-sm text-slate-500 dark:text-slate-400">No milestones defined.</p>
                {% else %}
                    <div class="space-y-3">
                        {% for milestone in contract.milestones %}
                            <div class="border border-slate-200 dark:border-slate-700 rounded-lg p-4">
                                <div class="flex items-start justify-between gap-3">
                                    <div>
                                        <p class="text-sm font-semibold text-slate-900 dark:text-white">{{ milestone.orderIndex }}. {{ milestone.title }}</p>
                                        {% if milestone.description %}
                                            <p class="text-xs text-slate-600 dark:text-slate-300 mt-1">{{ milestone.description }}</p>
                                        {% endif %}
                                        <p class="text-xs text-slate-500 dark:text-slate-400 mt-1">
                                            {% if milestone.dueDate %}Due {{ milestone.dueDate|date('M d, Y') }}{% else %}No due date{% endif %}
                                            {% if milestone.amount %} · {{ milestone.amount|number_format(2) }} {{ contract.currency }}{% endif %}
                                        </p>
                                    </div>
                                    <span class="text-xs font-medium px-2 py-0.5 rounded-full
                                        {% if milestone.status == 'COMPLETED' %}bg-emerald-100 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-400
                                        {% elseif milestone.status == 'IN_PROGRESS' %}bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400
                                        {% elseif milestone.status == 'DELIVERED' %}bg-cyan-100 text-cyan-700 dark:bg-cyan-900/30 dark:text-cyan-300
                                        {% elseif milestone.status == 'REVISION_REQUESTED' %}bg-amber-100 text-amber-700 dark:bg-amber-900/30 dark:text-amber-300
                                        {% elseif milestone.status == 'CANCELLED' %}bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400
                                        {% else %}bg-slate-100 text-slate-700 dark:bg-slate-700 dark:text-slate-300{% endif %}">
                                        {{ milestone.status|replace({'_': ' '}) }}
                                    </span>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        </div>

        <div class="space-y-6">
            <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900 sticky top-6">
                <h2 class="text-lg font-semibold text-slate-900 dark:text-white mb-4">Actions</h2>
                <div class="space-y-3">
                    <a href="{{ path('admin_contracts_pdf', {id: contract.id}) }}" target="_blank"
                       class="w-full inline-flex items-center justify-center gap-2 rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-sm font-semibold text-slate-700 hover:bg-slate-50 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-200 dark:hover:bg-slate-700">
                        Download PDF
                    </a>
                    <a href="{{ path('admin_contracts_edit', {id: contract.id}) }}"
                       class="w-full inline-flex items-center justify-center gap-2 rounded-lg bg-blue-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-blue-700">
                        Edit Contract
                    </a>
                </div>
            </div>

            <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900">
                <h3 class="text-sm font-semibold text-slate-900 dark:text-white mb-3">Quick Info</h3>
                <dl class="space-y-2 text-sm">
                    <div class="flex justify-between gap-3">
                        <dt class="text-slate-500 dark:text-slate-400">Status</dt>
                        <dd class="font-medium text-slate-900 dark:text-white">{{ contract.status|replace({'_': ' '}) }}</dd>
                    </div>
                    <div class="flex justify-between gap-3">
                        <dt class="text-slate-500 dark:text-slate-400">Currency</dt>
                        <dd class="font-medium text-slate-900 dark:text-white">{{ contract.currency }}</dd>
                    </div>
                    <div class="flex justify-between gap-3">
                        <dt class="text-slate-500 dark:text-slate-400">Milestones</dt>
                        <dd class="font-medium text-slate-900 dark:text-white">{{ contract.milestones|length }}</dd>
                    </div>
                </dl>
            </div>
        </div>
    </div>
</div>
{% endblock %}
