{% extends 'layout_admin.html.twig' %}

{% block title %}Select Service Request - Orion{% endblock %}

{% block main %}
<div class="space-y-6">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h2 class="text-2xl font-bold text-slate-900 dark:text-white">Select a Service Request</h2>
            <p class="text-sm text-slate-500 dark:text-slate-400">Choose a service request to reply with an offer — {{ total }} requests found</p>
        </div>
        <div class="flex flex-col sm:flex-row gap-3">
            <a href="{{ path('admin_offers_index') }}"
               class="inline-flex items-center gap-2 px-4 py-2 border border-slate-300 text-slate-700 rounded-lg hover:bg-slate-50 transition font-medium text-sm dark:border-slate-700 dark:text-slate-300 dark:hover:bg-slate-800">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
                </svg>
                Back to Offers
            </a>
            <form method="get" action="{{ path('admin_offers_select_request') }}" class="flex gap-2">
                <input type="text"
                       name="search"
                       value="{{ search_keyword }}"
                       placeholder="Search by title or client"
                       class="px-4 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-emerald-500 dark:bg-slate-900 dark:border-slate-700 dark:text-white">
                <select name="status"
                        class="px-4 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-emerald-500 dark:bg-slate-900 dark:border-slate-700 dark:text-white"
                        onchange="this.form.submit()">
                    <option value="all" {{ status_filter == 'all' or status_filter == '' ? 'selected' : '' }}>All statuses</option>
                    <option value="open" {{ status_filter == 'open' ? 'selected' : '' }}>Open</option>
                    <option value="in_progress" {{ status_filter == 'in_progress' ? 'selected' : '' }}>In Progress</option>
                    <option value="closed" {{ status_filter == 'closed' ? 'selected' : '' }}>Closed</option>
                    <option value="expired" {{ status_filter == 'expired' ? 'selected' : '' }}>Expired</option>
                </select>
                <button type="submit"
                        class="px-4 py-2 bg-slate-600 text-white rounded-lg hover:bg-slate-700 transition">
                    Search
                </button>
            </form>
        </div>
    </div>

    <div class="bg-white dark:bg-slate-900 rounded-lg border border-slate-200 dark:border-slate-800 overflow-hidden shadow-sm">
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead class="bg-slate-50 dark:bg-slate-800 border-b border-slate-200 dark:border-slate-700">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider">ID</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider">Title</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider">Client</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider">Budget</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider">Duration</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider">Status</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider">Created</th>
                        <th class="px-6 py-3 text-right text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider">Action</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-200 dark:divide-slate-800">
                    {% for sr in service_requests %}
                        <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/50 transition">
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-900 dark:text-slate-300">
                                {{ sr.id }}
                            </td>
                            <td class="px-6 py-4">
                                <div class="font-medium text-slate-900 dark:text-white">
                                    {{ sr.title|length > 45 ? sr.title|slice(0, 45) ~ '…' : sr.title }}
                                </div>
                                <div class="text-sm text-slate-500 dark:text-slate-400 mt-0.5">
                                    {{ sr.description|length > 80 ? sr.description|slice(0, 80) ~ '…' : sr.description }}
                                </div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <div class="flex items-center gap-3">
                                    <div class="w-8 h-8 rounded-full bg-blue-600 flex items-center justify-center text-white text-xs font-semibold">
                                        {{ sr.client.firstName|first|upper }}{{ sr.client.lastName|first|upper }}
                                    </div>
                                    <div class="text-sm text-slate-900 dark:text-white">{{ sr.client.fullName }}</div>
                                </div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-600 dark:text-slate-400">
                                {% if sr.budgetMin and sr.budgetMax %}
                                    <span class="font-semibold text-emerald-600 dark:text-emerald-400">${{ sr.budgetMin|number_format(0) }} - ${{ sr.budgetMax|number_format(0) }}</span>
                                {% else %}
                                    <span class="text-slate-400">—</span>
                                {% endif %}
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-600 dark:text-slate-400">
                                {{ sr.duration }} days
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <span class="px-2 py-1 text-xs font-semibold rounded-full
                                    {% if sr.status == 'OPEN' %}bg-emerald-100 text-emerald-800 dark:bg-emerald-900/30 dark:text-emerald-400
                                    {% elseif sr.status == 'IN_PROGRESS' %}bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-400
                                    {% elseif sr.status == 'CLOSED' %}bg-slate-100 text-slate-800 dark:bg-slate-800 dark:text-slate-400
                                    {% else %}bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-400{% endif %}">
                                    {{ sr.status|replace({'_': ' '}) }}
                                </span>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-600 dark:text-slate-400">
                                {{ sr.createdAt|date('Y-m-d') }}
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-right">
                                <a href="{{ path('admin_offers_new', {serviceRequest: sr.id}) }}"
                                   class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-emerald-600 text-white text-sm font-medium rounded-lg hover:bg-emerald-700 transition">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6"/>
                                    </svg>
                                    Reply with Offer
                                </a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="8" class="px-6 py-8 text-center text-slate-500 dark:text-slate-400">
                                No service requests found.
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    {% if total_pages > 1 %}
        <div class="flex items-center justify-between">
            <div class="text-sm text-slate-500 dark:text-slate-400">
                Page {{ page }} of {{ total_pages }}
            </div>
            <div class="flex items-center gap-2">
                {% if page > 1 %}
                    <a href="{{ path('admin_offers_select_request', {page: page - 1, search: search_keyword, status: status_filter}) }}"
                       class="px-3 py-2 text-sm border border-slate-300 rounded-lg hover:bg-slate-50 dark:border-slate-700 dark:hover:bg-slate-800">
                        Previous
                    </a>
                {% endif %}
                {% if page < total_pages %}
                    <a href="{{ path('admin_offers_select_request', {page: page + 1, search: search_keyword, status: status_filter}) }}"
                       class="px-3 py-2 text-sm border border-slate-300 rounded-lg hover:bg-slate-50 dark:border-slate-700 dark:hover:bg-slate-800">
                        Next
                    </a>
                {% endif %}
            </div>
        </div>
    {% endif %}
</div>
{% endblock %}
