{% extends 'layout_admin.html.twig' %}

{% set topbar_title = 'Offer Details' %}

{% block title %}Offer #{{ offer.id }} - Orion{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .detail-card {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .detail-card:hover {
            transform: translateY(-1px);
        }
        .status-glow {
            animation: status-pulse 3s ease-in-out infinite;
        }
        @keyframes status-pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.7; }
        }
        .info-section {
            position: relative;
        }
        .info-section::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 3px;
            border-radius: 9999px;
        }
        .info-section-emerald::before { background: linear-gradient(to bottom, #10b981, #059669); }
        .info-section-blue::before { background: linear-gradient(to bottom, #3b82f6, #2563eb); }
        .info-section-purple::before { background: linear-gradient(to bottom, #8b5cf6, #7c3aed); }
        .info-section-amber::before { background: linear-gradient(to bottom, #f59e0b, #d97706); }
    </style>
{% endblock %}

{% block main %}
<div class="space-y-8">

    {# Page Header #}
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6">
        <div>
            <a href="{{ path('admin_offers_index') }}"
               class="inline-flex items-center gap-1.5 text-sm text-slate-500 dark:text-slate-400 hover:text-emerald-600 dark:hover:text-emerald-400 transition-colors mb-3">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                Back to Offers
            </a>
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-emerald-500 to-emerald-600 flex items-center justify-center shadow-lg shadow-emerald-500/30">
                    <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/>
                    </svg>
                </div>
                <div>
                    <h2 class="text-2xl font-extrabold text-slate-900 dark:text-white tracking-tight">Offer #{{ offer.id }}</h2>
                    <p class="text-sm text-slate-500 dark:text-slate-400">{{ offer.serviceRequest.title }}</p>
                </div>
            </div>
        </div>
        <div class="flex items-center gap-3">
            <a href="{{ path('admin_offers_edit', {id: offer.id}) }}"
               class="inline-flex items-center gap-2 px-5 py-2.5 bg-slate-800 dark:bg-slate-700 hover:bg-slate-900 dark:hover:bg-slate-600 text-white rounded-xl font-semibold text-sm transition-all shadow-lg hover:shadow-xl hover:scale-105">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                Edit Offer
            </a>
            <form method="post" action="{{ path('admin_offers_delete', {id: offer.id}) }}" class="inline">

                <button type="submit"
                        class="inline-flex items-center gap-2 px-5 py-2.5 bg-red-600 hover:bg-red-700 text-white rounded-xl font-semibold text-sm transition-all shadow-lg shadow-red-500/30 hover:shadow-xl hover:shadow-red-500/40 hover:scale-105">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                    Delete
                </button>
            </form>
        </div>
    </div>

    {# Status Banner #}
    <div class="relative overflow-hidden rounded-2xl border shadow-sm
        {% if offer.status == 'ACCEPTED' %}bg-gradient-to-r from-emerald-50 to-emerald-100/50 dark:from-emerald-900/20 dark:to-emerald-800/10 border-emerald-200 dark:border-emerald-800/50
        {% elseif offer.status == 'REJECTED' %}bg-gradient-to-r from-red-50 to-red-100/50 dark:from-red-900/20 dark:to-red-800/10 border-red-200 dark:border-red-800/50
        {% elseif offer.status == 'EXPIRED' %}bg-gradient-to-r from-slate-50 to-slate-100/50 dark:from-slate-800/30 dark:to-slate-800/20 border-slate-200 dark:border-slate-700/50
        {% else %}bg-gradient-to-r from-amber-50 to-amber-100/50 dark:from-amber-900/20 dark:to-amber-800/10 border-amber-200 dark:border-amber-800/50{% endif %} p-5">
        <div class="flex items-center justify-between">
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-xl flex items-center justify-center
                    {% if offer.status == 'ACCEPTED' %}bg-emerald-500/10 dark:bg-emerald-500/20
                    {% elseif offer.status == 'REJECTED' %}bg-red-500/10 dark:bg-red-500/20
                    {% elseif offer.status == 'EXPIRED' %}bg-slate-500/10 dark:bg-slate-500/20
                    {% else %}bg-amber-500/10 dark:bg-amber-500/20{% endif %}">
                    {% if offer.status == 'ACCEPTED' %}
                        <svg class="w-6 h-6 text-emerald-600 dark:text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    {% elseif offer.status == 'REJECTED' %}
                        <svg class="w-6 h-6 text-red-600 dark:text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    {% elseif offer.status == 'EXPIRED' %}
                        <svg class="w-6 h-6 text-slate-500 dark:text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    {% else %}
                        <svg class="w-6 h-6 text-amber-600 dark:text-amber-400 status-glow" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    {% endif %}
                </div>
                <div>
                    <p class="text-sm font-medium
                        {% if offer.status == 'ACCEPTED' %}text-emerald-600 dark:text-emerald-400
                        {% elseif offer.status == 'REJECTED' %}text-red-600 dark:text-red-400
                        {% elseif offer.status == 'EXPIRED' %}text-slate-500 dark:text-slate-400
                        {% else %}text-amber-600 dark:text-amber-400{% endif %}">Current Status</p>
                    <p class="text-xl font-extrabold
                        {% if offer.status == 'ACCEPTED' %}text-emerald-700 dark:text-emerald-300
                        {% elseif offer.status == 'REJECTED' %}text-red-700 dark:text-red-300
                        {% elseif offer.status == 'EXPIRED' %}text-slate-700 dark:text-slate-300
                        {% else %}text-amber-700 dark:text-amber-300{% endif %}">{{ offer.status }}</p>
                </div>
            </div>
            <div class="text-right">
                <p class="text-xs font-medium text-slate-500 dark:text-slate-400">Created</p>
                <p class="text-sm font-bold text-slate-700 dark:text-slate-300">{{ offer.createdAt|date('M d, Y') }}</p>
                <p class="text-xs text-slate-400 dark:text-slate-500">{{ offer.createdAt|date('h:i A') }}</p>
            </div>
        </div>
        {% if offer.isUrgent %}
            <div class="mt-4 flex items-center gap-2 p-3 rounded-xl bg-red-100/80 dark:bg-red-900/30 border border-red-200 dark:border-red-800/40">
                <svg class="w-5 h-5 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                <span class="text-sm font-bold text-red-600 dark:text-red-400">URGENT DELIVERY REQUESTED</span>
                {% if offer.rushFee %}
                    <span class="ml-auto text-sm font-semibold text-red-500 dark:text-red-400">+${{ offer.rushFee|number_format(2) }} rush fee</span>
                {% endif %}
            </div>
        {% endif %}
    </div>

    {# Key Metrics Row #}
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
        <div class="detail-card relative overflow-hidden rounded-xl bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 p-5 shadow-sm">
            <div class="flex items-center justify-between mb-3">
                <div class="w-10 h-10 rounded-lg bg-emerald-500/10 dark:bg-emerald-500/20 flex items-center justify-center">
                    <svg class="w-5 h-5 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </div>
            </div>
            <p class="text-2xl font-extrabold text-emerald-600 dark:text-emerald-400">${{ offer.price|number_format(2) }}</p>
            <p class="text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider mt-1">Total Price</p>
        </div>

        <div class="detail-card relative overflow-hidden rounded-xl bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 p-5 shadow-sm">
            <div class="flex items-center justify-between mb-3">
                <div class="w-10 h-10 rounded-lg bg-blue-500/10 dark:bg-blue-500/20 flex items-center justify-center">
                    <svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                </div>
            </div>
            <p class="text-2xl font-extrabold text-blue-600 dark:text-blue-400">{{ offer.estimatedTimeDays }}</p>
            <p class="text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider mt-1">Est. Days</p>
        </div>

        <div class="detail-card relative overflow-hidden rounded-xl bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 p-5 shadow-sm">
            <div class="flex items-center justify-between mb-3">
                <div class="w-10 h-10 rounded-lg bg-purple-500/10 dark:bg-purple-500/20 flex items-center justify-center">
                    <svg class="w-5 h-5 text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
                </div>
            </div>
            <p class="text-2xl font-extrabold
                {% if offer.priorityLevel == 'HIGH' %}text-red-600 dark:text-red-400
                {% elseif offer.priorityLevel == 'MEDIUM' %}text-amber-600 dark:text-amber-400
                {% else %}text-slate-600 dark:text-slate-400{% endif %}">{{ offer.priorityLevel }}</p>
            <p class="text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider mt-1">Priority</p>
        </div>

        <div class="detail-card relative overflow-hidden rounded-xl bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 p-5 shadow-sm">
            <div class="flex items-center justify-between mb-3">
                <div class="w-10 h-10 rounded-lg bg-amber-500/10 dark:bg-amber-500/20 flex items-center justify-center">
                    <svg class="w-5 h-5 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
                </div>
            </div>
            <p class="text-2xl font-extrabold text-amber-600 dark:text-amber-400">{{ offer.includedRevisions }}</p>
            <p class="text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider mt-1">Revisions</p>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        {# Main Content â€” Left Column (2/3) #}

        <div class="lg:col-span-2 space-y-6">

            {# Offer Details Card #}
            <div class="bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm overflow-hidden">
                <div class="px-6 py-4 border-b border-slate-100 dark:border-slate-800 flex items-center gap-2">
                    <svg class="w-5 h-5 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                    <h3 class="text-lg font-bold text-slate-900 dark:text-white">Offer Details</h3>
                </div>
                <div class="p-6 space-y-5">
                    {% if offer.scopeSummary %}
                    <div class="info-section info-section-emerald pl-5">
                        <p class="text-xs font-semibold text-emerald-600 dark:text-emerald-400 uppercase tracking-wider mb-2">Scope Summary</p>
                        <p class="text-sm text-slate-700 dark:text-slate-300 leading-relaxed">{{ offer.scopeSummary }}</p>
                    </div>
                    {% endif %}

                    {% if offer.message %}
                    <div class="info-section info-section-blue pl-5">
                        <p class="text-xs font-semibold text-blue-600 dark:text-blue-400 uppercase tracking-wider mb-2">Worker Message</p>
                        <p class="text-sm text-slate-700 dark:text-slate-300 leading-relaxed">{{ offer.message }}</p>
                    </div>
                    {% endif %}

                    {% if offer.deliverables %}
                    <div class="info-section info-section-purple pl-5">
                        <p class="text-xs font-semibold text-purple-600 dark:text-purple-400 uppercase tracking-wider mb-2">Deliverables</p>
                        <p class="text-sm text-slate-700 dark:text-slate-300 leading-relaxed">{{ offer.deliverables }}</p>
                    </div>
                    {% endif %}

                    {% if offer.acceptanceCriteria %}
                    <div class="info-section info-section-amber pl-5">
                        <p class="text-xs font-semibold text-amber-600 dark:text-amber-400 uppercase tracking-wider mb-2">Acceptance Criteria</p>
                        <p class="text-sm text-slate-700 dark:text-slate-300 leading-relaxed">{{ offer.acceptanceCriteria }}</p>
                    </div>
                    {% endif %}

                    {% if not offer.scopeSummary and not offer.message and not offer.deliverables and not offer.acceptanceCriteria %}
                    <div class="text-center py-6">
                        <svg class="w-10 h-10 mx-auto text-slate-300 dark:text-slate-600 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                        <p class="text-sm text-slate-400 dark:text-slate-500">No additional details provided</p>
                    </div>
                    {% endif %}
                </div>
            </div>

            {# Service Request Card #}
            <div class="bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm overflow-hidden">
                <div class="px-6 py-4 border-b border-slate-100 dark:border-slate-800 flex items-center gap-2">
                    <svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                    <h3 class="text-lg font-bold text-slate-900 dark:text-white">Linked Service Request</h3>
                </div>
                <div class="p-6">
                    <div class="flex items-start gap-4">
                        <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-blue-500 to-blue-600 flex items-center justify-center text-white flex-shrink-0 shadow-lg shadow-blue-500/20">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
                        </div>
                        <div class="flex-1 min-w-0">
                            <h4 class="text-base font-bold text-slate-900 dark:text-white mb-1">{{ offer.serviceRequest.title }}</h4>
                            <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed mb-4">{{ offer.serviceRequest.description|slice(0, 300) }}{% if offer.serviceRequest.description|length > 300 %}â€¦{% endif %}</p>
                            <div class="flex flex-wrap gap-3">
                                <div class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-emerald-50 dark:bg-emerald-900/20 border border-emerald-100 dark:border-emerald-800/30">
                                    <svg class="w-3.5 h-3.5 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                                    <span class="text-xs font-bold text-emerald-700 dark:text-emerald-400">${{ offer.serviceRequest.budgetMin|number_format(0) }} â€“ ${{ offer.serviceRequest.budgetMax|number_format(0) }}</span>

                                </div>
                                <div class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700">
                                    <svg class="w-3.5 h-3.5 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                                    <span class="text-xs font-bold text-slate-600 dark:text-slate-400">{{ offer.serviceRequest.client.fullName }}</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {# Sidebar â€” Right Column (1/3) #}

        <div class="space-y-6">

            {# Worker Info Card #}
            <div class="bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm overflow-hidden">
                <div class="px-6 py-4 border-b border-slate-100 dark:border-slate-800 flex items-center gap-2">
                    <svg class="w-5 h-5 text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                    <h3 class="text-lg font-bold text-slate-900 dark:text-white">Worker</h3>
                </div>
                <div class="p-6">
                    <div class="flex flex-col items-center text-center">
                        <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-emerald-500 to-emerald-600 flex items-center justify-center text-white text-xl font-bold shadow-lg shadow-emerald-500/30 mb-3">
                            {{ offer.worker.firstName|first|upper }}{{ offer.worker.lastName|first|upper }}
                        </div>
                        <p class="font-bold text-slate-900 dark:text-white text-lg">{{ offer.worker.fullName }}</p>
                        <p class="text-sm text-slate-500 dark:text-slate-400 mt-0.5">{{ offer.worker.email }}</p>
                        {% if offer.worker.ratingAvg is defined and offer.worker.ratingAvg %}
                        <div class="flex items-center gap-1 mt-3">
                            <div class="flex items-center gap-0.5">
                                {% for i in 1..5 %}
                                    {% if i <= offer.worker.ratingAvg|round %}
                                        <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                                    {% else %}
                                        <svg class="w-4 h-4 text-slate-300 dark:text-slate-600" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                                    {% endif %}
                                {% endfor %}
                            </div>
                            <span class="text-sm font-semibold text-amber-600 dark:text-amber-400 ml-1">{{ offer.worker.ratingAvg }}</span>
                        </div>
                        {% endif %}
                    </div>
                </div>
            </div>

            {# Timeline & Dates Card #}
            <div class="bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm overflow-hidden">
                <div class="px-6 py-4 border-b border-slate-100 dark:border-slate-800 flex items-center gap-2">
                    <svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                    <h3 class="text-lg font-bold text-slate-900 dark:text-white">Timeline</h3>
                </div>
                <div class="p-6 space-y-4">
                    <div class="flex items-center gap-3">
                        <div class="w-8 h-8 rounded-lg bg-emerald-500/10 dark:bg-emerald-500/20 flex items-center justify-center flex-shrink-0">
                            <svg class="w-4 h-4 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
                        </div>
                        <div>
                            <p class="text-xs font-medium text-slate-500 dark:text-slate-400">Created</p>
                            <p class="text-sm font-semibold text-slate-900 dark:text-white">{{ offer.createdAt|date('M d, Y \\a\\t h:i A') }}</p>
                        </div>
                    </div>
                    {% if offer.startDateAvailable %}
                    <div class="flex items-center gap-3">
                        <div class="w-8 h-8 rounded-lg bg-blue-500/10 dark:bg-blue-500/20 flex items-center justify-center flex-shrink-0">
                            <svg class="w-4 h-4 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        </div>
                        <div>
                            <p class="text-xs font-medium text-slate-500 dark:text-slate-400">Available From</p>
                            <p class="text-sm font-semibold text-slate-900 dark:text-white">{{ offer.startDateAvailable|date('M d, Y') }}</p>
                        </div>
                    </div>
                    {% endif %}
                    {% if offer.deliveryDateEstimated %}
                    <div class="flex items-center gap-3">
                        <div class="w-8 h-8 rounded-lg bg-purple-500/10 dark:bg-purple-500/20 flex items-center justify-center flex-shrink-0">
                            <svg class="w-4 h-4 text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                        </div>
                        <div>
                            <p class="text-xs font-medium text-slate-500 dark:text-slate-400">Est. Delivery</p>
                            <p class="text-sm font-semibold text-slate-900 dark:text-white">{{ offer.deliveryDateEstimated|date('M d, Y') }}</p>
                        </div>
                    </div>
                    {% endif %}
                </div>
            </div>

            {# Extra Details Card #}
            <div class="bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm overflow-hidden">
                <div class="px-6 py-4 border-b border-slate-100 dark:border-slate-800 flex items-center gap-2">
                    <svg class="w-5 h-5 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    <h3 class="text-lg font-bold text-slate-900 dark:text-white">Additional Info</h3>
                </div>
                <div class="p-6">
                    <div class="space-y-3">
                        <div class="flex items-center justify-between py-2.5 border-b border-slate-100 dark:border-slate-800">
                            <span class="text-sm text-slate-500 dark:text-slate-400">Revisions Included</span>
                            <span class="text-sm font-bold text-slate-900 dark:text-white">{{ offer.includedRevisions }}</span>
                        </div>
                        {% if offer.extraRevisionFee %}
                        <div class="flex items-center justify-between py-2.5 border-b border-slate-100 dark:border-slate-800">
                            <span class="text-sm text-slate-500 dark:text-slate-400">Extra Revision Fee</span>
                            <span class="text-sm font-bold text-emerald-600 dark:text-emerald-400">${{ offer.extraRevisionFee|number_format(2) }}</span>
                        </div>
                        {% endif %}
                        {% if offer.responseSlaHours %}
                        <div class="flex items-center justify-between py-2.5 border-b border-slate-100 dark:border-slate-800">
                            <span class="text-sm text-slate-500 dark:text-slate-400">Response SLA</span>
                            <span class="text-sm font-bold text-slate-900 dark:text-white">{{ offer.responseSlaHours }}h</span>
                        </div>
                        {% endif %}
                        <div class="flex items-center justify-between py-2.5 border-b border-slate-100 dark:border-slate-800">
                            <span class="text-sm text-slate-500 dark:text-slate-400">Priority Level</span>
                            <span class="inline-flex items-center gap-1 px-2.5 py-1 text-xs font-bold rounded-full
                                {% if offer.priorityLevel == 'HIGH' %}bg-red-100 text-red-700 dark:bg-red-900/40 dark:text-red-400
                                {% elseif offer.priorityLevel == 'MEDIUM' %}bg-amber-100 text-amber-700 dark:bg-amber-900/40 dark:text-amber-400
                                {% else %}bg-slate-100 text-slate-600 dark:bg-slate-800 dark:text-slate-400{% endif %}">
                                {% if offer.priorityLevel == 'HIGH' %}
                                    <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M12.395 2.553a1 1 0 00-1.45-.385c-.345.23-.614.558-.822.88-.214.33-.403.713-.57 1.116-.334.804-.614 1.768-.84 2.734a31.365 31.365 0 00-.613 3.58 2.64 2.64 0 01-.945-1.067c-.328-.68-.398-1.534-.398-2.654A1 1 0 005.05 6.05 6.981 6.981 0 003 11a7 7 0 1011.95-4.95c-.592-.591-.98-.985-1.348-1.467-.363-.476-.724-1.063-1.207-2.03zM12.12 15.12A3 3 0 017 13s.879.5 2.5.5c0-1 .5-4 1.25-4.5.5 1 .786 1.293 1.371 1.879A2.99 2.99 0 0113 13a2.99 2.99 0 01-.879 2.121z" clip-rule="evenodd"/></svg>
                                {% endif %}
                                {{ offer.priorityLevel }}
                            </span>
                        </div>
                        <div class="flex items-center justify-between py-2.5">
                            <span class="text-sm text-slate-500 dark:text-slate-400">Urgent Delivery</span>
                            {% if offer.isUrgent %}
                                <span class="inline-flex items-center gap-1 px-2.5 py-1 text-xs font-bold rounded-full bg-red-100 text-red-700 dark:bg-red-900/40 dark:text-red-400">
                                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                                    Yes
                                </span>
                            {% else %}
                                <span class="text-sm font-bold text-slate-400 dark:text-slate-500">No</span>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
