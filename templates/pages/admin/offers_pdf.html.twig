{% extends 'base.html.twig' %}

{% block body %}
    <h1>Offers List (PDF Export)</h1>
    <table border="1" cellpadding="5" cellspacing="0">
        <thead>
            <tr>
                <th>ID</th>
                <th>Title</th>
                <th>Status</th>
                <th>Created At</th>
            </tr>
        </thead>
        <tbody>
        {% for offer in offers %}
            <tr>
                <td>{{ offer.id }}</td>
                <td>{{ offer.serviceRequest.title }}</td>
                <td>{{ offer.status }}</td>
                <td>{{ offer.createdAt|date('Y-m-d H:i') }}</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
{% endblock %}
