{% extends 'layout_admin.html.twig' %}

{% block title %}{{ is_edit ? 'Edit User' : 'Create User' }} - Orion{% endblock %}

{% block main %}
<div class="max-w-4xl mx-auto">
    <div class="mb-6">
        <a href="{{ path('admin_users_index') }}" 
           class="inline-flex items-center gap-2 text-slate-600 hover:text-slate-900 dark:text-slate-400 dark:hover:text-white">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
            </svg>
            Back to Users
        </a>
    </div>

    {# Flash messages #}
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="mb-4 p-4 rounded-lg {% if label == 'success' %}bg-emerald-100 text-emerald-800 dark:bg-emerald-900/20 dark:text-emerald-400{% elseif label == 'warning' %}bg-yellow-100 text-yellow-800 dark:bg-yellow-900/20 dark:text-yellow-400{% else %}bg-red-100 text-red-800 dark:bg-red-900/20 dark:text-red-400{% endif %}">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    <div class="bg-white dark:bg-slate-900 rounded-lg border border-slate-200 dark:border-slate-800 p-6">
        <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-6">
            {{ is_edit ? 'Edit User' : 'Create User' }}
        </h2>

        {{ form_start(form, {'attr': {'class': 'space-y-6', 'enctype': 'multipart/form-data'}}) }}

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {# Username #}
            <div>
                {{ form_label(form.username, null, {'label_attr': {'class': 'block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2'}}) }}
                {{ form_widget(form.username) }}
                {{ form_errors(form.username) }}
            </div>

            {# Email #}
            <div>
                {{ form_label(form.email, null, {'label_attr': {'class': 'block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2'}}) }}
                {{ form_widget(form.email) }}
                {{ form_errors(form.email) }}
            </div>

            {# First Name #}
            <div>
                {{ form_label(form.firstName, null, {'label_attr': {'class': 'block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2'}}) }}
                {{ form_widget(form.firstName) }}
                {{ form_errors(form.firstName) }}
            </div>

            {# Last Name #}
            <div>
                {{ form_label(form.lastName, null, {'label_attr': {'class': 'block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2'}}) }}
                {{ form_widget(form.lastName) }}
                {{ form_errors(form.lastName) }}
            </div>

            {# Phone #}
            <div>
                {{ form_label(form.phone, null, {'label_attr': {'class': 'block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2'}}) }}
                {{ form_widget(form.phone) }}
                {{ form_errors(form.phone) }}
            </div>

            {# Password #}
            <div>
                {{ form_label(form.plainPassword, null, {'label_attr': {'class': 'block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2'}}) }}
                {{ form_widget(form.plainPassword) }}
                {{ form_errors(form.plainPassword) }}
            </div>

            {# Role #}
            <div>
                {{ form_label(form.role, null, {'label_attr': {'class': 'block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2'}}) }}
                {{ form_widget(form.role) }}
                {{ form_errors(form.role) }}
            </div>

            {# Status #}
            <div>
                {{ form_label(form.status, null, {'label_attr': {'class': 'block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2'}}) }}
                {{ form_widget(form.status) }}
                {{ form_errors(form.status) }}
            </div>

            {# Country #}
            <div>
                {{ form_label(form.country, null, {'label_attr': {'class': 'block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2'}}) }}
                {{ form_widget(form.country) }}
                {{ form_errors(form.country) }}
            </div>

            {# City #}
            <div>
                {{ form_label(form.city, null, {'label_attr': {'class': 'block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2'}}) }}
                {{ form_widget(form.city) }}
                {{ form_errors(form.city) }}
            </div>

            {# Timezone #}
            <div class="md:col-span-2">
                {{ form_label(form.timezone, null, {'label_attr': {'class': 'block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2'}}) }}
                {{ form_widget(form.timezone) }}
                {{ form_errors(form.timezone) }}
            </div>
        </div>

        {# Checkboxes #}
        <div class="border-t border-slate-200 dark:border-slate-700 pt-6">
            <h3 class="text-lg font-semibold text-slate-900 dark:text-white mb-4">Verification Status</h3>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div class="flex items-center gap-2">
                    {{ form_widget(form.emailVerified) }}
                    {{ form_label(form.emailVerified, null, {'label_attr': {'class': 'text-sm text-slate-700 dark:text-slate-300'}}) }}
                </div>
                <div class="flex items-center gap-2">
                    {{ form_widget(form.phoneVerified) }}
                    {{ form_label(form.phoneVerified, null, {'label_attr': {'class': 'text-sm text-slate-700 dark:text-slate-300'}}) }}
                </div>
                <div class="flex items-center gap-2">
                    {{ form_widget(form.twoFactorEnabled) }}
                    {{ form_label(form.twoFactorEnabled, null, {'label_attr': {'class': 'text-sm text-slate-700 dark:text-slate-300'}}) }}
                </div>
            </div>
        </div>

        {# File uploads #}
        <div class="border-t border-slate-200 dark:border-slate-700 pt-6">
            <h3 class="text-lg font-semibold text-slate-900 dark:text-white mb-4">Images</h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    {{ form_label(form.profilePictureFile, null, {'label_attr': {'class': 'block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2'}}) }}
                    {% if is_edit and user.profilePicture %}
                        <img src="{{ asset(user.profilePicture) }}" alt="Current profile" class="w-20 h-20 rounded-full object-cover mb-2">
                    {% endif %}
                    {{ form_widget(form.profilePictureFile) }}
                    {{ form_errors(form.profilePictureFile) }}
                </div>
                <div>
                    {{ form_label(form.faceImageFile, null, {'label_attr': {'class': 'block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2'}}) }}
                    {% if is_edit and user.faceImagePath %}
                        <img src="{{ asset(user.faceImagePath) }}" alt="Current face" class="w-20 h-20 rounded-full object-cover mb-2">
                        <p class="text-xs text-slate-500 dark:text-slate-400 mb-2">
                            Model: {{ user.faceModelVersion ?? 'N/A' }} | 
                            Last verified: {{ user.faceLastVerified ? user.faceLastVerified|date('Y-m-d H:i') : 'Never' }}
                        </p>
                    {% endif %}
                    {{ form_widget(form.faceImageFile) }}
                    {{ form_errors(form.faceImageFile) }}
                </div>
            </div>
        </div>

        {# Submit button #}
        <div class="flex gap-4 pt-6 border-t border-slate-200 dark:border-slate-700">
            <button type="submit" 
                    class="px-6 py-2 bg-emerald-600 text-white rounded-lg hover:bg-emerald-700 transition font-medium">
                {{ is_edit ? 'Update User' : 'Create User' }}
            </button>
            <a href="{{ path('admin_users_index') }}"
               class="px-6 py-2 border border-slate-300 dark:border-slate-700 text-slate-700 dark:text-slate-300 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-800 transition font-medium">
                Cancel
            </a>
        </div>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
