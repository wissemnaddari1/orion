{% extends 'layout_admin.html.twig' %}

{% block title %}{{ user.fullName }} - User Details - Orion{% endblock %}

{% block main %}
<div class="max-w-4xl mx-auto">
    <div class="mb-6 flex items-center justify-between">
        <a href="{{ path('admin_users_index') }}" 
           class="inline-flex items-center gap-2 text-slate-600 hover:text-slate-900 dark:text-slate-400 dark:hover:text-white">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
            </svg>
            Back to Users
        </a>

        <div class="flex gap-2">
            <a href="{{ path('admin_users_edit', {id: user.id}) }}" 
               class="px-4 py-2 bg-emerald-600 text-white rounded-lg hover:bg-emerald-700 transition">

                Edit User
            </a>
            <form method="post" action="{{ path('admin_users_delete', {id: user.id}) }}" 
                  onsubmit="return confirm('Are you sure you want to delete this user?');">

                <button type="submit" 
                        class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition">
                    Delete
                </button>
            </form>
        </div>
    </div>

    {# Flash messages #}
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="mb-4 p-4 rounded-lg {% if label == 'success' %}bg-emerald-100 text-emerald-800 dark:bg-emerald-900/20 dark:text-emerald-400{% else %}bg-red-100 text-red-800 dark:bg-red-900/20 dark:text-red-400{% endif %}">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    {# User Profile Card #}
    <div class="bg-white dark:bg-slate-900 rounded-lg border border-slate-200 dark:border-slate-800 p-6 mb-6">
        <div class="flex items-start gap-6">
            {# Profile Picture #}
            <div class="flex-shrink-0">
                {% if user.profilePicture %}
                    <img src="{{ asset(user.profilePicture) }}" 
                         alt="{{ user.fullName }}" 
                         class="w-24 h-24 rounded-full object-cover">
                {% else %}
                    <div class="w-24 h-24 rounded-full bg-emerald-600 flex items-center justify-center text-white text-2xl font-bold">
                        {{ user.firstName|first|upper }}{{ user.lastName|first|upper }}
                    </div>
                {% endif %}
            </div>

            {# User Info #}
            <div class="flex-1">
                <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-1">
                    {{ user.fullName }}
                </h2>
                <p class="text-slate-600 dark:text-slate-400 mb-3">@{{ user.username }}</p>
                
                <div class="flex flex-wrap gap-2 mb-4">
                    <span class="px-3 py-1 text-sm font-semibold rounded-full 
                        {% if user.role.value == 'ADMIN' %}bg-teal-100 text-teal-800 dark:bg-teal-900/30 dark:text-teal-400
                        {% elseif user.role.value == 'WORKER' %}bg-emerald-100 text-emerald-800 dark:bg-emerald-900/30 dark:text-emerald-400

                        {% else %}bg-slate-100 text-slate-800 dark:bg-slate-800 dark:text-slate-400{% endif %}">
                        {{ user.role.value }}
                    </span>
                    <span class="px-3 py-1 text-sm font-semibold rounded-full 
                        {% if user.status.value == 'ACTIVE' %}bg-emerald-100 text-emerald-800 dark:bg-emerald-900/30 dark:text-emerald-400
                        {% elseif user.status.value == 'SUSPENDED' %}bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-400
                        {% else %}bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-400{% endif %}">
                        {{ user.status.value }}
                    </span>
                </div>

                <div class="grid grid-cols-2 gap-4 text-sm">
                    <div>
                        <span class="text-slate-500 dark:text-slate-400">Email:</span>
                        <span class="text-slate-900 dark:text-white ml-2">{{ user.email }}</span>
                        {% if user.emailVerified %}
                            <span class="text-emerald-600 dark:text-emerald-400 ml-1">✓</span>
                        {% endif %}
                    </div>
                    <div>
                        <span class="text-slate-500 dark:text-slate-400">Phone:</span>
                        <span class="text-slate-900 dark:text-white ml-2">{{ user.phone ?? 'N/A' }}</span>
                        {% if user.phoneVerified %}
                            <span class="text-emerald-600 dark:text-emerald-400 ml-1">✓</span>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# Details Grid #}
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
        {# Personal Info #}
        <div class="bg-white dark:bg-slate-900 rounded-lg border border-slate-200 dark:border-slate-800 p-6">
            <h3 class="text-lg font-semibold text-slate-900 dark:text-white mb-4">Personal Information</h3>
            <dl class="space-y-3">
                <div>
                    <dt class="text-sm text-slate-500 dark:text-slate-400">Country</dt>
                    <dd class="text-sm font-medium text-slate-900 dark:text-white">{{ user.country ?? 'N/A' }}</dd>
                </div>
                <div>
                    <dt class="text-sm text-slate-500 dark:text-slate-400">City</dt>
                    <dd class="text-sm font-medium text-slate-900 dark:text-white">{{ user.city ?? 'N/A' }}</dd>
                </div>
                <div>
                    <dt class="text-sm text-slate-500 dark:text-slate-400">Timezone</dt>
                    <dd class="text-sm font-medium text-slate-900 dark:text-white">{{ user.timezone ?? 'N/A' }}</dd>
                </div>
                <div>
                    <dt class="text-sm text-slate-500 dark:text-slate-400">2FA Enabled</dt>
                    <dd class="text-sm font-medium text-slate-900 dark:text-white">
                        {% if user.twoFactorEnabled %}
                            <span class="text-emerald-600 dark:text-emerald-400">Yes</span>
                        {% else %}
                            <span class="text-slate-400">No</span>
                        {% endif %}
                    </dd>
                </div>
            </dl>
        </div>

        {# Account Info #}
        <div class="bg-white dark:bg-slate-900 rounded-lg border border-slate-200 dark:border-slate-800 p-6">
            <h3 class="text-lg font-semibold text-slate-900 dark:text-white mb-4">Account Information</h3>
            <dl class="space-y-3">
                <div>
                    <dt class="text-sm text-slate-500 dark:text-slate-400">Account Balance</dt>
                    <dd class="text-sm font-medium text-slate-900 dark:text-white">
                        {{ user.accountBalance|number_format(2) }} {{ user.walletCurrency }}
                    </dd>
                </div>
                <div>
                    <dt class="text-sm text-slate-500 dark:text-slate-400">Rating</dt>
                    <dd class="text-sm font-medium text-slate-900 dark:text-white">
                        {% if user.ratingAvg %}
                            ⭐ {{ user.ratingAvg|number_format(2) }} ({{ user.totalReviews }} reviews)
                        {% else %}
                            No ratings yet
                        {% endif %}
                    </dd>
                </div>
                <div>
                    <dt class="text-sm text-slate-500 dark:text-slate-400">Last Login</dt>
                    <dd class="text-sm font-medium text-slate-900 dark:text-white">
                        {{ user.lastLogin ? user.lastLogin|date('Y-m-d H:i:s') : 'Never' }}
                    </dd>
                </div>
                <div>
                    <dt class="text-sm text-slate-500 dark:text-slate-400">Last IP</dt>
                    <dd class="text-sm font-medium text-slate-900 dark:text-white">{{ user.lastIp ?? 'N/A' }}</dd>
                </div>
            </dl>
        </div>
    </div>

    {# Facial Recognition Info #}
    {% if user.faceImagePath or user.faceEmbedding %}
    <div class="bg-white dark:bg-slate-900 rounded-lg border border-slate-200 dark:border-slate-800 p-6 mb-6">
        <h3 class="text-lg font-semibold text-slate-900 dark:text-white mb-4">Facial Recognition</h3>
        <div class="flex gap-6">
            {% if user.faceImagePath %}
                <div>
                    <img src="{{ asset(user.faceImagePath) }}" 
                         alt="Face image" 
                         class="w-32 h-32 rounded-lg object-cover">
                </div>
            {% endif %}
            <div class="flex-1">
                <dl class="space-y-3">
                    <div>
                        <dt class="text-sm text-slate-500 dark:text-slate-400">Model Version</dt>
                        <dd class="text-sm font-medium text-slate-900 dark:text-white">{{ user.faceModelVersion ?? 'N/A' }}</dd>
                    </div>
                    <div>
                        <dt class="text-sm text-slate-500 dark:text-slate-400">Last Verified</dt>
                        <dd class="text-sm font-medium text-slate-900 dark:text-white">
                            {{ user.faceLastVerified ? user.faceLastVerified|date('Y-m-d H:i:s') : 'Never' }}
                        </dd>
                    </div>
                    <div>
                        <dt class="text-sm text-slate-500 dark:text-slate-400">Failed Attempts</dt>
                        <dd class="text-sm font-medium text-slate-900 dark:text-white">{{ user.faceFailedAttempts ?? 0 }}</dd>
                    </div>
                    {% if user.faceLockedUntil %}
                    <div>
                        <dt class="text-sm text-slate-500 dark:text-slate-400">Locked Until</dt>
                        <dd class="text-sm font-medium text-red-600 dark:text-red-400">
                            {{ user.faceLockedUntil|date('Y-m-d H:i:s') }}
                        </dd>
                    </div>
                    {% endif %}
                    <div>
                        <dt class="text-sm text-slate-500 dark:text-slate-400">Embedding Status</dt>
                        <dd class="text-sm font-medium text-slate-900 dark:text-white">
                            {% if user.faceEmbedding %}
                                <span class="text-emerald-600 dark:text-emerald-400">✓ Generated</span>
                            {% else %}
                                <span class="text-slate-400">Not generated</span>
                            {% endif %}
                        </dd>
                    </div>
                </dl>
            </div>
        </div>
    </div>
    {% endif %}

    {# Timestamps #}
    <div class="bg-white dark:bg-slate-900 rounded-lg border border-slate-200 dark:border-slate-800 p-6">
        <h3 class="text-lg font-semibold text-slate-900 dark:text-white mb-4">Timestamps</h3>
        <div class="grid grid-cols-2 gap-4 text-sm">
            <div>
                <span class="text-slate-500 dark:text-slate-400">Created:</span>
                <span class="text-slate-900 dark:text-white ml-2">{{ user.createdAt|date('Y-m-d H:i:s') }}</span>
            </div>
            <div>
                <span class="text-slate-500 dark:text-slate-400">Updated:</span>
                <span class="text-slate-900 dark:text-white ml-2">{{ user.updatedAt|date('Y-m-d H:i:s') }}</span>
            </div>
        </div>
    </div>
</div>
{% endblock %}
