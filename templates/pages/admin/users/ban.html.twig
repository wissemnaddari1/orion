{% extends 'layout_admin.html.twig' %}

{% block title %}Ban {{ user.fullName }} — Orion{% endblock %}

{% block main %}
<div class="max-w-2xl mx-auto space-y-6">
    <a href="{{ path('admin_users_show', {id: user.id}) }}"
       class="inline-flex items-center gap-2 text-slate-600 hover:text-slate-900 dark:text-slate-400 dark:hover:text-white text-sm font-medium">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        Back to user
    </a>

    <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 p-6 shadow-sm">
        <h2 class="text-xl font-bold text-slate-900 dark:text-white mb-2">Ban user: {{ user.fullName }}</h2>
        <p class="text-sm text-slate-500 dark:text-slate-400 mb-6">@{{ user.username }}</p>

        {% for message in app.flashes('error') %}
            <div class="mb-4 p-4 rounded-lg bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-300 text-sm">
                {{ message }}
            </div>
        {% endfor %}

        {{ form_start(form) }}
        {{ form_row(form.reason) }}
        {{ form_row(form.note) }}
        {{ form_row(form.duration_preset) }}
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4" id="custom-duration-fields">
            {{ form_row(form.custom_value) }}
            {{ form_row(form.custom_unit) }}
        </div>
        <div class="flex gap-3 mt-6">
            <button type="submit" class="px-4 py-2 bg-red-600 text-white rounded-xl hover:bg-red-700 text-sm font-medium">
                Ban user
            </button>
            <a href="{{ path('admin_users_show', {id: user.id}) }}"
               class="px-4 py-2 border border-slate-300 dark:border-slate-600 rounded-xl text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-800 text-sm font-medium">
                Cancel
            </a>
        </div>
        {{ form_end(form) }}
    </div>
</div>
<script>
(function() {
    var preset = document.getElementById('ban_duration_preset');
    var customBlock = document.getElementById('custom-duration-fields');
    if (!preset || !customBlock) return;
    function toggle() {
        customBlock.style.display = preset.value === 'custom' ? 'grid' : 'none';
    }
    preset.addEventListener('change', toggle);
    toggle();
})();
</script>
{% endblock %}
