{% extends 'layout_admin.html.twig' %}

{% block title %}User Management - Orion{% endblock %}

{% block main %}
<div class="space-y-6">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h2 class="text-2xl font-bold text-slate-900 dark:text-white">Users</h2>
            <p class="text-sm text-slate-500 dark:text-slate-400">{{ total }} total users</p>
        </div>
        <div class="flex flex-col sm:flex-row gap-3">
            <form method="get" action="{{ path('admin_users_index') }}" class="flex gap-2">
                <input type="text"
                       name="search"
                       value="{{ search_keyword }}"
                       placeholder="Search by username or email"
                       class="px-4 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-emerald-500 dark:bg-slate-900 dark:border-slate-700 dark:text-white">
                <button type="submit"
                        class="px-4 py-2 bg-slate-600 text-white rounded-lg hover:bg-slate-700 transition">
                    Search
                </button>
            </form>
            <a href="{{ path('admin_users_new') }}"
               class="inline-flex items-center gap-2 px-4 py-2 bg-emerald-600 text-white rounded-lg hover:bg-emerald-700 transition">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                </svg>
                Create User
            </a>
        </div>
    </div>

    <div class="bg-white dark:bg-slate-900 rounded-lg border border-slate-200 dark:border-slate-800 overflow-hidden shadow-sm">
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead class="bg-slate-50 dark:bg-slate-800 border-b border-slate-200 dark:border-slate-700">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider">ID</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider">User</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider">Email</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider">Role</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider">Status</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider">Created</th>
                        <th class="px-6 py-3 text-right text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-200 dark:divide-slate-800">
                    {% for user in users %}
                        <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/50 transition">
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-900 dark:text-slate-300">
                                {{ user.id }}
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <div class="flex items-center gap-3">
                                    <div class="relative w-10 h-10">
                                        {% if user.profilePicture %}
                                            <img src="{{ asset(user.profilePicture) }}"
                                                 alt="{{ user.fullName }}"
                                                 class="w-10 h-10 rounded-full object-cover"
                                                 onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
                                            <div class="w-10 h-10 rounded-full bg-emerald-600 items-center justify-center text-white font-semibold hidden"
                                                 style="display: none;">
                                                {{ user.firstName|first|upper }}{{ user.lastName|first|upper }}
                                            </div>
                                        {% else %}
                                            <div class="w-10 h-10 rounded-full bg-emerald-600 flex items-center justify-center text-white font-semibold">
                                                {{ user.firstName|first|upper }}{{ user.lastName|first|upper }}
                                            </div>
                                        {% endif %}
                                    </div>
                                    <div>
                                        <div class="font-medium text-slate-900 dark:text-white">{{ user.fullName }}</div>
                                        <div class="text-sm text-slate-500 dark:text-slate-400">@{{ user.username }}</div>
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-600 dark:text-slate-400">
                                {{ user.email }}
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <span class="px-2 py-1 text-xs font-semibold rounded-full
                                    {% if user.role and user.role.value == 'ADMIN' %}bg-teal-100 text-teal-800 dark:bg-teal-900/30 dark:text-teal-400
                                    {% elseif user.role and user.role.value == 'WORKER' %}bg-emerald-100 text-emerald-800 dark:bg-emerald-900/30 dark:text-emerald-400
                                    {% else %}bg-slate-100 text-slate-800 dark:bg-slate-800 dark:text-slate-400{% endif %}">
                                    {{ user.role ? user.role.value : '-' }}
                                </span>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <span class="px-2 py-1 text-xs font-semibold rounded-full
                                    {% if user.status and user.status.value == 'ACTIVE' %}bg-emerald-100 text-emerald-800 dark:bg-emerald-900/30 dark:text-emerald-400
                                    {% elseif user.status and user.status.value == 'SUSPENDED' %}bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-400
                                    {% elseif user.status and user.status.value == 'BANNED' %}bg-rose-100 text-rose-800 dark:bg-rose-900/30 dark:text-rose-400
                                    {% else %}bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-400{% endif %}">
                                    {{ user.status ? user.status.value : '-' }}
                                </span>
                                {% if user.isBanned %}
                                    <span class="ml-1 text-xs text-slate-500 dark:text-slate-400" title="Ban end">
                                        {% if user.banEndsAt %}until {{ user.banEndsAt|date('Y-m-d') }}{% else %}(permanent){% endif %}
                                    </span>
                                {% endif %}
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-600 dark:text-slate-400">
                                {{ user.createdAt ? user.createdAt|date('Y-m-d') : '-' }}
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium space-x-2">
                                <a href="{{ path('admin_users_show', {id: user.id}) }}"
                                   class="text-emerald-600 hover:text-emerald-900 dark:text-emerald-400 dark:hover:text-emerald-300">
                                    View
                                </a>
                                <a href="{{ path('admin_users_edit', {id: user.id}) }}"
                                   class="text-emerald-600 hover:text-emerald-900 dark:text-emerald-400 dark:hover:text-emerald-300">
                                    Edit
                                </a>
                                {% if user.isBanned %}
                                    <form method="post" action="{{ path('admin_users_unban', {id: user.id}) }}" class="inline">
                                        <button type="submit" class="text-amber-600 hover:text-amber-800 dark:text-amber-400 dark:hover:text-amber-300">
                                            Unban
                                        </button>
                                    </form>
                                {% else %}
                                    <a href="{{ path('admin_users_ban', {id: user.id}) }}"
                                       class="text-red-600 hover:text-red-800 dark:text-red-400 dark:hover:text-red-300">
                                        Ban
                                    </a>
                                {% endif %}
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="7" class="px-6 py-8 text-center text-slate-500 dark:text-slate-400">
                                No users found. <a href="{{ path('admin_users_new') }}" class="text-emerald-600 hover:underline">Create one now</a>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    {% if total_pages > 1 %}
        <div class="flex items-center justify-between">
            <div class="text-sm text-slate-500 dark:text-slate-400">
                Page {{ page }} of {{ total_pages }}
            </div>
            <div class="flex items-center gap-2">
                {% if page > 1 %}
                    <a href="{{ path('admin_users_index', {page: page - 1, search: search_keyword}) }}"
                       class="px-3 py-2 text-sm border border-slate-300 rounded-lg hover:bg-slate-50 dark:border-slate-700 dark:hover:bg-slate-800">
                        Previous
                    </a>
                {% endif %}
                {% if page < total_pages %}
                    <a href="{{ path('admin_users_index', {page: page + 1, search: search_keyword}) }}"
                       class="px-3 py-2 text-sm border border-slate-300 rounded-lg hover:bg-slate-50 dark:border-slate-700 dark:hover:bg-slate-800">
                        Next
                    </a>
                {% endif %}
            </div>
        </div>
    {% endif %}
</div>
{% endblock %}
