{% extends 'layout_admin.html.twig' %}

{% block title %}{{ user.fullName }} - User Details - Orion{% endblock %}

{% block main %}
<div class="max-w-4xl mx-auto space-y-6">
    <a href="{{ path('admin_users_index') }}"
       class="inline-flex items-center gap-2 text-slate-600 hover:text-slate-900 dark:text-slate-400 dark:hover:text-white text-sm font-medium">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        Back to Users
    </a>

    {# Profile header card: avatar + name (left), actions (right). On mobile actions stack below. #}
    <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 p-6 shadow-sm">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 sm:gap-6">
            {# Left: avatar + name #}
            <div class="flex items-start gap-4 sm:gap-6">
                <div class="flex-shrink-0">
                    <div class="relative w-20 h-20 sm:w-24 sm:h-24">
                        {% if user.profilePicture %}
                            <img src="{{ asset(user.profilePicture) }}"
                                 alt="{{ user.fullName }}"
                                 class="w-20 h-20 sm:w-24 sm:h-24 rounded-full object-cover"
                                 onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
                            <div class="w-20 h-20 sm:w-24 sm:h-24 rounded-full bg-emerald-600 flex items-center justify-center text-white text-xl sm:text-2xl font-bold hidden" style="display: none;">
                                {{ user.firstName|first|upper }}{{ user.lastName|first|upper }}
                            </div>
                        {% else %}
                            <div class="w-20 h-20 sm:w-24 sm:h-24 rounded-full bg-emerald-600 flex items-center justify-center text-white text-xl sm:text-2xl font-bold">
                                {{ user.firstName|first|upper }}{{ user.lastName|first|upper }}
                            </div>
                        {% endif %}
                    </div>
                </div>
                <div class="min-w-0">
                    <h2 class="text-xl sm:text-2xl font-bold text-slate-900 dark:text-white mb-1">{{ user.fullName }}</h2>
                    <p class="text-slate-500 dark:text-slate-400 text-sm">@{{ user.username }}</p>
                    <div class="mt-3 flex flex-wrap gap-2">
                        <span class="px-2 py-1 text-xs font-semibold rounded-full
                            {% if user.role and user.role.value == 'ADMIN' %}bg-purple-100 text-purple-800 dark:bg-purple-900/30 dark:text-purple-400
                            {% elseif user.role and user.role.value == 'WORKER' %}bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-400
                            {% else %}bg-slate-100 text-slate-800 dark:bg-slate-800 dark:text-slate-400{% endif %}">
                            {{ user.role ? user.role.value : 'N/A' }}
                        </span>
                        <span class="px-2 py-1 text-xs font-semibold rounded-full
                            {% if user.status and user.status.value == 'ACTIVE' %}bg-emerald-100 text-emerald-800 dark:bg-emerald-900/30 dark:text-emerald-400
                            {% elseif user.status and user.status.value == 'SUSPENDED' %}bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-400
                            {% elseif user.status and user.status.value == 'BANNED' %}bg-rose-100 text-rose-800 dark:bg-rose-900/30 dark:text-rose-400
                            {% else %}bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-400{% endif %}">
                            {{ user.status ? user.status.value : 'N/A' }}
                        </span>
                    </div>
                </div>
            </div>

            {# Right: actions (outlined, icon + label). Stack on mobile. #}
            <div class="flex flex-wrap items-center gap-2 sm:flex-shrink-0">
                {% if not user.emailVerified %}
                    <form method="post" action="{{ path('admin_users_verify_email', {id: user.id}) }}" class="inline">
                        <input type="hidden" name="_token" value="{{ csrf_token('verify_email' ~ user.id) }}">
                        <button type="submit"
                                class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium rounded-xl border border-emerald-500/50 text-emerald-600 dark:text-emerald-400 bg-transparent hover:bg-emerald-500/10 dark:hover:bg-emerald-500/10 transition">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                            Verify Email
                        </button>
                    </form>
                {% endif %}
                <a href="{{ path('admin_users_edit', {id: user.id}) }}"
                   class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium rounded-xl border border-slate-300 dark:border-slate-700 bg-transparent dark:bg-slate-800/60 hover:bg-slate-100 dark:hover:bg-slate-700/60 hover:border-emerald-500/50 hover:text-emerald-600 dark:hover:text-emerald-400 text-slate-700 dark:text-slate-300 transition">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-11.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>
                    Edit
                </a>
                {% if user.isBanned %}
                    <form method="post" action="{{ path('admin_users_unban', {id: user.id}) }}" class="inline">
                        <button type="submit"
                                class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium rounded-xl border border-amber-500/40 text-amber-600 dark:text-amber-400 bg-transparent hover:bg-amber-500/10 dark:hover:bg-amber-500/10 transition">
                            Unban
                        </button>
                    </form>
                {% else %}
                    <a href="{{ path('admin_users_ban', {id: user.id}) }}"
                       class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium rounded-xl border border-red-500/40 text-red-500 dark:text-red-400 bg-transparent hover:bg-red-500/10 dark:hover:bg-red-500/10 transition">
                        Ban user
                    </a>
                {% endif %}
                <form method="post" action="{{ path('admin_users_delete', {id: user.id}) }}" class="inline"
                      onsubmit="return confirm('Are you sure you want to delete this user? This action cannot be undone.');">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
                    <button type="submit"
                            class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium rounded-xl border border-red-500/40 text-red-500 dark:text-red-400 bg-transparent hover:bg-red-500/10 dark:hover:bg-red-500/10 transition">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                        Delete
                    </button>
                </form>
            </div>
        </div>
    </div>

    <div class="bg-white dark:bg-slate-900 rounded-lg border border-slate-200 dark:border-slate-800 p-6 shadow-sm">
        <h3 class="text-lg font-semibold text-slate-900 dark:text-white mb-4">Account Details</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm">
            <div class="flex justify-between"><span class="text-slate-500 dark:text-slate-400">Email:</span> <span class="text-slate-900 dark:text-white font-medium">{{ user.email }}</span></div>
            <div class="flex justify-between"><span class="text-slate-500 dark:text-slate-400">Phone:</span> <span class="text-slate-900 dark:text-white font-medium">{{ user.phone ?: '-' }}</span></div>
            <div class="flex justify-between"><span class="text-slate-500 dark:text-slate-400">Email Verified:</span> <span class="text-slate-900 dark:text-white font-medium">{{ user.emailVerified ? 'Yes' : 'No' }}</span></div>
            <div class="flex justify-between"><span class="text-slate-500 dark:text-slate-400">Phone Verified:</span> <span class="text-slate-900 dark:text-white font-medium">{{ user.phoneVerified ? 'Yes' : 'No' }}</span></div>
            <div class="flex justify-between"><span class="text-slate-500 dark:text-slate-400">Two Factor:</span> <span class="text-slate-900 dark:text-white font-medium">{{ user.twoFactorEnabled ? 'Enabled' : 'Disabled' }}</span></div>
            <div class="flex justify-between"><span class="text-slate-500 dark:text-slate-400">Balance:</span> <span class="text-slate-900 dark:text-white font-medium">{{ user.accountBalance }} {{ user.walletCurrency }}</span></div>
        </div>
    </div>

    <div class="bg-white dark:bg-slate-900 rounded-lg border border-slate-200 dark:border-slate-800 p-6 shadow-sm">
        <h3 class="text-lg font-semibold text-slate-900 dark:text-white mb-4">Location</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm">
            <div class="flex justify-between"><span class="text-slate-500 dark:text-slate-400">Country:</span> <span class="text-slate-900 dark:text-white font-medium">{{ user.country ?: '-' }}</span></div>
            <div class="flex justify-between"><span class="text-slate-500 dark:text-slate-400">City:</span> <span class="text-slate-900 dark:text-white font-medium">{{ user.city ?: '-' }}</span></div>
            <div class="flex justify-between"><span class="text-slate-500 dark:text-slate-400">Timezone:</span> <span class="text-slate-900 dark:text-white font-medium">{{ user.timezone ?: '-' }}</span></div>
        </div>
    </div>

    <div class="bg-white dark:bg-slate-900 rounded-lg border border-slate-200 dark:border-slate-800 p-6 shadow-sm">
        <h3 class="text-lg font-semibold text-slate-900 dark:text-white mb-4">Timestamps</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm">
            <div class="flex justify-between"><span class="text-slate-500 dark:text-slate-400">Created At:</span> <span class="text-slate-900 dark:text-white font-medium">{{ user.createdAt ? user.createdAt|date('Y-m-d H:i') : '-' }}</span></div>
            <div class="flex justify-between"><span class="text-slate-500 dark:text-slate-400">Updated At:</span> <span class="text-slate-900 dark:text-white font-medium">{{ user.updatedAt ? user.updatedAt|date('Y-m-d H:i') : '-' }}</span></div>
            <div class="flex justify-between"><span class="text-slate-500 dark:text-slate-400">Last Login:</span> <span class="text-slate-900 dark:text-white font-medium">{{ user.lastLogin ? user.lastLogin|date('Y-m-d H:i') : 'Never' }}</span></div>
            <div class="flex justify-between"><span class="text-slate-500 dark:text-slate-400">Last IP:</span> <span class="text-slate-900 dark:text-white font-medium">{{ user.lastIp ?: '-' }}</span></div>
            {% if user.isBanned %}
            <div class="flex justify-between"><span class="text-slate-500 dark:text-slate-400">Banned at:</span> <span class="text-slate-900 dark:text-white font-medium">{{ user.bannedAt ? user.bannedAt|date('Y-m-d H:i') : '-' }}</span></div>
            <div class="flex justify-between"><span class="text-slate-500 dark:text-slate-400">Ban ends:</span> <span class="text-slate-900 dark:text-white font-medium">{{ user.banEndsAt ? user.banEndsAt|date('Y-m-d H:i') : 'Permanent' }}</span></div>
            <div class="flex justify-between"><span class="text-slate-500 dark:text-slate-400">Ban reason:</span> <span class="text-slate-900 dark:text-white font-medium">{{ user.banReason ?: '-' }}</span></div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
