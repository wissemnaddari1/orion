{% extends 'base.html.twig' %}
{% block title %}Face Login Successful — Orion{% endblock %}

{% block body %}
<div class="min-h-screen flex items-center justify-center px-4 py-12
            bg-gradient-to-br from-emerald-600/10 via-white to-emerald-700/5
            dark:from-emerald-500/10 dark:via-slate-950 dark:to-emerald-500/5">

    <div class="w-full max-w-md">
        <div class="rounded-2xl border border-slate-200 bg-white/90 p-8 shadow-xl backdrop-blur
                    dark:border-slate-800 dark:bg-slate-950/70 text-center">

            {# Success icon #}
            <div class="mx-auto w-16 h-16 bg-emerald-100 dark:bg-emerald-900/30 rounded-full flex items-center justify-center mb-4">
                <svg class="w-10 h-10 text-emerald-600 dark:text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
            </div>

            <h1 class="text-2xl font-extrabold text-slate-900 dark:text-white mb-2">
                Face Recognized Successfully!
            </h1>

            <p class="text-slate-600 dark:text-slate-400 mb-6">
                Welcome back, <span class="font-semibold text-emerald-600 dark:text-emerald-400">{{ user.fullName }}</span>
            </p>

            {# User info card #}
            <div class="bg-slate-50 dark:bg-slate-900/40 rounded-xl p-4 mb-6">
                <div class="flex items-center gap-4 justify-center">
                    {% if user.profilePicture %}
                        <img src="{{ asset(user.profilePicture) }}" 
                             alt="{{ user.fullName }}" 
                             class="w-16 h-16 rounded-full object-cover">
                    {% else %}
                        <div class="w-16 h-16 rounded-full bg-emerald-600 flex items-center justify-center text-white text-xl font-bold">
                            {{ user.firstName|first|upper }}{{ user.lastName|first|upper }}
                        </div>
                    {% endif %}
                    <div class="text-left">
                        <p class="font-semibold text-slate-900 dark:text-white">{{ user.fullName }}</p>
                        <p class="text-sm text-slate-600 dark:text-slate-400">{{ user.email }}</p>
                        <span class="inline-block px-2 py-1 text-xs font-semibold rounded-full bg-emerald-100 text-emerald-800 dark:bg-emerald-900/30 dark:text-emerald-400 mt-1">
                            {{ user.role.value }}
                        </span>
                    </div>
                </div>
            </div>

            {# Note: In a real implementation, you would automatically redirect after authentication #}
            <p class="text-sm text-slate-500 dark:text-slate-400 mb-4">
                Note: In production, authentication would be completed automatically. 
                For now, click below to continue.
            </p>

            {# Continue buttons based on role #}
            <div class="space-y-3">
                {% if user.role.value == 'ADMIN' %}
                    <a href="{{ path('admin_users_index') }}" 
                       class="block w-full px-6 py-3 bg-emerald-600 text-white rounded-xl font-semibold hover:bg-emerald-700 transition">
                        Go to Admin Dashboard
                    </a>
                {% elseif user.role.value == 'WORKER' %}
                    <a href="{{ path('worker_dashboard') }}" 
                       class="block w-full px-6 py-3 bg-emerald-600 text-white rounded-xl font-semibold hover:bg-emerald-700 transition">
                        Go to Worker Dashboard
                    </a>
                {% else %}
                    <a href="{{ path('client_dashboard') }}" 
                       class="block w-full px-6 py-3 bg-emerald-600 text-white rounded-xl font-semibold hover:bg-emerald-700 transition">
                        Go to Dashboard
                    </a>
                {% endif %}

                <a href="{{ path('app_login') }}" 
                   class="block w-full px-6 py-3 border border-slate-300 dark:border-slate-700 text-slate-700 dark:text-slate-300 rounded-xl font-semibold hover:bg-slate-50 dark:hover:bg-slate-800 transition">
                    Back to Login
                </a>
            </div>

            {# Security info #}
            <div class="mt-6 text-xs text-slate-500 dark:text-slate-400">
                <p>Last verified: {{ "now"|date('Y-m-d H:i:s') }}</p>
                <p>IP: {{ app.request.clientIp }}</p>
            </div>

        </div>
    </div>
</div>
{% endblock %}
