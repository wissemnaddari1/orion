{% extends 'layout_auth.html.twig' %}
{% block title %}Forgot password - Orion{% endblock %}

{% block auth_content %}
<div class="auth-form-inner p-6 sm:p-8">
    {# Brand header — matches login/register #}
    <div class="text-center mb-2">
        <a href="{{ path('app_login') }}" class="inline-flex items-center justify-center">
            <img
                src="{{ asset('images/orion_light_mode.png') }}"
                alt="Orion Logo"
                class="h-20 sm:h-24 w-auto object-contain
                       drop-shadow-[0_0_25px_rgba(16,185,129,0.55)]
                       hover:scale-105 transition-transform duration-300 dark:invert"
            />
        </a>
        <h1 class="mt-8 text-2xl font-extrabold tracking-tight text-slate-900 dark:text-white">
            Forgot password?
        </h1>
        <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">
            Enter your email and we'll send you a link to reset your password.
        </p>
    </div>

    {% if success %}
        <div class="mt-4 p-4 rounded-xl bg-emerald-100 text-emerald-800 dark:bg-emerald-900/20 dark:text-emerald-400 text-sm">
            If an account exists for that email, you will receive a password reset link shortly. Please check your inbox and spam folder. The link expires in 30 minutes.
        </div>
        <p class="mt-6 text-center text-sm text-slate-600 dark:text-slate-300">
            <a href="{{ path('app_login') }}" class="font-semibold text-emerald-600 hover:underline dark:text-emerald-400">Back to login</a>
        </p>
    {% else %}
        <form method="post" action="{{ path('app_forgot_password') }}" class="mt-8 space-y-6">
            <div>
                <label for="email" class="block text-sm font-semibold text-slate-700 dark:text-slate-200">Email</label>
                <input id="email" name="email" type="email" required autocomplete="email" value="{{ email }}"
                       placeholder="you@example.com"
                       class="mt-2 block w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-slate-900
                              focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20
                              dark:border-slate-700 dark:bg-slate-900/40 dark:text-white dark:placeholder-slate-400">
            </div>
            <button type="submit"
                    class="w-full inline-flex items-center justify-center rounded-xl bg-emerald-600 px-6 py-3
                           text-sm font-extrabold text-white shadow-sm hover:bg-emerald-700 transition">
                Send reset link
            </button>
        </form>
        <p class="mt-6 text-center text-sm text-slate-600 dark:text-slate-300">
            <a href="{{ path('app_login') }}" class="font-semibold text-emerald-600 hover:underline dark:text-emerald-400">Back to login</a>
        </p>
    {% endif %}
</div>
{% endblock %}
