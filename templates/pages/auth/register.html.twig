{% extends 'layout_auth.html.twig' %}
{% set card_wide = true %}

{% block auth_content %}
<div class="register-page">
{# Hero header #}
<header class="register-hero text-center mb-10">
  <a href="{{ path('app_home') }}" class="inline-block focus:outline-none focus-visible:ring-2 focus-visible:ring-emerald-500 focus-visible:ring-offset-2 rounded-lg">
    <img src="{{ asset('images/orion_light_mode.png') }}" alt="Orion" class="register-hero__logo h-16 sm:h-20 w-auto mx-auto dark:hidden">
    <img src="{{ asset('images/orion_light_mode.png') }}" alt="Orion" class="register-hero__logo h-16 sm:h-20 w-auto mx-auto hidden dark:block">
  </a>
  <h1 class="register-hero__title mt-8 text-3xl sm:text-4xl font-extrabold tracking-tight text-slate-900 dark:text-white">
    Join Orion
  </h1>
  <p class="register-hero__subtitle mt-3 text-base text-slate-500 dark:text-slate-400 font-medium">
    Choose how you want to get started
  </p>
</header>

{# Role selection cards #}
<div class="register-cards space-y-4">
  {# Client card — teal/blue accent #}
  <a href="{{ path('app_register_client') }}"
     class="role-card role-card--client group"
     aria-label="Register as Client — I want to hire freelancers for my projects">
    <div class="role-card__icon role-card__icon--client">
      <svg class="w-6 h-6 sm:w-7 sm:h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
      </svg>
    </div>
    <div class="role-card__content">
      <h3 class="role-card__title">I'm a Client</h3>
      <p class="role-card__desc">I want to hire freelancers for my projects</p>
    </div>
    <span class="role-card__arrow" aria-hidden="true">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
    </span>
  </a>

  {# Freelancer card — purple accent + badge #}
  <a href="{{ path('app_register_freelancer') }}"
     class="role-card role-card--freelancer group"
     aria-label="Register as Freelancer — I want to offer my services and find work. Verification required.">
    <div class="role-card__icon role-card__icon--freelancer">
      <svg class="w-6 h-6 sm:w-7 sm:h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
      </svg>
    </div>
    <div class="role-card__content">
      <h3 class="role-card__title">I'm a Freelancer</h3>
      <p class="role-card__desc">I want to offer my services and find work</p>
      <span class="role-card__badge">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
        </svg>
        Verification required
      </span>
    </div>
    <span class="role-card__arrow" aria-hidden="true">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
    </span>
  </a>
</div>

{# Footer #}
<p class="register-footer mt-10 text-center text-sm text-slate-500 dark:text-slate-400">
  Already have an account?
  <a href="{{ path('app_login') }}" class="font-semibold text-emerald-600 hover:text-emerald-500 dark:text-emerald-400 dark:hover:text-emerald-300 transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-emerald-500 focus-visible:ring-offset-2 rounded">
    Sign in
  </a>
</p>

<script>
(function() {
  document.querySelectorAll('.role-card').forEach(function(card) {
    card.addEventListener('keydown', function(e) {
      if (e.key === ' ') {
        e.preventDefault();
        card.click();
      }
    });
  });
})();
</script>
</div>
{% endblock %}
