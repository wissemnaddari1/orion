{% extends 'layout_auth.html.twig' %}
{% block title %}Reset password — Orion{% endblock %}

{% block auth_content %}
<div class="auth-form-inner p-6 sm:p-8">
    <div class="text-center mb-6">
        <a href="{{ path('app_login') }}" class="inline-flex items-center justify-center">
            <img src="{{ asset('images/orion_light_mode.png') }}" alt="Orion" class="h-16 sm:h-20 w-auto object-contain dark:invert" />
        </a>
        <h1 class="mt-6 text-2xl font-extrabold tracking-tight text-slate-900 dark:text-white">
            Set new password
        </h1>
        <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">
            Enter your new password below. Use the checklist to meet all requirements.
        </p>
    </div>

    {{ form_start(form, { 'action': path('app_reset_password', { token: token }), 'method': 'POST', 'attr': { 'class': 'space-y-5 js-reset-password-form' } }) }}
        <div>
            {{ form_label(form.plainPassword.first, null, { 'label_attr': { 'class': 'block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2' } }) }}
            {{ form_widget(form.plainPassword.first) }}
            {{ form_errors(form.plainPassword.first) }}
            <ul id="password-checklist" class="password-checklist mt-2 p-3 rounded-lg bg-slate-50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700 space-y-2 text-sm" aria-live="polite">
                <li class="flex items-center gap-2.5 transition-colors" data-rule="min8"><span class="rule-icon text-slate-400 dark:text-slate-500 flex-shrink-0 w-4 h-4">❌</span><span class="rule-text text-slate-500 dark:text-slate-400">Min 8 characters</span></li>
                <li class="flex items-center gap-2.5 transition-colors" data-rule="startsUppercase"><span class="rule-icon text-slate-400 dark:text-slate-500 flex-shrink-0 w-4 h-4">❌</span><span class="rule-text text-slate-500 dark:text-slate-400">Starts with uppercase</span></li>
                <li class="flex items-center gap-2.5 transition-colors" data-rule="hasUppercase"><span class="rule-icon text-slate-400 dark:text-slate-500 flex-shrink-0 w-4 h-4">❌</span><span class="rule-text text-slate-500 dark:text-slate-400">At least 1 uppercase</span></li>
                <li class="flex items-center gap-2.5 transition-colors" data-rule="hasLowercase"><span class="rule-icon text-slate-400 dark:text-slate-500 flex-shrink-0 w-4 h-4">❌</span><span class="rule-text text-slate-500 dark:text-slate-400">At least 1 lowercase</span></li>
                <li class="flex items-center gap-2.5 transition-colors" data-rule="hasDigit"><span class="rule-icon text-slate-400 dark:text-slate-500 flex-shrink-0 w-4 h-4">❌</span><span class="rule-text text-slate-500 dark:text-slate-400">At least 1 digit</span></li>
                <li class="flex items-center gap-2.5 transition-colors" data-rule="hasSpecial"><span class="rule-icon text-slate-400 dark:text-slate-500 flex-shrink-0 w-4 h-4">❌</span><span class="rule-text text-slate-500 dark:text-slate-400">At least 1 special character</span></li>
            </ul>
        </div>
        <div>
            {{ form_label(form.plainPassword.second, null, { 'label_attr': { 'class': 'block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2' } }) }}
            {{ form_widget(form.plainPassword.second) }}
            {{ form_errors(form.plainPassword.second) }}
        </div>
        <button type="submit" id="reset-password-submit" disabled
                class="w-full inline-flex items-center justify-center rounded-xl bg-emerald-600 px-6 py-3
                       text-sm font-extrabold text-white shadow-sm hover:bg-emerald-700 transition
                       disabled:opacity-50 disabled:cursor-not-allowed mt-4">
            Reset password
        </button>
    {{ form_end(form) }}

    <p class="mt-6 text-center text-sm text-slate-600 dark:text-slate-300">
        <a href="{{ path('app_login') }}" class="font-semibold text-emerald-600 hover:underline dark:text-emerald-400">Back to login</a>
    </p>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script src="{{ asset('js/password-checker.js') }}"></script>
{% endblock %}
