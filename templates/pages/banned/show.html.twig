{% extends 'base.html.twig' %}
{% block title %}Account restricted — Orion{% endblock %}

{% block body %}
<div class="min-h-screen flex items-center justify-center px-4 py-12
            bg-gradient-to-br from-rose-500/10 via-white to-slate-100
            dark:from-rose-900/20 dark:via-slate-950 dark:to-slate-900">

    <div class="w-full max-w-lg">
        <div class="rounded-2xl border border-slate-200 bg-white p-8 shadow-xl
                    dark:border-slate-800 dark:bg-slate-900/80">

            {# Icon and title #}
            <div class="text-center mb-6">
                <div class="mx-auto w-16 h-16 rounded-full bg-rose-100 dark:bg-rose-900/40 flex items-center justify-center mb-4">
                    <svg class="w-8 h-8 text-rose-600 dark:text-rose-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
                    </svg>
                </div>
                <h1 class="text-2xl font-bold text-slate-900 dark:text-white">
                    Account restricted
                </h1>
                <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">
                    Your account has been temporarily or permanently restricted.
                </p>
            </div>

            {# Ban details card #}
            <div class="rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800/50 p-5 space-y-4">
                <div>
                    <span class="text-xs font-semibold uppercase tracking-wider text-slate-500 dark:text-slate-400">Reason</span>
                    <p class="mt-1 text-slate-900 dark:text-white">
                        {{ user.banReason ?: 'No reason provided.' }}
                    </p>
                </div>
                <div>
                    <span class="text-xs font-semibold uppercase tracking-wider text-slate-500 dark:text-slate-400">Banned on</span>
                    <p class="mt-1 text-slate-900 dark:text-white">
                        {{ user.bannedAt ? user.bannedAt|date('F j, Y \a\t g:i A') : '—' }}
                    </p>
                </div>
                <div>
                    <span class="text-xs font-semibold uppercase tracking-wider text-slate-500 dark:text-slate-400">Ends</span>
                    <p class="mt-1 text-slate-900 dark:text-white font-medium">
                        {% if is_permanent %}
                            Permanent ban
                        {% else %}
                            {{ user.banEndsAt ? user.banEndsAt|date('F j, Y \a\t g:i A') : '—' }}
                        {% endif %}
                    </p>
                </div>
                {% if remaining and not is_permanent %}
                    <div class="pt-2 border-t border-slate-200 dark:border-slate-700">
                        <span class="text-xs font-semibold uppercase tracking-wider text-slate-500 dark:text-slate-400">Time remaining</span>
                        <p class="mt-1 text-emerald-600 dark:text-emerald-400 font-semibold" id="ban-countdown">
                            {{ remaining.d }} day{{ remaining.d != 1 ? 's' : '' }},
                            {{ remaining.h }} hour{{ remaining.h != 1 ? 's' : '' }},
                            {{ remaining.i }} minute{{ remaining.i != 1 ? 's' : '' }}
                        </p>
                    </div>
                {% endif %}
            </div>

            <p class="mt-4 text-sm text-slate-500 dark:text-slate-400 text-center">
                If you believe this is an error, please contact support.
            </p>

            <div class="mt-6 flex justify-center">
                <a href="{{ path('app_logout') }}"
                   class="inline-flex items-center gap-2 rounded-xl bg-slate-700 px-6 py-3 text-sm font-semibold text-white transition hover:bg-slate-800 dark:bg-slate-600 dark:hover:bg-slate-500">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                    </svg>
                    Sign out
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
