<div>
    <label for="name" class="block text-sm font-medium text-[#000000] mb-2">
        Category Name <span class="text-red-500">*</span>
    </label>
    <input
        type="text"
        id="name"
        name="name"
        required
        value="{{ category.name|default('') }}"
        placeholder="e.g., Plumbing, Electrical, Carpentry..."
        class="w-full block rounded-lg border border-gray-300 px-4 py-2 text-sm text-[#000000] placeholder-gray-400 focus:border-[#0FAF7A] focus:ring-2 focus:ring-[#0FAF7A]/20"
    />
</div>

<div>
    <label for="description" class="block text-sm font-medium text-[#000000] mb-2">
        Description <span class="text-red-500">*</span>
    </label>
    <textarea
        id="description"
        name="description"
        required
        rows="4"
        placeholder="Describe this worker category..."
        class="w-full block rounded-lg border border-gray-300 px-4 py-2 text-sm text-[#000000] placeholder-gray-400 focus:border-[#0FAF7A] focus:ring-2 focus:ring-[#0FAF7A]/20"
    >{{ category.description|default('') }}</textarea>
</div>

<div class="grid grid-cols-2 gap-4">
    <div>
        <label for="status" class="block text-sm font-medium text-[#000000] mb-2">
            Status <span class="text-red-500">*</span>
        </label>
        <select
            id="status"
            name="status"
            class="w-full block rounded-lg border border-gray-300 px-4 py-2 text-sm text-[#000000] focus:border-[#0FAF7A] focus:ring-2 focus:ring-[#0FAF7A]/20"
        >
            <option value="active" {% if category.status is defined and (category.status == 'active' or category.status == 'actif') %}selected{% endif %}>Active</option>
            <option value="inactive" {% if category.status is defined and (category.status == 'inactive' or category.status == 'inactif') %}selected{% endif %}>Inactive</option>
        </select>
    </div>

    <div>
        <label for="display_order" class="block text-sm font-medium text-[#000000] mb-2">
            Display Order <span class="text-red-500">*</span>
        </label>
        <input
            type="number"
            id="display_order"
            name="display_order"
            value="{{ category.displayOrder|default(0) }}"
            class="w-full block rounded-lg border border-gray-300 px-4 py-2 text-sm text-[#000000] focus:border-[#0FAF7A] focus:ring-2 focus:ring-[#0FAF7A]/20"
        />
    </div>
</div>

<div class="grid grid-cols-2 gap-4">
    <div>
        <label for="total_workers" class="block text-sm font-medium text-[#000000] mb-2">
            Total Workers
        </label>
        <input
            type="number"
            id="total_workers"
            name="total_workers"
            value="{{ category.totalWorkers|default(0) }}"
            class="w-full block rounded-lg border border-gray-300 px-4 py-2 text-sm text-[#000000] focus:border-[#0FAF7A] focus:ring-2 focus:ring-[#0FAF7A]/20"
        />
    </div>

    <div>
        <label for="average_hourly_rate" class="block text-sm font-medium text-[#000000] mb-2">
            Average Hourly Rate (€)
        </label>
        <input
            type="number"
            id="average_hourly_rate"
            name="average_hourly_rate"
            value="{{ category.averageHourlyRate|default('0.00') }}"
            step="0.01"
            class="w-full block rounded-lg border border-gray-300 px-4 py-2 text-sm text-[#000000] focus:border-[#0FAF7A] focus:ring-2 focus:ring-[#0FAF7A]/20"
        />
    </div>
</div>

<div>
    <label for="icon" class="block text-sm font-medium text-[#000000] mb-2">
        Icon Image (PNG/SVG)
    </label>
    {% if category.icon is defined and category.icon and category.icon != 'default-icon' %}
        <div class="mb-3 flex items-center gap-3">
            <img src="/images/icons/{{ category.icon }}" alt="Current icon" class="w-12 h-12 border border-gray-300 rounded-lg p-1" />
            <span class="text-sm text-slate-600">Current: {{ category.icon }}</span>
        </div>
    {% endif %}
    <input
        type="file"
        id="icon"
        name="icon"
        accept=".png,.svg,.jpg,.jpeg"
        class="w-full block rounded-lg border border-gray-300 px-4 py-2 text-sm text-[#000000] focus:border-[#0FAF7A] focus:ring-2 focus:ring-[#0FAF7A]/20"
    />
    <p class="mt-1 text-xs text-slate-500">Supported formats: PNG, SVG, JPG (recommended size: 64x64px)</p>
</div>

{# Actions: allow overriding cancel path #}
<div class="flex gap-3 pt-4 border-t border-gray-200">
    <button
        type="submit"
        class="flex-1 rounded-lg bg-[#0FAF7A] px-6 py-2 text-sm font-semibold text-white hover:bg-[#0a9a6f] transition"
    >
        {{ submit_label|default('Save') }}
    </button>
    <a
        href="{{ cancel_path|default(path('client_categories_index')) }}"
        class="flex-1 text-center rounded-lg border border-gray-300 px-6 py-2 text-sm font-semibold text-slate-700 hover:bg-gray-50 transition"
    >
        Cancel
    </a>
</div>
