{% if offers|length > 0 %}
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-8">
        {% for o in offers %}
        <div class="offer-card group relative {{ recommended_offer_id is defined and o.id == recommended_offer_id ? 'best-value-highlight' : '' }}"
             data-service-request-id="{{ o.serviceRequest.id }}">
            <a href="{{ path('client_offers_show', {id: o.id}) }}" class="block h-full">
                <div class="relative overflow-hidden rounded-[40px] bg-white dark:bg-slate-900/40 border border-slate-200 dark:border-slate-800 shadow-sm h-full flex flex-col backdrop-blur-sm transition-all duration-300">
                    

                    <div class="p-8 flex-1 flex flex-col">
                        {# Freelancer Info + Badges Row #}
                        <div class="flex items-start justify-between mb-8">
                            <div class="flex items-center gap-4">
                                <div class="relative">
                                    <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-slate-100 to-slate-200 dark:from-slate-800 dark:to-slate-700 flex items-center justify-center text-slate-900 dark:text-white text-xl font-black shadow-inner">
                                        {{ o.worker.firstName|first|upper }}{{ o.worker.lastName|first|upper }}
                                    </div>
                                    {% if o.worker.verified ?? true %}
                                    <div class="absolute -bottom-1 -right-1 w-6 h-6 bg-blue-500 border-2 border-white dark:border-slate-900 rounded-full flex items-center justify-center text-white">
                                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
                                    </div>
                                    {% endif %}
                                </div>
                                <div class="space-y-1">
                                    <h3 class="text-lg font-black text-slate-900 dark:text-white leading-tight group-hover:text-emerald-500 transition-colors">{{ o.worker.fullName }}</h3>
                                    <div class="flex items-center gap-2">
                                        <div class="flex items-center text-amber-500">
                                            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                                            <span class="text-xs font-black ml-1">{{ o.worker.ratingAvg|default('5.0') }}</span>
                                        </div>
                                        <span class="text-slate-300 dark:text-slate-700">•</span>
                                        <span class="text-[10px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-widest">{{ o.worker.totalReviews|default('12') }} Reviews</span>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="flex flex-col items-end gap-1.5">
                                {# Best Value Badge #}
                                {% if recommended_offer_id is defined and o.id == recommended_offer_id %}
                                    <div class="flex items-center gap-1.5 px-2.5 py-0.5 bg-emerald-500 text-white rounded-full shadow-sm shadow-emerald-500/25 text-[9px] font-bold uppercase tracking-wide">
                                        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                                        Best Value
                                    </div>
                                {% endif %}

                                <span class="px-3 py-1.5 text-[10px] font-black rounded-xl uppercase tracking-[0.15em] border
                                    {% if o.status == 'ACCEPTED' %}bg-emerald-50 text-emerald-600 border-emerald-100 dark:bg-emerald-900/20 dark:text-emerald-400 dark:border-emerald-800
                                    {% elseif o.status == 'REJECTED' %}bg-red-50 text-red-600 border-red-100 dark:bg-red-900/20 dark:text-red-400 dark:border-red-800
                                    {% elseif o.status == 'NEGOTIATING' %}bg-indigo-50 text-indigo-600 border-indigo-100 dark:bg-indigo-900/20 dark:text-indigo-400 dark:border-indigo-800
                                    {% else %}bg-slate-50 text-slate-600 border-slate-100 dark:bg-slate-800 dark:text-slate-400 dark:border-slate-700{% endif %}">
                                    {{ o.status }}
                                </span>
                            </div>
                        </div>

                        {# Project Title #}
                        <div class="mb-8">
                            <p class="text-[10px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-[0.2em] mb-2">Service Request</p>
                            <p class="text-xl font-black text-slate-900 dark:text-white leading-snug">{{ o.serviceRequest.title|length > 60 ? o.serviceRequest.title|slice(0, 60) ~ '…' : o.serviceRequest.title }}</p>
                        </div>

                        {# Main Metrics Grid #}
                        <div class="grid grid-cols-2 gap-6 mb-8">
                            <div class="bg-slate-50/50 dark:bg-slate-800/30 rounded-[32px] p-6 border border-slate-100 dark:border-slate-800">
                                <p class="text-[10px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-widest mb-1">Fixed Quote</p>
                                <p class="text-4xl font-black text-slate-900 dark:text-white tracking-tighter">${{ o.price|number_format(0) }}</p>
                            </div>
                            <div class="bg-slate-50/50 dark:bg-slate-800/30 rounded-[32px] p-6 border border-slate-100 dark:border-slate-800">
                                <p class="text-[10px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-widest mb-1">Delivery</p>
                                <p class="text-4xl font-black text-slate-900 dark:text-white tracking-tighter">{{ o.estimatedTimeDays }}<span class="text-lg ml-0.5">d</span></p>
                            </div>
                        </div>

                        {# AI Match Score #}
                        {% set pred = predictions[o.id] ?? null %}
                        {% if pred is not null %}
                            {% set score = (pred.probability * 100)|round %}
                            {% set score_color = score >= 80 ? 'text-emerald-500' : (score >= 50 ? 'text-indigo-500' : 'text-amber-500') %}
                            
                            <div class="rounded-[32px] p-1 mb-2 bg-slate-50/50 dark:bg-slate-800/20 border border-slate-100 dark:border-slate-800">
                                <div class="flex items-center justify-between px-6 py-5">
                                    <div class="flex items-center gap-4">
                                        <div class="relative w-12 h-12 flex items-center justify-center">
                                            <svg class="w-full h-full -rotate-90" viewBox="0 0 36 36">
                                                <circle cx="18" cy="18" r="16" fill="none" class="stroke-slate-200/50 dark:stroke-slate-700/50" stroke-width="2.5"></circle>
                                                <circle cx="18" cy="18" r="16" fill="none" class="match-score-ring stroke-current {{ score_color }}" stroke-width="2.5" stroke-dasharray="100" stroke-dashoffset="{{ 100 - score }}"></circle>
                                            </svg>
                                            <span class="absolute text-[10px] font-black text-slate-900 dark:text-white">{{ score }}%</span>
                                        </div>
                                        <div>
                                            <p class="text-xs font-black text-slate-900 dark:text-white tracking-tight">AI Confidence</p>
                                            <p class="text-[9px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-wider">{{ score >= 80 ? 'Perfect Fit' : 'Qualified' }}</p>
                                        </div>
                                    </div>
                                    {% if score >= 90 %}
                                    <div class="px-3 py-1 bg-emerald-500/10 text-emerald-500 text-[9px] font-black rounded-lg uppercase tracking-widest border border-emerald-500/20 animate-pulse">
                                        Smart Match
                                    </div>
                                    {% endif %}
                                </div>
                            </div>
                        {% endif %}

                        {# Footer Buttons #}
                        <div class="mt-auto pt-8 border-t border-slate-100 dark:border-slate-800 flex items-center justify-between gap-4">
                            {% set count = offers_by_request_count[o.serviceRequest.id]|default(0) %}
                            {% if count > 1 %}
                            <button onclick="event.preventDefault(); window.location.href='{{ path('client_offers_comparison', {id: o.serviceRequest.id}) }}'"
                                    data-compare-trigger="{{ o.serviceRequest.id }}"
                                    class="compare-btn flex-1 px-4 py-4 bg-slate-100 dark:bg-slate-800 text-slate-900 dark:text-white text-[10px] font-black uppercase tracking-widest rounded-2xl hover:bg-slate-200 dark:hover:bg-slate-700 transition-all flex items-center justify-center gap-2 border border-transparent hover:border-slate-300 dark:hover:border-slate-600 whitespace-nowrap">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
                                <span>Compare ({{ count }})</span>
                            </button>
                            {% endif %}
                            <button class="flex-1 px-6 py-4 bg-emerald-500 text-white text-xs font-black uppercase tracking-widest rounded-2xl hover:bg-emerald-600 shadow-lg shadow-emerald-500/25 transition-all flex items-center justify-center gap-2 hover:scale-[1.02] active:scale-[0.98]">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                                View Details
                            </button>
                        </div>
                    </div>
                </div>
            </a>
        </div>
        {% endfor %}
    </div>
{% else %}
    <div class="rounded-[40px] border border-slate-200 bg-white dark:bg-slate-900/50 p-20 text-center shadow-sm dark:border-slate-800 backdrop-blur-xl">
        <div class="w-20 h-20 mx-auto rounded-3xl bg-slate-50 dark:bg-slate-800 flex items-center justify-center mb-6">
            <svg class="w-10 h-10 text-slate-300 dark:text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/>
            </svg>
        </div>
        <h3 class="text-2xl font-black text-slate-900 dark:text-white mb-3">No offers found</h3>
        <p class="text-sm text-slate-500 dark:text-slate-400 max-w-sm mx-auto font-medium">
            We couldn't find any offers matching your current filters. Try adjusting your search or status selection.
        </p>
    </div>
{% endif %}

{# Pagination #}
{% if total_pages > 1 %}
    <div class="flex flex-col sm:flex-row items-center justify-between mt-12 gap-6 pb-12">
        <p class="text-sm font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest">
            Page <span class="text-slate-900 dark:text-white">{{ page }}</span> of {{ total_pages }}
        </p>
        <div class="flex items-center gap-3">
            {% if page > 1 %}
                <button type="button" onclick="loadPage({{ page - 1 }})"
                   class="inline-flex items-center gap-2 px-6 py-4 text-xs font-black uppercase tracking-widest border border-slate-200 dark:border-slate-800 rounded-2xl hover:bg-slate-50 dark:hover:bg-slate-800 dark:text-white transition-all shadow-sm">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7"/></svg>
                    Prev
                </button>
            {% endif %}
            {% if page < total_pages %}
                <button type="button" onclick="loadPage({{ page + 1 }})"
                   class="inline-flex items-center gap-2 px-6 py-4 text-xs font-black uppercase tracking-widest bg-slate-900 dark:bg-slate-800 text-white rounded-2xl hover:bg-black dark:hover:bg-slate-700 transition-all shadow-xl">
                    Next
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
                </button>
            {% endif %}
        </div>
    </div>
{% endif %}
