{% extends 'layout_client.html.twig' %}

{% set topbar_title = 'Edit Category' %}
{% set user_name = 'Jane Client' %}
{% set notification_count = 2 %}

{% block main %}
    <div class="space-y-6 max-w-2xl">
        
        {# Header #}
        <div>
            <a href="{{ path('client_categories_detail', {id: category.id}) }}" class="text-sm text-[#0FAF7A] hover:underline mb-2">
                ← Back to {{ category.name }}
            </a>
            <h1 class="text-3xl font-bold text-[#000000]">Edit {{ category.name }}</h1>
            <p class="mt-1 text-slate-600">Update worker category details</p>
        </div>

        {# Form #}
        <div class="rounded-xl border border-gray-200 bg-white shadow-sm p-6">
            <form method="POST" enctype="multipart/form-data" class="space-y-6">
                {% include 'pages/client/_category_form_fields.html.twig' with { submit_label: 'Save Changes', cancel_path: path('client_categories_detail', {id: category.id}), category: category } %}
            </form>
        </div>
    </div>
{% endblock %}
