{% extends 'layout_client.html.twig' %}
{% set topbar_title = 'Create Contract from Offer' %}
{% block main %}
    <div class="max-w-4xl mx-auto space-y-6">
        <div class="flex items-center gap-3">
            <a href="#" onclick="history.back()" class="text-gray-500 hover:text-gray-700 transition">
                â† Back

            </a>
        </div>

        <div class="rounded-lg bg-blue-50 border border-blue-200 p-4">
            <div class="flex items-start gap-3">
                <div class="text-blue-600 text-xl">â„¹ï¸</div>

                <div>
                    <h3 class="font-semibold text-blue-900">Create Contract from Accepted Offer</h3>
                    <p class="text-sm text-blue-700 mt-1">
                        Review and confirm the contract details below. The contract will be created based on the accepted offer.
                    </p>
                </div>
            </div>
        </div>

        <h1 class="text-2xl font-bold text-[#000000]">Contract Details</h1>

        <form method="POST" action="{{ path('client_contract_create_from_offer') }}" class="space-y-6" novalidate data-validate="contract-offer" data-turbo="false">
            <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
                <h2 class="text-lg font-semibold text-[#000000] mb-4">Contract Information</h2>
                
                <div class="grid gap-6 md:grid-cols-2">
                    <div>
                        <label for="service_request_id" class="block text-sm font-medium text-gray-700 mb-2">
                            Service Request ID <span class="text-red-500">*</span>
                        </label>
                        <input type="number" id="service_request_id" name="service_request_id" required
                               value="{{ service_request_id }}"
                               class="w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm text-gray-900 bg-gray-50" readonly>
                    </div>

                    <div>
                        <label for="offer_id" class="block text-sm font-medium text-gray-700 mb-2">
                            Offer ID <span class="text-red-500">*</span>
                        </label>
                        <input type="number" id="offer_id" name="offer_id" required
                               value="{{ offer_id }}"
                               class="w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm text-gray-900 bg-gray-50" readonly>
                    </div>

                    <div>
                        <label for="client_id" class="block text-sm font-medium text-gray-700 mb-2">
                            Client ID <span class="text-red-500">*</span>
                        </label>
                        <input type="number" id="client_id" name="client_id" required
                               value="{{ client_id }}"
                               class="w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm text-gray-900 bg-gray-50" readonly>
                    </div>

                    <div>
                        <label for="worker_id" class="block text-sm font-medium text-gray-700 mb-2">
                            Worker ID <span class="text-red-500">*</span>
                        </label>
                        <input type="number" id="worker_id" name="worker_id" required
                               value="{{ worker_id }}"
                               class="w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm text-gray-900 bg-gray-50" readonly>
                    </div>

                    <div class="md:col-span-2">
                        <label for="agreed_price" class="block text-sm font-medium text-gray-700 mb-2">
                            Agreed Price ($) <span class="text-red-500">*</span>
                        </label>
                        <input type="number" step="0.01" id="agreed_price" name="agreed_price" required
                               value="{{ agreed_price }}"
                               class="w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm text-gray-900 focus:border-[#0FAF7A] focus:ring-2 focus:ring-[#0FAF7A]/20">
                        <p class="mt-1 text-xs text-gray-500">You can adjust the price if needed</p>
                    </div>

                    <div class="md:col-span-2">
                        <label for="scope" class="block text-sm font-medium text-gray-700 mb-2">
                            Scope of Work <span class="text-red-500">*</span>
                        </label>
                        <textarea id="scope" name="scope" rows="6" required
                                  class="w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm text-gray-900 focus:border-[#0FAF7A] focus:ring-2 focus:ring-[#0FAF7A]/20">{{ scope }}</textarea>
                        <p class="mt-1 text-xs text-gray-500">Review and adjust the scope if needed</p>
                    </div>
                </div>

                <div class="mt-6 p-4 bg-gray-50 rounded-lg">
                    <p class="text-sm text-gray-700">
                        <strong>Note:</strong> The contract will be created with:
                    </p>
                    <ul class="mt-2 text-sm text-gray-600 space-y-1">
                        <li>â€¢ <strong>Status:</strong> Active (ready to start)</li>
                        <li>â€¢ <strong>Start Date:</strong> Today</li>
                        <li>â€¢ <strong>End Date:</strong> 30 days from now</li>

                    </ul>
                </div>
            </div>

            <div class="flex gap-3">
                <button type="submit" 
                        class="inline-flex items-center gap-2 rounded-lg bg-emerald-600 px-6 py-2.5 text-sm font-semibold text-white transition hover:bg-emerald-700">
                    âœ“ Create Contract

                </button>
                <a href="#" onclick="history.back()" 
                   class="inline-flex items-center gap-2 rounded-lg border border-gray-300 bg-white px-6 py-2.5 text-sm font-semibold text-gray-700 transition hover:bg-gray-50">
                    Cancel
                </a>
            </div>
        </form>
    </div>
{% endblock %}
