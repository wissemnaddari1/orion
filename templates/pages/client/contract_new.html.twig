{% extends 'layout_client.html.twig' %}
{% block main %}
    <div class="max-w-3xl mx-auto space-y-6">

        {# Back link #}
        <div class="flex items-center gap-3">
            <a href="{{ path('client_contracts_list') }}"
               class="inline-flex items-center gap-1 text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-200 transition text-sm">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                </svg>
                Back to contracts
            </a>
        </div>

        {# Heading #}
        <div>
            <h1 class="text-2xl font-bold text-slate-900 dark:text-white">Create New Contract</h1>
            <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">Fill in the details below. The contract will be saved as a Draft.</p>
        </div>

        <form method="POST" action="{{ path('client_contract_create') }}" class="space-y-6" novalidate data-validate="contract" data-turbo="false">
            {# Contract Details Card #}
            <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900">
                <h2 class="text-lg font-semibold text-slate-900 dark:text-white mb-5">Contract Information</h2>

                <div class="grid gap-5 md:grid-cols-2">
                    {# Title #}
                    <div class="md:col-span-2">
                        <label for="title" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">
                            Title <span class="text-red-500">*</span>
                        </label>
                        <input type="text" id="title" name="title"
                               value="{{ old.title|default('') }}"
                               class="w-full rounded-lg border {{ errors.title is defined ? 'border-red-500' : 'border-gray-300 dark:border-slate-600' }} bg-white dark:bg-slate-800 px-4 py-2.5 text-sm text-slate-900 dark:text-white placeholder-slate-400 focus:border-[#0FAF7A] focus:ring-2 focus:ring-[#0FAF7A]/20 transition"
                               placeholder="e.g. Website Redesign Project">
                        {% if errors.title is defined %}
                            <p class="mt-1 text-xs text-red-600 dark:text-red-400">{{ errors.title }}</p>
                        {% endif %}
                    </div>

                    {# Worker #}
                    <div class="md:col-span-2">
                        <label for="worker_id" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">
                            Worker <span class="text-red-500">*</span>
                        </label>
                        <select id="worker_id" name="worker_id"
                                class="w-full rounded-lg border {{ errors.worker_id is defined ? 'border-red-500' : 'border-gray-300 dark:border-slate-600' }} bg-white dark:bg-slate-800 px-4 py-2.5 text-sm text-slate-900 dark:text-white focus:border-[#0FAF7A] focus:ring-2 focus:ring-[#0FAF7A]/20 transition">
                            <option value="">Select a worker...</option>
                            {% for worker in workers %}
                                <option value="{{ worker.id }}" {% if old.worker_id|default('') == worker.id %}selected{% endif %}>
                                    {{ worker.firstName ~ ' ' ~ worker.lastName ~ ' (' ~ worker.email ~ ')' }}
                                </option>
                            {% endfor %}
                        </select>
                        {% if errors.worker_id is defined %}
                            <p class="mt-1 text-xs text-red-600 dark:text-red-400">{{ errors.worker_id }}</p>
                        {% endif %}
                    </div>

                    {# Agreed Price #}
                    <div>
                        <label for="agreed_price" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">
                            Agreed Price <span class="text-red-500">*</span>
                        </label>
                        <input type="number" step="0.01" id="agreed_price" name="agreed_price"
                               value="{{ old.agreed_price|default('') }}"
                               class="w-full rounded-lg border {{ errors.agreed_price is defined ? 'border-red-500' : 'border-gray-300 dark:border-slate-600' }} bg-white dark:bg-slate-800 px-4 py-2.5 text-sm text-slate-900 dark:text-white placeholder-slate-400 focus:border-[#0FAF7A] focus:ring-2 focus:ring-[#0FAF7A]/20 transition"
                               placeholder="0.00">
                        {% if errors.agreed_price is defined %}
                            <p class="mt-1 text-xs text-red-600 dark:text-red-400">{{ errors.agreed_price }}</p>
                        {% endif %}
                    </div>

                    {# Currency #}
                    <div>
                        <label for="currency" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">
                            Currency <span class="text-red-500">*</span>
                        </label>
                        <select id="currency" name="currency"
                                class="w-full rounded-lg border {{ errors.currency is defined ? 'border-red-500' : 'border-gray-300 dark:border-slate-600' }} bg-white dark:bg-slate-800 px-4 py-2.5 text-sm text-slate-900 dark:text-white focus:border-[#0FAF7A] focus:ring-2 focus:ring-[#0FAF7A]/20 transition">
                            <option value="USD" {% if old.currency|default('') == 'USD' %}selected{% endif %}>USD – US Dollar</option>
                            <option value="EUR" {% if old.currency|default('') == 'EUR' %}selected{% endif %}>EUR – Euro</option>
                            <option value="TND" {% if old.currency|default('') == 'TND' %}selected{% endif %}>TND – Tunisian Dinar</option>
                            <option value="MAD" {% if old.currency|default('') == 'MAD' %}selected{% endif %}>MAD – Moroccan Dirham</option>
                        </select>
                        {% if errors.currency is defined %}
                            <p class="mt-1 text-xs text-red-600 dark:text-red-400">{{ errors.currency }}</p>
                        {% endif %}
                    </div>

                    {# Start Date #}
                    <div>
                        <label for="start_date" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">
                            Start Date <span class="text-red-500">*</span>
                        </label>
                        <input type="date" id="start_date" name="start_date"
                               value="{{ old.start_date|default('') }}"
                               class="w-full rounded-lg border {{ errors.start_date is defined ? 'border-red-500' : 'border-gray-300 dark:border-slate-600' }} bg-white dark:bg-slate-800 px-4 py-2.5 text-sm text-slate-900 dark:text-white focus:border-[#0FAF7A] focus:ring-2 focus:ring-[#0FAF7A]/20 transition">
                        {% if errors.start_date is defined %}
                            <p class="mt-1 text-xs text-red-600 dark:text-red-400">{{ errors.start_date }}</p>
                        {% endif %}
                    </div>

                    {# End Date #}
                    <div>
                        <label for="end_date" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">
                            End Date <span class="text-red-500">*</span>
                        </label>
                        <input type="date" id="end_date" name="end_date"
                               value="{{ old.end_date|default('') }}"
                               class="w-full rounded-lg border {{ errors.end_date is defined ? 'border-red-500' : 'border-gray-300 dark:border-slate-600' }} bg-white dark:bg-slate-800 px-4 py-2.5 text-sm text-slate-900 dark:text-white focus:border-[#0FAF7A] focus:ring-2 focus:ring-[#0FAF7A]/20 transition">
                        {% if errors.end_date is defined %}
                            <p class="mt-1 text-xs text-red-600 dark:text-red-400">{{ errors.end_date }}</p>
                        {% endif %}
                    </div>

                    {# Scope #}
                    <div class="md:col-span-2">
                        <label for="scope" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">
                            Scope of Work <span class="text-red-500">*</span>
                        </label>
                        <textarea id="scope" name="scope" rows="6"
                                  class="w-full rounded-lg border {{ errors.scope is defined ? 'border-red-500' : 'border-gray-300 dark:border-slate-600' }} bg-white dark:bg-slate-800 px-4 py-2.5 text-sm text-slate-900 dark:text-white placeholder-slate-400 focus:border-[#0FAF7A] focus:ring-2 focus:ring-[#0FAF7A]/20 transition"
                                  placeholder="Describe the scope of work, deliverables, and expectations...">{{ old.scope|default('') }}</textarea>
                        {% if errors.scope is defined %}
                            <p class="mt-1 text-xs text-red-600 dark:text-red-400">{{ errors.scope }}</p>
                        {% else %}
                            <p class="mt-1 text-xs text-slate-400">Minimum 10 characters, maximum 5000 characters.</p>
                        {% endif %}
                    </div>
                </div>
            </div>

            {# Submit #}
            <div class="flex items-center gap-3">
                <button type="submit"
                        class="inline-flex items-center gap-2 rounded-lg bg-[#0FAF7A] px-6 py-2.5 text-sm font-semibold text-white transition hover:bg-emerald-600 shadow-sm">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
                    </svg>
                    Create Contract
                </button>
                <a href="{{ path('client_contracts_list') }}"
                   class="inline-flex items-center gap-2 rounded-lg border border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-800 px-6 py-2.5 text-sm font-semibold text-slate-700 dark:text-slate-300 transition hover:bg-gray-50 dark:hover:bg-slate-700">
                    Cancel
                </a>
            </div>
        </form>
    </div>
{% endblock %}
