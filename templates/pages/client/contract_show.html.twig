{% extends 'layout_client.html.twig' %}
{% block main %}
    <div class="space-y-6">
        {# Flash messages #}
        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div class="rounded-lg px-4 py-3 text-sm font-medium
                    {% if type == 'success' %} bg-emerald-50 text-emerald-800 border border-emerald-200 dark:bg-emerald-900/20 dark:text-emerald-400 dark:border-emerald-800
                    {% elseif type == 'error' or type == 'danger' %} bg-red-50 text-red-800 border border-red-200 dark:bg-red-900/20 dark:text-red-400 dark:border-red-800
                    {% else %} bg-blue-50 text-blue-800 border border-blue-200 dark:bg-blue-900/20 dark:text-blue-400 dark:border-blue-800
                    {% endif %}">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        {% if app.request.query.get('payment') == 'success' %}
            <div class="rounded-lg px-4 py-3 text-sm font-medium bg-cyan-50 text-cyan-800 border border-cyan-200 dark:bg-cyan-900/20 dark:text-cyan-300 dark:border-cyan-800">
                Payment initiated successfully. Upfront status will update after webhook confirmation.
            </div>
        {% elseif app.request.query.get('payment') == 'cancelled' %}
            <div class="rounded-lg px-4 py-3 text-sm font-medium bg-amber-50 text-amber-800 border border-amber-200 dark:bg-amber-900/20 dark:text-amber-300 dark:border-amber-800">
                Payment was cancelled. No charge was made.
            </div>
        {% elseif app.request.query.get('payment') == 'error' %}
            <div class="rounded-lg px-4 py-3 text-sm font-medium bg-red-50 text-red-800 border border-red-200 dark:bg-red-900/20 dark:text-red-400 dark:border-red-800">
                Unable to start Stripe checkout. Verify Stripe configuration.
            </div>
        {% elseif app.request.query.get('payment') == 'mock_success' %}
            <div class="rounded-lg px-4 py-3 text-sm font-medium bg-emerald-50 text-emerald-800 border border-emerald-200 dark:bg-emerald-900/20 dark:text-emerald-400 dark:border-emerald-800">
                Mock payment completed successfully. Upfront is now funded.
            </div>
        {% elseif app.request.query.get('payment') == 'mock_cancelled' %}
            <div class="rounded-lg px-4 py-3 text-sm font-medium bg-amber-50 text-amber-800 border border-amber-200 dark:bg-amber-900/20 dark:text-amber-300 dark:border-amber-800">
                Mock payment was cancelled.
            </div>
        {% elseif app.request.query.get('payment') == 'not_configured' %}
            <div class="rounded-lg px-4 py-3 text-sm font-medium bg-red-50 text-red-800 border border-red-200 dark:bg-red-900/20 dark:text-red-400 dark:border-red-800">
                Stripe test mode is not configured. Set STRIPE_SECRET_KEY and STRIPE_WEBHOOK_SECRET in your .env.local.
            </div>
        {% elseif app.request.query.get('payment') == 'fallback' %}
            <div class="rounded-lg px-4 py-3 text-sm font-medium bg-blue-50 text-blue-800 border border-blue-200 dark:bg-blue-900/20 dark:text-blue-300 dark:border-blue-800">
                Stripe is not configured. Local fallback marked upfront as paid.
            </div>
        {% endif %}


                    </dl>
                </div>

                {# Scope of Work Card #}
                <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900">
                    <h2 class="text-lg font-semibold text-slate-900 dark:text-white mb-4">Scope of Work</h2>
                    <div class="prose prose-sm prose-slate dark:prose-invert max-w-none whitespace-pre-line text-slate-700 dark:text-slate-300">{{ contract.scope }}</div>
                </div>

                {# eSign Status Card #}
                <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900">
                    <h2 class="text-lg font-semibold text-slate-900 dark:text-white mb-5">eSign Status</h2>
                    <div class="grid gap-6 sm:grid-cols-2">
                        {# Client Signature #}
                        <div class="rounded-lg border {{ contract.clientSigned ? 'border-emerald-200 bg-emerald-50/50 dark:border-emerald-800 dark:bg-emerald-900/10' : 'border-gray-200 bg-slate-50 dark:border-slate-700 dark:bg-slate-800/50' }} p-4">
                            <div class="flex items-center gap-2 mb-3">
                                {% if contract.clientSigned %}
                                    <svg class="w-5 h-5 text-[#0FAF7A]" fill="currentColor" viewBox="0 0 20 20">
                                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                                    </svg>
                                {% else %}
                                    <svg class="w-5 h-5 text-slate-400" fill="currentColor" viewBox="0 0 20 20">
                                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
                                    </svg>
                                {% endif %}
                                <h3 class="font-semibold text-sm text-slate-900 dark:text-white">Client Signature</h3>
                            </div>
                            <dl class="space-y-1.5 text-xs">
                                <div class="flex justify-between">
                                    <dt class="text-slate-500 dark:text-slate-400">Signed</dt>
                                    <dd class="font-medium {{ contract.clientSigned ? 'text-[#0FAF7A]' : 'text-slate-600 dark:text-slate-300' }}">{{ contract.clientSigned ? 'Yes' : 'No' }}</dd>
                                </div>
                                {% if contract.clientSignedAt %}
                                <div class="flex justify-between">
                                    <dt class="text-slate-500 dark:text-slate-400">Date & Time</dt>
                                    <dd class="text-slate-700 dark:text-slate-300">{{ contract.clientSignedAt|date('M d, Y H:i') }}</dd>
                                </div>
                                {% endif %}
                                {% if contract.clientSignatureIp %}
                                <div class="flex justify-between">
                                    <dt class="text-slate-500 dark:text-slate-400">IP Address</dt>
                                    <dd class="text-slate-700 dark:text-slate-300 font-mono">{{ contract.clientSignatureIp }}</dd>
                                </div>
                                {% endif %}
                            </dl>
                        </div>

                        {# Worker Signature #}
                        <div class="rounded-lg border {{ contract.workerSigned ? 'border-emerald-200 bg-emerald-50/50 dark:border-emerald-800 dark:bg-emerald-900/10' : 'border-gray-200 bg-slate-50 dark:border-slate-700 dark:bg-slate-800/50' }} p-4">
                            <div class="flex items-center gap-2 mb-3">
                                {% if contract.workerSigned %}
                                    <svg class="w-5 h-5 text-[#0FAF7A]" fill="currentColor" viewBox="0 0 20 20">
                                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                                    </svg>
                                {% else %}
                                    <svg class="w-5 h-5 text-slate-400" fill="currentColor" viewBox="0 0 20 20">
                                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
                                    </svg>
                                {% endif %}
                                <h3 class="font-semibold text-sm text-slate-900 dark:text-white">Worker Signature</h3>
                            </div>
                            <dl class="space-y-1.5 text-xs">
                                <div class="flex justify-between">
                                    <dt class="text-slate-500 dark:text-slate-400">Signed</dt>
                                    <dd class="font-medium {{ contract.workerSigned ? 'text-[#0FAF7A]' : 'text-slate-600 dark:text-slate-300' }}">{{ contract.workerSigned ? 'Yes' : 'No' }}</dd>
                                </div>
                                {% if contract.workerSignedAt %}
                                <div class="flex justify-between">
                                    <dt class="text-slate-500 dark:text-slate-400">Date & Time</dt>
                                    <dd class="text-slate-700 dark:text-slate-300">{{ contract.workerSignedAt|date('M d, Y H:i') }}</dd>
                                </div>
                                {% endif %}
                                {% if contract.workerSignatureIp %}
                                <div class="flex justify-between">
                                    <dt class="text-slate-500 dark:text-slate-400">IP Address</dt>
                                    <dd class="text-slate-700 dark:text-slate-300 font-mono">{{ contract.workerSignatureIp }}</dd>
                                </div>
                                {% endif %}
                            </dl>
                        </div>
                    </div>
                </div>

                {# Milestones Card #}
                <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900">
                    <div class="flex items-center justify-between mb-4">
                        <h2 class="text-lg font-semibold text-slate-900 dark:text-white">Milestones</h2>
                        {% if contract.milestones|length > 0 %}
                            <span class="text-sm font-medium text-[#0FAF7A]">{{ contract.getProgressPercent() }}% complete</span>
                        {% endif %}
                    </div>

                    {# Progress bar #}
                    {% if contract.milestones|length > 0 %}
                        <div class="w-full bg-gray-200 dark:bg-slate-700 rounded-full h-2.5 mb-5">
                            <div class="bg-[#0FAF7A] h-2.5 rounded-full transition-all duration-500" style="width: {{ contract.getProgressPercent() }}%"></div>
                        </div>

                        <div class="space-y-3">
                            {% for milestone in contract.milestones %}
                                <div class="p-3.5 rounded-lg border border-gray-100 bg-slate-50 dark:border-slate-700 dark:bg-slate-800/50 space-y-3">
                                    <div class="flex items-center justify-between gap-3">
                                        <div class="flex items-center gap-3">
                                            {% if milestone.status == 'COMPLETED' %}
                                                <svg class="w-5 h-5 text-[#0FAF7A] shrink-0" fill="currentColor" viewBox="0 0 20 20">
                                                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                                                </svg>
                                            {% elseif milestone.status == 'DELIVERED' %}
                                                <svg class="w-5 h-5 text-cyan-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l3-3 2 2 5-5"/>
                                                </svg>
                                            {% elseif milestone.status == 'REVISION_REQUESTED' %}
                                                <svg class="w-5 h-5 text-amber-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h8M8 14h5"/>
                                                </svg>
                                            {% else %}
                                                <span class="w-5 h-5 rounded-full border-2 border-slate-300 dark:border-slate-500 shrink-0"></span>
                                            {% endif %}
                                            <span class="font-medium text-sm text-slate-900 dark:text-white">{{ milestone.title }}</span>
                                        </div>
                                        <span class="text-xs font-medium px-2 py-0.5 rounded-full
                                            {% if milestone.status == 'COMPLETED' %} bg-emerald-100 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-400
                                            {% elseif milestone.status == 'IN_PROGRESS' %} bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400
                                            {% elseif milestone.status == 'DELIVERED' %} bg-cyan-100 text-cyan-700 dark:bg-cyan-900/30 dark:text-cyan-300
                                            {% elseif milestone.status == 'REVISION_REQUESTED' %} bg-amber-100 text-amber-700 dark:bg-amber-900/30 dark:text-amber-300
                                            {% elseif milestone.status == 'CANCELLED' %} bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-300
                                            {% else %} bg-slate-100 text-slate-600 dark:bg-slate-700 dark:text-slate-300
                                            {% endif %}">
                                            {{ milestone.status|replace({'_': ' '})|capitalize }}
                                        </span>
                                    </div>
                                    <div class="text-xs text-slate-500 dark:text-slate-400 flex flex-wrap gap-3">
                                        <span>Due {{ milestone.dueDate|date('M d, Y') }}</span>
                                        {% if milestone.amount is not null %}<span>Amount {{ milestone.amount|number_format(2, '.', ',') }} {{ contract.currency }}</span>{% endif %}
                                        {% if milestone.deliveredAt %}<span>Delivered {{ milestone.deliveredAt|date('M d, Y H:i') }}</span>{% endif %}
                                    </div>

                                    {% if contract.upfrontPaid and milestone.status == 'DELIVERED' and contract.status in ['ACTIVE', 'IN_PROGRESS'] %}
                                        <div class="flex items-center gap-2">
                                            <form method="POST" action="{{ path('client_milestone_approve', {contractId: contract.id, milestoneId: milestone.id}) }}" onsubmit="return confirm('Approve this milestone and release payment?');">
                                                <button type="submit" class="inline-flex items-center gap-1 rounded-lg bg-emerald-600 px-3 py-1.5 text-xs font-semibold text-white transition hover:bg-emerald-700">
                                                    Approve & Release
                                                </button>
                                            </form>
                                            <form method="POST" action="{{ path('client_milestone_request_revision', {contractId: contract.id, milestoneId: milestone.id}) }}" onsubmit="return confirm('Request revision for this milestone?');">
                                                <button type="submit" class="inline-flex items-center gap-1 rounded-lg border border-amber-300 bg-amber-50 px-3 py-1.5 text-xs font-semibold text-amber-700 transition hover:bg-amber-100 dark:border-amber-700 dark:bg-amber-900/20 dark:text-amber-300 dark:hover:bg-amber-900/30">
                                                    Request Revision
                                                </button>
                                            </form>
                                        </div>
                                    {% endif %}

                                </div>
                            {% endfor %}
                        </div>
                    {% else %}
                        <p class="text-sm text-slate-500 dark:text-slate-400 text-center py-6">No milestones have been added yet.</p>
                    {% endif %}
                </div>
            </div>

            {# ===== Sidebar (1 col) ===== #}
            <div class="space-y-6">
                {# Payment Summary Card #}
                <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900">
                    <h2 class="text-lg font-semibold text-slate-900 dark:text-white mb-4">Payment Summary</h2>
                    <dl class="space-y-2.5 text-sm">
                        <div class="flex justify-between">
                            <dt class="text-slate-500 dark:text-slate-400">Upfront ({{ contract.upfrontPercent|number_format(2) }}%)</dt>
                            <dd class="font-medium text-slate-700 dark:text-slate-300">{{ contract.upfrontAmount|number_format(2, '.', ',') }} {{ contract.currency }}</dd>
                        </div>
                        <div class="flex justify-between">
                            <dt class="text-slate-500 dark:text-slate-400">Upfront funded</dt>
                            <dd class="font-medium {{ contract.upfrontPaid ? 'text-[#0FAF7A]' : 'text-amber-600 dark:text-amber-400' }}">
                                {{ contract.upfrontPaid ? 'Yes' : 'Pending' }}
                            </dd>
                        </div>
                        <div class="flex justify-between">
                            <dt class="text-slate-500 dark:text-slate-400">Released</dt>
                            <dd class="font-medium text-slate-700 dark:text-slate-300">{{ contract.releasedAmount|number_format(2, '.', ',') }} {{ contract.currency }}</dd>
                        </div>
                        <div class="flex justify-between">
                            <dt class="text-slate-500 dark:text-slate-400">Remaining</dt>
                            <dd class="font-medium text-slate-700 dark:text-slate-300">{{ contract.remainingAmount|number_format(2, '.', ',') }} {{ contract.currency }}</dd>
                        </div>
                    </dl>
                </div>


                        {% if contract.status == 'DRAFT' %}
                            <form method="POST" action="{{ path('client_contract_send_sign', {id: contract.id}) }}">
                                <button type="submit"
                                        class="flex w-full items-center justify-center gap-2 rounded-lg border border-amber-300 bg-amber-50 px-4 py-2.5 text-sm font-semibold text-amber-700 transition hover:bg-amber-100 dark:border-amber-700 dark:bg-amber-900/20 dark:text-amber-400 dark:hover:bg-amber-900/40">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
                                    </svg>
                                    Send for Signing
                                </button>
                            </form>
                        {% endif %}

                        {# Sign â€“ only PENDING_SIGN and client not yet signed #}
                        {% if contract.canBeSigned() and not contract.clientSigned %}

                            <a href="{{ path('client_contract_sign', {id: contract.id}) }}"
                               class="flex w-full items-center justify-center gap-2 rounded-lg bg-[#0FAF7A] px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-emerald-600">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                </svg>
                                Sign Contract
                            </a>
                        {% endif %}

                        {% if contract.status in ['ACTIVE', 'IN_PROGRESS'] and not contract.upfrontPaid %}
                            {% if contract.isFullySigned() %}
                                <form method="POST" action="{{ path('client_contract_fund_upfront', {id: contract.id}) }}"
                                      onsubmit="return confirm('Fund upfront payment now?');">
                                    <button type="submit"
                                            class="flex w-full items-center justify-center gap-2 rounded-lg border border-cyan-300 bg-cyan-50 px-4 py-2.5 text-sm font-semibold text-cyan-700 transition hover:bg-cyan-100 dark:border-cyan-700 dark:bg-cyan-900/20 dark:text-cyan-300 dark:hover:bg-cyan-900/40">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a5 5 0 00-10 0v2m-2 4h14M5 13l1.5 7h11L19 13"/>
                                        </svg>
                                        Pay Upfront
                                    </button>
                                </form>
                            {% else %}
                                <div class="rounded-lg border border-amber-200 bg-amber-50 px-3 py-2 text-xs text-amber-800 dark:border-amber-700 dark:bg-amber-900/20 dark:text-amber-300">
                                    Payment is blocked until both contract signatures are completed.
                                </div>
                            {% endif %}
                        {% elseif contract.status in ['DRAFT', 'PENDING_SIGN'] and not contract.upfrontPaid %}
                            <div class="rounded-lg border border-slate-200 bg-slate-50 px-3 py-2 text-xs text-slate-600 dark:border-slate-700 dark:bg-slate-800/60 dark:text-slate-300">
                                Payment will be available when the contract becomes active.
                            </div>
                        {% elseif contract.upfrontPaid %}
                            <div class="rounded-lg border border-emerald-200 bg-emerald-50 px-3 py-2 text-xs text-emerald-700 dark:border-emerald-700 dark:bg-emerald-900/20 dark:text-emerald-300">
                                Upfront payment already funded.
                            </div>
                        {% endif %}

                        {# Complete â€“ only ACTIVE #}
                        {% if contract.status in ['ACTIVE', 'IN_PROGRESS'] %}

                            <form method="POST" action="{{ path('client_contract_complete', {id: contract.id}) }}"
                                  onsubmit="return confirm('Mark this contract as completed?');">
                                <button type="submit"
                                        class="flex w-full items-center justify-center gap-2 rounded-lg border border-indigo-300 bg-indigo-50 px-4 py-2.5 text-sm font-semibold text-indigo-700 transition hover:bg-indigo-100 dark:border-indigo-700 dark:bg-indigo-900/20 dark:text-indigo-400 dark:hover:bg-indigo-900/40">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                                    </svg>
                                    Mark as Complete
                                </button>
                            </form>
                        {% endif %}

                        {# Cancel #}
                        {% if contract.status not in ['COMPLETED', 'CANCELLED'] %}
                            <form method="POST" action="{{ path('client_contract_cancel', {id: contract.id}) }}"
                                  onsubmit="return confirm('Are you sure you want to cancel this contract? This action cannot be undone.');">
                                <button type="submit"
                                        class="flex w-full items-center justify-center gap-2 rounded-lg border border-orange-300 px-4 py-2.5 text-sm font-semibold text-orange-600 transition hover:bg-orange-50 dark:border-orange-700 dark:text-orange-400 dark:hover:bg-orange-900/20">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/>
                                    </svg>
                                    Cancel Contract
                                </button>
                            </form>
                        {% endif %}


                    </div>
                </div>

                {# Quick Info Card #}
                <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900">
                    <h3 class="text-sm font-semibold text-slate-900 dark:text-white mb-3">Quick Info</h3>
                    <dl class="space-y-2.5 text-sm">
                        <div class="flex justify-between">
                            <dt class="text-slate-500 dark:text-slate-400">Fully Signed</dt>
                            <dd class="font-medium {{ contract.isFullySigned() ? 'text-[#0FAF7A]' : 'text-slate-600 dark:text-slate-300' }}">
                                {{ contract.isFullySigned() ? 'Yes' : 'No' }}
                            </dd>
                        </div>
                        <div class="flex justify-between">
                            <dt class="text-slate-500 dark:text-slate-400">Editable</dt>
                            <dd class="font-medium text-slate-600 dark:text-slate-300">{{ contract.canBeEdited() ? 'Yes' : 'No' }}</dd>
                        </div>
                        <div class="flex justify-between">
                            <dt class="text-slate-500 dark:text-slate-400">Can Sign</dt>
                            <dd class="font-medium text-slate-600 dark:text-slate-300">{{ contract.canBeSigned() ? 'Yes' : 'No' }}</dd>
                        </div>
                        <div class="flex justify-between">
                            <dt class="text-slate-500 dark:text-slate-400">Can Cancel</dt>
                            <dd class="font-medium text-slate-600 dark:text-slate-300">{{ contract.canBeCancelled() ? 'Yes' : 'No' }}</dd>
                        </div>
                        <div class="flex justify-between">
                            <dt class="text-slate-500 dark:text-slate-400">Progress</dt>
                            <dd class="font-medium text-slate-600 dark:text-slate-300">{{ contract.getProgressPercent() }}%</dd>
                        </div>
                        <div class="flex justify-between">
                            <dt class="text-slate-500 dark:text-slate-400">Upfront Funded</dt>
                            <dd class="font-medium {{ contract.upfrontPaid ? 'text-[#0FAF7A]' : 'text-amber-600 dark:text-amber-400' }}">
                                {{ contract.upfrontPaid ? 'Yes' : 'No' }}
                            </dd>
                        </div>
                        <div class="flex justify-between">
                            <dt class="text-slate-500 dark:text-slate-400">Pending Approvals</dt>
                            <dd class="font-medium text-slate-600 dark:text-slate-300">{{ contract.hasPendingApprovals() ? 'Yes' : 'No' }}</dd>
                        </div>
                    </dl>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
