{% extends 'layout_app.html.twig' %}

{% block javascripts %}
    {{ parent() }}
    <script>
        // JWT token is now handled automatically by auth-helper.js
        // Make CSRF token available for popup forms
        window.ticketCsrfToken = '{{ csrf_token('subticket_item') }}';
    </script>
{% endblock %}

{% block main %}
<div class="space-y-6">

    {# Header #}
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold text-slate-900 dark:text-white">
                Welcome back, {{ app.user.firstName }}!
            </h1>
            <p class="text-slate-600 dark:text-slate-400 mt-1">Here's what's happening with your account</p>
        </div>
        <a href="{{ path('request_new') }}"
            class="inline-flex items-center gap-2 px-4 py-2 bg-emerald-600 hover:bg-emerald-700 text-white rounded-lg font-medium transition">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
            </svg>
            New Request
        </a>
    </div>

    {# Certificate Banner #}
    {% if user.hasCertificate %}
        <div class="rounded-xl border p-5
            {% if user.isCertificatePending %}bg-amber-50 border-amber-200 dark:bg-amber-900/20 dark:border-amber-800
            {% elseif user.isCertificateApproved %}bg-emerald-50 border-emerald-200 dark:bg-emerald-900/20 dark:border-emerald-800
            {% else %}bg-red-50 border-red-200 dark:bg-red-900/20 dark:border-red-800{% endif %}">
            <div class="flex items-center gap-3">
                {% if user.isCertificatePending %}
                    <svg class="w-5 h-5 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    <p class="text-sm font-medium text-amber-800 dark:text-amber-200">Your freelancer certificate is under review.</p>
                {% elseif user.isCertificateApproved %}
                    <svg class="w-5 h-5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    <p class="text-sm font-medium text-emerald-800 dark:text-emerald-200">Certificate approved! 
                        <a href="{{ path('worker_dashboard') }}" class="underline">Go to Freelancer Dashboard →</a>
                    </p>
                {% else %}
                    <svg class="w-5 h-5 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    <p class="text-sm font-medium text-red-800 dark:text-red-200">Certificate rejected. {{ user.certificateReviewNote }}</p>
                {% endif %}
            </div>
        </div>
    {% else %}
        <div class="bg-gradient-to-r from-emerald-500 to-teal-600 rounded-xl p-6 text-white">
            <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
                <div>
                    <h3 class="text-xl font-bold">Become a Freelancer</h3>
                    <p class="mt-1 text-emerald-100">Share your skills and start earning.</p>
                </div>
                <a href="{{ path('client_apply_freelancer') }}"
                    class="inline-flex items-center gap-2 px-6 py-3 bg-white text-emerald-600 rounded-lg font-semibold hover:bg-emerald-50 transition">
                    Apply Now
                </a>
            </div>
        </div>
    {% endif %}

    {# Stats Cards #}
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {% include 'components/_stats_card.html.twig' with {
            title: 'Active Requests', value: stats.active_requests,
            icon: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>',
            color: 'emerald'
        } %}
        {% include 'components/_stats_card.html.twig' with {
            title: 'Active Contracts', value: stats.active_contracts,
            icon: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>',
            color: 'blue'
        } %}
        {% include 'components/_stats_card.html.twig' with {
            title: 'Pending Offers', value: stats.pending_offers,
            icon: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/></svg>',
            color: 'purple'
        } %}
        {% include 'components/_stats_card.html.twig' with {
            title: 'Total Budget Committed', value: total_budget_max|number_format(0) ~ '€',
            icon: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>',
            color: 'amber'
        } %}
    </div>

    {# Charts Row #}
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

        {# Activity Line Chart — spans 2 cols #}
        <div class="lg:col-span-2 bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm p-6">
            <div class="flex items-center justify-between mb-4">
                <div>
                    <h3 class="font-semibold text-slate-900 dark:text-white">My Request Activity</h3>
                    <p class="text-xs text-slate-400 mt-0.5">Requests you posted — last 30 days</p>
                </div>
            </div>
            <canvas id="client-chart-activity" height="100"></canvas>
        </div>

        {# Spending by Category — Doughnut #}
        <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm p-6">
            <h3 class="font-semibold text-slate-900 dark:text-white mb-1">Budget by Category</h3>
            <p class="text-xs text-slate-400 mb-4">Where your budget is allocated</p>
            {% if chart_spending != '[]' %}
                <canvas id="client-chart-spending"></canvas>
            {% else %}
                <div class="flex flex-col items-center justify-center h-40 text-slate-400">
                    <svg class="w-10 h-10 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                    </svg>
                    <p class="text-sm">No data yet</p>
                </div>
            {% endif %}
        </div>
    </div>

    {# Budget Range Bar #}
    <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm p-6">
        <div class="flex items-center justify-between mb-4">
            <div>
                <h3 class="font-semibold text-slate-900 dark:text-white">Budget Range Overview</h3>
                <p class="text-xs text-slate-400 mt-0.5">Your committed min vs max budget across all requests</p>
            </div>
            <div class="text-right">
                <p class="text-xs text-slate-400">Total range</p>
                <p class="font-bold text-slate-900 dark:text-white">
                    {{ total_budget_min|number_format(0) }}€ – {{ total_budget_max|number_format(0) }}€
                </p>
            </div>
        </div>
        {% if total_budget_max > 0 %}
            <div class="space-y-2">
                <div class="flex justify-between text-xs text-slate-500 mb-1">
                    <span>Min Budget</span>
                    <span>{{ total_budget_min|number_format(0) }}€</span>
                </div>
                <div class="w-full h-3 bg-slate-100 dark:bg-slate-800 rounded-full overflow-hidden">
                    <div class="h-full bg-emerald-400 rounded-full transition-all"
                        style="width: {{ ((total_budget_min / total_budget_max) * 100)|round }}%"></div>
                </div>
                <div class="flex justify-between text-xs text-slate-500 mt-1">
                    <span>Max Budget</span>
                    <span>{{ total_budget_max|number_format(0) }}€</span>
                </div>
                <div class="w-full h-3 bg-slate-100 dark:bg-slate-800 rounded-full overflow-hidden">
                    <div class="h-full bg-indigo-500 rounded-full" style="width: 100%"></div>
                </div>
            </div>
        {% else %}
            <p class="text-sm text-slate-400 text-center py-4">No budget data yet — post your first request!</p>
        {% endif %}
    </div>

    {# Recent Requests Table #}
    <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm">
        <div class="p-6 border-b border-slate-200 dark:border-slate-800 flex items-center justify-between">
            <h2 class="text-lg font-semibold text-slate-900 dark:text-white">Recent Requests</h2>
            <a href="{{ path('request_list') }}" class="text-sm text-emerald-600 hover:text-emerald-700 font-medium">View All →</a>
        </div>
        {% if recent_requests|length > 0 %}
            <div class="divide-y divide-slate-100 dark:divide-slate-800">
                {% for req in recent_requests %}
                <div class="flex items-center justify-between px-6 py-4 hover:bg-slate-50 dark:hover:bg-slate-800/30 transition-colors">
                    <div class="flex items-center gap-4">
                        <div class="w-9 h-9 rounded-lg bg-emerald-100 dark:bg-emerald-900/30 flex items-center justify-center">
                            <svg class="w-4 h-4 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                            </svg>
                        </div>
                        <div>
                            <p class="font-medium text-slate-900 dark:text-white">{{ req.title }}</p>
                            <p class="text-xs text-slate-400">
                                {{ req.category.name }} · {{ req.createdAt|date('M d, Y') }}
                            </p>
                        </div>
                    </div>
                    <div class="flex items-center gap-4">
                        <div class="text-right">
                            <p class="text-sm font-semibold text-slate-900 dark:text-white">
                                {{ req.budgetMin|number_format(0) }}€ – {{ req.budgetMax|number_format(0) }}€
                            </p>
                            <p class="text-xs text-slate-400">{{ req.duration }} days</p>
                        </div>
                        <span class="px-2.5 py-1 rounded-full text-xs font-semibold
                            {% if req.status == 'Expert' %}bg-purple-100 text-purple-700 dark:bg-purple-900/30 dark:text-purple-400
                            {% elseif req.status == 'Intermediate' %}bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400
                            {% elseif req.status == 'Specialist' %}bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400
                            {% else %}bg-slate-100 text-slate-600 dark:bg-slate-800 dark:text-slate-400{% endif %}">
                            {{ req.status }}
                        </span>
                        <a href="{{ path('request_show', {id: req.id}) }}"
                            class="p-1.5 text-slate-400 hover:text-emerald-600 transition-colors">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                            </svg>
                        </a>
                    </div>
                </div>
                {% endfor %}
            </div>
        {% else %}
            <div class="flex flex-col items-center py-12 text-slate-400">
                <svg class="w-12 h-12 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                </svg>
                <p class="font-medium">No requests yet</p>
                <a href="{{ path('request_new') }}" class="mt-2 text-sm text-emerald-600 hover:underline">Post your first request →</a>
            </div>
        {% endif %}
    </div>

    {# Quick Actions #}
    <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm p-6">
        <h2 class="text-lg font-semibold text-slate-900 dark:text-white mb-4">Quick Actions</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <a href="{{ path('request_new') }}" class="flex items-center gap-4 p-4 bg-slate-50 dark:bg-slate-800/50 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 transition">
                <div class="w-12 h-12 rounded-lg bg-emerald-100 dark:bg-emerald-900/30 flex items-center justify-center">
                    <svg class="w-6 h-6 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
                </div>
                <div>
                    <p class="font-medium text-slate-900 dark:text-white">New Service Request</p>
                    <p class="text-sm text-slate-500">Post a new job</p>
                </div>
            </a>
            <a href="{{ path('request_list') }}" class="flex items-center gap-4 p-4 bg-slate-50 dark:bg-slate-800/50 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 transition">
                <div class="w-12 h-12 rounded-lg bg-blue-100 dark:bg-blue-900/30 flex items-center justify-center">
                    <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"/></svg>
                </div>
                <div>
                    <p class="font-medium text-slate-900 dark:text-white">My Requests</p>
                    <p class="text-sm text-slate-500">View all your postings</p>
                </div>
            </a>
            <a href="{{ path('client_contracts_list') }}" class="flex items-center gap-4 p-4 bg-slate-50 dark:bg-slate-800/50 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 transition">
                <div class="w-12 h-12 rounded-lg bg-purple-100 dark:bg-purple-900/30 flex items-center justify-center">
                    <svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                </div>
                <div>
                    <p class="font-medium text-slate-900 dark:text-white">My Contracts</p>
                    <p class="text-sm text-slate-500">Track active contracts</p>
                </div>
            </a>
        </div>
    </div>
</div>

{# Charts #}
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<script>
document.addEventListener('turbo:load', () => {
    const isDark     = () => document.documentElement.classList.contains('dark');
    const gridColor  = () => isDark() ? 'rgba(255,255,255,0.07)' : 'rgba(0,0,0,0.06)';
    const labelColor = () => isDark() ? '#94a3b8' : '#64748b';
    const COLORS = ['#10b981','#6366f1','#f59e0b','#ef4444','#3b82f6','#8b5cf6'];

    // ── Activity Line Chart ───────────────────────────────────────────────────
    const activityRaw = {{ chart_activity|raw }};
    const actCanvas   = document.getElementById('client-chart-activity');
    if (actCanvas) {
        new Chart(actCanvas, {
            type: 'line',
            data: {
                labels: activityRaw.map(r => r.day),
                datasets: [{
                    label: 'Requests',
                    data: activityRaw.map(r => r.total),
                    borderColor: '#10b981',
                    backgroundColor: 'rgba(16,185,129,0.08)',
                    borderWidth: 2,
                    pointBackgroundColor: '#10b981',
                    pointRadius: 3,
                    fill: true,
                    tension: 0.4,
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { display: false } },
                scales: {
                    x: { grid: { color: gridColor() }, ticks: { color: labelColor(), maxTicksLimit: 10 } },
                    y: { grid: { color: gridColor() }, ticks: { color: labelColor(), stepSize: 1 }, beginAtZero: true }
                }
            }
        });
    }

    // ── Spending by Category Doughnut ─────────────────────────────────────────
    const spendCanvas = document.getElementById('client-chart-spending');
    if (spendCanvas) {
        const spendRaw = {{ chart_spending|raw }};
        new Chart(spendCanvas, {
            type: 'doughnut',
            data: {
                labels: spendRaw.map(r => r.category),
                datasets: [{
                    data: spendRaw.map(r => parseFloat(r.total)),
                    backgroundColor: COLORS,
                    borderWidth: 0,
                    hoverOffset: 6,
                }]
            },
            options: {
                responsive: true,
                cutout: '65%',
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: { color: labelColor(), padding: 10, font: { size: 11 } }
                    },
                    tooltip: {
                        callbacks: {
                            label: ctx => ` ${Number(ctx.raw).toLocaleString()}€`
                        }
                    }
                }
            }
        });
    }
});
</script>
{% endblock %}