{% extends 'layout_app.html.twig' %}

{% block title %}Compare Offers - Orion{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        :root {
            --slate-50: #f8fafc;
            --slate-100: #f1f5f9;
            --slate-200: #e2e8f0;
            --slate-900: #0f172a;
            --emerald-500: #10b981;
            --indigo-600: #4f46e5;
            
            --shadow-subtle: 0 2px 10px rgba(15, 23, 42, 0.02), 0 1px 3px rgba(15, 23, 42, 0.03);
            --shadow-premium: 0 25px 60px -15px rgba(15, 23, 42, 0.08), 0 12px 25px -8px rgba(15, 23, 42, 0.04);
            --shadow-glow: 0 0 25px rgba(16, 185, 129, 0.12), 0 0 10px rgba(16, 185, 129, 0.06);
            --bg-page: #F8FAFC;
        }

        .dark {
            --shadow-subtle: 0 4px 12px rgba(0, 0, 0, 0.15), 0 2px 4px rgba(0, 0, 0, 0.2);
            --shadow-premium: 0 30px 70px -12px rgba(0, 0, 0, 0.4), 0 15px 30px -8px rgba(0, 0, 0, 0.3);
            --shadow-glow: 0 0 35px rgba(16, 185, 129, 0.08);
            --bg-page: #020617;
        }

        body { 
            background-color: var(--bg-page) !important; 
            transition: background-color 0.4s ease;
        }

        .glass-card {
            background: rgba(255, 255, 255, 0.6);
            backdrop-filter: blur(16px) saturate(180%);
            -webkit-backdrop-filter: blur(16px) saturate(180%);
            border: 1px solid rgba(255, 255, 255, 0.4);
            box-shadow: var(--shadow-subtle);
        }
        .dark .glass-card {
            background: rgba(15, 23, 42, 0.5);
            border: 1px solid rgba(255, 255, 255, 0.04);
        }

        .compare-card { 
            transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
            transform: translateY(0);
        }
        .compare-card:hover {
            transform: translateY(-8px);
            box-shadow: var(--shadow-premium);
        }

        .best-value-highlight {
            background: rgba(16, 185, 129, 0.03) !important;
            border-color: rgba(16, 185, 129, 0.3) !important;
        }
        .dark .best-value-highlight {
            background: rgba(16, 185, 129, 0.06) !important;
            border-color: rgba(16, 185, 129, 0.2) !important;
        }

        .match-score-ring { transition: stroke-dashoffset 1.4s cubic-bezier(0.16, 1, 0.3, 1); }

        @keyframes slideUpFade {
            from { opacity: 0; transform: translateY(40px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .animate-premium-entry { 
            opacity: 0;
            transform: translateY(40px);
        }
        .animate-premium-entry.is-ready { 
            animation: slideUpFade 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards; 
        }

        .ai-reason-tooltip {
            visibility: hidden;
            opacity: 0;
            transition: all 0.2s;
            transform: translateY(10px);
        }
        .ai-reason-trigger:hover .ai-reason-tooltip {
            visibility: visible;
            opacity: 1;
            transform: translateY(0);
        }

        .modal-glass {
            background: rgba(255, 255, 255, 0.97) !important;
            backdrop-filter: blur(24px) saturate(180%);
            -webkit-backdrop-filter: blur(24px) saturate(180%);
        }
        .dark .modal-glass {
            background: rgba(15, 23, 42, 0.97) !important;
        }
    </style>
{% endblock %}

{% block main %}
<div class="space-y-8">
    {# Header & Navigation #}
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-6 animate-premium-entry">
        <div class="flex items-center gap-4">
            <a href="{{ path('client_offers_index') }}" class="p-3 rounded-2xl glass-card text-slate-500 hover:text-emerald-600 transition-all hover:scale-105 active:scale-95">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
            </a>
            <div>
                <h2 class="text-2xl font-black text-slate-900 dark:text-white tracking-tight">Offer Comparison</h2>
                <p class="text-sm text-slate-500 dark:text-slate-400">Comparing <span class="font-bold text-emerald-600 dark:text-emerald-400">{{ offers|length }} offers</span> for: <span class="font-bold text-slate-700 dark:text-slate-300">{{ request.title }}</span></p>
            </div>
        </div>

        {# Sort Controls #}
        <div class="flex items-center gap-3">
            <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Sort by</span>
            <button onclick="sortCards('price')" id="sort-price" class="px-4 py-2.5 rounded-xl text-[10px] font-black uppercase tracking-widest border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 text-slate-600 dark:text-slate-400 hover:border-emerald-300 dark:hover:border-emerald-500/50 transition-all">
                Price
            </button>
            <button onclick="sortCards('score')" id="sort-score" class="px-4 py-2.5 rounded-xl text-[10px] font-black uppercase tracking-widest border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 text-slate-600 dark:text-slate-400 hover:border-emerald-300 dark:hover:border-emerald-500/50 transition-all">
                AI Match
            </button>
        </div>
    </div>

    {# Pre-compute best/fastest #}
    {% set max_score = -1 %}
    {% set best_offer_id = null %}
    {% set min_days = 9999 %}
    {% set fastest_offer_id = null %}

    {% for o in offers %}
        {% set pred = predictions[o.id]|default(null) %}
        {% if pred and pred.probability|default(0) > max_score %}
            {% set max_score = pred.probability|default(0) %}
            {% set best_offer_id = o.id %}
        {% endif %}
        {% if o.estimatedTimeDays < min_days %}
            {% set min_days = o.estimatedTimeDays %}
            {% set fastest_offer_id = o.id %}
        {% endif %}
    {% endfor %}

    <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
        {# Left Column: Service Request Sidebar #}
        <div class="lg:col-span-1 space-y-6 animate-premium-entry">
            <div class="glass-card rounded-[32px] p-8 relative overflow-hidden">
                {# Decorative blur #}
                <div class="absolute -right-6 -top-6 w-28 h-28 bg-emerald-500/10 rounded-full blur-3xl"></div>

                <div class="relative z-10">
                    <p class="text-[10px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-[0.2em] mb-4">Service Request</p>
                    <h3 class="text-xl font-black text-slate-900 dark:text-white mb-3 leading-tight">{{ request.title }}</h3>
                    <p class="text-xs text-slate-500 dark:text-slate-400 mb-8 line-clamp-4 leading-relaxed">{{ request.description }}</p>

                    <div class="space-y-4 pt-6 border-t border-slate-100 dark:border-slate-800">
                        <div class="bg-slate-50/50 dark:bg-slate-800/30 rounded-2xl p-4 border border-slate-100 dark:border-slate-800">
                            <p class="text-[10px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-widest mb-1">Budget Range</p>
                            <p class="text-xl font-black text-slate-900 dark:text-white tracking-tight">${{ request.budgetMin|number_format(0) }} – ${{ request.budgetMax|number_format(0) }}</p>
                        </div>
                        <div class="bg-slate-50/50 dark:bg-slate-800/30 rounded-2xl p-4 border border-slate-100 dark:border-slate-800">
                            <p class="text-[10px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-widest mb-1">Expected Duration</p>
                            <p class="text-xl font-black text-slate-900 dark:text-white tracking-tight">{{ request.duration }} <span class="text-sm">Days</span></p>
                        </div>
                    </div>
                </div>
            </div>

            {# AI Assistant Box #}
            <div class="glass-card rounded-[32px] p-8 relative overflow-hidden bg-gradient-to-br from-slate-900 to-slate-800 dark:from-slate-800 dark:to-slate-950 text-white group">
                <div class="absolute inset-0 bg-emerald-500/10 opacity-0 group-hover:opacity-100 transition-opacity"></div>
                <div class="relative z-10">
                    <div class="w-12 h-12 rounded-2xl bg-emerald-500/20 flex items-center justify-center mb-5">
                        <svg class="w-6 h-6 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                    </div>
                    <h4 class="font-black text-sm mb-2 tracking-tight">AI Match Helper</h4>
                    <p class="text-[11px] leading-relaxed text-slate-400">
                        Our ML model has analyzed <strong class="text-white">{{ offers|length }} offers</strong> against your budget and marketplace standards. 
                        Top matches are highlighted with green accents.
                    </p>
                </div>
            </div>
        </div>

        {# Right Column: Offer Cards Grid #}
        <div class="lg:col-span-3">
            <div id="offers-compare-grid" class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-{{ offers|length > 2 ? '3' : offers|length }} gap-6">
                {% for o in offers %}
                    {% set pred = predictions[o.id]|default(null) %}
                    {% set score = pred ? (pred.probability * 100)|round : 0 %}
                    {% set score_color = score >= 80 ? 'text-emerald-500' : (score >= 50 ? 'text-indigo-500' : 'text-amber-500') %}
                    {% set is_best = best_offer_id == o.id %}
                    {% set is_fastest = fastest_offer_id == o.id %}

                    <div class="compare-card animate-premium-entry group"
                         data-price="{{ o.price }}" 
                         data-score="{{ score }}"
                         style="animation-delay: {{ loop.index0 * 100 }}ms">
                        <div class="relative overflow-hidden rounded-[32px] glass-card h-full flex flex-col {{ is_best ? 'best-value-highlight border-l-4 border-l-emerald-500' : '' }}">
                            <div class="p-7 flex-1 flex flex-col">
                                {# Freelancer Info + Badges #}
                                <div class="flex items-start justify-between mb-6">
                                    <div class="flex items-center gap-3.5">
                                        <div class="relative">
                                            <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-slate-100 to-slate-200 dark:from-slate-800 dark:to-slate-700 flex items-center justify-center text-slate-900 dark:text-white text-lg font-black shadow-inner">
                                                {{ o.worker.firstName|first|upper }}{{ o.worker.lastName|first|upper }}
                                            </div>
                                            {% if worker_profiles[o.worker.id].verified|default(false) %}
                                            <div class="absolute -bottom-1 -right-1 w-5 h-5 bg-blue-500 border-2 border-white dark:border-slate-900 rounded-full flex items-center justify-center text-white">
                                                <svg class="w-2.5 h-2.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                                            </div>
                                            {% endif %}
                                        </div>
                                        <div class="space-y-1">
                                            <h3 class="text-base font-black text-slate-900 dark:text-white leading-tight">{{ o.worker.firstName }} {{ o.worker.lastName }}</h3>
                                            <div class="flex items-center gap-2">
                                                <div class="flex items-center text-amber-500">
                                                    <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                                                    <span class="text-xs font-black ml-1">{{ o.worker.ratingAvg|number_format(1) }}</span>
                                                </div>
                                                <span class="text-slate-300 dark:text-slate-700">•</span>
                                                <span class="text-[10px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-widest">{{ o.worker.totalReviews|default(0) }} Reviews</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                {# Badges Row #}
                                <div class="flex flex-wrap items-center gap-2 mb-6">
                                    {% if is_best %}
                                        <div class="flex items-center gap-1.5 px-2.5 py-1 bg-emerald-500 text-white rounded-full shadow-sm shadow-emerald-500/25 text-[9px] font-bold uppercase tracking-wide">
                                            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                                            Best Value
                                        </div>
                                    {% endif %}
                                    {% if is_fastest %}
                                        <span class="px-2.5 py-1 rounded-full text-[9px] font-bold uppercase bg-amber-100 text-amber-700 dark:bg-amber-900/40 dark:text-amber-400 border border-amber-200 dark:border-amber-800/50">⚡ Fastest</span>
                                    {% endif %}
                                    <span class="px-3 py-1 text-[10px] font-black rounded-xl uppercase tracking-[0.15em] border
                                        {% if o.status == 'ACCEPTED' %}bg-emerald-50 text-emerald-600 border-emerald-100 dark:bg-emerald-900/20 dark:text-emerald-400 dark:border-emerald-800
                                        {% elseif o.status == 'REJECTED' %}bg-red-50 text-red-600 border-red-100 dark:bg-red-900/20 dark:text-red-400 dark:border-red-800
                                        {% elseif o.status == 'NEGOTIATING' %}bg-indigo-50 text-indigo-600 border-indigo-100 dark:bg-indigo-900/20 dark:text-indigo-400 dark:border-indigo-800
                                        {% else %}bg-slate-50 text-slate-600 border-slate-100 dark:bg-slate-800 dark:text-slate-400 dark:border-slate-700{% endif %}">
                                        {{ o.status }}
                                    </span>
                                </div>

                                {# Metrics Grid #}
                                <div class="grid grid-cols-2 gap-3 mb-6">
                                    <div class="bg-slate-50/50 dark:bg-slate-800/30 rounded-2xl p-4 border border-slate-100 dark:border-slate-800">
                                        <p class="text-[10px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-widest mb-1">Price</p>
                                        <p class="text-2xl font-black text-slate-900 dark:text-white tracking-tighter">${{ o.price|number_format(0) }}</p>
                                        <p class="text-[9px] font-bold text-slate-400 uppercase tracking-tight mt-0.5">{{ (o.price / request.budgetMax * 100)|round }}% of budget</p>
                                    </div>
                                    <div class="bg-slate-50/50 dark:bg-slate-800/30 rounded-2xl p-4 border border-slate-100 dark:border-slate-800">
                                        <p class="text-[10px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-widest mb-1">Delivery</p>
                                        <p class="text-2xl font-black text-slate-900 dark:text-white tracking-tighter">{{ o.estimatedTimeDays }}<span class="text-sm ml-0.5">d</span></p>
                                        <p class="text-[9px] font-bold text-slate-400 uppercase tracking-tight mt-0.5">Timeline</p>
                                    </div>
                                </div>

                                {# AI Match Score Ring #}
                                {% if pred is not null %}
                                <div class="rounded-2xl p-1 mb-6 bg-slate-50/50 dark:bg-slate-800/20 border border-slate-100 dark:border-slate-800">
                                    <div class="flex items-center justify-between px-4 py-4">
                                        <div class="flex items-center gap-3">
                                            <div class="relative w-11 h-11 flex items-center justify-center">
                                                <svg class="w-full h-full -rotate-90" viewBox="0 0 36 36">
                                                    <circle cx="18" cy="18" r="16" fill="none" class="stroke-slate-200/50 dark:stroke-slate-700/50" stroke-width="2.5"></circle>
                                                    <circle cx="18" cy="18" r="16" fill="none" class="match-score-ring stroke-current {{ score_color }}" stroke-width="2.5" stroke-dasharray="100" stroke-dashoffset="{{ 100 - score }}"></circle>
                                                </svg>
                                                <span class="absolute text-[10px] font-black text-slate-900 dark:text-white">{{ score }}%</span>
                                            </div>
                                            <div>
                                                <p class="text-xs font-black text-slate-900 dark:text-white tracking-tight">AI Confidence</p>
                                                <p class="text-[9px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-wider">{{ score >= 80 ? 'Perfect Fit' : (score >= 50 ? 'Good Match' : 'Fair Match') }}</p>
                                            </div>
                                        </div>

                                        {# AI Reasons Tooltip #}
                                        {% if pred.reasons is defined and pred.reasons|length > 0 %}
                                        <div class="relative ai-reason-trigger cursor-help">
                                            <svg class="w-4 h-4 text-slate-300 hover:text-indigo-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                            </svg>
                                            <div class="absolute right-0 bottom-full mb-3 w-52 p-4 glass-card rounded-2xl shadow-xl z-50 ai-reason-tooltip text-left pointer-events-none border border-slate-100 dark:border-slate-700">
                                                <div class="text-[9px] font-bold text-slate-400 uppercase tracking-widest mb-2 border-b border-slate-100 dark:border-slate-700 pb-1.5">Match Insights</div>
                                                <div class="space-y-1.5">
                                                    {% for r in pred.reasons %}
                                                    <div class="flex items-center gap-2">
                                                        <div class="w-1.5 h-1.5 rounded-full flex-shrink-0
                                                            {% if r.type == 'success' %}bg-emerald-500
                                                            {% elseif r.type == 'warning' %}bg-red-500
                                                            {% else %}bg-blue-500{% endif %}"></div>
                                                        <span class="text-[10px] font-bold leading-tight
                                                            {% if r.type == 'success' %}text-emerald-600 dark:text-emerald-400
                                                            {% elseif r.type == 'warning' %}text-red-600 dark:text-red-400
                                                            {% else %}text-slate-600 dark:text-slate-300{% endif %}">
                                                            {{ r.text }}
                                                        </span>
                                                    </div>
                                                    {% endfor %}
                                                </div>
                                            </div>
                                        </div>
                                        {% endif %}
                                    </div>
                                </div>
                                {% endif %}

                                {# Actions #}
                                <div class="mt-auto pt-6 border-t border-slate-100 dark:border-slate-800 space-y-3">
                                    <div class="flex items-center gap-2">
                                        <button onclick="showDeliverables(this)"
                                                data-worker="{{ o.worker.firstName }} {{ o.worker.lastName }}"
                                                data-deliverables="{{ o.deliverables }}"
                                                data-message="{{ o.message }}"
                                                class="flex-1 px-4 py-3.5 bg-slate-100 dark:bg-slate-800 text-slate-900 dark:text-white text-[10px] font-black uppercase tracking-widest rounded-2xl hover:bg-slate-200 dark:hover:bg-slate-700 transition-all flex items-center justify-center gap-2 border border-transparent hover:border-slate-300 dark:hover:border-slate-600">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                                            Scope
                                        </button>
                                        <a href="{{ path('client_offers_show', {id: o.id}) }}" 
                                           class="flex-1 px-4 py-3.5 bg-slate-100 dark:bg-slate-800 text-slate-900 dark:text-white text-[10px] font-black uppercase tracking-widest rounded-2xl hover:bg-slate-200 dark:hover:bg-slate-700 transition-all flex items-center justify-center gap-2 border border-transparent hover:border-slate-300 dark:hover:border-slate-600">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                                            Details
                                        </a>
                                    </div>
                                    {% if o.status == 'PENDING' %}
                                        <form action="{{ path('client_offers_accept', {id: o.id}) }}" method="POST">
                                            <input type="hidden" name="_token" value="{{ csrf_token('accept' ~ o.id) }}">
                                            <button class="w-full px-6 py-3.5 bg-emerald-500 text-white text-[10px] font-black uppercase tracking-widest rounded-2xl hover:bg-emerald-600 shadow-lg shadow-emerald-500/25 transition-all flex items-center justify-center gap-2 hover:scale-[1.02] active:scale-[0.98]">
                                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                                                Accept Offer
                                            </button>
                                        </form>
                                    {% else %}
                                        <div class="w-full px-6 py-3.5 text-center text-[10px] font-black rounded-2xl border border-slate-200 dark:border-slate-800 text-slate-400 bg-slate-50 dark:bg-slate-800/50 uppercase tracking-widest">
                                            {{ o.status }}
                                        </div>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    </div>
                {% else %}
                    <div class="col-span-full rounded-[32px] glass-card p-16 text-center">
                        <div class="w-16 h-16 mx-auto rounded-2xl bg-slate-50 dark:bg-slate-800 flex items-center justify-center mb-4">
                            <svg class="w-8 h-8 text-slate-300 dark:text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/>
                            </svg>
                        </div>
                        <h3 class="text-xl font-black text-slate-900 dark:text-white mb-2">No offers to compare</h3>
                        <p class="text-sm text-slate-500 dark:text-slate-400 font-medium">There are no offers for this service request yet.</p>
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>
</div>

{# Deliverables Modal #}
<div id="deliverablesModal" class="fixed inset-0 z-[100] hidden">
    <div class="absolute inset-0 bg-slate-900/60 backdrop-blur-sm" onclick="closeModal()"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-xl p-4">
        <div class="glass-card modal-glass rounded-[32px] shadow-2xl overflow-hidden">
            <div class="px-8 py-6 border-b border-slate-100 dark:border-slate-800 flex items-center justify-between">
                <div>
                    <h3 class="text-xl font-black text-slate-900 dark:text-white" id="modalWorkerName">Worker Scope</h3>
                    <p class="text-[10px] text-slate-400 uppercase font-black tracking-widest mt-1">Detailed Deliverables</p>
                </div>
                <button onclick="closeModal()" class="w-10 h-10 rounded-2xl bg-slate-50 dark:bg-slate-800 flex items-center justify-center text-slate-400 hover:text-slate-900 dark:hover:text-white transition-colors">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>
            <div class="p-8 max-h-[60vh] overflow-y-auto space-y-6">
                <div>
                    <h4 class="text-[10px] font-black text-emerald-500 uppercase tracking-widest mb-3">Project Deliverables</h4>
                    <div id="modalDeliverables" class="text-sm text-slate-600 dark:text-slate-300 whitespace-pre-wrap leading-relaxed bg-slate-50 dark:bg-slate-800/50 p-5 rounded-2xl border border-slate-100 dark:border-slate-700/50"></div>
                </div>
                <div>
                    <h4 class="text-[10px] font-black text-emerald-500 uppercase tracking-widest mb-3">Proposal Excerpt</h4>
                    <div id="modalProposal" class="text-xs text-slate-500 dark:text-slate-400 italic leading-relaxed border-l-2 border-emerald-500/30 pl-4 py-1"></div>
                </div>
            </div>
            <div class="px-8 py-5 bg-slate-50 dark:bg-slate-800/30 border-t border-slate-100 dark:border-slate-800 flex justify-end">
                <button onclick="closeModal()" class="px-6 py-3 bg-slate-900 dark:bg-white text-white dark:text-slate-900 text-[10px] font-black rounded-2xl uppercase tracking-widest hover:scale-105 transition-transform shadow-lg">
                    Got it
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    // Entry animations
    // Runs immediately — DOM is ready when Turbo swaps the body
    document.querySelectorAll('.animate-premium-entry').forEach((el, i) => {
        setTimeout(() => el.classList.add('is-ready'), 100 + (i * 80));
    });

    // Sort cards
    let sortOrders = {};
    function sortCards(type) {
        const grid = document.getElementById('offers-compare-grid');
        const cards = Array.from(grid.querySelectorAll('.compare-card'));
        
        // Toggle sort order
        sortOrders[type] = sortOrders[type] === 'asc' ? 'desc' : 'asc';
        const isAsc = sortOrders[type] === 'asc';

        // Reset all sort button styles
        document.querySelectorAll('[id^="sort-"]').forEach(btn => {
            btn.classList.remove('bg-emerald-50', 'text-emerald-600', 'border-emerald-300', 'dark:bg-emerald-900/20', 'dark:text-emerald-400', 'dark:border-emerald-500/50');
        });

        // Highlight active sort
        const activeBtn = document.getElementById('sort-' + type);
        activeBtn.classList.add('bg-emerald-50', 'text-emerald-600', 'border-emerald-300', 'dark:bg-emerald-900/20', 'dark:text-emerald-400', 'dark:border-emerald-500/50');

        cards.sort((a, b) => {
            const valA = parseFloat(a.dataset[type]);
            const valB = parseFloat(b.dataset[type]);
            return isAsc ? valA - valB : valB - valA;
        });

        // Re-append in sorted order with animation
        cards.forEach((card, i) => {
            card.style.opacity = '0';
            card.style.transform = 'translateY(20px)';
            setTimeout(() => {
                grid.appendChild(card);
                requestAnimationFrame(() => {
                    card.style.transition = 'all 0.4s cubic-bezier(0.16, 1, 0.3, 1)';
                    card.style.opacity = '1';
                    card.style.transform = 'translateY(0)';
                });
            }, i * 60);
        });
    }

    // Deliverables Modal
    function showDeliverables(btn) {
        const name = btn.dataset.worker;
        const deliverables = btn.dataset.deliverables;
        const proposal = btn.dataset.message;

        document.getElementById('modalWorkerName').innerText = name + "'s Scope";
        document.getElementById('modalDeliverables').innerText = deliverables || "No specific deliverables listed.";
        document.getElementById('modalProposal').innerText = proposal || "No proposal summary provided.";
        document.getElementById('deliverablesModal').classList.remove('hidden');
        document.body.style.overflow = 'hidden';
    }

    function closeModal() {
        document.getElementById('deliverablesModal').classList.add('hidden');
        document.body.style.overflow = 'auto';
    }

    // Close modal on ESC
    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeModal();
    });
</script>
{% endblock %}
