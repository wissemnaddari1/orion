{% extends 'layout_app.html.twig' %}

{% block title %}My Offers - Orion{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        :root {
            --slate-50: #f8fafc;
            --slate-100: #f1f5f9;
            --slate-200: #e2e8f0;
            --slate-900: #0f172a;
            --emerald-500: #10b981;
            --indigo-600: #4f46e5;
            
            --shadow-subtle: 0 2px 10px rgba(15, 23, 42, 0.02), 0 1px 3px rgba(15, 23, 42, 0.03);
            --shadow-premium: 0 25px 60px -15px rgba(15, 23, 42, 0.08), 0 12px 25px -8px rgba(15, 23, 42, 0.04);
            --shadow-glow: 0 0 25px rgba(16, 185, 129, 0.12), 0 0 10px rgba(16, 185, 129, 0.06);
            --bg-page: #F8FAFC;
        }

        .dark {
            --shadow-subtle: 0 4px 12px rgba(0, 0, 0, 0.15), 0 2px 4px rgba(0, 0, 0, 0.2);
            --shadow-premium: 0 30px 70px -12px rgba(0, 0, 0, 0.4), 0 15px 30px -8px rgba(0, 0, 0, 0.3);
            --shadow-glow: 0 0 35px rgba(16, 185, 129, 0.08);
            --bg-page: #020617;
        }

        body { 
            background-color: var(--bg-page) !important; 
            transition: background-color 0.4s ease;
        }

        .glass-card {
            background: rgba(255, 255, 255, 0.6);
            backdrop-filter: blur(16px) saturate(180%);
            -webkit-backdrop-filter: blur(16px) saturate(180%);
            border: 1px solid rgba(255, 255, 255, 0.4);
            box-shadow: var(--shadow-subtle);
        }
        .dark .glass-card {
            background: rgba(15, 23, 42, 0.5);
            border: 1px solid rgba(255, 255, 255, 0.04);
        }

        .offer-card { 
            transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
            transform: translateY(0);
        }
        .offer-card:hover {
            transform: translateY(-12px);
            box-shadow: var(--shadow-premium);
        }

        @keyframes slideUpFade {
            from { opacity: 0; transform: translateY(40px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .animate-premium-entry { 
            opacity: 0;
            transform: translateY(40px);
        }
        .animate-premium-entry.is-ready { 
            animation: slideUpFade 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards; 
        }

        .match-score-ring { transition: stroke-dashoffset 1.4s cubic-bezier(0.16, 1, 0.3, 1); }
        
        .best-value-highlight {
            background: rgba(16, 185, 129, 0.03) !important;
        }
        .dark .best-value-highlight {
            background: rgba(16, 185, 129, 0.06) !important;
        }

        .summary-card-refined {
            transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .summary-card-refined:hover {
            transform: translateY(-4px);
            border-color: var(--emerald-500);
            box-shadow: var(--shadow-premium);
        }

        /* Group Comparison Highlights */
        .offer-card {
            transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), 
                        opacity 0.2s ease, 
                        filter 0.2s ease;
        }

        .offer-card > a > div {
            transition: all 0.2s ease;
        }

        .compare-active > a > div {
            border-color: #10b981 !important;
            background: rgba(16, 185, 129, 0.08) !important;
            transform: scale(1.02) translateY(-4px);
            box-shadow: 0 20px 40px -10px rgba(16, 185, 129, 0.2);
            z-index: 10;
        }

        .compare-related > a > div {
            border-color: #34d399 !important;
            background: rgba(16, 185, 129, 0.04) !important;
            transform: scale(1.01);
            animation: pulse-border 2s infinite;
        }

        .compare-dimmed {
            opacity: 0.4;
            filter: grayscale(0.2) blur(0.5px);
            transform: scale(0.98);
        }

        @keyframes pulse-amber {
            0% { opacity: 1; transform: scale(1); border-width: 2px; }
            50% { opacity: 1; transform: scale(1.02); border-width: 2px; }
            100% { opacity: 1; transform: scale(1); border-width: 2px; }
            
        }
        .pulse-amber-active {
            position: relative;
        }
        .pulse-amber-active::after {
            content: "";
            position: absolute;
            inset: -1px;
            border: 2px solid #f59e0b;
            border-radius: 1.5rem; /* Matches card rounded-3xl */
            opacity: 0.8;
            pointer-events: none;
            animation: pulse-amber 2s cubic-bezier(0.24, 0, 0.38, 1) infinite;
        }
        .pulse-amber-active::after {
            animation-duration: 1.5s; /* Faster on hover for feedback */
        }

        @keyframes pulse-border {
            0% { box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.4); }
            70% { box-shadow: 0 0 0 10px rgba(16, 185, 129, 0); }
            100% { box-shadow: 0 0 0 0 rgba(16, 185, 129, 0); }
        }
    </style>
{% endblock %}

{% block main %}
<div class="max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-10">

    {# Page Header & Summary Section #}
    <div class="space-y-8">
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
            <div>
                <h1 class="text-3xl font-black text-slate-900 dark:text-white tracking-tight">Received Offers</h1>
                <p class="text-slate-500 dark:text-slate-400 mt-1 font-medium">Review and compare proposals from top-tier freelancers.</p>
            </div>
        </div>

        {# Summary Stats Cards #}
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            <div class="summary-card-refined glass-card p-6 rounded-3xl flex items-center gap-5">
                <div class="w-14 h-14 rounded-2xl bg-indigo-50 dark:bg-indigo-900/20 flex items-center justify-center text-indigo-600 dark:text-indigo-400">
                    <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </div>
                <div>
                    <p class="text-[10px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-[0.15em]">Average Price</p>
                    <p class="text-2xl font-black text-slate-900 dark:text-white mt-0.5">${{ avg_price|number_format(0) }}</p>
                </div>
            </div>
            
            <div class="summary-card-refined glass-card p-6 rounded-3xl flex items-center gap-5 border-l-4 border-l-emerald-500">
                <div class="w-14 h-14 rounded-2xl bg-emerald-50 dark:bg-emerald-900/20 flex items-center justify-center text-emerald-600 dark:text-emerald-400">
                    <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                </div>
                <div>
                    <p class="text-[10px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-[0.15em]">Fastest Delivery</p>
                    <p class="text-2xl font-black text-slate-900 dark:text-white mt-0.5">{{ fastest_delivery }} Days</p>
                </div>
            </div>

            <div onclick="window.filterByStatus('pending')" 
                 title="Click to show only pending offers"
                 class="summary-card-refined glass-card p-6 rounded-3xl flex items-center gap-5 cursor-pointer hover:border-amber-400 dark:hover:border-amber-500/50 hover:shadow-lg active:scale-[0.98] transition-all group {{ active_breakdown.PENDING > 0 ? 'pulse-amber-active' : '' }}">
                <div class="w-14 h-14 rounded-2xl bg-amber-50 dark:bg-amber-900/20 flex items-center justify-center text-amber-600 dark:text-amber-400 group-hover:scale-110 transition-transform">
                    <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </div>
                <div class="flex flex-col">
                    <p class="text-[10px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-[0.15em]">Pending Decisions</p>
                    <div class="flex items-center gap-2 mt-0.5">
                        <p class="text-2xl font-black text-slate-900 dark:text-white">{{ active_breakdown.PENDING }}</p>
                        <div class="transition-all duration-300">
                            <span class="text-[9px] font-bold text-amber-500 uppercase tracking-tight inline-block">Click to filter</span>
                        </div>
                    </div>
                    <p class="text-[11px] font-bold text-slate-500 dark:text-slate-400 mt-0.5">Needs your action</p>
                </div>
            </div>
        </div>
    </div>

    {# Search & Filter Bar #}
    <div class="relative z-[40] bg-white dark:bg-slate-900/50 backdrop-blur-xl rounded-[32px] border border-slate-200 dark:border-slate-800 p-4 shadow-xl shadow-slate-200/50 dark:shadow-none">
        <div class="flex flex-col lg:flex-row gap-4">
            <div class="relative flex-1 group">
                <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-slate-400 group-focus-within:text-emerald-500 transition-colors">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                </div>
                <input type="text" id="search-input" value="{{ search_query }}" placeholder="Search by freelancer or project title..."
                       class="w-full pl-12 pr-4 py-4 border-none rounded-2xl bg-slate-50 dark:bg-slate-800/50 text-slate-900 dark:text-white text-sm font-medium focus:ring-2 focus:ring-emerald-500/20 transition-all placeholder-slate-400">
            </div>
            <div class="flex flex-col sm:flex-row gap-4">
                {# Filter Dropdown — button + panel inside a relative wrapper #}
                <div class="relative w-full sm:w-64" data-controller="dropdown">
                    <button type="button" 
                            data-action="click->dropdown#toggle"
                            data-dropdown-target="button"
                            class="w-full px-6 py-4 bg-slate-50 dark:bg-slate-800/50 text-slate-900 dark:text-white text-sm font-bold rounded-2xl border border-transparent hover:border-emerald-300 dark:hover:border-emerald-500/50 transition-all flex items-center justify-between group">
                        <div class="flex items-center gap-3">
                            <svg class="w-4 h-4 text-slate-400 group-hover:text-emerald-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"/>
                            </svg>
                            <span data-dropdown-target="label">Filter: All Status</span>
                        </div>
                        <svg class="w-4 h-4 text-slate-400 transition-transform duration-200 chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>
                        </svg>
                    </button>

                    {# Hidden input for backend compatibility #}
                    <input type="hidden" name="status" id="status-filter" 
                           data-dropdown-target="valueInput" 
                           value="{{ status_filter == '' ? 'all' : status_filter }}">

                    {# Dropdown Panel — anchored to button via top:100% + right:0 #}
                    <div data-dropdown-target="menu"
                         class="hidden absolute right-0 top-full mt-2 min-w-full w-56 bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-700 shadow-[0_20px_60px_-15px_rgba(0,0,0,0.15)] dark:shadow-[0_20px_60px_-15px_rgba(0,0,0,0.5)] transition-all duration-150 opacity-0 -translate-y-2 pointer-events-none max-h-60 overflow-y-auto" style="z-index: 100;">
                        <div class="py-2">
                            {% set statuses = [
                                {'val': 'all', 'label': 'All Status', 'color': 'gray'},
                                {'val': 'pending', 'label': 'Pending', 'color': 'amber'},
                                {'val': 'negotiating', 'label': 'Negotiating', 'color': 'indigo'},
                                {'val': 'accepted', 'label': 'Accepted', 'color': 'emerald'},
                                {'val': 'rejected', 'label': 'Rejected', 'color': 'red'}
                            ] %}

                            {% for s in statuses %}
                                <div data-action="click->dropdown#select" 
                                     data-value="{{ s.val }}"
                                     class="px-4 py-3 flex items-center justify-between cursor-pointer hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors group">
                                    <div class="flex items-center gap-3">
                                        {% if s.color != 'gray' %}
                                            <span class="w-2.5 h-2.5 rounded-full bg-{{ s.color }}-500 shadow-[0_0_10px_rgba(var(--tw-gradient-from),0.5)] {{ 'shadow-' ~ s.color ~ '-500/40' }}"></span>
                                        {% else %}
                                            <span class="w-2.5 h-2.5 rounded-full bg-slate-400"></span>
                                        {% endif %}
                                        <span class="option-text text-sm font-bold text-slate-700 dark:text-slate-300 group-hover:text-emerald-500 dark:group-hover:text-emerald-400 transition-colors">{{ s.label }}</span>
                                    </div>
                                    <svg class="check-icon w-4 h-4 text-emerald-500 {{ (status_filter == s.val or (status_filter == '' and s.val == 'all')) ? '' : 'hidden' }}" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                                    </svg>
                                </div>
                            {% endfor %}
                        </div>
                    </div>
                </div>

                {# Sort Dropdown #}
                <div class="relative w-full sm:w-56" data-controller="dropdown">
                    <button type="button" 
                            data-action="click->dropdown#toggle"
                            data-dropdown-target="button"
                            class="w-full px-6 py-4 bg-slate-50 dark:bg-slate-800/50 text-slate-900 dark:text-white text-sm font-bold rounded-2xl border border-transparent hover:border-emerald-300 dark:hover:border-emerald-500/50 transition-all flex items-center justify-between group">
                        <div class="flex items-center gap-3">
                            <svg class="w-4 h-4 text-slate-400 group-hover:text-emerald-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4"/>
                            </svg>
                            <span data-dropdown-target="label">Sort: {% if sort is defined %}{{ {'newest':'Newest','oldest':'Oldest','price_low':'Price ↑','price_high':'Price ↓','fastest':'Fastest','slowest':'Slowest'}[sort]|default('Newest') }}{% else %}Newest{% endif %}</span>
                        </div>
                        <svg class="w-4 h-4 text-slate-400 transition-transform duration-200 chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>
                        </svg>
                    </button>

                    <input type="hidden" name="sort" id="sort-filter" 
                           data-dropdown-target="valueInput" 
                           value="{{ sort|default('newest') }}">

                    <div data-dropdown-target="menu"
                         class="hidden absolute right-0 top-full mt-2 min-w-full w-56 bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-700 shadow-[0_20px_60px_-15px_rgba(0,0,0,0.15)] dark:shadow-[0_20px_60px_-15px_rgba(0,0,0,0.5)] transition-all duration-150 opacity-0 -translate-y-2 pointer-events-none max-h-60 overflow-y-auto" style="z-index: 100;">
                        <div class="py-2">
                            {% set sorts = [
                                {'val': 'newest', 'label': 'Newest First'},
                                {'val': 'oldest', 'label': 'Oldest First'},
                                {'val': 'price_low', 'label': 'Price: Low → High'},
                                {'val': 'price_high', 'label': 'Price: High → Low'},
                                {'val': 'fastest', 'label': 'Fastest Delivery'},
                                {'val': 'slowest', 'label': 'Slowest Delivery'}
                            ] %}

                            {% for s in sorts %}
                                <div data-action="click->dropdown#select" 
                                     data-value="{{ s.val }}"
                                     class="px-4 py-3 flex items-center justify-between cursor-pointer hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors group">
                                    <span class="option-text text-sm font-bold text-slate-700 dark:text-slate-300 group-hover:text-emerald-500 dark:group-hover:text-emerald-400 transition-colors">{{ s.label }}</span>
                                    <svg class="check-icon w-4 h-4 text-emerald-500 {{ (sort|default('newest') == s.val) ? '' : 'hidden' }}" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                                    </svg>
                                </div>
                            {% endfor %}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# Flash messages #}
    {% include 'components/_flashes.html.twig' ignore missing %}

    {# Offers Container #}
    <div id="offers-grid-container" class="relative min-h-[400px] animate-premium-entry">
        {% include 'pages/client/_offers_list_grid.html.twig' %}
        
        {# Loading Overlay #}
        <div id="grid-loader" class="hidden absolute inset-0 bg-white/50 dark:bg-slate-900/50 backdrop-blur-[2px] z-50 rounded-2xl flex items-center justify-center transition-all duration-300 opacity-0">
            <div class="flex flex-col items-center gap-3">
                <div class="w-10 h-10 border-4 border-emerald-500 border-t-transparent rounded-full animate-spin"></div>
                <p class="text-xs font-bold text-emerald-600 dark:text-emerald-400 uppercase tracking-widest">Refreshing...</p>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
    (function() {
        function closeDropdown(wrapper) {
            const menu = wrapper.querySelector('[data-dropdown-target="menu"]');
            const chevron = wrapper.querySelector('.chevron');
            if (!menu) return;
            menu.classList.add('hidden', 'opacity-0', '-translate-y-2', 'pointer-events-none');
            chevron?.classList.remove('rotate-180');
        }

        function openDropdown(wrapper) {
            const menu = wrapper.querySelector('[data-dropdown-target="menu"]');
            const chevron = wrapper.querySelector('.chevron');
            if (!menu) return;
            menu.classList.remove('hidden');
            requestAnimationFrame(() => {
                menu.classList.remove('opacity-0', '-translate-y-2', 'pointer-events-none');
            });
            chevron?.classList.add('rotate-180');
        }

        function initDropdowns(root = document) {
            const wrappers = root.querySelectorAll('[data-controller="dropdown"]');
            if (!wrappers.length) return;

            wrappers.forEach((wrapper) => {
                if (wrapper.dataset.dropdownBound === '1') return;
                wrapper.dataset.dropdownBound = '1';

                const button = wrapper.querySelector('[data-dropdown-target="button"]');
                const menu = wrapper.querySelector('[data-dropdown-target="menu"]');
                const valueInput = wrapper.querySelector('[data-dropdown-target="valueInput"]');
                const label = wrapper.querySelector('[data-dropdown-target="label"]');
                const options = wrapper.querySelectorAll('[data-value]');
                if (!button || !menu || !valueInput || !label) return;

                const labelPrefix = (label.textContent || '').split(':')[0] || 'Filter';

                button.addEventListener('click', (e) => {
                    e.preventDefault();
                    const isOpen = !menu.classList.contains('hidden') && !menu.classList.contains('pointer-events-none');
                    wrappers.forEach((w) => closeDropdown(w));
                    if (!isOpen) openDropdown(wrapper);
                });

                options.forEach((option) => {
                    option.addEventListener('click', () => {
                        const selectedValue = option.getAttribute('data-value') || '';
                        const selectedLabel = option.querySelector('.option-text')?.textContent?.trim() || selectedValue;
                        valueInput.value = selectedValue;
                        label.textContent = `${labelPrefix}: ${selectedLabel}`;

                        menu.querySelectorAll('.check-icon').forEach((icon) => icon.classList.add('hidden'));
                        option.querySelector('.check-icon')?.classList.remove('hidden');

                        valueInput.dispatchEvent(new Event('change', { bubbles: true }));
                        closeDropdown(wrapper);
                    });
                });
            });
        }

        // Animation Guard - Prevent double entrance flicker
        const animateEntry = () => {
            const el = document.querySelector('.animate-premium-entry');
            if (el && !el.classList.contains('is-ready')) {
                requestAnimationFrame(() => {
                    el.classList.add('is-ready');
                });
            }
        };

        // Run animation immediately for initial parse/Turbo visit
        animateEntry();
        initDropdowns();

        // Prevent listener accumulation on global document
        if (window.offersListInitialized) {
            // If already initialized, we just need to re-run the animation for the new content
            animateEntry();
            initDropdowns();
            return;
        }
        window.offersListInitialized = true;

        document.addEventListener('click', (e) => {
            if (e.target.closest('[data-controller="dropdown"]')) return;
            document.querySelectorAll('[data-controller="dropdown"]').forEach((w) => closeDropdown(w));
        });

        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') {
                document.querySelectorAll('[data-controller="dropdown"]').forEach((w) => closeDropdown(w));
            }
        });

        document.addEventListener('turbo:load', () => {
            const searchInput = document.getElementById('search-input');
            const statusFilter = document.getElementById('status-filter');
            const container = document.getElementById('offers-grid-container');
            const loader = document.getElementById('grid-loader');

            if (!searchInput || !container) return;

            // Re-ensure animation on Turbo loads
            animateEntry();
            initDropdowns();

            // Comparison Hover Logic
            const initComparisonHovering = () => {
                const container = document.getElementById('offers-grid-container');
                if (!container) return;

                container.addEventListener('mouseenter', (e) => {
                    const trigger = e.target.closest('[data-compare-trigger]');
                    if (!trigger) return;

                    const serviceId = trigger.dataset.compareTrigger;
                    const allCards = document.querySelectorAll('.offer-card');
                    const targetCard = trigger.closest('.offer-card');

                    allCards.forEach(card => {
                        if (card === targetCard) {
                            card.classList.add('compare-active');
                        } else if (card.dataset.serviceRequestId === serviceId) {
                            card.classList.add('compare-related');
                        } else {
                            card.classList.add('compare-dimmed');
                        }
                    });
                }, true);

                container.addEventListener('mouseleave', (e) => {
                    const trigger = e.target.closest('[data-compare-trigger]');
                    if (!trigger) return;

                    document.querySelectorAll('.offer-card').forEach(card => {
                        card.classList.remove('compare-active', 'compare-related', 'compare-dimmed');
                    });
                }, true);
            };
            initComparisonHovering();

            let searchTimeout;

            function updateOffers(page = 1) {
                const query = searchInput.value;
                const status = statusFilter.value;
                const sortInput = document.getElementById('sort-filter');
                const sort = sortInput ? sortInput.value : 'newest';
                const url = new URL(window.location.href);
                
                url.searchParams.set('q', query);
                url.searchParams.set('status', status);
                url.searchParams.set('sort', sort);
                url.searchParams.set('page', page);

                loader.classList.remove('hidden');
                setTimeout(() => loader.classList.add('opacity-100'), 10);

                fetch(url, {
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                })
                .then(response => response.text())
                .then(html => {
                    container.innerHTML = html;
                    container.appendChild(loader);
                    loader.classList.remove('opacity-100');
                    setTimeout(() => loader.classList.add('hidden'), 300);
                    // Re-trigger animation for dynamically updated content
                    animateEntry();
                    window.history.pushState({}, '', url);
                })
                .catch(error => {
                    console.error('Error fetching offers:', error);
                    loader.classList.add('hidden');
                });
            }

            searchInput.addEventListener('input', () => {
                clearTimeout(searchTimeout);
                searchTimeout = setTimeout(() => updateOffers(1), 300);
            });

            statusFilter.addEventListener('change', () => updateOffers(1));

            const sortFilter = document.getElementById('sort-filter');
            if (sortFilter) {
                sortFilter.addEventListener('change', () => updateOffers(1));
            }
            
            // Card Click Helper - Triggers custom dropdown logic
            window.filterByStatus = function(status) {
                const option = document.querySelector(`[data-controller="dropdown"] [data-value="${status}"]`);
                if (option) {
                    option.click(); // Reuses Stimulus 'select' action
                    window.scrollTo({ top: searchInput.offsetTop - 100, behavior: 'smooth' });
                }
            };

            window.loadPage = function(page) {
                updateOffers(page);
                window.scrollTo({ top: 0, behavior: 'smooth' });
            };
        });
    })();
</script>
{% endblock %}
