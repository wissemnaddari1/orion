{% extends 'layout_app.html.twig' %}
{% set topbar_title = 'Service requests' %}
{% block main %}
    <div class="space-y-6">
        <div class="flex flex-wrap items-center justify-between gap-4">
            <h1 class="text-2xl font-bold text-[#000000]">Service requests</h1>
            {% include 'components/_button.html.twig' with { label: 'New request', href: '#', variant: 'primary' } %}
        </div>
        <div class="rounded-xl border border-gray-200 bg-white shadow-sm">
            <div class="border-b border-gray-100 p-4 sm:flex sm:items-center sm:justify-between">
                <input type="search" placeholder="Search requests" class="block w-full max-w-sm rounded-lg border border-gray-300 px-4 py-2 text-sm text-[#000000] placeholder-gray-400 focus:border-[#0FAF7A] focus:ring-2 focus:ring-[#0FAF7A]/20" aria-label="Search" />
                <div class="mt-2 flex gap-2 sm:mt-0">
                    <select class="rounded-lg border border-gray-300 px-3 py-2 text-sm text-[#3F3F3F] focus:border-[#0FAF7A]" aria-label="Filter by status">
                        <option>All statuses</option>
                        <option>Open</option>
                        <option>In progress</option>
                        <option>Closed</option>
                    </select>
                </div>
            </div>
            <div class="overflow-x-auto">
                {% set headers = ['Title', 'Status', 'Expires', 'Offers', 'Actions'] %}
                {% set rows = [
                    ['Website redesign', 'Open', '12:34:56', '5', 'View'],
                    ['Mobile app MVP', 'In progress', '08:12:00', '3', 'View'],
                    ['API integration', 'Closed', '—', '8', 'View'],
                    ['Brand identity', 'Open', '24:00:00', '2', 'View']
                ] %}
                {% include 'components/_table.html.twig' with { headers: headers, rows: rows } %}
            </div>
            {% include 'components/_pagination.html.twig' with { current_page: 1, total_pages: 5, base_path: '?page=' } %}
        </div>
    </div>
{% endblock %}
