{% extends 'layout_app.html.twig' %}
{% set topbar_title = 'New ticket' %}
{% block main %}
    <div class="mx-auto max-w-2xl space-y-8">
        <div>
            <h1 class="text-2xl font-bold text-[#000000]">New support ticket</h1>
            <p class="mt-1 text-[#3F3F3F]">Describe your issue and we’ll get back to you as soon as possible.</p>
        </div>
        <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
            <form class="space-y-6" action="#" method="post" novalidate>
                <div>
                    <label for="subject" class="block text-sm font-medium text-[#3F3F3F]">Subject</label>
                    <input id="subject" name="subject" type="text"  class="mt-1 block w-full rounded-lg border border-gray-300 px-4 py-2.5 text-[#000000] focus:border-[#0FAF7A] focus:ring-2 focus:ring-[#0FAF7A]/20" placeholder="Brief summary of your issue" />
                </div>
                <div>
                    <label for="message" class="block text-sm font-medium text-[#3F3F3F]">Message</label>
                    <textarea id="message" name="message" rows="6"  class="mt-1 block w-full rounded-lg border border-gray-300 px-4 py-2.5 text-[#000000] focus:border-[#0FAF7A] focus:ring-2 focus:ring-[#0FAF7A]/20" placeholder="Describe your issue in detail…"></textarea>
                </div>
                <div>
                    <label for="related" class="block text-sm font-medium text-[#3F3F3F]">Related (optional)</label>
                    <select id="related" name="related" class="mt-1 block w-full rounded-lg border border-gray-300 px-4 py-2.5 text-[#000000] focus:border-[#0FAF7A] focus:ring-2 focus:ring-[#0FAF7A]/20">
                        <option value="">None</option>
                        <option>Contract: Website redesign</option>
                        <option>Service request: Mobile app</option>
                    </select>
                </div>
                <div class="flex gap-3">
                    {% include 'components/_button.html.twig' with { label: 'Submit ticket', type: 'submit', variant: 'primary' } %}
                    {% include 'components/_button.html.twig' with { label: 'Cancel', href: '#', variant: 'ghost' } %}
                </div>
            </form>
        </div>
    </div>
{% endblock %}
