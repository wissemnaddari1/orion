{% extends 'layout_app.html.twig' %}
{% set topbar_title = 'Ticket: Contract delivery delay' %}
{% block main %}
    <div class="mx-auto max-w-4xl space-y-8">
        <div class="flex flex-wrap items-center justify-between gap-4">
            <div>
                <h1 class="text-2xl font-bold text-[#000000]">Contract delivery delay</h1>
                <div class="mt-2 flex items-center gap-2">
                    {% include 'components/_badge.html.twig' with { text: 'Open', variant: 'success' } %}
                    <span class="text-sm text-[#3F3F3F]">Created 1 day ago · Ticket #1234</span>
                </div>
            </div>
            <a href="#" class="text-sm font-medium text-[#0FAF7A] hover:underline">Back to tickets</a>
        </div>
        <div class="rounded-xl border border-gray-200 bg-white shadow-sm">
            <div class="space-y-0 divide-y divide-gray-100">
                <div class="p-6">
                    <div class="flex gap-4">
                        <div class="h-10 w-10 shrink-0 rounded-full bg-[#3F3F3F] flex items-center justify-center text-white font-medium">J</div>
                        <div class="min-w-0 flex-1">
                            <p class="font-medium text-[#000000]">Jane Client</p>
                            <p class="text-sm text-[#3F3F3F]">1 day ago</p>
                            <p class="mt-2 text-[#3F3F3F]">Hi, my freelancer said they’d deliver the first milestone by yesterday but I haven’t received anything. Can you check on this?</p>
                        </div>
                    </div>
                </div>
                <div class="p-6 bg-gray-50/50">
                    <div class="flex gap-4">
                        <div class="h-10 w-10 shrink-0 rounded-full bg-gradient-to-r from-[#0FAF7A] to-[#008F6A] flex items-center justify-center text-white font-medium">S</div>
                        <div class="min-w-0 flex-1">
                            <p class="font-medium text-[#000000]">Support</p>
                            <p class="text-sm text-[#3F3F3F]">12 hours ago</p>
                            <p class="mt-2 text-[#3F3F3F]">We’ve reached out to the freelancer and will update you within 24 hours.</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="border-t border-gray-100 p-6">
                <label for="reply" class="block text-sm font-medium text-[#3F3F3F]">Reply</label>
                <textarea id="reply" name="reply" rows="3" class="mt-2 block w-full rounded-lg border border-gray-300 px-4 py-2.5 text-[#000000] focus:border-[#0FAF7A] focus:ring-2 focus:ring-[#0FAF7A]/20" placeholder="Type your message…"></textarea>
                <div class="mt-3">
                    {% include 'components/_button.html.twig' with { label: 'Send reply', type: 'button', variant: 'primary' } %}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
