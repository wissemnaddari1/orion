{% extends 'layout_app.html.twig' %}
{% set topbar_title = 'Support tickets' %}
{% block main %}
    <div class="space-y-6">
        <div class="flex flex-wrap items-center justify-between gap-4">
            <h1 class="text-2xl font-bold text-[#000000]">Support tickets</h1>
            {% include 'components/_button.html.twig' with { label: 'New ticket', href: '#', variant: 'primary' } %}
        </div>
        <div class="rounded-xl border border-gray-200 bg-white shadow-sm">
            <div class="border-b border-gray-100 p-4 sm:flex sm:items-center sm:justify-between">
                <input type="search" placeholder="Search tickets…" class="block w-full max-w-sm rounded-lg border border-gray-300 px-4 py-2 text-sm text-[#000000] placeholder-gray-400 focus:border-[#0FAF7A] focus:ring-2 focus:ring-[#0FAF7A]/20" aria-label="Search" />
                <select class="mt-2 rounded-lg border border-gray-300 px-3 py-2 text-sm text-[#3F3F3F] sm:mt-0" aria-label="Filter">
                    <option>All statuses</option>
                    <option>Open</option>
                    <option>In progress</option>
                    <option>Closed</option>
                </select>
            </div>
            {% set headers = ['Subject', 'Status', 'Created', 'Actions'] %}
            {% set rows = [
                ['Contract delivery delay', 'Open', '1 day ago', 'View'],
                ['Invoice question', 'In progress', '3 days ago', 'View'],
                ['Refund request', 'Closed', '1 week ago', 'View']
            ] %}
            {% include 'components/_table.html.twig' with { headers: headers, rows: rows } %}
            {% include 'components/_pagination.html.twig' with { current_page: 1, total_pages: 2, base_path: '?page=' } %}
        </div>
    </div>
{% endblock %}
