{% extends 'layout_app.html.twig' %}

{% block main %}
<div class="max-w-5xl mx-auto space-y-6">
    {# Profile Header #}
    <div class="rounded-2xl border border-slate-200 bg-white shadow-sm dark:border-slate-800 dark:bg-slate-900">
        <div class="relative h-32 rounded-t-2xl bg-gradient-to-r from-emerald-500 to-emerald-600"></div>
        
        <div class="relative px-6 pb-6">
            <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 -mt-16">
                {# Profile Picture #}
                <div class="flex items-end gap-4">
                    <div class="relative h-32 w-32">
                        {% if user.profilePicture %}
                            {% set profilePicPath = user.profilePicture starts with '/' 
                                                     ? user.profilePicture 
                                                     : 'uploads/profile/' ~ user.profilePicture %}
                            <img src="{{ asset(profilePicPath) }}" 
                                 alt="{{ user.fullName }}"
                                 class="h-32 w-32 rounded-2xl border-4 border-white object-cover shadow-xl dark:border-slate-900"
                                 onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
                            <div class="h-32 w-32 items-center justify-center rounded-2xl border-4 border-white bg-gradient-to-br from-emerald-500 to-emerald-600 text-4xl font-bold text-white shadow-xl dark:border-slate-900 hidden" style="display: none;">
                                {{ user.firstName[0]|default('U') }}{{ user.lastName[0]|default('') }}
                            </div>
                        {% else %}
                            <div class="flex h-32 w-32 items-center justify-center rounded-2xl border-4 border-white bg-gradient-to-br from-emerald-500 to-emerald-600 text-4xl font-bold text-white shadow-xl dark:border-slate-900">
                                {{ user.firstName[0]|default('U') }}{{ user.lastName[0]|default('') }}
                            </div>
                        {% endif %}
                    </div>

                    <div class="pb-2">
                        <h1 class="text-2xl font-bold text-slate-900 dark:text-white">
                            {{ user.fullName|default(user.username) }}
                        </h1>
                        <p class="text-sm text-slate-500 dark:text-slate-400">@{{ user.username }}</p>
                    </div>
                </div>

                {# Action Buttons #}
                <div class="flex gap-3 pb-2">
                    <a href="{{ path('profile_edit') }}"
                       class="inline-flex items-center gap-2 rounded-xl bg-emerald-600 px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-emerald-700">
                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                                  d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                        </svg>
                        Edit Profile
                    </a>
                    <a href="{{ path('profile_face_settings') }}"
                       class="inline-flex items-center gap-2 rounded-xl bg-slate-100 px-4 py-2.5 text-sm font-semibold text-slate-700 transition hover:bg-slate-200 dark:bg-slate-800 dark:text-slate-200 dark:hover:bg-slate-700">
                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                        </svg>
                        Face Login
                    </a>
                </div>
            </div>
        </div>
    </div>

    {# Ban status (visible when banned; normally user is redirected to /banned) #}
    {% if user.isBanned %}
    <div class="rounded-2xl border border-rose-200 bg-rose-50/50 p-6 dark:border-rose-900/50 dark:bg-rose-900/10">
        <h2 class="mb-4 text-lg font-bold text-rose-900 dark:text-rose-200">Ban status</h2>
        <dl class="grid gap-3 sm:grid-cols-2">
            <div>
                <dt class="text-sm font-medium text-slate-500 dark:text-slate-400">Status</dt>
                <dd class="mt-1 text-sm font-semibold text-rose-700 dark:text-rose-300">
                    {{ user.banType == 'PERM' ? 'Permanent' : 'Temporary' }} ban
                </dd>
            </div>
            <div>
                <dt class="text-sm font-medium text-slate-500 dark:text-slate-400">Reason</dt>
                <dd class="mt-1 text-sm text-slate-900 dark:text-white">{{ user.banReason|default('Not provided') }}</dd>
            </div>
            <div>
                <dt class="text-sm font-medium text-slate-500 dark:text-slate-400">Banned at</dt>
                <dd class="mt-1 text-sm text-slate-900 dark:text-white">{{ user.bannedAt ? user.bannedAt|date('M d, Y H:i') : '—' }}</dd>
            </div>
            <div>
                <dt class="text-sm font-medium text-slate-500 dark:text-slate-400">Ends</dt>
                <dd class="mt-1 text-sm text-slate-900 dark:text-white">{{ user.banEndsAt ? user.banEndsAt|date('M d, Y H:i') : 'Permanent' }}</dd>
            </div>
        </dl>
        {% if user.banEndsAt and user.banEndsAt > date() %}
            <p class="mt-3 text-sm text-slate-600 dark:text-slate-400">Your access is restricted until the end date above.</p>
        {% endif %}
    </div>
    {% endif %}

    {# Profile Information #}
    <div class="grid gap-6 lg:grid-cols-2">
        {# Personal Information #}
        <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900">
            <h2 class="mb-4 text-lg font-bold text-slate-900 dark:text-white">Personal Information</h2>
            <dl class="space-y-3">
                <div>
                    <dt class="text-sm font-medium text-slate-500 dark:text-slate-400">Email</dt>
                    <dd class="mt-1 flex items-center gap-2 text-sm text-slate-900 dark:text-white">
                        {{ user.email }}
                        {% if user.emailVerified %}
                            <span class="rounded-full bg-emerald-100 px-2 py-0.5 text-xs font-semibold text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-300">
                                Verified
                            </span>
                        {% endif %}
                    </dd>
                </div>
                <div>
                    <dt class="text-sm font-medium text-slate-500 dark:text-slate-400">Phone</dt>
                    <dd class="mt-1 flex items-center gap-2 text-sm text-slate-900 dark:text-white">
                        {{ user.phone|default('Not provided') }}
                        {% if user.phone and user.phoneVerified %}
                            <span class="rounded-full bg-emerald-100 px-2 py-0.5 text-xs font-semibold text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-300">
                                Verified
                            </span>
                        {% endif %}
                    </dd>
                </div>
                <div>
                    <dt class="text-sm font-medium text-slate-500 dark:text-slate-400">Role</dt>
                    <dd class="mt-1 text-sm">
                        <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold
                                     {% if user.role.value == 'ADMIN' %}
                                       bg-purple-100 text-purple-700 dark:bg-purple-900/30 dark:text-purple-300
                                     {% elseif user.role.value == 'CLIENT' %}
                                       bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-300
                                     {% else %}
                                       bg-emerald-100 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-300
                                     {% endif %}">
                            {{ user.role.value }}
                        </span>
                    </dd>
                </div>
                <div>
                    <dt class="text-sm font-medium text-slate-500 dark:text-slate-400">Status</dt>
                    <dd class="mt-1 text-sm">
                        <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold
                                     {% if user.status.value == 'ACTIVE' %}
                                       bg-emerald-100 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-300
                                     {% elseif user.status.value == 'SUSPENDED' %}
                                       bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-300
                                     {% else %}
                                       bg-amber-100 text-amber-700 dark:bg-amber-900/30 dark:text-amber-300
                                     {% endif %}">
                            {{ user.status.value }}
                        </span>
                    </dd>
                </div>
            </dl>
        </div>

        {# Location & Settings #}
        <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900">
            <h2 class="mb-4 text-lg font-bold text-slate-900 dark:text-white">Location & Settings</h2>
            <dl class="space-y-3">
                <div>
                    <dt class="text-sm font-medium text-slate-500 dark:text-slate-400">Country</dt>
                    <dd class="mt-1 text-sm text-slate-900 dark:text-white">{{ user.country|default('Not provided') }}</dd>
                </div>
                <div>
                    <dt class="text-sm font-medium text-slate-500 dark:text-slate-400">City</dt>
                    <dd class="mt-1 text-sm text-slate-900 dark:text-white">{{ user.city|default('Not provided') }}</dd>
                </div>
                <div>
                    <dt class="text-sm font-medium text-slate-500 dark:text-slate-400">Timezone</dt>
                    <dd class="mt-1 text-sm text-slate-900 dark:text-white">{{ user.timezone|default('Not set') }}</dd>
                </div>
                <div>
                    <dt class="text-sm font-medium text-slate-500 dark:text-slate-400">Two-Factor Authentication</dt>
                    <dd class="mt-1 text-sm">
                        {% if user.twoFactorEnabled %}
                            <span class="inline-flex items-center gap-1 text-emerald-700 dark:text-emerald-300">
                                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                </svg>
                                Enabled
                            </span>
                        {% else %}
                            <span class="text-slate-500 dark:text-slate-400">Disabled</span>
                        {% endif %}
                    </dd>
                </div>
            </dl>
        </div>
    </div>

    {# Ban history (last 5) #}
    {% if ban_history|default([])|length > 0 %}
    <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900">
        <h2 class="mb-4 text-lg font-bold text-slate-900 dark:text-white">Ban history</h2>
        <ul class="space-y-3">
            {% for ban in ban_history %}
            <li class="flex flex-wrap items-center justify-between gap-2 rounded-xl border border-slate-200 dark:border-slate-700 p-3 text-sm">
                <div>
                    <span class="font-medium text-slate-900 dark:text-white">{{ ban.reason }}</span>
                    <span class="text-slate-500 dark:text-slate-400"> — {{ ban.bannedAt|date('M d, Y') }}</span>
                </div>
                <span class="px-2 py-0.5 rounded-full text-xs font-medium {{ ban.isActive ? 'bg-rose-100 text-rose-800 dark:bg-rose-900/40 dark:text-rose-300' : 'bg-slate-100 text-slate-600 dark:bg-slate-700 dark:text-slate-300' }}">
                    {{ ban.isActive ? 'Active' : 'Lifted' }}
                </span>
            </li>
            {% endfor %}
        </ul>
    </div>
    {% endif %}

    {# Account Details #}
    <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900">
        <h2 class="mb-4 text-lg font-bold text-slate-900 dark:text-white">Account Details</h2>
        <dl class="grid gap-4 sm:grid-cols-3">
            <div>
                <dt class="text-sm font-medium text-slate-500 dark:text-slate-400">Member Since</dt>
                <dd class="mt-1 text-sm font-semibold text-slate-900 dark:text-white">
                    {{ user.createdAt ? user.createdAt|date('M d, Y') : 'N/A' }}
                </dd>
            </div>
            <div>
                <dt class="text-sm font-medium text-slate-500 dark:text-slate-400">Last Login</dt>
                <dd class="mt-1 text-sm font-semibold text-slate-900 dark:text-white">
                    {{ user.lastLogin ? user.lastLogin|date('M d, Y H:i') : 'Never' }}
                </dd>
            </div>
            <div>
                <dt class="text-sm font-medium text-slate-500 dark:text-slate-400">Profile Updated</dt>
                <dd class="mt-1 text-sm font-semibold text-slate-900 dark:text-white">
                    {{ user.updatedAt ? user.updatedAt|date('M d, Y') : 'N/A' }}
                </dd>
            </div>
        </dl>
    </div>
</div>
{% endblock %}
