{% extends 'layout_app.html.twig' %}

{% block main %}
<div class="max-w-3xl mx-auto space-y-6">
    {# Page Header #}
    <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900">
        <div class="flex items-center gap-4">
            <div class="flex h-14 w-14 items-center justify-center rounded-xl bg-slate-100 dark:bg-slate-800">
                <svg class="h-7 w-7 text-slate-600 dark:text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
                </svg>
            </div>
            <div>
                <h1 class="text-xl font-bold text-slate-900 dark:text-white">Privacy & Security</h1>
                <p class="text-sm text-slate-500 dark:text-slate-400">Manage your account security and two-factor authentication</p>
            </div>
        </div>
    </div>

    {# Two-Factor Authentication Card #}
    <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900">
        <div class="flex flex-wrap items-center justify-between gap-4 mb-4">
            <div>
                <h2 class="text-lg font-bold text-slate-900 dark:text-white">Two-Factor Authentication (2FA)</h2>
                <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">Use Google Authenticator or any authenticator app to protect your account.</p>
            </div>
            <span class="inline-flex items-center rounded-full px-3 py-1 text-sm font-medium
                {% if user.twoFactorEnabled %}
                    bg-emerald-100 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-300
                {% else %}
                    bg-slate-100 text-slate-600 dark:bg-slate-800 dark:text-slate-400
                {% endif %}">
                {% if user.twoFactorEnabled %}Enabled{% else %}Disabled{% endif %}
            </span>
        </div>

        {% if user.twoFactorLocked %}
            <div class="mb-4 p-4 rounded-xl bg-amber-50 dark:bg-amber-900/20 text-amber-700 dark:text-amber-300 text-sm">
                Too many failed attempts. Please try again in 30 seconds.
            </div>
        {% endif %}

        {# Enrollment step: QR + secret + confirm form #}
        {% set showEnrollment = false %}
        {% set qrUri = '' %}
        {% set secretKey = '' %}
        {% if two_factor_enrollment is defined and two_factor_enrollment is not null %}
            {% set enrollment = two_factor_enrollment %}
            {% if enrollment.qr_data_uri is defined and enrollment.qr_data_uri is not empty %}
                {% set qrUri = enrollment.qr_data_uri %}
            {% endif %}
            {% if enrollment.secret is defined and enrollment.secret is not empty %}
                {% set secretKey = enrollment.secret %}
            {% endif %}
        {% endif %}
        {% if qrUri != '' and secretKey != '' %}
            {% set showEnrollment = true %}
            <div class="space-y-4 p-4 rounded-xl bg-slate-50 dark:bg-slate-800/50 mb-6">
                <p class="text-sm font-medium text-slate-700 dark:text-slate-300">Scan the QR code with your authenticator app, or enter the secret manually:</p>
                <div class="flex flex-wrap gap-6 items-start">
                    <div class="flex-shrink-0">
                        <img src="{{ qrUri }}" alt="QR code for 2FA" class="rounded-lg border-2 border-slate-200 dark:border-slate-700 w-44 h-44 object-contain bg-white p-2">
                    </div>
                    <div class="flex-1 min-w-0">
                        <label class="block text-sm font-medium text-slate-600 dark:text-slate-400 mb-1">Manual secret (base32):</label>
                        <code class="block p-3 rounded-lg bg-slate-200 dark:bg-slate-700 text-slate-800 dark:text-slate-200 text-sm break-all font-mono">{{ secretKey }}</code>
                    </div>
                </div>
                <form method="post" action="{{ path('settings_2fa_confirm') }}" class="space-y-3">
                    <label for="otp_code" class="block text-sm font-medium text-slate-700 dark:text-slate-300">Enter the 6-digit code from your app:</label>
                    <input type="text" id="otp_code" name="otp_code" inputmode="numeric" pattern="[0-9]*" maxlength="6" autocomplete="one-time-code"
                           class="w-full max-w-xs rounded-xl border border-slate-300 bg-white px-4 py-2.5 text-slate-900 dark:border-slate-600 dark:bg-slate-800 dark:text-white focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20"
                           placeholder="000000" required>
                    <div>
                        <button type="submit" class="inline-flex items-center gap-2 rounded-xl bg-emerald-600 px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-emerald-700">
                            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                            Confirm and enable 2FA
                        </button>
                    </div>
                </form>
            </div>
        {% endif %}

        {% if not showEnrollment %}

            {# Actions when not in enrollment step #}
            <div class="flex flex-wrap gap-3">
                {% if not user.twoFactorEnabled %}
                    <form method="post" action="{{ path('settings_2fa_start') }}" class="inline" data-turbo="false">
                        <button type="submit" {% if user.twoFactorLocked %}disabled{% endif %}
                                class="inline-flex items-center gap-2 rounded-xl bg-emerald-600 px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-emerald-700 disabled:opacity-50 disabled:cursor-not-allowed">
                            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
                            Enable 2FA
                        </button>
                    </form>
                {% else %}
                    <a href="{{ path('settings_2fa_backup_codes') }}" class="inline-flex items-center gap-2 rounded-xl bg-slate-100 px-4 py-2.5 text-sm font-semibold text-slate-700 transition hover:bg-slate-200 dark:bg-slate-800 dark:text-slate-200 dark:hover:bg-slate-700">
                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/></svg>
                        Show Backup Codes
                    </a>
                {% endif %}
            </div>

            {# Disable 2FA form (password or OTP) — shown when 2FA is enabled #}
            {% if user.twoFactorEnabled %}
                <div class="mt-6 pt-6 border-t border-slate-200 dark:border-slate-800">
                    <p class="text-sm text-slate-600 dark:text-slate-400 mb-3">To disable 2FA, enter your account password or a current 2FA code (or backup code) below:</p>
                    <form method="post" action="{{ path('settings_2fa_disable') }}" class="space-y-3 max-w-md" onsubmit="return confirm('Are you sure you want to disable two-factor authentication?');">
                        <div>
                            <label for="disable_password" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">Password</label>
                            <input type="password" id="disable_password" name="password" autocomplete="current-password"
                                   class="w-full rounded-xl border border-slate-300 bg-white px-4 py-2.5 text-slate-900 dark:border-slate-600 dark:bg-slate-800 dark:text-white focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20"
                                   placeholder="Your password">
                        </div>
                        <div>
                            <label for="disable_otp" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">Or 2FA / backup code</label>
                            <input type="text" id="disable_otp" name="otp_code" inputmode="numeric" autocomplete="one-time-code"
                                   class="w-full rounded-xl border border-slate-300 bg-white px-4 py-2.5 text-slate-900 dark:border-slate-600 dark:bg-slate-800 dark:text-white focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20"
                                   placeholder="6-digit code or backup code">
                        </div>
                        <button type="submit" {% if user.twoFactorLocked %}disabled{% endif %}
                                class="rounded-xl bg-red-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-red-700 disabled:opacity-50">
                            Disable 2FA
                        </button>
                    </form>
                </div>
            {% endif %}
        {% endif %}
    </div>

</div>
{% endblock %}
