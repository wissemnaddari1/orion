{# Offers Cards Grid #}
{% if offers|length > 0 %}
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-5">
        {% for o in offers %}
            <a href="{{ path('worker_offer_show', {id: o.id}) }}" class="offer-card group block bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm hover:shadow-xl hover:border-emerald-300 dark:hover:border-emerald-700 overflow-hidden cursor-pointer transition-all">
                {# Status Stripe #}
                <div class="h-1.5
                    {% if o.status == 'ACCEPTED' %}bg-gradient-to-r from-emerald-400 to-emerald-600
                    {% elseif o.status == 'REJECTED' %}bg-gradient-to-r from-red-400 to-red-600
                    {% elseif o.status == 'EXPIRED' %}bg-gradient-to-r from-slate-300 to-slate-500
                    {% elseif o.status == 'NEGOTIATING' %}bg-gradient-to-r from-indigo-400 to-purple-600
                    {% else %}bg-gradient-to-r from-amber-400 to-amber-600{% endif %}">
                </div>

                <div class="p-5">
                    {# Top Row: Service Request Title + Status #}
                    <div class="flex items-start justify-between gap-3 mb-4">
                        <div class="flex-1 min-w-0">
                            <h3 class="font-bold text-slate-900 dark:text-white truncate group-hover:text-emerald-600 dark:group-hover:text-emerald-400 transition-colors">
                                {{ o.serviceRequest.title|length > 40 ? o.serviceRequest.title|slice(0, 40) ~ '…' : o.serviceRequest.title }}
                            </h3>
                            <p class="text-xs text-slate-500 dark:text-slate-400 mt-0.5">
                                Client: {{ o.serviceRequest.client.fullName }}
                            </p>
                        </div>
                        <span class="flex-shrink-0 inline-flex items-center gap-1 px-2.5 py-1 text-xs font-bold rounded-full
                            {% if o.status == 'ACCEPTED' %}bg-emerald-100 text-emerald-700 dark:bg-emerald-900/40 dark:text-emerald-400
                            {% elseif o.status == 'REJECTED' %}bg-red-100 text-red-700 dark:bg-red-900/40 dark:text-red-400
                            {% elseif o.status == 'EXPIRED' %}bg-slate-100 text-slate-600 dark:bg-slate-800 dark:text-slate-400
                            {% elseif o.status == 'NEGOTIATING' %}bg-indigo-100 text-indigo-700 dark:bg-indigo-900/40 dark:text-indigo-400
                            {% else %}bg-amber-100 text-amber-700 dark:bg-amber-900/40 dark:text-amber-400{% endif %}">
                            {% if o.status == 'ACCEPTED' %}
                                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                            {% elseif o.status == 'REJECTED' %}
                                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
                            {% elseif o.status == 'NEGOTIATING' %}
                                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10c0 3.866-3.582 7-8 7a8.841 8.841 0 01-4.083-.98L2 17l1.338-3.123C2.493 12.767 2 11.434 2 10c0-3.866 3.582-7 8-7s8 3.134 8 7zM7 9H5v2h2V9zm8 0h-2v2h2V9zM9 9h2v2H9V9z" clip-rule="evenodd"/></svg>
                            {% elseif o.status == 'PENDING' %}
                                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/></svg>
                            {% endif %}
                            {{ o.status }}
                        </span>
                    </div>

                    {# Offer Details Grid #}
                    <div class="grid grid-cols-3 gap-3 mb-4">
                        <div class="text-center p-2.5 rounded-lg bg-emerald-50 dark:bg-emerald-900/20 border border-emerald-100 dark:border-emerald-800/30">
                            <p class="text-lg font-extrabold text-emerald-600 dark:text-emerald-400">${{ o.price|number_format(0) }}</p>
                            <p class="text-[10px] font-medium text-emerald-600/70 dark:text-emerald-400/60 uppercase tracking-wider mt-0.5">Price</p>
                        </div>
                        <div class="text-center p-2.5 rounded-lg bg-blue-50 dark:bg-blue-900/20 border border-blue-100 dark:border-blue-800/30">
                            <p class="text-lg font-extrabold text-blue-600 dark:text-blue-400">{{ o.estimatedTimeDays }}</p>
                            <p class="text-[10px] font-medium text-blue-600/70 dark:text-blue-400/60 uppercase tracking-wider mt-0.5">Days</p>
                        </div>
                        <div class="text-center p-2.5 rounded-lg bg-purple-50 dark:bg-purple-900/20 border border-purple-100 dark:border-purple-800/30">
                            <span class="inline-flex items-center gap-1 text-xs font-bold
                                {% if o.priorityLevel == 'HIGH' %}text-red-600 dark:text-red-400
                                {% elseif o.priorityLevel == 'MEDIUM' %}text-amber-600 dark:text-amber-400
                                {% else %}text-slate-500 dark:text-slate-400{% endif %}">
                                {% if o.priorityLevel == 'HIGH' %}
                                    <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M12.395 2.553a1 1 0 00-1.45-.385c-.345.23-.614.558-.822.88-.214.33-.403.713-.57 1.116-.334.804-.614 1.768-.84 2.734a31.365 31.365 0 00-.613 3.58 2.64 2.64 0 01-.945-1.067c-.328-.68-.398-1.534-.398-2.654A1 1 0 005.05 6.05 6.981 6.981 0 003 11a7 7 0 1011.95-4.95c-.592-.591-.98-.985-1.348-1.467-.363-.476-.724-1.063-1.207-2.03zM12.12 15.12A3 3 0 017 13s.879.5 2.5.5c0-1 .5-4 1.25-4.5.5 1 .786 1.293 1.371 1.879A2.99 2.99 0 0113 13a2.99 2.99 0 01-.879 2.121z" clip-rule="evenodd"/></svg>
                                {% endif %}
                                {{ o.priorityLevel }}
                            </span>
                            <p class="text-[10px] font-medium text-purple-600/70 dark:text-purple-400/60 uppercase tracking-wider mt-1">Priority</p>
                        </div>
                    </div>

                    {# Urgent Badge #}
                    {% if o.isUrgent %}
                        <div class="flex items-center gap-2 mb-4 p-2 rounded-lg bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800/40">
                            <svg class="w-4 h-4 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                            <span class="text-xs font-bold text-red-600 dark:text-red-400">URGENT DELIVERY</span>
                        </div>
                    {% endif %}

                    {# Footer: Date + View Action #}
                    <div class="flex items-center justify-between pt-4 border-t border-slate-100 dark:border-slate-800">
                        <span class="text-xs text-slate-400 dark:text-slate-500">
                            <svg class="w-3.5 h-3.5 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                            {{ o.createdAt|date('M d, Y') }}
                        </span>
                        <span class="inline-flex items-center gap-1 px-3 py-1.5 text-xs font-medium text-emerald-600 dark:text-emerald-400 bg-emerald-50 dark:bg-emerald-900/20 rounded-lg group-hover:bg-emerald-100 dark:group-hover:bg-emerald-900/40 transition-colors">
                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                            View Details
                        </span>
                    </div>
                </div>
            </a>
        {% endfor %}
    </div>
{% else %}
    {# Empty State #}
    <div class="bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm p-12 text-center">
        <div class="w-16 h-16 mx-auto mb-4 rounded-2xl bg-slate-100 dark:bg-slate-800 flex items-center justify-center">
            <svg class="w-8 h-8 text-slate-400 dark:text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/>
            </svg>
        </div>
        <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-1">No offers found</h3>
        <p class="text-sm text-slate-500 dark:text-slate-400">Try adjusting your search or filter settings.</p>
    </div>
{% endif %}

{# Pagination #}
{% if total_pages > 1 %}
    <div class="flex items-center justify-between bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 px-5 py-3 shadow-sm mt-8">
        <div class="text-sm text-slate-500 dark:text-slate-400">
            Page <span class="font-semibold text-slate-900 dark:text-white">{{ page }}</span> of <span class="font-semibold text-slate-900 dark:text-white">{{ total_pages }}</span>
        </div>
        <div class="flex items-center gap-2">
            {% if page > 1 %}
                <button type="button" onclick="loadPage({{ page - 1 }})"
                   class="inline-flex items-center gap-1 px-4 py-2 text-sm font-medium border border-slate-300 dark:border-slate-700 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-800 text-slate-700 dark:text-slate-300 transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                    Previous
                </button>
            {% endif %}
            {% if page < total_pages %}
                <button type="button" onclick="loadPage({{ page + 1 }})"
                   class="inline-flex items-center gap-1 px-4 py-2 text-sm font-medium border border-slate-300 dark:border-slate-700 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-800 text-slate-700 dark:text-slate-300 transition-colors">
                    Next
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                </button>
            {% endif %}
        </div>
    </div>
{% endif %}
