    {# Form actions - Create button at the very end (order ensures it stays last) #}
<div class="flex-shrink-0 flex items-center justify-between pt-8 mt-8 border-t border-slate-200 dark:border-slate-800" style="order: 999;">
    <a href="{{ cancel_path }}" class="text-sm font-semibold text-slate-500 hover:text-[#0FAF7A] dark:hover:text-[#0FAF7A] transition-colors duration-200">
        Annuler
    </a>
    {{ form_widget(form.save, {'label': submit_label, 'attr': {'class': 'px-8 py-3.5 bg-[#0FAF7A] hover:bg-[#0c8f63] text-white rounded-xl font-bold transition-all duration-300 shadow-lg shadow-[#0FAF7A]/25 hover:shadow-[#0FAF7A]/40 transform hover:-translate-y-0.5 cursor-pointer'}}) }}
</div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const form = document.querySelector('form[data-validate="worker-profile"]') || document.querySelector('form');
    if (!form) return;

    const fields = {
        title: { el: form.querySelector('[name*="[title]"]'), min: 3, msg: 'Professional title must be at least 3 characters.' },
        bio: { el: form.querySelector('[name*="[bio]"]'), min: 10, msg: 'Bio must be at least 10 characters.' },
        category: { el: form.querySelector('[name*="[workerCategory]"]'), required: true, msg: 'Please select a specialty category.' },
        rate: { el: form.querySelector('[name*="[hourly_rate]"]'), type: 'number', min: 0, msg: 'Hourly rate must be a positive number.' },
        experience: { el: form.querySelector('[name*="[experience_years]"]'), type: 'number', min: 0, msg: 'Experience must be a positive number.' },
        location: { el: form.querySelector('[name*="[location]"]'), required: true, msg: 'Location is required.' },
        phoneNumber: { el: form.querySelector('[name*="[phoneNumber]"]'), required: false, msg: 'Invalid phone number.' },
        email: { el: form.querySelector('[name*="[email]"]'), type: 'email', msg: 'Invalid email address.' },
        lat: { el: form.querySelector('[name*="[latitude]"]'), type: 'coords', min: -90, max: 90, msg: 'Invalid latitude selected.' },
        lng: { el: form.querySelector('[name*="[longitude]"]'), type: 'coords', min: -180, max: 180, msg: 'Invalid longitude selected.' }
    };

    function validateField(name, config) {
        const field = config.el;
        if (!field) return true;

        let isValid = true;
        let errorMsg = '';
        const value = field.value.trim();

        if (config.required && !value) {
            isValid = false;
            errorMsg = config.msg;
        } else if (config.min && value.length < config.min && config.type !== 'number' && config.type !== 'coords') {
            isValid = false;
            errorMsg = config.msg;
        } else if (config.type === 'number' && (isNaN(value) || parseFloat(value) < config.min)) {
            isValid = false;
            errorMsg = config.msg;
        } else if (config.type === 'email' && value !== '' && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value)) {
            isValid = false;
            errorMsg = config.msg;
        } else if (config.type === 'coords' && value !== '' && (isNaN(value) || parseFloat(value) < config.min || parseFloat(value) > config.max)) {
            isValid = false;
            errorMsg = config.msg;
        }

        updateUI(field, isValid, errorMsg);
        return isValid;
    }

    function updateUI(field, isValid, msg) {
        const container = field.closest('.group'); // Changed to .group to target the correct parent for error display
        if (!container) return;
        let errorEl = container.querySelector('.js-error');
        
        if (!isValid) {
            field.classList.add('border-red-500', 'ring-red-500/20');
            field.classList.remove('border-slate-200', 'dark:border-slate-700'); // Removed specific border classes to avoid conflicts
            if (!errorEl) {
                errorEl = document.createElement('p');
                errorEl.className = 'js-error mt-1 text-sm text-red-500'; // Adjusted class for consistency
                container.appendChild(errorEl);
            }
            errorEl.textContent = msg;
        } else {
            field.classList.remove('border-red-500', 'ring-red-500/20');
            field.classList.add('border-slate-200', 'dark:border-slate-700'); // Re-added original border classes
            if (errorEl) errorEl.remove();
        }
    }

    Object.keys(fields).forEach(key => {
        const config = fields[key];
        if (config.el) {
            ['input', 'blur'].forEach(evt => {
                config.el.addEventListener(evt, () => validateField(key, config));
            });
        }
    });

    form.addEventListener('submit', function(e) {
        let isFormValid = true;
        try {
            Object.keys(fields).forEach(key => {
                // Validate all fields and ensure isFormValid remains false if any validation fails
                if (!validateField(key, fields[key])) {
                    isFormValid = false;
                }
            });
        } catch (validationError) {
            console.error('Validation error:', validationError);
            // Do not block submit if front-end validation crashes.
            return;
        }

        if (!isFormValid) {
            e.preventDefault();
            const firstError = form.querySelector('.js-error');
            if (firstError) firstError.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
    });
});
</script>
