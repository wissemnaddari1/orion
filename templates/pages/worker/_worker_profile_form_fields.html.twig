    {# Section: Contact & Location - phone, email above location and map #}
    <div class="group space-y-6 pt-8 p-6 rounded-2xl bg-slate-50/50 dark:bg-slate-800/30 border border-slate-100 dark:border-slate-700/50 shadow-sm" style="order: 3;">
        <h3 class="text-xs font-semibold text-[#0FAF7A] dark:text-[#0FAF7A] uppercase tracking-wider mb-4 flex items-center gap-2">
            <span class="w-1 h-4 rounded-full bg-[#0FAF7A]"></span>
            Contact & Location
        </h3>
            <div class="relative space-y-6">
