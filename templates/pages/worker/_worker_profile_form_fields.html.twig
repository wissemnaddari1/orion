                {# Location input #}
                <div class="group">
                    <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">Location</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                            <svg class="w-5 h-5 text-slate-400 group-focus-within:text-[#0FAF7A] transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                        </div>
                        {{ form_widget(form.location, {'attr': {'class': 'block w-full bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-700 rounded-xl pl-11 pr-4 py-3 text-slate-900 dark:text-slate-200 placeholder-slate-500 shadow-sm focus:ring-2 focus:ring-[#0FAF7A]/30 focus:border-[#0FAF7A] transition-all duration-200', 'placeholder': 'e.g. Paris, London...'}}) }}
                    </div>
                    {{ form_errors(form.location, {'attr': {'class': 'mt-1 text-sm text-red-500'}}) }}
                </div>

                {# Map Container #}
                <div class="group">
                    <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">Map</label>
                    <div id="map" class="h-72 w-full rounded-2xl border border-slate-200 dark:border-slate-700 overflow-hidden shadow-md ring-1 ring-slate-200/50 dark:ring-slate-700/50 z-0"></div>
                </div>

                {# Leaflet Assets #}
                <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin=""/>
                <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>

                <script>
                    function initMap() {
                        const locInput = document.getElementById('{{ form.location.vars.id }}');
                        const mapEl = document.getElementById('map');
                        if (!locInput || !mapEl || typeof L === 'undefined') {
                            return;
                        }
                        if (mapEl.dataset.initialized === '1') {
                            return;
                        }
                        mapEl.dataset.initialized = '1';

                        const defaultLat = 48.8566;
                        const defaultLng = 2.3522;

                        const map = L.map('map').setView([defaultLat, defaultLng], 5);
                        window.leafletMap = map;

                        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                            attribution: '© OpenStreetMap contributors'
                        }).addTo(map);

                        let marker = null;

                        const placeMarker = (lat, lng, zoom = 13) => {
                            if (marker) {
                                marker.setLatLng([lat, lng]);
                            } else {
                                marker = L.marker([lat, lng]).addTo(map);
                            }
                            window.leafletMarker = marker;
                            map.setView([lat, lng], zoom);
                        };

                        const geocode = async (text) => {
                            if (!text || !text.trim()) return;
                            try {
                                const res = await fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(text)}`);
                                const data = await res.json();
                                if (Array.isArray(data) && data.length > 0) {
                                    placeMarker(parseFloat(data[0].lat), parseFloat(data[0].lon));
                                }
                            } catch (e) {
                                console.error('Geocoding error:', e);
                            }
                        };

                        map.on('click', function(e) {
                            const lat = e.latlng.lat;
                            const lng = e.latlng.lng;
                            placeMarker(lat, lng);

                            fetch(`https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lng}`)
                                .then(response => response.json())
                                .then(data => {
                                    if (data.display_name) {
                                        locInput.value = data.display_name;
                                        locInput.dispatchEvent(new Event('input', { bubbles: true }));
                                        locInput.dispatchEvent(new Event('change', { bubbles: true }));
                                    }
                                })
                                .catch(err => console.error('Reverse geocoding error:', err));
                        });

                        locInput.addEventListener('change', () => geocode(locInput.value));
                        locInput.addEventListener('blur', () => geocode(locInput.value));

                        if (locInput.value && locInput.value.trim() !== '') {
                            geocode(locInput.value);
                        }
                    }
                    document.addEventListener('DOMContentLoaded', initMap);
                    document.addEventListener('turbo:load', initMap);
                </script>
            </div>
        </div>

        {% if is_granted('ROLE_ADMIN') %}
        <div class="pt-8 mt-8 p-6 rounded-2xl bg-slate-50/50 dark:bg-slate-800/30 border border-slate-100 dark:border-slate-700/50">
            <h3 class="text-xs font-semibold text-[#0FAF7A] dark:text-[#0FAF7A] uppercase tracking-wider mb-4 flex items-center gap-2">
