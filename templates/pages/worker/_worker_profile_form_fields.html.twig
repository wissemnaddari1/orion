                                <svg class="w-5 h-5 text-slate-400 group-focus-within:text-[#0FAF7A] transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                            </div>
                            {{ form_widget(form.email, {'attr': {'class': 'block w-full bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-700 rounded-xl pl-11 pr-4 py-3 text-slate-900 dark:text-slate-200 shadow-sm focus:ring-2 focus:ring-[#0FAF7A]/30 focus:border-[#0FAF7A] transition-all duration-200', 'placeholder': 'name@example.com'}}) }}
                        </div>
                        {{ form_errors(form.email, {'attr': {'class': 'mt-1 text-sm text-red-500'}}) }}
