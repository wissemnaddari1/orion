{% extends 'layout_app.html.twig' %}

{% block main %}
    {% set statusColors = {
        'DRAFT': 'bg-slate-100 text-slate-700 border border-slate-200 dark:bg-slate-700 dark:text-slate-300 dark:border-slate-600',
        'PENDING_SIGN': 'bg-amber-100 text-amber-800 border border-amber-200 dark:bg-amber-900/30 dark:text-amber-400 dark:border-amber-700',
        'ACTIVE': 'bg-emerald-100 text-emerald-800 border border-emerald-200 dark:bg-emerald-900/30 dark:text-emerald-400 dark:border-emerald-700',
        'IN_PROGRESS': 'bg-blue-100 text-blue-800 border border-blue-200 dark:bg-blue-900/30 dark:text-blue-400 dark:border-blue-700',
        'COMPLETED': 'bg-indigo-100 text-indigo-800 border border-indigo-200 dark:bg-indigo-900/30 dark:text-indigo-400 dark:border-indigo-700',
        'CANCELLED': 'bg-red-100 text-red-800 border border-red-200 dark:bg-red-900/30 dark:text-red-400 dark:border-red-700',
        'DISPUTED': 'bg-orange-100 text-orange-800 border border-orange-200 dark:bg-orange-900/30 dark:text-orange-400 dark:border-orange-700'

    } %}
    {% set statusLabels = {
        'DRAFT': 'Draft',
        'PENDING_SIGN': 'Pending Sign',
        'ACTIVE': 'Active',
        'IN_PROGRESS': 'In Progress',
        'COMPLETED': 'Completed',
        'CANCELLED': 'Cancelled',
        'DISPUTED': 'Disputed'
    } %}
    {% set milestoneStatusColors = {
        'PENDING': 'bg-slate-100 text-slate-700 border border-slate-200 dark:bg-slate-700 dark:text-slate-300 dark:border-slate-600',
        'IN_PROGRESS': 'bg-blue-100 text-blue-800 border border-blue-200 dark:bg-blue-900/30 dark:text-blue-400 dark:border-blue-700',
        'DELIVERED': 'bg-cyan-100 text-cyan-800 border border-cyan-200 dark:bg-cyan-900/30 dark:text-cyan-300 dark:border-cyan-700',
        'REVISION_REQUESTED': 'bg-amber-100 text-amber-800 border border-amber-200 dark:bg-amber-900/30 dark:text-amber-300 dark:border-amber-700',
        'COMPLETED': 'bg-emerald-100 text-emerald-800 border border-emerald-200 dark:bg-emerald-900/30 dark:text-emerald-400 dark:border-emerald-700',
        'CANCELLED': 'bg-red-100 text-red-800 border border-red-200 dark:bg-red-900/30 dark:text-red-400 dark:border-red-700'
    } %}

    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-6 space-y-6">
        {% for message in app.flashes('success') %}
            <div class="rounded-lg border px-4 py-3 text-sm font-medium bg-emerald-50 text-emerald-800 border-emerald-200 dark:bg-emerald-900/20 dark:text-emerald-400 dark:border-emerald-800">

                {{ message }}
            </div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="rounded-lg border px-4 py-3 text-sm font-medium bg-red-50 text-red-800 border-red-200 dark:bg-red-900/20 dark:text-red-400 dark:border-red-800">
                {{ message }}
            </div>
        {% endfor %}
        {% for message in app.flashes('info') %}
            <div class="rounded-lg border px-4 py-3 text-sm font-medium bg-blue-50 text-blue-800 border-blue-200 dark:bg-blue-900/20 dark:text-blue-400 dark:border-blue-800">

                {{ message }}
            </div>
        {% endfor %}

        {# Header #}
        <div class="flex flex-wrap items-start justify-between gap-4">
            <div>
                <a href="{{ path('worker_contracts_list') }}" class="inline-flex items-center gap-1 text-sm font-medium text-slate-500 dark:text-slate-400 hover:text-slate-700 dark:hover:text-slate-200 transition"><svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg><span>Back to contracts</span></a>
                <div class="mt-2 flex items-center gap-3">
                    <div>
                        <h1 class="text-2xl font-bold text-slate-900 dark:text-white">{{ contract.title }}</h1>
                        <p class="text-sm text-slate-500 dark:text-slate-400 mt-0.5">Contract #{{ contract.id }}</p>
                    </div>
                    <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold {{ statusColors[contract.status] ?? 'bg-slate-600/30 text-slate-300 border border-slate-500/40' }}">

                        {{ statusLabels[contract.status] ?? contract.status }}
                    </span>
                </div>
            </div>
        </div>

        <div class="grid gap-6 lg:grid-cols-3">
            {# ===== Main Content (2 cols) ===== #}
            <div class="lg:col-span-2 space-y-6">
                {# Contract Details Card #}
                <div class="rounded-xl border border-slate-200 dark:border-slate-700/60 bg-white dark:bg-slate-900/40 p-6 shadow-lg backdrop-blur">
                    <div class="flex items-center justify-between mb-4">
                        <h2 class="text-lg font-semibold text-slate-900 dark:text-white">Contract Details</h2>
                        <span class="text-xs text-slate-500 dark:text-slate-400">Created {{ contract.createdAt|date('M d, Y \\a\\t H:i') }}</span>
                    </div>
                    <dl class="grid gap-x-6 gap-y-4 sm:grid-cols-2">
                        <div>
                            <dt class="text-xs font-medium uppercase tracking-wider text-slate-500 dark:text-slate-400">Title</dt>
                            <dd class="mt-1 text-sm font-semibold text-slate-900 dark:text-white">{{ contract.title }}</dd>
                        </div>
                        <div>
                            <dt class="text-xs font-medium uppercase tracking-wider text-slate-500 dark:text-slate-400">Client</dt>
                            <dd class="mt-1 text-sm font-semibold text-slate-900 dark:text-white">{{ contract.client.fullName ?? 'N/A' }}</dd>
                            <dd class="text-xs text-slate-500 dark:text-slate-400">{{ contract.client.email ?? '' }}</dd>
                        </div>
                        <div>
                            <dt class="text-xs font-medium uppercase tracking-wider text-slate-500 dark:text-slate-400">Worker (You)</dt>
                            <dd class="mt-1 text-sm font-semibold text-emerald-700 dark:text-emerald-300">{{ contract.worker.fullName ?? 'N/A' }}</dd>
                            <dd class="text-xs text-slate-500 dark:text-slate-400">{{ contract.worker.email ?? '' }}</dd>
                        </div>
                        <div>
                            <dt class="text-xs font-medium uppercase tracking-wider text-slate-500 dark:text-slate-400">Agreed Price</dt>
                            <dd class="mt-1 text-xl font-bold text-[#0FAF7A]">{{ contract.agreedPrice|number_format(2, '.', ',') }} {{ contract.currency }}</dd>
                        </div>
                        <div>
                            <dt class="text-xs font-medium uppercase tracking-wider text-slate-500 dark:text-slate-400">Start Date</dt>
                            <dd class="mt-1 text-sm font-semibold text-slate-900 dark:text-white">{{ contract.startDate ? contract.startDate|date('F j, Y') : 'N/A' }}</dd>
                        </div>
                        <div>
                            <dt class="text-xs font-medium uppercase tracking-wider text-slate-500 dark:text-slate-400">End Date</dt>
                            <dd class="mt-1 text-sm font-semibold text-slate-900 dark:text-white">{{ contract.endDate ? contract.endDate|date('F j, Y') : 'N/A' }}</dd>
                        </div>
                        {% if contract.updatedAt %}
                        <div class="sm:col-span-2">
                            <dt class="text-xs font-medium uppercase tracking-wider text-slate-500 dark:text-slate-400">Last Updated</dt>
                            <dd class="mt-1 text-sm text-slate-600 dark:text-slate-300">{{ contract.updatedAt|date('F j, Y \\a\\t g:i A') }}</dd>
                        </div>
                        {% endif %}
                        {% if contract.riskLevel is not null %}
                        <div class="sm:col-span-2">
                            <dt class="text-xs font-medium uppercase tracking-wider text-slate-400">AI Risk Assessment</dt>
                            <dd class="mt-2 flex items-center gap-3">
                                <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-bold
                                    {% if contract.riskLevel == 'LOW' %}bg-emerald-100 text-emerald-700 dark:bg-emerald-500/20 dark:text-emerald-400
                                    {% elseif contract.riskLevel == 'MEDIUM' %}bg-amber-100 text-amber-700 dark:bg-amber-500/20 dark:text-amber-400
                                    {% else %}bg-red-100 text-red-700 dark:bg-red-500/20 dark:text-red-400{% endif %}">
                                    <span class="w-2 h-2 rounded-full
                                        {% if contract.riskLevel == 'LOW' %}bg-emerald-500 dark:bg-emerald-400
                                        {% elseif contract.riskLevel == 'MEDIUM' %}bg-amber-500 dark:bg-amber-400
                                        {% else %}bg-red-500 dark:bg-red-400{% endif %}"></span>
                                    {{ contract.riskLevel }}
                                </span>
                                {% if contract.riskScore is not null %}
                                <span class="text-xs text-slate-400">Score: {{ (contract.riskScore * 100)|number_format(1) }}%</span>
                                {% endif %}
                            </dd>
                        </div>
                        {% endif %}
                    </dl>
                </div>

                {# Scope of Work #}
                <div class="rounded-xl border border-slate-200 dark:border-slate-700/60 bg-white dark:bg-slate-900/40 p-6 shadow-lg backdrop-blur">
                    <h2 class="text-lg font-semibold text-slate-900 dark:text-white mb-3">Scope of Work</h2>
                    <div class="prose prose-sm prose-slate dark:prose-invert max-w-none text-slate-700 dark:text-slate-300">{{ contract.scope|nl2br }}</div>
                </div>

                {# Electronic Signatures #}
                <div class="rounded-xl border border-slate-200 dark:border-slate-700/60 bg-white dark:bg-slate-900/40 p-6 shadow-lg backdrop-blur">
                    <h2 class="text-lg font-semibold text-slate-900 dark:text-white mb-4">Electronic Signatures</h2>
                    <div class="grid gap-6 sm:grid-cols-2">
                        {# Client Signature #}
                        <div class="rounded-lg border {{ contract.clientSigned ? 'border-emerald-200 bg-emerald-50/50 dark:border-emerald-800 dark:bg-emerald-900/10' : 'border-gray-200 bg-slate-50 dark:border-slate-700 dark:bg-slate-800/50' }} p-4">
                            <div class="flex items-center gap-2 mb-2">
                                {% if contract.clientSigned %}
                                    <svg class="w-5 h-5 text-[#0FAF7A]" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                                {% else %}
                                    <svg class="w-5 h-5 text-slate-400" fill="currentColor" viewBox="0 0 20 20">
                                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
                                    </svg>
                                {% endif %}
                                <h3 class="text-sm font-semibold text-slate-900 dark:text-white">Client Signature</h3>
                            </div>
                            {% if contract.clientSigned %}
                                <p class="text-xs text-slate-600 dark:text-slate-300">Signed on {{ contract.clientSignedAt|date('F j, Y \\a\\t g:i A') }}</p>
                                {% if contract.clientSignatureIp %}<p class="text-xs text-slate-500 dark:text-slate-400 mt-1">IP: {{ contract.clientSignatureIp }}</p>{% endif %}
                            {% else %}
                                <p class="text-xs text-slate-500 dark:text-slate-400">Not yet signed</p>
                            {% endif %}
                        </div>
                        {# Worker Signature #}
                        <div class="rounded-lg border {{ contract.workerSigned ? 'border-emerald-200 bg-emerald-50/50 dark:border-emerald-800 dark:bg-emerald-900/10' : 'border-gray-200 bg-slate-50 dark:border-slate-700 dark:bg-slate-800/50' }} p-4">
                            <div class="flex items-center gap-2 mb-2">
                                {% if contract.workerSigned %}
                                    <svg class="w-5 h-5 text-[#0FAF7A]" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                                {% else %}
                                    <svg class="w-5 h-5 text-slate-400" fill="currentColor" viewBox="0 0 20 20">
                                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
                                    </svg>
                                {% endif %}
                                <h3 class="text-sm font-semibold text-slate-900 dark:text-white">Worker Signature (You)</h3>
                            </div>
                            {% if contract.workerSigned %}
                                <p class="text-xs text-slate-600 dark:text-slate-300">Signed on {{ contract.workerSignedAt|date('F j, Y \\a\\t g:i A') }}</p>
                                {% if contract.workerSignatureIp %}<p class="text-xs text-slate-500 dark:text-slate-400 mt-1">IP: {{ contract.workerSignatureIp }}</p>{% endif %}
                            {% else %}
                                <p class="text-xs text-slate-500 dark:text-slate-400">Not yet signed</p>

                            {% endif %}
                        </div>
                    </div>
                </div>

                {# Funding Status #}
                <div class="rounded-xl border border-slate-200 dark:border-slate-700/60 bg-white dark:bg-slate-900/40 p-6 shadow-lg backdrop-blur">
                    <h2 class="text-lg font-semibold text-slate-900 dark:text-white mb-4">Funding Status</h2>
                    <dl class="grid gap-4 sm:grid-cols-2 text-sm">
                        <div>
                            <dt class="text-slate-500 dark:text-slate-400">Upfront ({{ contract.upfrontPercent|number_format(2) }}%)</dt>
                            <dd class="mt-1 font-semibold text-slate-900 dark:text-slate-100">{{ contract.upfrontAmount|number_format(2, '.', ',') }} {{ contract.currency }}</dd>
                        </div>
                        <div>
                            <dt class="text-slate-500 dark:text-slate-400">Upfront funded</dt>
                            <dd class="mt-1 font-semibold {{ contract.upfrontPaid ? 'text-emerald-600 dark:text-emerald-400' : 'text-amber-600 dark:text-amber-400' }}">
                                {{ contract.upfrontPaid ? 'Yes' : 'Pending' }}
                            </dd>
                        </div>
                        <div>
                            <dt class="text-slate-500 dark:text-slate-400">Released to worker</dt>
                            <dd class="mt-1 font-semibold text-slate-900 dark:text-slate-100">{{ contract.releasedAmount|number_format(2, '.', ',') }} {{ contract.currency }}</dd>
                        </div>
                        <div>
                            <dt class="text-slate-500 dark:text-slate-400">Remaining</dt>
                            <dd class="mt-1 font-semibold text-slate-900 dark:text-slate-100">{{ contract.remainingAmount|number_format(2, '.', ',') }} {{ contract.currency }}</dd>
                        </div>
                    </dl>
                    {% if not contract.upfrontPaid %}
                        <p class="mt-3 text-xs text-amber-700 dark:text-amber-300">Milestone delivery is blocked until the client funds the upfront amount.</p>
                    {% endif %}
                </div>

                {# Milestones #}
                <div class="rounded-xl border border-slate-200 dark:border-slate-700/60 bg-white dark:bg-slate-900/40 p-6 shadow-lg backdrop-blur">
                    <div class="flex items-center justify-between mb-4">
                        <h2 class="text-lg font-semibold text-slate-900 dark:text-white">Milestones</h2>
                        <a href="{{ path('worker_milestone_new', {id: contract.id}) }}" class="inline-flex items-center gap-1 text-sm font-semibold text-[#0FAF7A] hover:text-emerald-300">+ Add Milestone</a>
                    </div>

                    {% if contract.milestones is empty %}
                        <div class="text-center py-8 text-slate-500 dark:text-slate-400">
                            <p class="text-sm">No milestones defined yet</p>
                            <a href="{{ path('worker_milestone_new', {id: contract.id}) }}" class="mt-3 inline-flex items-center gap-2 rounded-lg bg-[#0FAF7A] px-4 py-2 text-sm font-semibold text-white transition hover:bg-emerald-500">Create First Milestone</a>

                        </div>
                    {% else %}
                        <div class="space-y-4">
                            {% for milestone in contract.milestones %}
                                <div class="border border-gray-200 bg-white rounded-lg p-4 hover:bg-slate-50 dark:border-slate-700 dark:bg-slate-800/40 dark:hover:bg-slate-800/60 transition">
                                    <div class="flex items-start justify-between gap-3 mb-2">
                                        <div class="flex-1">
                                            <div class="flex items-center gap-2 mb-1">
                                                <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-slate-100 text-xs font-semibold text-slate-700 dark:bg-slate-700 dark:text-slate-200">{{ milestone.orderIndex }}</span>
                                                <h3 class="font-semibold text-slate-900 dark:text-slate-100">{{ milestone.title }}</h3>
                                            </div>
                                            {% if milestone.description %}<p class="text-sm text-slate-700 dark:text-slate-300 mt-1 ml-8">{{ milestone.description }}</p>{% endif %}
                                        </div>
                                        <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold {{ milestoneStatusColors[milestone.status] ?? 'bg-slate-100 text-slate-700 border border-slate-200 dark:bg-slate-700 dark:text-slate-300 dark:border-slate-600' }}">
                                            {{ milestone.status|replace({'_': ' '}) }}
                                        </span>
                                    </div>
                                    <div class="flex flex-wrap items-center gap-4 text-sm text-slate-700 dark:text-slate-300 mt-3 ml-8">
                                        <span>Due: {{ milestone.dueDate|date('M j, Y') }}</span>
                                        {% if milestone.amount is not null %}<span>Amount: {{ milestone.amount|number_format(2, '.', ',') }} {{ contract.currency }}</span>{% endif %}
                                        {% if milestone.isOverdue() %}<span class="text-red-500 dark:text-red-400 font-semibold text-xs">Overdue</span>{% endif %}
                                        {% if milestone.deliveredAt %}
                                            <span>Delivered: {{ milestone.deliveredAt|date('M j, Y H:i') }}</span>
                                        {% endif %}
                                    </div>
                                    <div class="flex gap-3 mt-3 pt-3 border-t border-slate-200 dark:border-slate-700 ml-8">
                                        {% if contract.upfrontPaid and contract.status in ['ACTIVE', 'IN_PROGRESS'] and milestone.status in ['PENDING', 'IN_PROGRESS', 'REVISION_REQUESTED'] %}
                                            <form method="POST" action="{{ path('worker_milestone_deliver', {contractId: contract.id, milestoneId: milestone.id}) }}" class="inline" onsubmit="return confirm('Deliver this milestone to client review?');">
                                                <input type="hidden" name="_token" value="{{ csrf_token('milestone_deliver_' ~ milestone.id) }}">
                                                <button type="submit" class="text-xs font-semibold text-cyan-700 hover:text-cyan-600 dark:text-cyan-300 dark:hover:text-cyan-200">Deliver</button>
                                            </form>
                                        {% endif %}
                                        <a href="{{ path('worker_milestone_edit', {contractId: contract.id, milestoneId: milestone.id}) }}" class="text-xs font-semibold text-[#0FAF7A] hover:text-emerald-600 dark:hover:text-emerald-300">Edit</a>
                                        <form method="POST" action="{{ path('worker_milestone_delete', {contractId: contract.id, milestoneId: milestone.id}) }}" class="inline" onsubmit="return confirm('Delete this milestone?');">
                                            <input type="hidden" name="_token" value="{{ csrf_token('milestone_delete_' ~ milestone.id) }}">
                                            <button type="submit" class="text-xs font-semibold text-red-600 hover:text-red-500 dark:text-red-400 dark:hover:text-red-300">Delete</button>

                                        </form>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>

                        <div class="mt-6 pt-6 border-t border-slate-200 dark:border-slate-700">
                            <div class="flex items-center justify-between mb-2">
                                <span class="text-sm font-medium text-slate-600 dark:text-slate-300">Overall Progress</span>
                                <span class="text-sm font-semibold text-[#0FAF7A]">{{ contract.getProgressPercent() }}%</span>
                            </div>
                            <div class="w-full bg-gray-200 dark:bg-slate-700 rounded-full h-3">
                                <div class="bg-[#0FAF7A] h-3 rounded-full transition-all duration-300" style="width: {{ contract.getProgressPercent() }}%"></div>
                            </div>
                            <p class="text-xs text-slate-500 dark:text-slate-400 mt-2">{{ contract.getCompletedMilestonesCount() }} of {{ contract.milestones|length }} milestones completed</p>

                        </div>
                    {% endif %}
                </div>
            </div>

            {# ===== Sidebar (1 col) ===== #}
            <div class="space-y-6">
                {# Actions Card #}
                <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-lg dark:border-slate-700/60 dark:bg-slate-900/40 backdrop-blur sticky top-6">
                    <h2 class="text-lg font-semibold text-slate-900 dark:text-slate-100 mb-4">Actions</h2>
                    <div class="space-y-3">
                        <a href="{{ path('worker_contract_pdf', {id: contract.id}) }}" target="_blank" class="w-full inline-flex items-center justify-center gap-2 rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-sm font-semibold text-slate-700 transition hover:bg-slate-50 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-200 dark:hover:bg-slate-700">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                            Download PDF
                        </a>


                        {% if contract.canBeSigned() and not contract.workerSigned %}
                            <a href="{{ path('worker_contract_sign', {id: contract.id}) }}" class="w-full inline-flex items-center justify-center gap-2 rounded-lg bg-blue-600 px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-blue-500">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>

                                Sign Contract
                            </a>
                        {% endif %}

                        {% if contract.status in ['ACTIVE', 'IN_PROGRESS'] and not contract.upfrontPaid %}
                            <div class="rounded-lg border border-amber-200 bg-amber-50 px-3 py-2 text-xs text-amber-700 dark:border-amber-700 dark:bg-amber-900/20 dark:text-amber-300">
                                Waiting for client upfront funding before milestone delivery.
                            </div>
                        {% endif %}

                        <a href="{{ path('worker_milestone_new', {id: contract.id}) }}" class="w-full inline-flex items-center justify-center gap-2 rounded-lg border border-emerald-300 bg-emerald-50 px-4 py-2.5 text-sm font-semibold text-emerald-700 transition hover:bg-emerald-100 dark:border-emerald-500/40 dark:bg-emerald-500/10 dark:text-emerald-300 dark:hover:bg-emerald-500/20">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                            Add Milestone
                        </a>

                    </div>
                </div>

                {# Quick Info Card #}
                <div class="rounded-xl border border-slate-200 dark:border-slate-700/60 bg-white dark:bg-slate-900/40 p-6 shadow-lg backdrop-blur">
                    <h3 class="text-sm font-semibold text-slate-900 dark:text-white mb-3">Quick Info</h3>
                    <dl class="space-y-2.5 text-sm">
                        <div class="flex justify-between">
                            <dt class="text-slate-500 dark:text-slate-400">Fully Signed</dt>
                            <dd class="font-medium {{ contract.isFullySigned() ? 'text-[#0FAF7A]' : 'text-slate-600 dark:text-slate-300' }}">
                                {{ contract.isFullySigned() ? 'Yes' : 'No' }}
                            </dd>
                        </div>
                        <div class="flex justify-between">
                            <dt class="text-slate-500 dark:text-slate-400">Editable</dt>
                            <dd class="font-medium text-slate-600 dark:text-slate-300">{{ contract.canBeEdited() ? 'Yes' : 'No' }}</dd>
                        </div>
                        <div class="flex justify-between">
                            <dt class="text-slate-500 dark:text-slate-400">Can Sign</dt>
                            <dd class="font-medium text-slate-600 dark:text-slate-300">{{ contract.canBeSigned() ? 'Yes' : 'No' }}</dd>
                        </div>
                        <div class="flex justify-between">
                            <dt class="text-slate-500 dark:text-slate-400">Can Cancel</dt>
                            <dd class="font-medium text-slate-600 dark:text-slate-300">{{ contract.canBeCancelled() ? 'Yes' : 'No' }}</dd>
                        </div>
                        <div class="flex justify-between">
                            <dt class="text-slate-500 dark:text-slate-400">Progress</dt>
                            <dd class="font-medium text-slate-600 dark:text-slate-300">{{ contract.getProgressPercent() }}%</dd>
                        </div>
                        <div class="flex justify-between">
                            <dt class="text-slate-500 dark:text-slate-400">Milestones</dt>
                            <dd class="font-medium text-slate-600 dark:text-slate-300">{{ contract.milestones|length }}</dd>
                        </div>
                        <div class="flex justify-between">
                            <dt class="text-slate-500 dark:text-slate-400">Currency</dt>
                            <dd class="font-medium text-slate-600 dark:text-slate-300">{{ contract.currency }}</dd>
                        </div>
                        <div class="flex justify-between">
                            <dt class="text-slate-500 dark:text-slate-400">Upfront funded</dt>
                            <dd class="font-medium {{ contract.upfrontPaid ? 'text-emerald-600 dark:text-emerald-400' : 'text-amber-600 dark:text-amber-400' }}">
                                {{ contract.upfrontPaid ? 'Yes' : 'No' }}
                            </dd>
                        </div>
                    </dl>
                </div>

            </div>
        </div>
    </div>
{% endblock %}
