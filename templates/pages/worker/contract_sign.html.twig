{% extends 'layout_app.html.twig' %}
{% block main %}
    <div class="max-w-3xl mx-auto space-y-6">
        <div class="flex items-center gap-3">
            <a href="{{ path('worker_contract_show', {id: contract.id}) }}" 
               class="text-gray-500 hover:text-gray-700 dark:text-slate-400 dark:hover:text-slate-200 transition">
                ← Back to contract
            </a>
        </div>

        <h1 class="text-2xl font-bold text-slate-900 dark:text-white">Sign Contract</h1>
        <p class="text-sm text-slate-500 dark:text-slate-400">{{ contract.title ?? 'Contract #' ~ contract.id }}</p>

        {# Contract Summary #}
        <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900">
            <h2 class="text-lg font-semibold text-slate-900 dark:text-white mb-4">Contract Summary</h2>
            <dl class="grid gap-4 sm:grid-cols-2 text-sm">
                <div>
                    <dt class="font-medium text-slate-500 dark:text-slate-400">Client</dt>
                    <dd class="mt-1 text-slate-900 dark:text-white">{{ contract.client.firstName ~ ' ' ~ contract.client.lastName }}</dd>
                </div>
                <div>
                    <dt class="font-medium text-slate-500 dark:text-slate-400">Agreed Price</dt>
                    <dd class="mt-1 text-slate-900 dark:text-white font-semibold">${{ contract.agreedPrice|number_format(2) }} {{ contract.currency }}</dd>
                </div>
                <div>
                    <dt class="font-medium text-slate-500 dark:text-slate-400">Period</dt>
                    <dd class="mt-1 text-slate-900 dark:text-white">{{ contract.startDate|date('M d, Y') }} — {{ contract.endDate|date('M d, Y') }}</dd>
                </div>
                <div>
                    <dt class="font-medium text-slate-500 dark:text-slate-400">Milestones</dt>
                    <dd class="mt-1 text-slate-900 dark:text-white">{{ contract.milestones|length }}</dd>
                </div>
                <div class="sm:col-span-2">
                    <dt class="font-medium text-slate-500 dark:text-slate-400">Scope of Work</dt>
                    <dd class="mt-1 text-slate-700 dark:text-slate-300 whitespace-pre-line text-sm max-h-32 overflow-y-auto">{{ contract.scope }}</dd>
                </div>
            </dl>
        </div>

        {# Signature Status #}
        <div class="rounded-xl border border-amber-200 bg-amber-50 p-4 dark:border-amber-800 dark:bg-amber-900/20">
            <div class="flex items-center gap-2">
                <svg class="w-5 h-5 text-amber-600 dark:text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/>
                </svg>
                <p class="text-sm font-medium text-amber-800 dark:text-amber-300">
                    By signing below, you agree to fulfil this contract's scope. This action cannot be undone.
                </p>
            </div>
            <div class="mt-2 flex items-center gap-4 text-xs text-amber-700 dark:text-amber-400">
                <span>Client: {{ contract.clientSigned ? '✓ Signed' : '✗ Not signed' }}</span>
                <span>Worker: You are about to sign</span>
            </div>
        </div>

        {# Signature Pad #}
        <form method="POST" action="{{ path('worker_contract_sign_submit', {id: contract.id}) }}" id="signForm">
            <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900">
                <h2 class="text-lg font-semibold text-slate-900 dark:text-white mb-4">Draw Your Signature</h2>
                <div id="canvasWrapper" class="border-2 border-dashed border-gray-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-800 relative overflow-hidden" style="height: 200px;">
                    <canvas id="signatureCanvas" class="absolute inset-0 rounded-lg cursor-crosshair" style="touch-action: none; width: 100%; height: 100%;"></canvas>
                    <div id="signaturePlaceholder" class="absolute inset-0 flex items-center justify-center pointer-events-none text-slate-400 dark:text-slate-500">
                        Sign here...
                    </div>
                </div>
                <input type="hidden" name="signature_data" id="signatureData">
                <div class="flex items-center justify-between mt-4">
                    <button type="button" id="clearBtn" class="text-sm text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-200">
                        Clear Signature
                    </button>
                    <p class="text-xs text-slate-400 dark:text-slate-500">Your IP address will be recorded</p>
                </div>
            </div>

            <div class="flex gap-3 mt-6">
                <button type="submit" id="submitBtn" disabled
                        class="inline-flex items-center gap-2 rounded-lg bg-emerald-600 px-6 py-2.5 text-sm font-semibold text-white transition hover:bg-emerald-700 disabled:opacity-50 disabled:cursor-not-allowed">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    Confirm &amp; Sign Contract
                </button>
                <a href="{{ path('worker_contract_show', {id: contract.id}) }}" 
                   class="inline-flex items-center gap-2 rounded-lg border border-gray-300 bg-white px-6 py-2.5 text-sm font-semibold text-gray-700 transition hover:bg-gray-50 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-300 dark:hover:bg-slate-700">
                    Cancel
                </a>
            </div>
        </form>
    </div>

    <script>
    (function() {
        var canvas = document.getElementById('signatureCanvas');
        var ctx = canvas.getContext('2d');
        var placeholder = document.getElementById('signaturePlaceholder');
        var hiddenInput = document.getElementById('signatureData');
        var submitBtn = document.getElementById('submitBtn');
        var clearBtn = document.getElementById('clearBtn');
        var form = document.getElementById('signForm');
        var drawing = false;
        var signed = false;

        function initCanvas() {
            var w = canvas.offsetWidth;
            var h = canvas.offsetHeight;
            canvas.width = w;
            canvas.height = h;
            ctx.strokeStyle = document.documentElement.classList.contains('dark') ? '#e2e8f0' : '#1e293b';
            ctx.lineWidth = 2.5;
            ctx.lineCap = 'round';
            ctx.lineJoin = 'round';
        }

        // Wait for layout to settle
        setTimeout(initCanvas, 50);

        function getXY(e) {
            var rect = canvas.getBoundingClientRect();
            if (e.touches && e.touches.length > 0) {
                return { x: e.touches[0].clientX - rect.left, y: e.touches[0].clientY - rect.top };
            }
            return { x: e.clientX - rect.left, y: e.clientY - rect.top };
        }

        function onDown(e) {
            e.preventDefault();
            drawing = true;
            var p = getXY(e);
            ctx.beginPath();
            ctx.moveTo(p.x, p.y);
        }

        function onMove(e) {
            if (!drawing) return;
            e.preventDefault();
            var p = getXY(e);
            ctx.lineTo(p.x, p.y);
            ctx.stroke();
            if (!signed) {
                signed = true;
                placeholder.style.display = 'none';
                submitBtn.disabled = false;
            }
        }

        function onUp() {
            if (!drawing) return;
            drawing = false;
            hiddenInput.value = canvas.toDataURL('image/png');
        }

        // Mouse
        canvas.addEventListener('mousedown', onDown);
        canvas.addEventListener('mousemove', onMove);
        canvas.addEventListener('mouseup', onUp);
        canvas.addEventListener('mouseleave', onUp);

        // Touch
        canvas.addEventListener('touchstart', onDown, { passive: false });
        canvas.addEventListener('touchmove', onMove, { passive: false });
        canvas.addEventListener('touchend', onUp);

        // Clear
        clearBtn.addEventListener('click', function() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            signed = false;
            hiddenInput.value = '';
            submitBtn.disabled = true;
            placeholder.style.display = 'flex';
        });

        // Submit guard
        form.addEventListener('submit', function(e) {
            if (!signed || !hiddenInput.value) {
                e.preventDefault();
                alert('Veuillez dessiner votre signature.');
            }
        });
    })();
    </script>
{% endblock %}
