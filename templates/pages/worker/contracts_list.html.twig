{% extends 'layout_app.html.twig' %}

{% block main %}
<div class="max-w-6xl mx-auto px-6 py-6">
    <div class="space-y-6">
        {# Flash Messages — dark theme #}
        {% for message in app.flashes('success') %}
            <div class="rounded-lg bg-emerald-500/20 border border-emerald-500/40 p-4 text-sm text-emerald-300">
                {{ message }}
            </div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="rounded-lg bg-red-500/20 border border-red-500/40 p-4 text-sm text-red-300">
                {{ message }}
            </div>
        {% endfor %}

        {# Header: title + Browse requests (contracts come from accepted offers) #}
        <div class="flex flex-wrap items-center justify-between gap-4">
            <h1 class="text-2xl font-bold text-slate-100 dark:text-white">My Contracts</h1>
            <a href="{{ path('worker_service_requests') }}"
               class="inline-flex items-center gap-2 rounded-lg bg-emerald-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-500 focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2 focus:ring-offset-slate-900">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                </svg>
                Browse Service Requests
            </a>
        </div>

        {# Dark dashboard card #}
        <div class="rounded-xl border border-slate-700/60 bg-slate-900/40 shadow-lg backdrop-blur overflow-hidden">
            {% if contracts is empty %}
                {# Empty state — centered, integrated with dashboard design #}
                <div class="flex flex-col items-center justify-center py-20 px-6 text-center">
                    <svg class="mx-auto h-14 w-14 text-slate-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                    </svg>
                    <h3 class="mt-4 text-lg font-semibold text-slate-200">No contracts yet</h3>
                    <p class="mt-2 max-w-sm text-sm text-slate-400">Contracts will appear here when clients create them with you or when you start from a service request.</p>
                    <a href="{{ path('worker_service_requests') }}" class="mt-6 inline-flex items-center gap-2 rounded-lg bg-slate-700 px-4 py-2.5 text-sm font-medium text-slate-200 transition hover:bg-slate-600 focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2 focus:ring-offset-slate-900">
                        Browse service requests
                    </a>
                </div>
            {% else %}
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-slate-700/50">
                        <thead class="bg-slate-800/60">
                            <tr>
                                <th class="px-6 py-3 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">Title</th>
                                <th class="px-6 py-3 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">Client</th>
                                <th class="px-6 py-3 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">Price</th>
                                <th class="px-6 py-3 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">Status</th>
                                <th class="px-6 py-3 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">Progress</th>
                                <th class="px-6 py-3 text-center text-xs font-semibold text-slate-400 uppercase tracking-wider">Signatures</th>
                                <th class="px-6 py-3 text-right text-xs font-semibold text-slate-400 uppercase tracking-wider">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-700/50 bg-slate-900/20">
                            {% for contract in contracts %}
                                {% set statusColors = {
                                    'DRAFT': 'bg-slate-600/40 text-slate-300 border border-slate-500/40',
                                    'PENDING_SIGN': 'bg-amber-500/20 text-amber-400 border-amber-500/40',
                                    'ACTIVE': 'bg-emerald-500/20 text-emerald-400 border-emerald-500/40',
                                    'IN_PROGRESS': 'bg-blue-500/20 text-blue-400 border-blue-500/40',
                                    'COMPLETED': 'bg-indigo-500/20 text-indigo-400 border-indigo-500/40',
                                    'CANCELLED': 'bg-red-500/20 text-red-400 border-red-500/40',
                                    'DISPUTED': 'bg-orange-500/20 text-orange-400 border-orange-500/40'
                                } %}
                                {% set statusLabels = {
                                    'DRAFT': 'Draft',
                                    'PENDING_SIGN': 'Pending Sign',
                                    'ACTIVE': 'Active',
                                    'IN_PROGRESS': 'In Progress',
                                    'COMPLETED': 'Completed',
                                    'CANCELLED': 'Cancelled',
                                    'DISPUTED': 'Disputed'
                                } %}
                                <tr class="transition hover:bg-slate-800/40">
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <span class="text-sm font-semibold text-slate-100">{{ contract.title }}</span>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-400">
                                        {{ contract.client.fullName ?? contract.client.email ?? '—' }}
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-slate-200">
                                        {{ contract.agreedPrice|number_format(2, '.', ',') }} {{ contract.currency }}
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <span class="inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-semibold {{ statusColors[contract.status] ?? 'bg-slate-600/40 text-slate-300' }}">
                                            {{ statusLabels[contract.status] ?? contract.status }}
                                        </span>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <div class="flex items-center gap-2">
                                            <div class="w-20 h-2 rounded-full bg-slate-700">
                                                <div class="h-2 rounded-full bg-emerald-500" style="width: {{ contract.getProgressPercent() }}%"></div>
                                            </div>
                                            <span class="text-xs text-slate-400">{{ contract.getProgressPercent() }}%</span>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap text-center">
                                        <div class="flex items-center justify-center gap-1.5">
                                            <span title="Client {{ contract.clientSigned ? 'signed' : 'not signed' }}" class="inline-block w-3 h-3 rounded-full {{ contract.clientSigned ? 'bg-emerald-500' : 'bg-slate-600' }}"></span>
                                            <span title="Worker {{ contract.workerSigned ? 'signed' : 'not signed' }}" class="inline-block w-3 h-3 rounded-full {{ contract.workerSigned ? 'bg-emerald-500' : 'bg-slate-600' }}"></span>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap text-right">
                                        <div class="flex items-center justify-end gap-3">
                                            <a href="{{ path('worker_contract_show', {id: contract.id}) }}" class="text-sm font-semibold text-emerald-400 hover:text-emerald-300 transition">
                                                View
                                            </a>
                                            <a href="{{ path('worker_contract_pdf', {id: contract.id}) }}" target="_blank"
                                               class="text-sm text-slate-400 hover:text-slate-300 transition" title="Download PDF">
                                                PDF
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
