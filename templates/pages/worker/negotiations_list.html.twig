{% extends 'layout_app.html.twig' %}
{% set topbar_title = 'Negotiations' %}
{% set user_name = 'Sam Worker' %}
{% block main %}
    <div class="space-y-6">
        <h1 class="text-2xl font-bold text-[#000000]">Negotiations</h1>
        <div class="rounded-xl border border-gray-200 bg-white shadow-sm">
            <div class="border-b border-gray-100 p-4">
                <input type="search" placeholder="Search negotiations" class="block w-full max-w-sm rounded-lg border border-gray-300 px-4 py-2 text-sm text-[#000000] placeholder-gray-400 focus:border-[#0FAF7A] focus:ring-2 focus:ring-[#0FAF7A]/20" aria-label="Search" />
            </div>
            {% set headers = ['Service', 'Client', 'Status', 'Last update', 'Actions'] %}
            {% set rows = [
                ['Website redesign', 'Acme Inc.', 'In progress', '2 hours ago', 'View'],
                ['Mobile app MVP', 'Startup Co.', 'Pending', '1 day ago', 'View']
            ] %}
            {% include 'components/_table.html.twig' with { headers: headers, rows: rows } %}
            {% include 'components/_pagination.html.twig' with { current_page: 1, total_pages: 1, base_path: '?page=' } %}
        </div>
    </div>
{% endblock %}
