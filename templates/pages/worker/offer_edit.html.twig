{% extends 'layout_app.html.twig' %}
{% set sidebar_items = [
    { label: 'Dashboard', path: path('worker_dashboard'), active: false },
    { label: 'Contracts', path: path('worker_contracts_list'), active: false },
    { label: 'Worker Profile', path: path('worker_profiles_index'), active: false }
] %}
{% set topbar_title = 'Edit offer' %}
{% set user_name = 'Sam Worker' %}
{% block main %}
    <div class="mx-auto max-w-3xl space-y-8">
        <div>
            <h1 class="text-2xl font-bold text-[#000000]">Edit offer</h1>
            <p class="mt-1 text-[#3F3F3F]">Service: Website redesign · Acme Inc.</p>
        </div>
        <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
            <form class="space-y-6" action="#" method="post" novalidate>
                <div>
                    <label for="price" class="block text-sm font-medium text-[#3F3F3F]">Price (USD)</label>
                    <input id="price" name="price" type="text" value="2400" required class="mt-1 block w-full rounded-lg border border-gray-300 px-4 py-2.5 text-[#000000] focus:border-[#0FAF7A] focus:ring-2 focus:ring-[#0FAF7A]/20" />
                </div>
                <div>
                    <label for="eta" class="block text-sm font-medium text-[#3F3F3F]">Delivery (ETA)</label>
                    <input id="eta" name="eta" type="text" value="4 weeks" required class="mt-1 block w-full rounded-lg border border-gray-300 px-4 py-2.5 text-[#000000] focus:border-[#0FAF7A] focus:ring-2 focus:ring-[#0FAF7A]/20" />
                </div>
                <div>
                    <label for="revisions" class="block text-sm font-medium text-[#3F3F3F]">Revisions included</label>
                    <input id="revisions" name="revisions" type="number" value="3" min="0" class="mt-1 block w-full rounded-lg border border-gray-300 px-4 py-2.5 text-[#000000] focus:border-[#0FAF7A] focus:ring-2 focus:ring-[#0FAF7A]/20" />
                </div>
                <div>
                    <label for="sla" class="block text-sm font-medium text-[#3F3F3F]">Response SLA</label>
                    <input id="sla" name="sla" type="text" value="24h response" class="mt-1 block w-full rounded-lg border border-gray-300 px-4 py-2.5 text-[#000000] focus:border-[#0FAF7A] focus:ring-2 focus:ring-[#0FAF7A]/20" />
                </div>
                <div>
                    <label for="message" class="block text-sm font-medium text-[#3F3F3F]">Message to client</label>
                    <textarea id="message" name="message" rows="4" class="mt-1 block w-full rounded-lg border border-gray-300 px-4 py-2.5 text-[#000000] focus:border-[#0FAF7A] focus:ring-2 focus:ring-[#0FAF7A]/20">I will deliver a modern, responsive design with up to 3 revision rounds.</textarea>
                </div>
                <div class="flex gap-3">
                    {% include 'components/_button.html.twig' with { label: 'Save changes', type: 'submit', variant: 'primary' } %}
                    {% include 'components/_button.html.twig' with { label: 'Cancel', href: '#', variant: 'ghost' } %}
                </div>
            </form>
        </div>
    </div>
{% endblock %}
