{% extends 'layout_app.html.twig' %}

{% block title %}Submit Offer - Orion{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .form-error {
            display: block;
            margin-top: 0.5rem;
            font-size: 0.75rem;
            color: #dc2626;
        }
        .dark .form-error { color: #f87171; }
        .form-error ul { list-style: none; padding: 0; margin: 0; }
        .form-error li { margin: 0.15rem 0; }
        .is-invalid { border-color: #dc2626 !important; }
        .dark .is-invalid { border-color: #ef4444 !important; }

        .section-card {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .section-card:hover {
            box-shadow: 0 4px 24px -4px rgba(0,0,0,0.08);
        }
        .dark .section-card:hover {
            box-shadow: 0 4px 24px -4px rgba(0,0,0,0.3);
        }

        input[type="text"],
        input[type="email"],
        input[type="number"],
        input[type="date"],
        select,
        textarea {
            transition: all 0.2s ease;
        }
        input[type="text"]:focus,
        input[type="email"]:focus,
        input[type="number"]:focus,
        input[type="date"]:focus,
        select:focus,
        textarea:focus {
            border-color: #10b981 !important;
            box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.1) !important;
        }
        .dark input[type="text"]:focus,
        .dark input[type="email"]:focus,
        .dark input[type="number"]:focus,
        .dark input[type="date"]:focus,
        .dark select:focus,
        .dark textarea:focus {
            border-color: #10b981 !important;
            box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.15) !important;
        }
        input[type="checkbox"] {
            cursor: pointer;
            transition: all 0.2s ease;
        }
        input[type="checkbox"]:checked {
            background-color: #10b981 !important;
            border-color: #10b981 !important;
        }

        .step-indicator {
            position: relative;
        }
        .step-indicator::after {
            content: '';
            position: absolute;
            left: 50%;
            bottom: -12px;
            transform: translateX(-50%);
            width: 2px;
            height: 12px;
            background: linear-gradient(to bottom, #e2e8f0, transparent);
        }
        .dark .step-indicator::after {
            background: linear-gradient(to bottom, #334155, transparent);
        }
    </style>
{% endblock %}

{% block main %}
<div class="space-y-8">

    {# Page Header #}
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6">
        <div>
            <a href="{{ path('worker_service_requests') }}"
               class="inline-flex items-center gap-1.5 text-sm text-slate-500 dark:text-slate-400 hover:text-emerald-600 dark:hover:text-emerald-400 transition-colors mb-3">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                Back to Service Requests
            </a>
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-emerald-500 to-emerald-600 flex items-center justify-center shadow-lg shadow-emerald-500/30">
                    <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                    </svg>
                </div>
                <div>
                    <h2 class="text-2xl font-extrabold text-slate-900 dark:text-white tracking-tight">Submit New Offer</h2>
                    <p class="text-sm text-slate-500 dark:text-slate-400">Create an offer for the selected service request</p>
                </div>
            </div>
        </div>
    </div>

    {# Steps Progress Indicator #}
    <div class="hidden sm:flex items-center justify-center gap-0">
        <div class="flex items-center gap-2">
            <div class="w-8 h-8 rounded-full bg-emerald-600 text-white flex items-center justify-center text-xs font-bold shadow-lg shadow-emerald-500/30">1</div>
            <span class="text-xs font-semibold text-emerald-600 dark:text-emerald-400">Service Request</span>
        </div>
        <div class="w-12 h-px bg-emerald-300 dark:bg-emerald-700 mx-2"></div>
        <div class="flex items-center gap-2">
            <div class="w-8 h-8 rounded-full bg-emerald-600 text-white flex items-center justify-center text-xs font-bold shadow-lg shadow-emerald-500/30">2</div>
            <span class="text-xs font-semibold text-emerald-600 dark:text-emerald-400">Offer Details</span>
        </div>
        <div class="w-12 h-px bg-slate-300 dark:bg-slate-700 mx-2"></div>
        <div class="flex items-center gap-2">
            <div class="w-8 h-8 rounded-full bg-slate-200 dark:bg-slate-700 text-slate-500 dark:text-slate-400 flex items-center justify-center text-xs font-bold">3</div>
            <span class="text-xs font-medium text-slate-400 dark:text-slate-500">Submitted</span>
        </div>
    </div>

    {# Flash messages #}
    {% for message in app.flashes('error') %}
        <div class="flex items-center gap-3 rounded-xl bg-red-50 border border-red-200 p-4 text-red-700 text-sm dark:bg-red-900/20 dark:border-red-800 dark:text-red-400">
            <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            {{ message }}
        </div>
    {% endfor %}

    {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

        {# Left Column (2/3) — Main Form Sections #}
        <div class="lg:col-span-2 space-y-6">

            {# Pricing & Priority Section #}
            <div class="section-card bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm overflow-hidden">
                <div class="px-6 py-4 border-b border-slate-100 dark:border-slate-800 flex items-center gap-2">
                    <div class="w-8 h-8 rounded-lg bg-emerald-500/10 dark:bg-emerald-500/20 flex items-center justify-center">
                        <svg class="w-4 h-4 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    </div>
                    <h3 class="text-base font-bold text-slate-900 dark:text-white">Pricing & Priority</h3>
                </div>
                <div class="p-6">
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                        <div>
                            {{ form_label(form.price, null, {'label_attr': {'class': 'block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-1.5'}}) }}
                            {{ form_widget(form.price) }}
                            <div class="form-error">{{ form_errors(form.price) }}</div>
                        </div>
                        <div>
                            {{ form_label(form.priorityLevel, null, {'label_attr': {'class': 'block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-1.5'}}) }}
                            {{ form_widget(form.priorityLevel) }}
                            <div class="form-error">{{ form_errors(form.priorityLevel) }}</div>
                        </div>
                        <div>
                            {{ form_label(form.extraRevisionFee, null, {'label_attr': {'class': 'block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-1.5'}}) }}
                            {{ form_widget(form.extraRevisionFee) }}
                            <p class="text-[11px] text-slate-400 dark:text-slate-500 mt-1">Fee per additional revision beyond included</p>
                            <div class="form-error">{{ form_errors(form.extraRevisionFee) }}</div>
                        </div>
                        <div>
                            {{ form_label(form.rushFee, null, {'label_attr': {'class': 'block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-1.5'}}) }}
                            {{ form_widget(form.rushFee) }}
                            <p class="text-[11px] text-slate-400 dark:text-slate-500 mt-1">Additional fee charged for urgent delivery</p>
                            <div class="form-error">{{ form_errors(form.rushFee) }}</div>
                        </div>
                    </div>
                </div>
            </div>

            {# Timeline Section #}
            <div class="section-card bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm overflow-hidden">
                <div class="px-6 py-4 border-b border-slate-100 dark:border-slate-800 flex items-center gap-2">
                    <div class="w-8 h-8 rounded-lg bg-blue-500/10 dark:bg-blue-500/20 flex items-center justify-center">
                        <svg class="w-4 h-4 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                    </div>
                    <h3 class="text-base font-bold text-slate-900 dark:text-white">Timeline & Schedule</h3>
                </div>
                <div class="p-6">
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                        <div>
                            {{ form_label(form.estimatedTimeDays, null, {'label_attr': {'class': 'block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-1.5'}}) }}
                            {{ form_widget(form.estimatedTimeDays) }}
                            <div class="form-error">{{ form_errors(form.estimatedTimeDays) }}</div>
                        </div>
                        <div>
                            {{ form_label(form.includedRevisions, null, {'label_attr': {'class': 'block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-1.5'}}) }}
                            {{ form_widget(form.includedRevisions) }}
                            <div class="form-error">{{ form_errors(form.includedRevisions) }}</div>
                        </div>
                        <div>
                            {{ form_label(form.startDateAvailable, null, {'label_attr': {'class': 'block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-1.5'}}) }}
                            {{ form_widget(form.startDateAvailable) }}
                            <div class="form-error">{{ form_errors(form.startDateAvailable) }}</div>
                        </div>
                        <div>
                            {{ form_label(form.deliveryDateEstimated, null, {'label_attr': {'class': 'block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-1.5'}}) }}
                            {{ form_widget(form.deliveryDateEstimated) }}
                            <div class="form-error">{{ form_errors(form.deliveryDateEstimated) }}</div>
                        </div>
                        <div>
                            {{ form_label(form.responseSlaHours, null, {'label_attr': {'class': 'block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-1.5'}}) }}
                            {{ form_widget(form.responseSlaHours) }}
                            <p class="text-[11px] text-slate-400 dark:text-slate-500 mt-1">Maximum response time guarantee</p>
                            <div class="form-error">{{ form_errors(form.responseSlaHours) }}</div>
                        </div>
                    </div>
                </div>
            </div>

            {# Scope & Details Section #}
            <div class="section-card bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm overflow-hidden">
                <div class="px-6 py-4 border-b border-slate-100 dark:border-slate-800 flex items-center gap-2">
                    <div class="w-8 h-8 rounded-lg bg-purple-500/10 dark:bg-purple-500/20 flex items-center justify-center">
                        <svg class="w-4 h-4 text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                    </div>
                    <h3 class="text-base font-bold text-slate-900 dark:text-white">Scope & Details</h3>
                </div>
                <div class="p-6 space-y-5">
                    <div>
                        {{ form_label(form.message, null, {'label_attr': {'class': 'block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-1.5'}}) }}
                        {{ form_widget(form.message) }}
                        <div class="form-error">{{ form_errors(form.message) }}</div>
                    </div>
                    <div>
                        {{ form_label(form.scopeSummary, null, {'label_attr': {'class': 'block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-1.5'}}) }}
                        {{ form_widget(form.scopeSummary) }}
                        <div class="form-error">{{ form_errors(form.scopeSummary) }}</div>
                    </div>
                    <div>
                        {{ form_label(form.deliverables, null, {'label_attr': {'class': 'block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-1.5'}}) }}
                        {{ form_widget(form.deliverables) }}
                        <div class="form-error">{{ form_errors(form.deliverables) }}</div>
                    </div>
                    <div>
                        {{ form_label(form.acceptanceCriteria, null, {'label_attr': {'class': 'block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-1.5'}}) }}
                        {{ form_widget(form.acceptanceCriteria) }}
                        <div class="form-error">{{ form_errors(form.acceptanceCriteria) }}</div>
                    </div>
                </div>
            </div>
        </div>

        {# Right Column (1/3) — Service Request, Urgency, Actions #}
        <div class="space-y-6">

            {# Service Request Context Card #}
            <div class="section-card bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm overflow-hidden">
                <div class="px-6 py-4 border-b border-slate-100 dark:border-slate-800 flex items-center gap-2">
                    <div class="w-8 h-8 rounded-lg bg-blue-500/10 dark:bg-blue-500/20 flex items-center justify-center">
                        <svg class="w-4 h-4 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
                    </div>
                    <h3 class="text-base font-bold text-slate-900 dark:text-white">Service Request</h3>
                </div>
                <div class="p-6">
                    <div class="flex items-start gap-3 mb-4">
                        <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-blue-500 to-blue-600 flex items-center justify-center text-white flex-shrink-0 shadow-lg shadow-blue-500/20">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                        </div>
                        <div class="min-w-0">
                            <h4 class="font-bold text-slate-900 dark:text-white text-sm">{{ service_request.title }}</h4>
                            <p class="text-xs text-slate-500 dark:text-slate-400 mt-0.5">Replying to this request</p>
                        </div>
                    </div>
                    <p class="text-xs text-slate-600 dark:text-slate-400 leading-relaxed mb-4">{{ service_request.description|slice(0, 200) }}{% if service_request.description|length > 200 %}…{% endif %}</p>
                    <div class="space-y-2">
                        {% if service_request.budgetMin or service_request.budgetMax %}
                        <div class="flex items-center gap-2 p-2.5 rounded-lg bg-emerald-50 dark:bg-emerald-900/20 border border-emerald-100 dark:border-emerald-800/30">
                            <svg class="w-3.5 h-3.5 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                            <span class="text-xs font-bold text-emerald-700 dark:text-emerald-400">${{ service_request.budgetMin|number_format(0) }} – ${{ service_request.budgetMax|number_format(0) }}</span>
                        </div>
                        {% endif %}
                        <div class="flex items-center gap-2 p-2.5 rounded-lg bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700">
                            <svg class="w-3.5 h-3.5 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                            <span class="text-xs font-bold text-slate-600 dark:text-slate-400">{{ service_request.client.fullName }}</span>
                        </div>
                        {% if service_request.duration %}
                        <div class="flex items-center gap-2 p-2.5 rounded-lg bg-blue-50 dark:bg-blue-900/20 border border-blue-100 dark:border-blue-800/30">
                            <svg class="w-3.5 h-3.5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                            <span class="text-xs font-bold text-blue-700 dark:text-blue-400">{{ service_request.duration }} days</span>
                        </div>
                        {% endif %}
                        {% if service_request.category %}
                        <div class="flex items-center gap-2 p-2.5 rounded-lg bg-purple-50 dark:bg-purple-900/20 border border-purple-100 dark:border-purple-800/30">
                            <svg class="w-3.5 h-3.5 text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/></svg>
                            <span class="text-xs font-bold text-purple-700 dark:text-purple-400">{{ service_request.category.name }}</span>
                        </div>
                        {% endif %}
                    </div>
                </div>
            </div>

            {# Urgency Card #}
            <div class="section-card bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm overflow-hidden">
                <div class="px-6 py-4 border-b border-slate-100 dark:border-slate-800 flex items-center gap-2">
                    <div class="w-8 h-8 rounded-lg bg-red-500/10 dark:bg-red-500/20 flex items-center justify-center">
                        <svg class="w-4 h-4 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/></svg>
                    </div>
                    <h3 class="text-base font-bold text-slate-900 dark:text-white">Urgency</h3>
                </div>
                <div class="p-6">
                    <div class="group relative bg-gradient-to-br from-red-50/50 to-orange-50/30 dark:from-red-900/10 dark:to-orange-900/5 rounded-xl p-5 border-2 border-dashed border-red-200 dark:border-red-800/40 hover:border-red-400 dark:hover:border-red-600 transition-all duration-300 cursor-pointer">
                        <label class="cursor-pointer">
                            <div class="flex items-center gap-4">
                                <div class="flex-shrink-0 w-11 h-11 rounded-xl bg-gradient-to-br from-red-500 to-red-600 flex items-center justify-center shadow-lg shadow-red-500/30 group-hover:scale-110 transition-transform duration-300">
                                    <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/>
                                    </svg>
                                </div>
                                <div class="flex-1">
                                    <span class="block font-bold text-slate-900 dark:text-white text-sm group-hover:text-red-600 dark:group-hover:text-red-400 transition-colors">Urgent Delivery</span>
                                    <p class="text-[11px] text-slate-500 dark:text-slate-400 mt-0.5">Rush fee will apply to this offer</p>
                                </div>
                            </div>
                            <div class="flex items-center gap-2 mt-4 pt-3 border-t border-red-100 dark:border-red-800/30">
                                {{ form_widget(form.isUrgent) }}
                                <span class="text-xs font-medium text-slate-700 dark:text-slate-300">Mark as urgent</span>
                            </div>
                        </label>
                        <div class="form-error mt-2">{{ form_errors(form.isUrgent) }}</div>
                    </div>
                </div>
            </div>

            {# AI Enhancement Assistant Card #}
            <div id="ai-assistant-card" class="section-card bg-white dark:bg-slate-900 rounded-2xl border-2 border-emerald-100 dark:border-emerald-800/30 shadow-xl overflow-hidden relative group">
                {# Header #}
                <div class="px-6 py-4 border-b border-emerald-50 dark:border-emerald-800/20 bg-emerald-50/30 dark:bg-emerald-500/5 flex items-center justify-between">
                    <div class="flex items-center gap-2">
                        <div class="w-8 h-8 rounded-lg bg-emerald-500 flex items-center justify-center shadow-lg shadow-emerald-500/20">
                            <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                        </div>
                        <h3 class="text-base font-bold text-slate-900 dark:text-white">AI Offer Assistant</h3>
                    </div>
                    <span id="ai-status-badge" class="px-2 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wider bg-slate-100 dark:bg-slate-800 text-slate-500 dark:text-slate-400">Waiting for data...</span>
                </div>

                <div class="p-6">
                    {# Main Score Display #}
                    <div class="flex items-center justify-center mb-8 relative">
                        <div class="text-center">
                            <div class="relative inline-flex items-center justify-center">
                                <svg class="w-28 h-28 transform -rotate-90">
                                    <circle cx="56" cy="56" r="48" stroke="currentColor" stroke-width="8" fill="transparent" class="text-slate-100 dark:text-slate-800"></circle>
                                    <circle id="ai-score-progress" cx="56" cy="56" r="48" stroke="currentColor" stroke-width="8" fill="transparent" stroke-dasharray="301.59" stroke-dashoffset="301.59" class="text-emerald-500 transition-all duration-1000 ease-out"></circle>
                                </svg>
                                <div class="absolute inset-0 flex flex-col items-center justify-center">
                                    <span id="ai-score-text" class="text-3xl font-black text-slate-900 dark:text-white leading-none">0%</span>
                                    <span class="text-[10px] font-bold text-slate-500 uppercase tracking-tighter mt-1">Acceptance</span>
                                </div>
                            </div>
                        </div>
                        
                        {# Risk level on top right of the gauge #}
                        <div id="ai-risk-badge" class="absolute top-0 right-0 transform translate-x-2 -translate-y-2 px-3 py-1 rounded-full text-xs font-black shadow-lg hidden">
                            LOW RISK
                        </div>
                    </div>

                    {# Summary / Logic Stats #}
                    <div class="grid grid-cols-2 gap-3 mb-6">
                        <div class="bg-slate-50 dark:bg-slate-800/50 p-3 rounded-xl border border-slate-100 dark:border-slate-800">
                            <span class="block text-[10px] font-bold text-slate-400 uppercase mb-1">Impact score</span>
                            <div id="ai-impact-level" class="h-1.5 w-full bg-slate-200 dark:bg-slate-700 rounded-full overflow-hidden">
                                <div class="h-full bg-emerald-500 w-0 transition-all duration-500"></div>
                            </div>
                        </div>
                        <div class="bg-slate-50 dark:bg-slate-800/50 p-3 rounded-xl border border-slate-100 dark:border-slate-800">
                            <span class="block text-[10px] font-bold text-slate-400 uppercase mb-1">Market Match</span>
                            <div id="ai-match-level" class="h-1.5 w-full bg-slate-200 dark:bg-slate-700 rounded-full overflow-hidden">
                                <div class="h-full bg-blue-500 w-0 transition-all duration-500"></div>
                            </div>
                        </div>
                    </div>

                    {# Suggestions List #}
                    <div id="ai-suggestions-container" class="space-y-3">
                        <div class="flex items-center gap-3 p-4 rounded-xl bg-orange-50/50 dark:bg-orange-500/5 border border-dashed border-orange-200 dark:border-orange-800/50">
                            <div class="w-8 h-8 rounded-full bg-orange-100 dark:bg-orange-500/10 flex items-center justify-center flex-shrink-0">
                                <svg class="w-4 h-4 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                            </div>
                            <p class="text-xs text-orange-700 dark:text-orange-400 font-medium leading-tight italic">Enter offer details to see AI suggestions.</p>
                        </div>
                    </div>

                    <div id="ai-loader" class="absolute inset-0 bg-white/80 dark:bg-slate-900/80 backdrop-blur-[2px] z-50 flex flex-col items-center justify-center hidden">
                        <div class="w-10 h-10 border-4 border-emerald-500/20 border-t-emerald-500 rounded-full animate-spin"></div>
                        <span class="text-xs font-bold text-slate-600 dark:text-slate-400 mt-3 animate-pulse">AI is thinking...</span>
                    </div>

                </div>
            </div>

            {# Action Buttons Card #}
            <div class="section-card bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm overflow-hidden">
                <div class="p-6 space-y-3">
                    <button type="submit"
                            class="w-full inline-flex items-center justify-center gap-2 px-6 py-3 bg-gradient-to-r from-emerald-600 to-emerald-700 hover:from-emerald-700 hover:to-emerald-800 text-white font-bold rounded-xl transition-all shadow-lg shadow-emerald-500/30 hover:shadow-xl hover:shadow-emerald-500/40 hover:scale-[1.02]">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6"/>
                        </svg>
                        Submit Offer
                    </button>
                    <a href="{{ path('worker_service_requests') }}"
                       class="w-full inline-flex items-center justify-center gap-2 px-6 py-3 text-sm font-semibold text-slate-600 hover:text-slate-900 dark:text-slate-400 dark:hover:text-white border border-slate-300 dark:border-slate-700 rounded-xl hover:bg-slate-50 dark:hover:bg-slate-800 transition-all">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                        Cancel
                    </a>
                </div>
            </div>
        </div>
    </div>

    {{ form_end(form) }}
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const form = document.querySelector('form[name="offer"]');
    const analyzeUrl = "{{ path('worker_offer_enhance', {id: service_request.id}) }}";
    
    // UI Elements
    const scoreProgress = document.getElementById('ai-score-progress');
    const scoreText = document.getElementById('ai-score-text');
    const riskBadge = document.getElementById('ai-risk-badge');
    const suggestionsContainer = document.getElementById('ai-suggestions-container');
    const statusBadge = document.getElementById('ai-status-badge');
    const loader = document.getElementById('ai-loader');
    
    // Inputs
    const priceInput = document.querySelector('[name="offer[price]"]');
    const messageInput = document.querySelector('[name="offer[message]"]');
    const timeInput = document.querySelector('[name="offer[estimatedTimeDays]"]');
    const revisionsInput = document.querySelector('[name="offer[includedRevisions]"]');
    const deliverablesInput = document.querySelector('[name="offer[deliverables]"]');
    
    let debounceTimer;

    function updateAI() {
        const payload = {
            price: priceInput.value,
            message: messageInput.value,
            estimated_time_days: timeInput.value,
            included_revisions: revisionsInput.value,
            deliverables: deliverablesInput.value
        };

        statusBadge.textContent = 'Updating...';
        statusBadge.className = 'px-2 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wider bg-blue-100 dark:bg-blue-900/40 text-blue-600 dark:text-blue-400';
        loader.classList.remove('hidden');

        fetch(analyzeUrl, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        })
        .then(response => response.json())
        .then(data => {
            if (data.error) throw new Error(data.error);
            renderResults(data);
        })
        .catch(error => {
            console.error('AI Assistant Error:', error);
            statusBadge.textContent = 'Offline';
            statusBadge.className = 'px-2 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wider bg-red-100 dark:bg-red-900/40 text-red-600 dark:text-red-400';
        })
        .finally(() => {
            loader.classList.add('hidden');
        });
    }

    function renderResults(data) {
        // 1. Update Score Gauge
        const score = data.score;
        const circumference = 301.59;
        const offset = circumference - (score / 100) * circumference;
        scoreProgress.style.strokeDashoffset = offset;
        scoreText.textContent = `${Math.round(score)}%`;
        
        // Color based on score
        if (score >= 75) scoreProgress.classList.replace('text-emerald-500', 'text-emerald-500');
        else if (score >= 40) {
            scoreProgress.classList.remove('text-emerald-500', 'text-red-500');
            scoreProgress.classList.add('text-orange-500');
        } else {
            scoreProgress.classList.remove('text-emerald-500', 'text-orange-500');
            scoreProgress.classList.add('text-red-500');
        }

        // 2. Risk Badge
        riskBadge.classList.remove('hidden', 'bg-emerald-500', 'bg-orange-500', 'bg-red-500', 'text-white');
        riskBadge.textContent = `${data.risk_level} RISK`;
        if (data.risk_level === 'LOW') riskBadge.classList.add('bg-emerald-500', 'text-white');
        else if (data.risk_level === 'MEDIUM') riskBadge.classList.add('bg-orange-500', 'text-white');
        else riskBadge.classList.add('bg-red-500', 'text-white');

        // 3. Status Badge
        statusBadge.textContent = 'Live Assistant';
        statusBadge.className = 'px-2 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wider bg-emerald-100 dark:bg-emerald-900/40 text-emerald-600 dark:text-emerald-400';

        // 4. Suggestions
        suggestionsContainer.innerHTML = '';
        if (data.suggestions.length === 0) {
            suggestionsContainer.innerHTML = `
                <div class="flex items-center gap-3 p-4 rounded-xl bg-emerald-50/50 dark:bg-emerald-500/5 border border-emerald-100 dark:border-emerald-800/50">
                    <div class="w-8 h-8 rounded-full bg-emerald-100 dark:bg-emerald-500/10 flex items-center justify-center flex-shrink-0">
                        <svg class="w-4 h-4 text-emerald-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                    </div>
                    <p class="text-xs text-emerald-700 dark:text-emerald-400 font-bold">Excellent! Your offer is highly optimized.</p>
                </div>
            `;
        } else {
            data.suggestions.forEach(suggestion => {
                const div = document.createElement('div');
                div.className = 'flex items-start gap-3 p-3 rounded-xl bg-slate-50 dark:bg-slate-800 border border-slate-100 dark:border-slate-800 hover:border-blue-200 dark:hover:border-blue-800 transition-colors';
                div.innerHTML = `
                    <div class="w-6 h-6 rounded-lg bg-blue-100 dark:bg-blue-500/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                        <svg class="w-3.5 h-3.5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    </div>
                    <p class="text-[11px] text-slate-600 dark:text-slate-400 font-semibold leading-normal">${suggestion}</p>
                `;
                suggestionsContainer.appendChild(div);
            });
        }

        // 5. Impact bars (simulated for aesthetics)
        const impactLevel = document.getElementById('ai-impact-level').querySelector('div');
        const matchLevel = document.getElementById('ai-match-level').querySelector('div');
        impactLevel.style.width = `${Math.min(100, data.score + 10)}%`;
        matchLevel.style.width = `${Math.min(100, data.score - 5)}%`;
    }

    function debouncedUpdate() {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(updateAI, 600);
    }

    [priceInput, messageInput, timeInput, revisionsInput, deliverablesInput].forEach(input => {
        if (input) {
            input.addEventListener('input', debouncedUpdate);
        }
    });

    // Initial check if values exist
    if (priceInput.value) updateAI();
});
</script>
{% endblock %}
