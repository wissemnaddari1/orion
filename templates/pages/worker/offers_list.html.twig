{% extends 'layout_app.html.twig' %}

{% block title %}My Offers - Orion{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        :root {
            --shadow-subtle: 0 2px 10px rgba(15, 23, 42, 0.02), 0 1px 3px rgba(15, 23, 42, 0.03);
            --shadow-premium: 0 25px 60px -15px rgba(15, 23, 42, 0.08), 0 12px 25px -8px rgba(15, 23, 42, 0.04);
        }
        .dark {
            --shadow-subtle: 0 4px 12px rgba(0, 0, 0, 0.15), 0 2px 4px rgba(0, 0, 0, 0.2);
            --shadow-premium: 0 30px 70px -12px rgba(0, 0, 0, 0.4), 0 15px 30px -8px rgba(0, 0, 0, 0.3);
        }

        .offer-card {
            transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
            box-shadow: var(--shadow-subtle);
        }
        .offer-card:hover {
            transform: translateY(-6px);
            box-shadow: var(--shadow-premium);
        }

        @keyframes slideUpFade {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .animate-premium-entry {
            opacity: 0;
            transform: translateY(30px);
        }
        .animate-premium-entry.is-ready {
            animation: slideUpFade 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }
    </style>
{% endblock %}

{% block main %}
<div class="space-y-8">
    {# Page Header #}
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 animate-premium-entry">
        <div>
            <div class="flex items-center gap-3 mb-2">
                <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-emerald-500 to-emerald-600 flex items-center justify-center shadow-lg shadow-emerald-500/30">
                    <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/>
                    </svg>
                </div>
                <div>
                    <h2 class="text-2xl font-black text-slate-900 dark:text-white tracking-tight">My Offers</h2>
                    <p class="text-sm text-slate-500 dark:text-slate-400">Track and manage your submitted offers</p>
                </div>
            </div>
        </div>
        <a href="{{ path('worker_service_requests') }}"
           class="inline-flex items-center gap-2 px-6 py-3.5 bg-emerald-500 text-white text-[10px] font-black uppercase tracking-widest rounded-2xl hover:bg-emerald-600 shadow-lg shadow-emerald-500/25 transition-all hover:scale-[1.02] active:scale-[0.98]">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
            Browse Requests
        </a>
    </div>

    {# Stats Row — flat metric boxes matching client design #}
    {% set pending_count = 0 %}
    {% set accepted_count = 0 %}
    {% set rejected_count = 0 %}
    {% set expired_count = 0 %}
    {% set negotiating_count = 0 %}
    {% for o in offers %}
        {% if o.status == 'PENDING' %}{% set pending_count = pending_count + 1 %}
        {% elseif o.status == 'ACCEPTED' %}{% set accepted_count = accepted_count + 1 %}
        {% elseif o.status == 'REJECTED' %}{% set rejected_count = rejected_count + 1 %}
        {% elseif o.status == 'EXPIRED' %}{% set expired_count = expired_count + 1 %}
        {% elseif o.status == 'NEGOTIATING' %}{% set negotiating_count = negotiating_count + 1 %}
        {% endif %}
    {% endfor %}

    <div class="grid grid-cols-2 sm:grid-cols-5 gap-4 animate-premium-entry">
        <div class="bg-white dark:bg-slate-900/40 rounded-[32px] border border-slate-200 dark:border-slate-800 p-5 backdrop-blur-sm">
            <p class="text-[10px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-[0.2em] mb-1">Pending</p>
            <p class="text-3xl font-black text-amber-600 dark:text-amber-400 tracking-tighter">{{ pending_count }}</p>
            <p class="text-[10px] font-bold text-slate-400 dark:text-slate-500 mt-1">Awaiting response</p>
        </div>
        <div class="bg-white dark:bg-slate-900/40 rounded-[32px] border border-slate-200 dark:border-slate-800 p-5 backdrop-blur-sm">
            <p class="text-[10px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-[0.2em] mb-1">Accepted</p>
            <p class="text-3xl font-black text-emerald-600 dark:text-emerald-400 tracking-tighter">{{ accepted_count }}</p>
            <p class="text-[10px] font-bold text-slate-400 dark:text-slate-500 mt-1">Won offers</p>
        </div>
        <div class="bg-white dark:bg-slate-900/40 rounded-[32px] border border-slate-200 dark:border-slate-800 p-5 backdrop-blur-sm">
            <p class="text-[10px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-[0.2em] mb-1">Rejected</p>
            <p class="text-3xl font-black text-red-600 dark:text-red-400 tracking-tighter">{{ rejected_count }}</p>
            <p class="text-[10px] font-bold text-slate-400 dark:text-slate-500 mt-1">Not selected</p>
        </div>
        <div class="bg-white dark:bg-slate-900/40 rounded-[32px] border border-slate-200 dark:border-slate-800 p-5 backdrop-blur-sm">
            <p class="text-[10px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-[0.2em] mb-1">Negotiating</p>
            <p class="text-3xl font-black text-indigo-600 dark:text-indigo-400 tracking-tighter">{{ negotiating_count }}</p>
            <p class="text-[10px] font-bold text-slate-400 dark:text-slate-500 mt-1">In discussion</p>
        </div>
        <div class="bg-white dark:bg-slate-900/40 rounded-[32px] border border-slate-200 dark:border-slate-800 p-5 backdrop-blur-sm">
            <p class="text-[10px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-[0.2em] mb-1">Total</p>
            <p class="text-3xl font-black text-slate-900 dark:text-white tracking-tighter">{{ total }}</p>
            <p class="text-[10px] font-bold text-slate-400 dark:text-slate-500 mt-1">All offers</p>
        </div>
    </div>

    {# Filter Bar — matching client search/filter bar style #}
    <div class="relative z-[40] bg-white dark:bg-slate-900/50 backdrop-blur-xl rounded-[32px] border border-slate-200 dark:border-slate-800 p-4 shadow-xl shadow-slate-200/50 dark:shadow-none animate-premium-entry">
        <div class="flex flex-col sm:flex-row gap-4">
            {# Search Input #}
            <div class="relative flex-1">
                <div class="absolute inset-y-0 left-0 pl-5 flex items-center pointer-events-none">
                    <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                    </svg>
                </div>
                <input type="text"
                       id="search-input"
                       value="{{ q }}"
                       placeholder="Search offers by title, client…"
                       class="w-full pl-12 pr-6 py-4 bg-slate-50 dark:bg-slate-800/50 text-slate-900 dark:text-white text-sm font-bold rounded-2xl border border-transparent hover:border-emerald-300 dark:hover:border-emerald-500/50 focus:border-emerald-400 focus:ring-2 focus:ring-emerald-500/20 dark:focus:ring-emerald-500/10 outline-none transition-all placeholder:text-slate-400 placeholder:font-medium">
                {% if q is not empty %}
                <button id="clear-search"
                        class="absolute inset-y-0 right-0 pr-5 flex items-center text-slate-400 hover:text-red-500 transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                </button>
                {% endif %}
            </div>

            {# Filter Dropdown #}
            <div class="relative w-full sm:w-64" data-controller="dropdown">
                <button type="button"
                        data-action="click->dropdown#toggle"
                        data-dropdown-target="button"
                        class="w-full px-6 py-4 bg-slate-50 dark:bg-slate-800/50 text-slate-900 dark:text-white text-sm font-bold rounded-2xl border border-transparent hover:border-emerald-300 dark:hover:border-emerald-500/50 transition-all flex items-center justify-between group">
                    <div class="flex items-center gap-3">
                        <svg class="w-4 h-4 text-slate-400 group-hover:text-emerald-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"/>
                        </svg>
                        <span data-dropdown-target="label">Filter: {{ status_filter == '' or status_filter == 'all' ? 'All Status' : status_filter|capitalize }}</span>
                    </div>
                    <svg class="w-4 h-4 text-slate-400 transition-transform duration-200 chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>
                    </svg>
                </button>

                <input type="hidden" name="status" id="status-filter"
                       data-dropdown-target="valueInput"
                       value="{{ status_filter == '' ? 'all' : status_filter }}">

                <div data-dropdown-target="menu"
                     class="hidden absolute right-0 top-full mt-2 min-w-full w-56 bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-700 shadow-[0_20px_60px_-15px_rgba(0,0,0,0.15)] dark:shadow-[0_20px_60px_-15px_rgba(0,0,0,0.5)] transition-all duration-150 opacity-0 -translate-y-2 pointer-events-none max-h-60 overflow-y-auto" style="z-index: 100;">
                    <div class="py-2">
                        {% set statuses = [
                            {'val': 'all', 'label': 'All Status', 'color': 'gray'},
                            {'val': 'pending', 'label': 'Pending', 'color': 'amber'},
                            {'val': 'accepted', 'label': 'Accepted', 'color': 'emerald'},
                            {'val': 'rejected', 'label': 'Rejected', 'color': 'red'},
                            {'val': 'negotiating', 'label': 'Negotiating', 'color': 'indigo'}
                        ] %}

                        {% for s in statuses %}
                            <div data-action="click->dropdown#select"
                                 data-value="{{ s.val }}"
                                 class="px-4 py-3 flex items-center justify-between cursor-pointer hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors group">
                                <div class="flex items-center gap-3">
                                    {% if s.color != 'gray' %}
                                        <span class="w-2.5 h-2.5 rounded-full bg-{{ s.color }}-500"></span>
                                    {% else %}
                                        <span class="w-2.5 h-2.5 rounded-full bg-slate-400"></span>
                                    {% endif %}
                                    <span class="option-text text-sm font-bold text-slate-700 dark:text-slate-300 group-hover:text-emerald-500 dark:group-hover:text-emerald-400 transition-colors">{{ s.label }}</span>
                                </div>
                                <svg class="check-icon w-4 h-4 text-emerald-500 {{ (status_filter == s.val or (status_filter == '' and s.val == 'all')) ? '' : 'hidden' }}" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                                </svg>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# Flash messages #}
    {% for message in app.flashes('success') %}
        <div class="flex items-center gap-3 rounded-2xl bg-emerald-50 border border-emerald-200 p-4 text-emerald-700 text-sm dark:bg-emerald-900/20 dark:border-emerald-800 dark:text-emerald-400">
            <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            {{ message }}
        </div>
    {% endfor %}

    {# Offers Cards Grid #}
    {% if offers|length > 0 %}
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-8">
            {% for o in offers %}
                <div class="offer-card animate-premium-entry" style="animation-delay: {{ loop.index0 * 60 }}ms">
                    <a href="{{ path('worker_offer_show', {id: o.id}) }}" class="block h-full">
                        <div class="relative overflow-hidden rounded-[32px] bg-white dark:bg-slate-900/40 border border-slate-200 dark:border-slate-800 h-full flex flex-col backdrop-blur-sm
                            {% if o.status == 'ACCEPTED' %} border-l-4 border-l-emerald-500
                            {% elseif o.status == 'NEGOTIATING' %} border-l-4 border-l-indigo-500
                            {% endif %}">

                            <div class="p-7 flex-1 flex flex-col">
                                {# Top Row: Title + Status Badge #}
                                <div class="flex items-start justify-between gap-3 mb-6">
                                    <div class="flex-1 min-w-0 space-y-1">
                                        <h3 class="text-lg font-black text-slate-900 dark:text-white leading-tight group-hover:text-emerald-500 transition-colors">
                                            {{ o.serviceRequest.title|length > 45 ? o.serviceRequest.title|slice(0, 45) ~ '…' : o.serviceRequest.title }}
                                        </h3>
                                        <div class="flex items-center gap-2">
                                            <span class="text-[10px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-widest">Client</span>
                                            <span class="text-slate-300 dark:text-slate-700">•</span>
                                            <span class="text-xs font-bold text-slate-600 dark:text-slate-400">{{ o.serviceRequest.client.fullName }}</span>
                                        </div>
                                    </div>
                                    <span class="flex-shrink-0 px-3 py-1 text-[10px] font-black rounded-xl uppercase tracking-[0.15em] border
                                        {% if o.status == 'ACCEPTED' %}bg-emerald-50 text-emerald-600 border-emerald-100 dark:bg-emerald-900/20 dark:text-emerald-400 dark:border-emerald-800
                                        {% elseif o.status == 'REJECTED' %}bg-red-50 text-red-600 border-red-100 dark:bg-red-900/20 dark:text-red-400 dark:border-red-800
                                        {% elseif o.status == 'NEGOTIATING' %}bg-indigo-50 text-indigo-600 border-indigo-100 dark:bg-indigo-900/20 dark:text-indigo-400 dark:border-indigo-800
                                        {% elseif o.status == 'EXPIRED' %}bg-slate-50 text-slate-500 border-slate-100 dark:bg-slate-800 dark:text-slate-400 dark:border-slate-700
                                        {% else %}bg-amber-50 text-amber-600 border-amber-100 dark:bg-amber-900/20 dark:text-amber-400 dark:border-amber-800{% endif %}">
                                        {{ o.status }}
                                    </span>
                                </div>

                                {# Metrics Grid — same neutral boxes as client cards #}
                                <div class="grid grid-cols-3 gap-3 mb-6">
                                    <div class="bg-slate-50/50 dark:bg-slate-800/30 rounded-2xl p-4 border border-slate-100 dark:border-slate-800 text-center">
                                        <p class="text-[10px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-widest mb-1">Price</p>
                                        <p class="text-xl font-black text-slate-900 dark:text-white tracking-tighter">${{ o.price|number_format(0) }}</p>
                                    </div>
                                    <div class="bg-slate-50/50 dark:bg-slate-800/30 rounded-2xl p-4 border border-slate-100 dark:border-slate-800 text-center">
                                        <p class="text-[10px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-widest mb-1">Days</p>
                                        <p class="text-xl font-black text-slate-900 dark:text-white tracking-tighter">{{ o.estimatedTimeDays }}<span class="text-sm ml-0.5">d</span></p>
                                    </div>
                                    <div class="bg-slate-50/50 dark:bg-slate-800/30 rounded-2xl p-4 border border-slate-100 dark:border-slate-800 text-center">
                                        <p class="text-[10px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-widest mb-1">Priority</p>
                                        <p class="text-sm font-black tracking-tight
                                            {% if o.priorityLevel == 'HIGH' %}text-red-600 dark:text-red-400
                                            {% elseif o.priorityLevel == 'MEDIUM' %}text-amber-600 dark:text-amber-400
                                            {% else %}text-slate-600 dark:text-slate-400{% endif %}">
                                            {{ o.priorityLevel }}
                                        </p>
                                    </div>
                                </div>

                                {# Urgent Badge #}
                                {% if o.isUrgent %}
                                    <div class="flex items-center gap-2 mb-6 px-4 py-3 rounded-2xl bg-red-50/50 dark:bg-red-900/10 border border-red-100 dark:border-red-800/30">
                                        <svg class="w-4 h-4 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                                        <span class="text-[10px] font-black text-red-600 dark:text-red-400 uppercase tracking-widest">Urgent</span>
                                        {% if o.rushFee %}
                                            <span class="ml-auto text-[10px] font-black text-red-500 dark:text-red-400">+${{ o.rushFee|number_format(0) }}</span>
                                        {% endif %}
                                    </div>
                                {% endif %}

                                {# Footer #}
                                <div class="mt-auto pt-6 border-t border-slate-100 dark:border-slate-800 flex items-center justify-between">
                                    <span class="text-[10px] font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest">
                                        {{ o.createdAt|date('M d, Y') }}
                                    </span>
                                    <span class="inline-flex items-center gap-2 px-4 py-2 text-[10px] font-black text-emerald-600 dark:text-emerald-400 bg-emerald-50 dark:bg-emerald-900/20 rounded-xl uppercase tracking-widest transition-colors">
                                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                                        View
                                    </span>
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
            {% endfor %}
        </div>
    {% else %}
        {# Empty State #}
        <div class="rounded-[32px] border border-slate-200 bg-white dark:bg-slate-900/50 p-16 text-center dark:border-slate-800 backdrop-blur-xl">
            <div class="w-16 h-16 mx-auto rounded-2xl bg-slate-50 dark:bg-slate-800 flex items-center justify-center mb-4">
                <svg class="w-8 h-8 text-slate-300 dark:text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/>
                </svg>
            </div>
            <h3 class="text-xl font-black text-slate-900 dark:text-white mb-2">No offers yet</h3>
            <p class="text-sm text-slate-500 dark:text-slate-400 mb-6 font-medium">Browse service requests and submit your first offer</p>
            <a href="{{ path('worker_service_requests') }}"
               class="inline-flex items-center gap-2 px-6 py-3.5 bg-emerald-500 text-white text-[10px] font-black uppercase tracking-widest rounded-2xl hover:bg-emerald-600 shadow-lg shadow-emerald-500/25 transition-all hover:scale-[1.02]">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                Browse Requests
            </a>
        </div>
    {% endif %}

    {# Pagination — matching client pagination style #}
    {% if total_pages > 1 %}
        <div class="flex flex-col sm:flex-row items-center justify-between mt-4 gap-6 pb-8">
            <p class="text-[10px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-widest">
                Page <span class="text-slate-900 dark:text-white">{{ page }}</span> of {{ total_pages }}
            </p>
            <div class="flex items-center gap-3">
                {% if page > 1 %}
                    <a href="{{ path('worker_offers_list', {page: page - 1, status: status_filter}) }}"
                       class="inline-flex items-center gap-2 px-6 py-3.5 text-[10px] font-black uppercase tracking-widest border border-slate-200 dark:border-slate-800 rounded-2xl hover:bg-slate-50 dark:hover:bg-slate-800 dark:text-white transition-all">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7"/></svg>
                        Prev
                    </a>
                {% endif %}
                {% if page < total_pages %}
                    <a href="{{ path('worker_offers_list', {page: page + 1, status: status_filter}) }}"
                       class="inline-flex items-center gap-2 px-6 py-3.5 text-[10px] font-black uppercase tracking-widest bg-slate-900 dark:bg-slate-800 text-white rounded-2xl hover:bg-black dark:hover:bg-slate-700 transition-all shadow-xl">
                        Next
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
                    </a>
                {% endif %}
            </div>
        </div>
    {% endif %}
</div>

<script>
    function closeWorkerDropdown(wrapper) {
        const menu = wrapper.querySelector('[data-dropdown-target="menu"]');
        const chevron = wrapper.querySelector('.chevron');
        if (!menu) return;
        menu.classList.add('hidden', 'opacity-0', '-translate-y-2', 'pointer-events-none');
        chevron?.classList.remove('rotate-180');
    }

    function openWorkerDropdown(wrapper) {
        const menu = wrapper.querySelector('[data-dropdown-target="menu"]');
        const chevron = wrapper.querySelector('.chevron');
        if (!menu) return;
        menu.classList.remove('hidden');
        requestAnimationFrame(() => {
            menu.classList.remove('opacity-0', '-translate-y-2', 'pointer-events-none');
        });
        chevron?.classList.add('rotate-180');
    }

    function initWorkerDropdowns(root = document) {
        const wrappers = root.querySelectorAll('[data-controller="dropdown"]');
        wrappers.forEach((wrapper) => {
            if (wrapper.dataset.dropdownBound === '1') return;
            wrapper.dataset.dropdownBound = '1';

            const button = wrapper.querySelector('[data-dropdown-target="button"]');
            const menu = wrapper.querySelector('[data-dropdown-target="menu"]');
            const valueInput = wrapper.querySelector('[data-dropdown-target="valueInput"]');
            const label = wrapper.querySelector('[data-dropdown-target="label"]');
            const options = wrapper.querySelectorAll('[data-value]');
            if (!button || !menu || !valueInput || !label) return;

            const labelPrefix = (label.textContent || '').split(':')[0] || 'Filter';

            button.addEventListener('click', (e) => {
                e.preventDefault();
                const isOpen = !menu.classList.contains('hidden') && !menu.classList.contains('pointer-events-none');
                wrappers.forEach((w) => closeWorkerDropdown(w));
                if (!isOpen) openWorkerDropdown(wrapper);
            });

            options.forEach((option) => {
                option.addEventListener('click', () => {
                    const selectedValue = option.getAttribute('data-value') || '';
                    const selectedLabel = option.querySelector('.option-text')?.textContent?.trim() || selectedValue;
                    valueInput.value = selectedValue;
                    label.textContent = `${labelPrefix}: ${selectedLabel}`;

                    menu.querySelectorAll('.check-icon').forEach((icon) => icon.classList.add('hidden'));
                    option.querySelector('.check-icon')?.classList.remove('hidden');

                    valueInput.dispatchEvent(new Event('change', { bubbles: true }));
                    closeWorkerDropdown(wrapper);
                });
            });
        });
    }

    // Runs immediately — DOM is ready when Turbo swaps the body
    document.querySelectorAll('.animate-premium-entry').forEach((el, i) => {
        setTimeout(() => el.classList.add('is-ready'), 100 + (i * 60));
    });
    initWorkerDropdowns();

    document.addEventListener('click', (e) => {
        if (e.target.closest('[data-controller="dropdown"]')) return;
        document.querySelectorAll('[data-controller="dropdown"]').forEach((w) => closeWorkerDropdown(w));
    });

    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
            document.querySelectorAll('[data-controller="dropdown"]').forEach((w) => closeWorkerDropdown(w));
        }
    });

    // Handle search
    const searchInput = document.getElementById('search-input');
    if (searchInput) {
        searchInput.addEventListener('keydown', (e) => {
            if (e.key === 'Enter') {
                const url = new URL(window.location.href);
                const val = searchInput.value.trim();
                if (val) {
                    url.searchParams.set('q', val);
                } else {
                    url.searchParams.delete('q');
                }
                url.searchParams.delete('page');
                window.location.href = url.toString();
            }
        });
    }
    const clearBtn = document.getElementById('clear-search');
    if (clearBtn) {
        clearBtn.addEventListener('click', () => {
            const url = new URL(window.location.href);
            url.searchParams.delete('q');
            url.searchParams.delete('page');
            window.location.href = url.toString();
        });
    }

    // Handle filter selection — redirect with status param
    const statusInput = document.getElementById('status-filter');
    if (statusInput && !statusInput.dataset.bound) {
        statusInput.dataset.bound = '1';
        statusInput.addEventListener('change', () => {
            const val = statusInput.value;
            const url = new URL(window.location.href);
            if (val === 'all') {
                url.searchParams.delete('status');
            } else {
                url.searchParams.set('status', val);
            }
            url.searchParams.delete('page');
            window.location.href = url.toString();
        });
    }
</script>
{% endblock %}
