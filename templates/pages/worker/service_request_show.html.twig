{% extends 'layout_app.html.twig' %}

{% block title %}Service Request Details - Orion{% endblock %}

{% block main %}
<div class="max-w-4xl mx-auto space-y-6">
    <div class="flex items-center justify-between">
        <h1 class="text-2xl font-bold text-slate-900 dark:text-white">Service Request Details</h1>
        <a href="{{ path('worker_service_requests') }}"
           class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-slate-600 dark:text-slate-300 border border-slate-300 dark:border-slate-700 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 transition">
            Back
        </a>
    </div>

    <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl p-6 space-y-6">
        <div>
            <h2 class="text-xl font-semibold text-slate-900 dark:text-white">{{ service_request.title }}</h2>
            <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">
                Posted on {{ service_request.createdAt|date('M d, Y') }}
            </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="p-4 rounded-lg bg-slate-50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700">
                <p class="text-xs uppercase tracking-wider text-slate-500 dark:text-slate-400">Client</p>
                <p class="mt-1 font-medium text-slate-900 dark:text-white">{{ service_request.client.fullName }}</p>
            </div>
            <div class="p-4 rounded-lg bg-slate-50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700">
                <p class="text-xs uppercase tracking-wider text-slate-500 dark:text-slate-400">Category</p>
                <p class="mt-1 font-medium text-slate-900 dark:text-white">{{ service_request.category.name|default('—') }}</p>
            </div>
            <div class="p-4 rounded-lg bg-slate-50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700">
                <p class="text-xs uppercase tracking-wider text-slate-500 dark:text-slate-400">Budget</p>
                <p class="mt-1 font-medium text-emerald-600 dark:text-emerald-400">
                    {% if service_request.budgetMin and service_request.budgetMax %}
                        ${{ service_request.budgetMin|number_format(0) }} - ${{ service_request.budgetMax|number_format(0) }}
                    {% else %}
                        —
                    {% endif %}
                </p>
            </div>
            <div class="p-4 rounded-lg bg-slate-50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700">
                <p class="text-xs uppercase tracking-wider text-slate-500 dark:text-slate-400">Duration</p>
                <p class="mt-1 font-medium text-slate-900 dark:text-white">{{ service_request.duration }} days</p>
            </div>
        </div>

        <div>
            <h3 class="text-sm font-semibold text-slate-700 dark:text-slate-300 mb-2">Project Description</h3>
            <div class="p-4 rounded-lg bg-slate-50 dark:bg-slate-800/40 border border-slate-200 dark:border-slate-700 text-slate-700 dark:text-slate-200 whitespace-pre-line leading-relaxed">
                {{ service_request.description ?: 'No description provided.' }}
            </div>
        </div>

        <div>
            <h3 class="text-sm font-semibold text-slate-700 dark:text-slate-300 mb-2">All Requirements</h3>
            {% if service_request.requirements|length > 0 %}
                <div class="space-y-3">
                    {% for req in service_request.requirements %}
                        <div class="p-4 rounded-lg bg-slate-50 dark:bg-slate-800/40 border border-slate-200 dark:border-slate-700">
                            <div class="flex flex-wrap items-center gap-2 mb-2">
                                <p class="font-semibold text-slate-900 dark:text-white">{{ req.title ?: 'Untitled requirement' }}</p>
                                <span class="px-2 py-0.5 text-xs rounded-full bg-blue-100 text-blue-700 dark:bg-blue-900/40 dark:text-blue-300">
                                    {{ req.requirementType ?: 'General' }}
                                </span>
                                <span class="px-2 py-0.5 text-xs rounded-full {{ req.isMandatory ? 'bg-rose-100 text-rose-700 dark:bg-rose-900/40 dark:text-rose-300' : 'bg-slate-200 text-slate-700 dark:bg-slate-700 dark:text-slate-200' }}">
                                    {{ req.isMandatory ? 'Mandatory' : 'Optional' }}
                                </span>
                                <span class="px-2 py-0.5 text-xs rounded-full bg-amber-100 text-amber-700 dark:bg-amber-900/40 dark:text-amber-300">
                                    Priority {{ req.priorityLevel ?: 1 }}
                                </span>
                            </div>

                            <p class="text-sm text-slate-700 dark:text-slate-200 whitespace-pre-line">
                                {{ req.details ?: 'No details provided.' }}
                            </p>

                            {% if req.answerFormat %}
                                <p class="text-xs text-slate-500 dark:text-slate-400 mt-2">
                                    Answer format: <span class="font-medium">{{ req.answerFormat }}</span>
                                </p>
                            {% endif %}

                            {% if req.optionsJson is not empty %}
                                <div class="mt-2">
                                    <p class="text-xs text-slate-500 dark:text-slate-400 mb-1">Options:</p>
                                    <div class="flex flex-wrap gap-1.5">
                                        {% for option in req.optionsJson %}
                                            <span class="px-2 py-0.5 text-xs rounded-md bg-slate-200 text-slate-700 dark:bg-slate-700 dark:text-slate-200">
                                                {{ option }}
                                            </span>
                                        {% endfor %}
                                    </div>
                                </div>
                            {% endif %}
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <div class="p-4 rounded-lg bg-slate-50 dark:bg-slate-800/40 border border-slate-200 dark:border-slate-700 text-slate-600 dark:text-slate-300">
                    No detailed requirements were added for this request.
                </div>
            {% endif %}
        </div>

        <div class="pt-2">
            <a href="{{ path('worker_offer_new', {serviceRequest: service_request.id}) }}"
               class="inline-flex items-center gap-2 px-4 py-2 bg-emerald-600 text-white text-sm font-medium rounded-lg hover:bg-emerald-700 transition">
                Submit Offer
            </a>
        </div>
    </div>
</div>
{% endblock %}
