{% extends 'layout_app.html.twig' %}

{% block title %}Available Service Requests - Orion{% endblock %}

{% block main %}
<div class="space-y-6">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h2 class="text-2xl font-bold text-slate-900 dark:text-white">Available Service Requests</h2>
            <p class="text-sm text-slate-500 dark:text-slate-400">Browse open requests and submit your offers — {{ total }} requests found</p>
        </div>
        <div class="flex flex-col sm:flex-row gap-3">
            <form method="get" action="{{ path('worker_service_requests') }}" class="flex gap-2">
                <input type="text"
                       name="search"
                       value="{{ search_keyword }}"
                       placeholder="Search requests..."
                       class="px-4 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-emerald-500 dark:bg-slate-900 dark:border-slate-700 dark:text-white">
                <button type="submit"
                        class="px-4 py-2 bg-slate-600 text-white rounded-lg hover:bg-slate-700 transition">
                    Search
                </button>
            </form>
        </div>
    </div>

    {# Flash messages #}
    {% for message in app.flashes('success') %}
        <div class="rounded-lg bg-emerald-50 border border-emerald-200 p-4 text-emerald-700 text-sm dark:bg-emerald-900/20 dark:border-emerald-800 dark:text-emerald-400">
            {{ message }}
        </div>
    {% endfor %}

    <div class="bg-white dark:bg-slate-900 rounded-lg border border-slate-200 dark:border-slate-800 overflow-hidden shadow-sm">
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead class="bg-slate-50 dark:bg-slate-800 border-b border-slate-200 dark:border-slate-700">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider">Title</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider">Client</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider">Category</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider">Budget</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider">Duration</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider">Posted</th>
                        <th class="px-6 py-3 text-right text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider">Action</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-200 dark:divide-slate-800">
                    {% for sr in service_requests %}
                        <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/50 transition">
                            <td class="px-6 py-4">
                                <a href="{{ path('worker_service_request_show', {id: sr.id}) }}"
                                   class="font-medium text-slate-900 dark:text-white hover:text-emerald-600 dark:hover:text-emerald-400 transition-colors underline-offset-2 hover:underline">
                                    {{ sr.title|length > 45 ? sr.title|slice(0, 45) ~ '…' : sr.title }}
                                </a>
                                <div class="text-sm text-slate-500 dark:text-slate-400 mt-0.5">
                                    {{ sr.description|length > 80 ? sr.description|slice(0, 80) ~ '…' : sr.description }}
                                </div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <div class="flex items-center gap-3">
                                    <div class="w-8 h-8 rounded-full bg-blue-600 flex items-center justify-center text-white text-xs font-semibold">
                                        {{ sr.client.firstName|first|upper }}{{ sr.client.lastName|first|upper }}
                                    </div>
                                    <div class="text-sm text-slate-900 dark:text-white">{{ sr.client.fullName }}</div>
                                </div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <span class="px-2 py-1 text-xs font-semibold rounded-full bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-400">
                                    {{ sr.category.name|default('—') }}
                                </span>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm">
                                {% if sr.budgetMin and sr.budgetMax %}
                                    <span class="font-semibold text-emerald-600 dark:text-emerald-400">${{ sr.budgetMin|number_format(0) }} - ${{ sr.budgetMax|number_format(0) }}</span>
                                {% else %}
                                    <span class="text-slate-400">—</span>
                                {% endif %}
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-600 dark:text-slate-400">
                                {{ sr.duration }} days
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-600 dark:text-slate-400">
                                {{ sr.createdAt|date('M d, Y') }}
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-right">
                                <a href="{{ path('worker_offer_new', {serviceRequest: sr.id}) }}"
                                   class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-emerald-600 text-white text-sm font-medium rounded-lg hover:bg-emerald-700 transition">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6"/>
                                    </svg>
                                    Submit Offer
                                </a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="7" class="px-6 py-12 text-center">
                                <div class="flex flex-col items-center gap-3">
                                    <svg class="w-12 h-12 text-slate-300 dark:text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                                    </svg>
                                    <p class="text-slate-500 dark:text-slate-400 font-medium">No open service requests found</p>
                                    <p class="text-sm text-slate-400 dark:text-slate-500">Check back later for new opportunities</p>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    {% if total_pages > 1 %}
        <div class="flex items-center justify-between">
            <div class="text-sm text-slate-500 dark:text-slate-400">
                Page {{ page }} of {{ total_pages }}
            </div>
            <div class="flex items-center gap-2">
                {% if page > 1 %}
                    <a href="{{ path('worker_service_requests', {page: page - 1, search: search_keyword}) }}"
                       class="px-3 py-2 text-sm border border-slate-300 rounded-lg hover:bg-slate-50 dark:border-slate-700 dark:hover:bg-slate-800 dark:text-slate-300">
                        Previous
                    </a>
                {% endif %}
                {% if page < total_pages %}
                    <a href="{{ path('worker_service_requests', {page: page + 1, search: search_keyword}) }}"
                       class="px-3 py-2 text-sm border border-slate-300 rounded-lg hover:bg-slate-50 dark:border-slate-700 dark:hover:bg-slate-800 dark:text-slate-300">
                        Next
                    </a>
                {% endif %}
            </div>
        </div>
    {% endif %}
</div>
{% endblock %}
