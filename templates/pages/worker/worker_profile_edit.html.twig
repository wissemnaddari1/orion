{% extends 'layout_app.html.twig' %}

{% block title %}Modifier Profil{% endblock %}

{% set topbar_title = 'Modifier Profil' %}

{% block main %}
<div class="bg-slate-50/30 dark:bg-slate-950 py-6">
    <div class="max-w-4xl mx-auto">
        <div class="bg-white dark:bg-slate-900 rounded-2xl shadow-2xl shadow-gray-200/50 dark:shadow-black/30 overflow-hidden border border-gray-100 dark:border-slate-800">
            <div class="grid md:grid-cols-3 min-h-[600px]">
                 {# Sidebar / Info Panel #}
                <div class="bg-[#0FAF7A] p-8 text-white flex flex-col justify-between relative overflow-hidden">
                     <div class="relative z-10">
                        <h2 class="text-3xl font-bold mb-2">Modifier Profil</h2>
                            <p class="text-[#0FAF7A]/10 text-xl font-medium bg-white/10 inline-block px-3 py-1 rounded-lg backdrop-blur-sm mb-6">Expert Mode</p>
                            <p class="text-white/80 leading-relaxed">Mettez a jour vos informations pour rester competitif et attirer plus de clients.</p>
                         </div>
                         
                         {# Decorative circles #}
                         <div class="absolute top-0 right-0 -mr-16 -mt-16 w-64 h-64 rounded-full bg-white/10 blur-3xl"></div>
                         <div class="absolute bottom-0 left-0 -ml-16 -mb-16 w-48 h-48 rounded-full bg-black/5 blur-2xl"></div>

                         <div class="relative z-10 mt-12 space-y-4">
                             <div class="flex items-center space-x-3">
                                 <div class="w-8 h-8 rounded-full bg-white/20 flex items-center justify-center">✓</div>
                                 <span class="font-medium">Profil verifie</span>
                             </div>
                             <div class="flex items-center space-x-3">
                                 <div class="w-8 h-8 rounded-full bg-white/20 flex items-center justify-center">✓</div>
                                 <span class="font-medium">Statut de disponibilite</span>
                             </div>
                         </div>
                    </div>

                    {# Form Area #}
                    <div class="md:col-span-2 p-8 md:p-10 text-slate-800 dark:text-slate-100">
                        <div class="flex justify-between items-center mb-8">
                             <h1 class="text-2xl font-bold text-gray-800 dark:text-slate-100">Edition Profil</h1>
                             <span class="text-sm text-gray-400 dark:text-slate-400">ID: {{ profile.id }}</span>
                        </div>

                        {{ form_start(form, {'attr': {'data-ajax-form': 'true', 'class': 'space-y-6 edit-profile-form', 'novalidate': 'novalidate', 'data-validate': 'worker-profile'}}) }}
                        
                        <div class="space-y-6">
                            {# Professional Info #}
                            <div class="space-y-5">
                                 <div>
                                     {{ form_label(form.title) }}
                                     {{ form_widget(form.title) }}
                                     {{ form_errors(form.title) }}
                                 </div>
                                 
                                 <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                                      <div>
                                         {{ form_label(form.workerCategory) }}
                                         {{ form_widget(form.workerCategory) }}
                                         {{ form_errors(form.workerCategory) }}
                                      </div>
                                      <div>
                                         {{ form_label(form.experience_years) }}
                                         {{ form_widget(form.experience_years) }}
                                         {{ form_errors(form.experience_years) }}
                                      </div>
                                 </div>
                            </div>

                             {# Bio #}
                            <div>
                                {{ form_label(form.bio) }}
                                {{ form_widget(form.bio) }}
                                {{ form_errors(form.bio) }}
                            </div>

                             {# Details: Hourly rate #}
                            <div class="p-5 bg-gray-50 dark:bg-slate-800/40 rounded-xl border border-gray-100 dark:border-slate-700/60">
                                <div>
                                    {{ form_label(form.hourly_rate) }}
                                    <div class="relative">
                                         <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                            <span class="text-gray-500 dark:text-slate-400 sm:text-sm">EUR/h</span>
                                        </div>
                                        {{ form_widget(form.hourly_rate, {'attr': {'class': 'pl-10 mt-1 block w-full rounded-xl border-gray-200 bg-white shadow-sm focus:border-[#0FAF7A] focus:ring-[#0FAF7A] focus:ring-opacity-50 transition-all sm:text-sm py-3'}}) }}
                                    </div>
                                    {{ form_errors(form.hourly_rate) }}
                                </div>
                            </div>

                            {# Contact: Phone & Email - above map #}
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-5 p-5 bg-gray-50 dark:bg-slate-800/40 rounded-xl border border-gray-100 dark:border-slate-700/60">
                                <div>
                                    {{ form_label(form.phoneNumber) }}
                                    {{ form_widget(form.phoneNumber) }}
                                    {{ form_errors(form.phoneNumber) }}
                                </div>
                                <div>
                                    {{ form_label(form.email) }}
                                    {{ form_widget(form.email) }}
                                    {{ form_errors(form.email) }}
                                </div>
                            </div>

                            {# Location & Map #}
                            <div class="p-5 bg-gray-50 dark:bg-slate-800/40 rounded-xl border border-gray-100 dark:border-slate-700/60">
                                <div>
                                    {{ form_label(form.location) }}
                                     <div class="relative">
                                         <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                            <svg class="h-4 w-4 text-gray-400 dark:text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                                        </div>
                                        {{ form_widget(form.location, {'attr': {'class': 'pl-9 mt-1 block w-full rounded-xl border-gray-200 bg-white shadow-sm focus:border-[#0FAF7A] focus:ring-[#0FAF7A] focus:ring-opacity-50 transition-all sm:text-sm py-3'}}) }}
                                     </div>
                                    {{ form_errors(form.location) }}
                                    <div id="worker-location-map" class="mt-3 h-52 w-full rounded-xl border border-gray-200 dark:border-slate-700 overflow-hidden"></div>
                                </div>
                            </div>

                             {# Status & Verification #}
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-5 items-end">
                                <div>
                                     {{ form_label(form.availability_status) }}
                                     {{ form_widget(form.availability_status) }}
                                     {{ form_errors(form.availability_status) }}
                                </div>
                                <div class="bg-indigo-50/50 dark:bg-indigo-900/20 p-3 rounded-xl border border-indigo-100 dark:border-indigo-800/40">
                                     {{ form_row(form.verified) }}
                                </div>
                            </div>
                        </div>

                        <div class="mt-8 pt-6 border-t border-gray-100 dark:border-slate-700 flex items-center justify-between">
                             <a href="{{ path('worker_profiles_index') }}" class="text-sm text-gray-500 dark:text-slate-400 hover:text-gray-900 dark:hover:text-white font-medium transition-colors">Annuler</a>
                             <div class="w-full max-w-[220px]">
                                {{ form_widget(form.save, {'label': 'Sauvegarder'}) }}
                             </div>
                        </div>

                        {{ form_end(form) }}
                    </div>
                </div>
            </div>
        </div>
    </div>

    </div>
</div>
{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin=""/>
    <style>
        .dark .edit-profile-form label {
            color: #cbd5e1;
        }
        .dark .edit-profile-form input,
        .dark .edit-profile-form select,
        .dark .edit-profile-form textarea {
            background-color: #0f172a !important;
            color: #e2e8f0 !important;
            border-color: #334155 !important;
        }
        .dark .edit-profile-form input::placeholder,
        .dark .edit-profile-form textarea::placeholder {
            color: #64748b !important;
        }
    </style>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
    <script>
        function initEditMap() {
            const input = document.getElementById('{{ form.location.vars.id }}');
            const mapEl = document.getElementById('worker-location-map');
            if (!input || !mapEl || typeof L === 'undefined') {
                return;
            }
            if (mapEl.dataset.initialized === '1') {
                return;
            }
            mapEl.dataset.initialized = '1';

            const map = L.map('worker-location-map').setView([48.8566, 2.3522], 5);
            window.leafletMap = map;

            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '© OpenStreetMap contributors'
            }).addTo(map);

            let marker = null;

            const setMarker = (lat, lng, zoom = 13) => {
                if (marker) {
                    marker.setLatLng([lat, lng]);
                } else {
                    marker = L.marker([lat, lng]).addTo(map);
                }
                window.leafletMarker = marker;
                map.setView([lat, lng], zoom);
            };

            const geocode = async (value) => {
                if (!value || !value.trim()) {
                    return;
                }
                try {
                    const response = await fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(value)}`);
                    const data = await response.json();
                    if (Array.isArray(data) && data.length > 0) {
                        setMarker(parseFloat(data[0].lat), parseFloat(data[0].lon));
                    }
                } catch (error) {
                    console.error('Geocoding error:', error);
                }
            };

            map.on('click', function (e) {
                const lat = e.latlng.lat;
                const lng = e.latlng.lng;
                setMarker(lat, lng);

                fetch(`https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lng}`)
                    .then(response => response.json())
                    .then(data => {
                        if (data.display_name) {
                            input.value = data.display_name;
                            input.dispatchEvent(new Event('change', { bubbles: true }));
                        }
                    })
                    .catch(error => console.error('Reverse geocoding error:', error));
            });

            input.addEventListener('change', () => geocode(input.value));
            input.addEventListener('blur', () => geocode(input.value));

            if (input.value && input.value.trim() !== '') {
                geocode(input.value);
            }
        }
        document.addEventListener('DOMContentLoaded', initEditMap);
        document.addEventListener('turbo:load', initEditMap);
    </script>
{% endblock %}
