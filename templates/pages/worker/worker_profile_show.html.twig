{% extends 'layout_app.html.twig' %}

{% set topbar_title = 'Profile' %}

{% block main %}
<div class="max-w-2xl">
    {% if is_public_view|default(false) %}
        <a href="javascript:history.back()" class="text-sm text-[#0FAF7A] hover:underline">â† Back</a>
    {% else %}
        <a href="{{ path('worker_profiles_index') }}" class="text-sm text-[#0FAF7A] hover:underline">â† Back to list</a>
    {% endif %}
    <h1 class="text-2xl font-bold mt-3">{{ profile.title }}</h1>

    <div class="rounded-xl border bg-white p-6 mt-4 dark:border-slate-700 dark:bg-slate-900">
        <div class="mb-3 text-sm text-slate-600 dark:text-slate-400">Location: {{ profile.location }}</div>
        {% if profile.phoneNumber %}
            <div class="mb-3 text-sm text-slate-600 dark:text-slate-400">Phone: {{ profile.phoneNumber }}</div>
        {% endif %}
        {% if profile.email %}
            <div class="mb-3 text-sm text-slate-600 dark:text-slate-400">Email: {{ profile.email }}</div>
        {% endif %}
        <div id="worker-show-map" class="mb-4 h-56 w-full rounded-xl border border-slate-200 dark:border-slate-700 overflow-hidden"></div>
        <div class="mb-3 text-sm text-slate-600 dark:text-slate-400">Hourly rate: â‚¬{{ profile.hourlyRate }}</div>
        <div class="mb-3 text-sm text-slate-600 dark:text-slate-400">Experience: {{ profile.experienceYears }} years</div>
        <div class="mb-3 text-slate-700 dark:text-slate-300">{{ profile.bio }}</div>
        {% if not is_public_view|default(false) %}
        <div class="flex gap-3 mt-4">
            <a href="{{ path('worker_profiles_edit', {id: profile.id}) }}" class="rounded-lg bg-[#0FAF7A] px-4 py-2 text-white">Edit</a>
            <form method="POST" action="{{ path('worker_profiles_delete', {id: profile.id}) }}" onsubmit="return confirm('Delete this profile?');">
                <button type="submit" class="rounded-lg border border-red-600 px-4 py-2 text-red-600">Delete</button>
            </form>
        </div>
        {% endif %}

    </div>
</div>
{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin=""/>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
    <script>
        document.addEventListener('DOMContentLoaded', async function () {
            const mapEl = document.getElementById('worker-show-map');
            const locationText = {{ (profile.location ?? '')|json_encode|raw }};

            if (!mapEl || typeof L === 'undefined') {
                return;
            }

            const map = L.map('worker-show-map', { zoomControl: true, dragging: true }).setView([48.8566, 2.3522], 5);
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '© OpenStreetMap contributors'
            }).addTo(map);

            if (!locationText || !locationText.trim()) {
                return;
            }

            try {
                const response = await fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(locationText)}`);
                const data = await response.json();
                if (Array.isArray(data) && data.length > 0) {
                    const lat = parseFloat(data[0].lat);
                    const lon = parseFloat(data[0].lon);
                    L.marker([lat, lon]).addTo(map);
                    map.setView([lat, lon], 13);
                }
            } catch (error) {
                console.error('Unable to geocode profile location:', error);
            }
        });
    </script>
{% endblock %}
