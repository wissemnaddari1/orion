{% extends 'layout_app.html.twig' %}

{% block title %}Mes Profils{% endblock %}

{% set topbar_title = 'Worker Profiles' %}

{% block main %}
<div class="min-h-screen bg-[#020617] py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-6xl mx-auto space-y-8">
        
        {# Header: title + New Profile button #}
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
            <div>
                <h1 class="text-4xl font-extrabold text-white tracking-tight">Profiles</h1>
                <p class="mt-2 text-slate-400">Manage your professional visibility and skills.</p>
            </div>
            
            {% if profiles|length == 0 %}
                <a href="{{ path('worker_profiles_new') }}" data-turbo="false"
                   class="inline-flex items-center justify-center gap-2 rounded-xl bg-[#0FAF7A] hover:bg-[#0c8f63] px-6 py-3 text-sm font-bold text-white shadow-lg shadow-[#0FAF7A]/20 transition-all duration-300 transform hover:-translate-y-0.5">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                    New Profile
                </a>
            {% endif %}
        </div>

        {# Grid of Profiles #}
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {% for profile in profiles %}
                <div class="group bg-[#0f172a] rounded-3xl p-6 border border-slate-800 hover:border-[#0FAF7A]/50 transition-all duration-300 shadow-xl flex flex-col justify-between relative overflow-hidden">
                    <div class="absolute top-0 right-0 w-24 h-24 bg-[#0FAF7A]/5 rounded-full blur-2xl -mr-12 -mt-12 group-hover:bg-[#0FAF7A]/10 transition-colors"></div>
                    
                    <div>
                        <div class="flex items-start justify-between mb-4">
                            <div class="w-12 h-12 rounded-2xl bg-[#0FAF7A]/10 flex items-center justify-center">
                                <svg class="w-6 h-6 text-[#0FAF7A]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                            </div>
                            <div class="flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[10px] font-bold uppercase
                                {% if profile.availabilityStatus == 'available' %}
                                    bg-emerald-500/10 text-emerald-400 border border-emerald-500/20
                                {% elseif profile.availabilityStatus == 'busy' %}
                                    bg-amber-500/10 text-amber-400 border border-amber-500/20
                                {% else %}
                                    bg-red-500/10 text-red-400 border border-red-500/20
                                {% endif %}">
                                <span class="w-1.5 h-1.5 rounded-full bg-current animate-pulse"></span>
                                {{ profile.availabilityStatus|capitalize }}
                            </div>
                        </div>

                        <h3 class="text-xl font-bold text-white mb-2 group-hover:text-[#0FAF7A] transition-colors leading-tight">
                            {{ profile.title }}
                        </h3>
                        
                        <div class="space-y-2 mb-6">
                            <div class="flex items-center text-sm text-slate-400">
                                <svg class="w-4 h-4 mr-2 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                                <span class="truncate">{{ profile.location }}</span>
                            </div>
                            <div class="flex items-center text-sm text-slate-400">
                                <svg class="w-4 h-4 mr-2 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 1.343-3 3s1.343 3 3 3 3-1.343 3-3-1.343-3-3-3z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zM7.05 15.55l1.41-1.41M15.55 7.05l1.41-1.41M15.55 15.55l1.41 1.41M7.05 8.45l1.41 1.41"></path></svg>
                                <span>€{{ profile.hourlyRate }}/h</span>
                            </div>
                        </div>
                    </div>

                    <div class="flex items-center justify-between pt-6 border-t border-slate-800/50">
                        <div class="flex items-center gap-2">
                            <a href="{{ path('worker_profiles_show', {id: profile.id}) }}" class="text-sm font-bold text-[#0FAF7A] hover:text-[#0c8f63] transition-colors">Details</a>
                            <span class="w-1 h-1 rounded-full bg-slate-700"></span>
                            <a href="{{ path('worker_profiles_edit', {id: profile.id}) }}" class="text-sm font-bold text-slate-400 hover:text-white transition-colors">Edit</a>
                        </div>
                        
                        <form method="post" action="{{ path('worker_profiles_delete', {id: profile.id}) }}" class="inline" onsubmit="return confirm('Delete this profile permanently?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ profile.id) }}">
                            <button type="submit" class="text-slate-500 hover:text-red-500 transition-colors">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                            </button>
                        </form>
                    </div>
                </div>
            {% else %}
                <div class="col-span-1 md:col-span-2 lg:col-span-3 py-24 px-6 text-center bg-[#0f172a] rounded-3xl border border-dashed border-slate-800">
                    <div class="w-20 h-20 bg-slate-800/50 rounded-full flex items-center justify-center mx-auto mb-6">
                        <svg class="w-10 h-10 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                    </div>
                    <h3 class="text-2xl font-bold text-white mb-2">No profiles yet</h3>
                    <p class="text-slate-400 max-w-sm mx-auto mb-8">Create your professional profile to start receiving offers and appearing in searches.</p>
                    <a href="{{ path('worker_profiles_new') }}" data-turbo="false"
                       class="inline-flex items-center justify-center gap-2 rounded-xl bg-[#0FAF7A] hover:bg-[#0c8f63] px-8 py-3.5 text-base font-bold text-white shadow-lg shadow-[#0FAF7A]/20 transition-all duration-300 transform hover:-translate-y-0.5">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                        Create My Profile
                    </a>
                </div>
            {% endfor %}
        </div>
    </div>
</div>
{% endblock %}
