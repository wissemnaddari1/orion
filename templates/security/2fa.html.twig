{% extends 'base.html.twig' %}

{% block title %}Two-Factor Authentication — Orion{% endblock %}

{% block body %}
<div class="min-h-screen flex items-center justify-center px-4 py-12
            bg-gradient-to-br from-emerald-600/10 via-white to-emerald-700/5
            dark:from-emerald-500/10 dark:via-slate-950 dark:to-emerald-500/5">
    <div class="w-full max-w-md">
        <div class="rounded-2xl border border-slate-200 bg-white/90 p-8 shadow-xl backdrop-blur
                    transition-all duration-300 hover:shadow-2xl hover:-translate-y-1
                    dark:border-slate-800 dark:bg-slate-950/70">

            {# Brand header #}
            <div class="text-center mb-2">
                <a href="{{ path('app_login') }}" class="inline-flex items-center justify-center">
                    <img
                        src="{{ asset('images/orion_light_mode.png') }}"
                        alt="Orion Logo"
                        class="h-20 sm:h-24 w-auto object-contain
                               drop-shadow-[0_0_25px_rgba(16,185,129,0.55)]
                               hover:scale-105 transition-transform duration-300"
                    />
                </a>

                <h1 class="mt-8 text-2xl font-extrabold tracking-tight text-slate-900 dark:text-white">
                    Two-Factor Authentication
                </h1>
                <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">
                    Enter the 6-digit code from your authenticator app.
                </p>
                {% if email is defined %}
                <p class="mt-1 text-xs text-slate-500 dark:text-slate-400">
                    Logging in as: <strong>{{ email }}</strong>
                </p>
                {% endif %}
            </div>

            <div id="twofa-error" class="mt-4 p-4 rounded-xl bg-red-100 text-red-800 dark:bg-red-900/20 dark:text-red-400 hidden" role="alert" style="display: none;"></div>

            {# Lockout message #}
            {% if is_locked %}
                <div class="mt-4 p-4 rounded-xl bg-amber-100 text-amber-800 dark:bg-amber-900/20 dark:text-amber-400" role="alert">
                    Too many failed attempts. Please try again in 30 seconds.
                </div>
            {% endif %}

            {# Attempts remaining #}
            {% if attempts_remaining is defined and attempts_remaining > 0 and attempts_remaining < 5 and not is_locked %}
                <div class="mt-4 p-3 rounded-xl bg-slate-100 text-slate-700 dark:bg-slate-800/50 dark:text-slate-300 text-sm">
                    {{ attempts_remaining }} attempt{{ attempts_remaining != 1 ? 's' : '' }} remaining.
                </div>
            {% endif %}

            {# Stateless 2FA verify: POST /api/auth/2fa/verify with temp_token + otp_code #}
            <form id="twofa-form" method="post" action="#" class="mt-8 space-y-6" novalidate>

                {# OTP Code Input #}
                <div>
                    <label for="otp_code" class="block text-sm font-semibold text-slate-700 dark:text-slate-200 mb-2">
                        6-Digit Code
                    </label>
                    <input
                        type="text"
                        id="otp_code"
                        name="otp_code"
                        inputmode="numeric"
                        pattern="[0-9]*"
                        maxlength="6"
                        autocomplete="one-time-code"
                        autofocus
                        required
                        {% if is_locked %}disabled{% endif %}
                        class="w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-slate-900
                               placeholder:text-slate-400
                               focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20 focus:outline-none
                               disabled:opacity-50 disabled:cursor-not-allowed
                               dark:border-slate-600 dark:bg-slate-800 dark:text-white dark:placeholder:text-slate-500
                               dark:focus:border-emerald-500 dark:focus:ring-emerald-500/20
                               text-center text-2xl tracking-widest font-mono"
                        placeholder="000000"
                    />
                    <p class="mt-2 text-xs text-slate-500 dark:text-slate-400">
                        You can also use a backup code if you've saved one.
                    </p>
                </div>

                {# Submit Button #}
                <button
                    type="submit"
                    {% if is_locked %}disabled{% endif %}
                    class="w-full rounded-xl bg-emerald-600 px-4 py-3 text-sm font-semibold text-white
                           transition hover:bg-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-500/20
                           disabled:opacity-50 disabled:cursor-not-allowed
                           dark:bg-emerald-500 dark:hover:bg-emerald-600"
                >
                    {% if is_locked %}
                        Please wait...
                    {% else %}
                        Verify & Continue
                    {% endif %}
                </button>
            </form>

            {# Back to login link #}
            <div class="mt-6 text-center">
                <a href="{{ path('app_login') }}" class="text-sm text-emerald-600 hover:underline dark:text-emerald-400">
                    Back to login
                </a>
            </div>

            {# Help text #}
            <div class="mt-6 p-4 rounded-xl bg-slate-100 dark:bg-slate-800/50 text-xs text-slate-600 dark:text-slate-400">
                <strong>Tip:</strong> Open your authenticator app (Google Authenticator, Authy, etc.) and enter the 6-digit code shown. If you've lost access, use a backup code you saved when enabling 2FA.
            </div>
        </div>
    </div>
</div>

<script>
(function() {
    const params = new URLSearchParams(window.location.search || '');
    const tempToken = params.get('temp_token');

    // Auto-focus and format OTP input
    const input = document.getElementById('otp_code');
    const form = document.getElementById('twofa-form');
    const errorBox = document.getElementById('twofa-error');
    const submitButton = form ? form.querySelector('button[type="submit"]') : null;
    
    let isSubmitting = false; // Prevent double submission

    function showError(msg) {
        if (!errorBox) return;
        errorBox.textContent = msg || 'Verification failed.';
        errorBox.classList.remove('hidden');
        errorBox.style.display = 'block';
    }
    
    function hideError() {
        if (!errorBox) return;
        errorBox.classList.add('hidden');
        errorBox.style.display = 'none';
        errorBox.textContent = '';
    }
    
    function setSubmitting(state) {
        isSubmitting = state;
        if (submitButton) {
            submitButton.disabled = state;
            if (state) {
                submitButton.textContent = 'Verifying...';
            } else {
                submitButton.textContent = 'Verify & Continue';
            }
        }
        if (input) {
            input.disabled = state;
        }
    }

    if (form) {
        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            
            // Prevent double submission
            if (isSubmitting) {
                return;
            }
            
            hideError();
            setSubmitting(true);

            if (!tempToken) {
                showError('Missing temporary token. Please log in again.');
                setSubmitting(false);
                return;
            }

            const code = input ? String(input.value || '').trim() : '';
            if (!code) {
                showError('Please enter the 6-digit code.');
                setSubmitting(false);
                return;
            }

            try {
                const res = await fetch('/api/auth/2fa/verify', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ temp_token: tempToken, otp_code: code }),
                });
                
                let data = {};
                try {
                    data = await res.json();
                } catch (jsonErr) {
                    // If response is not JSON, it's likely an error
                    if (!res.ok) {
                        showError('Invalid response from server.');
                        setSubmitting(false);
                        return;
                    }
                }
                
                if (!res.ok) {
                    // If token was already consumed (double submission), check if we already have a token
                    // This happens when auto-submit triggers twice - first succeeds, second fails
                    if (data.error === 'invalid_temp_token') {
                        const existingToken = localStorage.getItem('token');
                        if (existingToken) {
                            // First request already succeeded and stored token, just redirect
                            const role = (data.user && data.user.role) ? String(data.user.role) : 'CLIENT';
                            const routes = {
                                'ADMIN': '{{ path('admin_dashboard') }}',
                                'WORKER': '{{ path('worker_dashboard') }}',
                                'CLIENT': '{{ path('client_dashboard') }}'
                            };
                            window.location.href = routes[role] || routes.CLIENT;
                            return;
                        }
                    }
                    showError(data.message || 'Invalid code.');
                    setSubmitting(false);
                    return;
                }

                if (!data.token) {
                    showError('Verification failed (no token returned).');
                    setSubmitting(false);
                    return;
                }

                // Hide any error messages before successful redirect
                hideError();

                localStorage.setItem('token', data.token);

                const role = (data.user && data.user.role) ? String(data.user.role) : 'CLIENT';
                const routes = {
                    'ADMIN': '{{ path('admin_dashboard') }}',
                    'WORKER': '{{ path('worker_dashboard') }}',
                    'CLIENT': '{{ path('client_dashboard') }}'
                };
                // Redirect immediately - don't reset submitting state
                window.location.href = routes[role] || routes.CLIENT;
            } catch (err) {
                console.error('2FA verification error:', err);
                showError('Verification failed. Please try again.');
                setSubmitting(false);
            }
        });
    }

    if (input && !input.disabled) {
        input.focus();
        
        // Only allow digits
        input.addEventListener('input', function(e) {
            e.target.value = e.target.value.replace(/[^0-9]/g, '');
        });
        
        // Auto-submit when 6 digits are entered
        input.addEventListener('input', function(e) {
            if (e.target.value.length === 6 && !isSubmitting) {
                // Small delay to ensure the value is set
                setTimeout(() => {
                    if (form && !isSubmitting && submitButton && !submitButton.disabled) {
                        form.requestSubmit();
                    }
                }, 100);
            }
        });
    }
})();
</script>
{% endblock %}
