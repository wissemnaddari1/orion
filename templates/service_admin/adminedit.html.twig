{% extends 'layout_admin.html.twig' %}

{% block title %}Edit Service Request #{{ service.id }}{% endblock %}

{% block main %}
<div class="max-w-4xl mx-auto space-y-6">
    {# Breadcrumbs #}
    <nav class="flex items-center gap-2 text-sm text-slate-500 dark:text-slate-400">
        <a href="{{ path('admin_services_index') }}" class="hover:text-blue-600 transition-colors">Service Management</a>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7"/></svg>
        <span class="text-slate-900 dark:text-white font-medium">Edit Request</span>
    </nav>

    <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl shadow-lg overflow-hidden">
        {# Header Area #}
        <div class="px-8 py-6 border-b border-slate-100 dark:border-slate-800 bg-slate-50/50 dark:bg-slate-800/30">
            <h1 class="text-2xl font-bold text-slate-900 dark:text-white">Update Content</h1>
            <p class="text-slate-500 dark:text-slate-400 text-sm">You are moderating the public details of this service request.</p>
        </div>

        <form method="POST" class="p-8 space-y-8">
            {# Information Grid (Read Only + Category Selection) #}
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 p-4 bg-blue-50/50 dark:bg-blue-900/10 rounded-lg border border-blue-100 dark:border-blue-900/30">
                <div class="space-y-4">
                    <div>
                        <span class="block text-xs font-semibold text-blue-600 dark:text-blue-400 uppercase tracking-wider">Client</span>
                        <span class="text-sm font-medium">{{ service.client.firstName }} {{ service.client.lastName }}</span>
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-blue-600 dark:text-blue-400 uppercase tracking-wider mb-1">Category</label>
                        <select name="category_id" class="w-full bg-white dark:bg-slate-800 border border-slate-300 dark:border-slate-700 rounded-md text-sm p-2 outline-none focus:ring-2 focus:ring-blue-500">
                            {% for category in categories %}
                                <option value="{{ category.id }}" {{ service.Category and service.Category.id == category.id ? 'selected' : '' }}>
                                    {{ category.name }}
                                </option>
                            {% endfor %}
                        </select>
                    </div>
                </div>
                <div class="space-y-4">
                    <div>
                        <span class="block text-xs font-semibold text-blue-600 dark:text-blue-400 uppercase tracking-wider">created at</span>
                        <span class="text-sm font-medium">{{ service.createdAt ? service.createdAt|date('M d, Y') : 'N/A' }}</span>
                        
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-blue-600 dark:text-blue-400 uppercase tracking-wider mb-1">Freelancer Level</label>
                        <select name="level" class="w-full bg-white dark:bg-slate-800 border border-slate-300 dark:border-slate-700 rounded-md text-sm p-2 outline-none focus:ring-2 focus:ring-blue-500">
                            <option value="ENTRY" {{ service.level == 'ENTRY' ? 'selected' : '' }}>ENTRY</option>
                            <option value="INTERMEDIATE" {{ service.level == 'INTERMEDIATE' ? 'selected' : '' }}>INTERMEDIATE</option>
                            <option value="EXPERT" {{ service.level == 'EXPERT' ? 'selected' : '' }}>EXPERT</option>
                            <option value="SPECIALIST" {{ service.level == 'SPECIALIST' ? 'selected' : '' }}>SPECIALIST</option>
                        </select>
                    </div>
                </div>
            </div>
            {# Editable Section #}
            <div class="space-y-6">
                {# 1. Title #}
                <div class="space-y-2">
                    <label for="title" class="block text-sm font-bold text-slate-700 dark:text-slate-300">
                        Service Title <span class="text-red-500">*</span>
                    </label>
                    <input type="text" id="title" name="title" value="{{ service.title }}" required
                        class="w-full px-4 py-3 rounded-lg border border-slate-300 dark:border-slate-700 dark:bg-slate-800 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all outline-none">
                </div>

                {# 2. Budget and Duration Group #}
                <div class="space-y-4 p-4 bg-slate-50 dark:bg-slate-800/50 rounded-lg border border-slate-100 dark:border-slate-800">
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs font-semibold text-blue-600 dark:text-blue-400 uppercase tracking-wider mb-1">Min Budget (€)</label>
                            <input type="number" step="0.01" name="budget_min" value="{{ old_data.budget_min|default(service.budgetMin) }}" 
                                class="w-full bg-white dark:bg-slate-800 border border-slate-300 dark:border-slate-700 rounded-md text-sm p-2 outline-none focus:ring-2 focus:ring-blue-500">
                        </div>
                        <div>
                            <label class="block text-xs font-semibold text-blue-600 dark:text-blue-400 uppercase tracking-wider mb-1">Max Budget (€)</label>
                            <input type="number" step="0.01" name="budget_max" value="{{ old_data.budget_max|default(service.budgetMax) }}" 
                                class="w-full bg-white dark:bg-slate-800 border border-slate-300 dark:border-slate-700 rounded-md text-sm p-2 outline-none focus:ring-2 focus:ring-blue-500">
                        </div>
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-blue-600 dark:text-blue-400 uppercase tracking-wider mb-1">Duration (Days)</label>
                        <input type="number" name="duration" value="{{ old_data.duration|default(service.duration) }}" 
                            class="w-full bg-white dark:bg-slate-800 border border-slate-300 dark:border-slate-700 rounded-md text-sm p-2 outline-none focus:ring-2 focus:ring-blue-500">
                    </div>
                </div>

                {# 3. Description (Last) #}
                <div class="space-y-2">
                    <label for="description" class="block text-sm font-bold text-slate-700 dark:text-slate-300">
                        Detailed Description <span class="text-red-500">*</span>
                    </label>
                    <textarea id="description" name="description" rows="10" required
                            class="w-full px-4 py-3 rounded-lg border border-slate-300 dark:border-slate-700 dark:bg-slate-800 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all outline-none resize-none font-sans">{{ service.description }}</textarea>
                </div>
            </div>
            


            {# Form Actions #}
            <div class="pt-6 border-t border-slate-100 dark:border-slate-800 flex items-center justify-between">
                <button type="button" onclick="history.back()" class="px-6 py-2.5 text-sm font-semibold text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white transition-colors">
                    Discard Changes
                </button>
                <button type="submit" class="px-8 py-2.5 bg-emerald-600 hover:bg-emerald-700 text-white font-bold rounded-lg shadow-md shadow-emerald-500/20 transition-all transform active:scale-95">
                    Save Updates
                </button>
            </div>
        </form>
    </div>
</div>
{% endblock %}