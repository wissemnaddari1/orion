{% extends 'layout_admin.html.twig' %}

{% block main %}
<div class="max-w-3xl mx-auto">

    {# Header #}
    <div class="flex justify-between items-center mb-8">
        <div>
            <h1 class="text-2xl font-bold text-slate-900 dark:text-white">New Requirement</h1>
            <p class="text-slate-500 dark:text-slate-400">
                For <span class="text-emerald-500 font-semibold">{{ service.title }}</span>
                — {{ service.client.firstName }} {{ service.client.lastName }}
            </p>
        </div>
        <a href="{{ path('admin_service_requirements', {id: service.id}) }}" 
            class="text-slate-500 hover:text-slate-700 dark:hover:text-white text-sm font-medium transition-colors">
            ← Cancel
        </a>
    </div>

    {% for message in app.flashes('error') %}
        <div class="mb-4 p-4 bg-red-50 border-l-4 border-red-500 text-red-700 rounded-lg text-sm">
            {{ message }}
        </div>
    {% endfor %}

    <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl shadow-sm">
        <form method="POST" class="p-6 lg:p-8 space-y-6">

            <div>
                <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">Requirement Title</label>
                <input type="text" name="title" placeholder="e.g. Project Specifications Document" required
                    class="w-full px-4 py-2 bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-lg dark:text-white outline-none focus:ring-2 focus:ring-emerald-500">
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">Details</label>
                <textarea name="details" rows="4" placeholder="Describe what the freelancer needs to provide..." required
                    class="w-full px-4 py-2 bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-lg dark:text-white outline-none focus:ring-2 focus:ring-emerald-500"></textarea>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div>
                    <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">Answer Format</label>
                    <select name="answer_format" class="w-full px-4 py-2 bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-lg dark:text-white outline-none focus:ring-2 focus:ring-emerald-500">
                        <option value="text">Text</option>
                        <option value="pdf">PDF Document</option>
                        <option value="image">Image File</option>
                        <option value="zip">ZIP File</option>
                    </select>
                </div>

                <div>
                    <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">Priority Level</label>
                    <select name="priority_level" class="w-full px-4 py-2 bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-lg dark:text-white outline-none focus:ring-2 focus:ring-emerald-500">
                        <option value="1">Low</option>
                        <option value="2" selected>Medium</option>
                        <option value="3">High</option>
                    </select>
                </div>

                <div class="flex items-end pb-2">
                    <label class="flex items-center gap-3 cursor-pointer">
                        <div class="relative">
                            <input type="checkbox" name="is_mandatory" class="sr-only peer">
                            <div class="w-10 h-6 bg-slate-200 dark:bg-slate-700 rounded-full peer-checked:bg-emerald-500 transition-colors"></div>
                            <div class="absolute top-1 left-1 w-4 h-4 bg-white rounded-full shadow transition-transform peer-checked:translate-x-4"></div>
                        </div>
                        <span class="text-sm font-medium text-slate-700 dark:text-slate-300">Mandatory</span>
                    </label>
                </div>
            </div>

            <div class="flex items-center justify-end gap-4 pt-4 border-t border-slate-100 dark:border-slate-800">
                <a href="{{ path('admin_service_requirements', {id: service.id}) }}" 
                    class="text-slate-500 hover:text-slate-700 dark:hover:text-white">Cancel</a>
                <button type="submit" 
                    class="px-6 py-2 bg-emerald-600 hover:bg-emerald-700 text-white font-semibold rounded-lg shadow-md transition-all">
                    Create Requirement
                </button>
            </div>
        </form>
    </div>
</div>
{% endblock %}