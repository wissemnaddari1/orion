{% extends 'layout_admin.html.twig' %}

{% block main %}
<div class="max-w-6xl mx-auto">

    {# Header #}
    <div class="flex justify-between items-center mb-8">
        <div>
            <h1 class="text-2xl font-bold text-slate-900 dark:text-white">Requirements</h1>
            <p class="text-slate-500 dark:text-slate-400">
                Managing requirements for 
                <span class="text-emerald-500 font-semibold">{{ service.title }}</span>
                — {{ service.client.firstName }} {{ service.client.lastName }}
            </p>
        </div>
        <div class="flex items-center gap-3">
            <a href="{{ path('admin_services_index') }}" 
                class="px-4 py-2 text-slate-500 hover:text-slate-700 dark:hover:text-white text-sm font-medium transition-colors">
                ← Back
            </a>
            <a href="{{ path('admin_requirement_create', {id: service.id}) }}" 
                class="flex items-center gap-2 px-5 py-2.5 bg-emerald-600 hover:bg-emerald-700 text-white rounded-lg font-bold transition-all shadow-md shadow-emerald-500/20">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                </svg>
                Add Requirement
            </a>
        </div>
    </div>

    {# Stats Row #}
    <div class="grid grid-cols-3 gap-4 mb-6">
        <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl p-4 flex items-center gap-4">
            <div class="p-3 bg-blue-100 dark:bg-blue-900/30 text-blue-600 rounded-lg">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                </svg>
            </div>
            <div>
                <p class="text-xs text-slate-500 font-medium uppercase tracking-wider">Total</p>
                <p class="text-2xl font-bold text-slate-900 dark:text-white">{{ requirements|length }}</p>
            </div>
        </div>
        <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl p-4 flex items-center gap-4">
            <div class="p-3 bg-red-100 dark:bg-red-900/30 text-red-500 rounded-lg">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
                </svg>
            </div>
            <div>
                <p class="text-xs text-slate-500 font-medium uppercase tracking-wider">Mandatory</p>
                <p class="text-2xl font-bold text-slate-900 dark:text-white">
                    {{ requirements|filter(r => r.isMandatory)|length }}
                </p>
            </div>
        </div>
        <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl p-4 flex items-center gap-4">
            <div class="p-3 bg-amber-100 dark:bg-amber-900/30 text-amber-500 rounded-lg">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                </svg>
            </div>
            <div>
                <p class="text-xs text-slate-500 font-medium uppercase tracking-wider">High Priority</p>
                <p class="text-2xl font-bold text-slate-900 dark:text-white">
                    {{ requirements|filter(r => r.priorityLevel == 3)|length }}
                </p>
            </div>
        </div>
    </div>

    {# Table #}
    <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl shadow-sm overflow-hidden">
        <table class="w-full text-left border-collapse">
            <thead class="bg-slate-50 dark:bg-slate-800/50 border-b border-slate-200 dark:border-slate-800">
                <tr>
                    <th class="px-6 py-4 text-sm font-semibold text-slate-700 dark:text-slate-300">#</th>
                    <th class="px-6 py-4 text-sm font-semibold text-slate-700 dark:text-slate-300">Requirement</th>
                    <th class="px-6 py-4 text-sm font-semibold text-slate-700 dark:text-slate-300">Format</th>
                    <th class="px-6 py-4 text-sm font-semibold text-slate-700 dark:text-slate-300">Priority</th>
                    <th class="px-6 py-4 text-sm font-semibold text-slate-700 dark:text-slate-300">Mandatory</th>
                    <th class="px-6 py-4 text-sm font-semibold text-slate-700 dark:text-slate-300 text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
                {% for req in requirements %}
                <tr class="hover:bg-slate-50/50 dark:hover:bg-slate-800/30 transition-colors">
                    <td class="px-6 py-4 text-sm text-slate-400 font-mono">
                        {{ loop.index }}
                    </td>
                    <td class="px-6 py-4">
                        <p class="font-semibold text-slate-900 dark:text-white">{{ req.title }}</p>
                        <p class="text-xs text-slate-500 dark:text-slate-400 mt-1 leading-relaxed max-w-md">
                            {{ req.details|slice(0, 100) }}{% if req.details|length > 100 %}…{% endif %}
                        </p>
                    </td>
                    <td class="px-6 py-4">
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-md text-xs font-medium bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-300">
                            {{ req.answerFormat|upper }}
                        </span>
                    </td>
                    <td class="px-6 py-4">
                        {% if req.priorityLevel == 3 %}
                            <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-bold bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400">
                                <span class="w-1.5 h-1.5 rounded-full bg-red-500"></span> High
                            </span>
                        {% elseif req.priorityLevel == 2 %}
                            <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-bold bg-amber-100 text-amber-700 dark:bg-amber-900/30 dark:text-amber-400">
                                <span class="w-1.5 h-1.5 rounded-full bg-amber-500"></span> Medium
                            </span>
                        {% else %}
                            <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-bold bg-slate-100 text-slate-600 dark:bg-slate-800 dark:text-slate-400">
                                <span class="w-1.5 h-1.5 rounded-full bg-slate-400"></span> Low
                            </span>
                        {% endif %}
                    </td>
                    <td class="px-6 py-4">
                        {% if req.isMandatory %}
                            <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-bold bg-emerald-100 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-400">
                                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                                Yes
                            </span>
                        {% else %}
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold bg-slate-100 text-slate-500 dark:bg-slate-800 dark:text-slate-400">
                                No
                            </span>
                        {% endif %}
                    </td>
                    <td class="px-6 py-4">
                        <div class="flex items-center justify-end gap-3">
                            <a href="{{ path('admin_requirement_edit', {id: req.id}) }}" 
                                class="text-amber-600 hover:text-amber-700 font-medium text-sm transition-colors">
                                Edit
                            </a>
                            <form method="POST" action="{{ path('admin_requirement_delete', {id: req.id}) }}" 
                                class="inline" onsubmit="return confirm('Delete this requirement?')">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ req.id) }}">
                                <button type="submit" class="text-red-500 hover:text-red-700 transition-colors">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                                    </svg>
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="6" class="px-6 py-16 text-center">
                        <div class="flex flex-col items-center">
                            <svg class="w-12 h-12 text-slate-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                            </svg>
                            <p class="text-lg font-medium text-slate-500">No requirements yet</p>
                            <p class="text-sm text-slate-400 mt-1">Add the first requirement for this service.</p>
                        </div>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}