{% for req in requests %}
{# Added 'group' for better hover control #}
                <tr class="hover:bg-slate-50/50 dark:hover:bg-slate-800/30 transition-colors group">
                    <td class="px-6 py-4 font-medium text-slate-900 dark:text-white">
                        {# The link to the detail page #}
                        <a href="{{ path('request_show', {id: req.id}) }}" class="flex items-center hover:text-emerald-600 transition-colors">
                            <span class="border-b border-transparent group-hover:border-emerald-500/50">
                                {{ req.title }}
                            </span>
                            {# Subtle arrow icon that appears on hover #}
                            <svg class="w-3 h-3 ml-2 opacity-0 group-hover:opacity-100 transition-opacity text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                            </svg>
                        </a>
                    </td>
                    <td class="px-6 py-4 text-sm text-slate-600 dark:text-slate-400">
                        {{ req.budgetMin|number_format(0) }}€ - {{ req.budgetMax|number_format(0) }}€
                    </td>
                    <td class="px-6 py-4">
                        <span class="px-2 py-1 text-xs font-medium rounded-full 
                            {% if req.level|upper == 'ENTRY' %} bg-emerald-100 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-400
                            {% elseif req.level|upper == 'INTERMEDIATE' %} bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400
                            {% elseif req.level|upper == 'EXPERT' %} bg-indigo-100 text-indigo-700 dark:bg-indigo-900/30 dark:text-indigo-400
                            {% elseif req.level|upper == 'SPECIALIST' %} bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400
                            {% else %} bg-slate-100 text-slate-700 dark:bg-slate-800 dark:text-slate-400 {% endif %}">
                            {{ req.level }}
                        </span>
                    </td>
                    <td class="px-6 py-4 text-sm text-slate-500">
                        {{ req.createdAt ? req.createdAt|date('M d, Y') : 'N/A' }}
                    </td>
                    <td class="px-6 py-4 text-right space-x-3">
                        <a href="{{ path('request_edit', {id: req.id}) }}" class="text-amber-600 hover:text-amber-700 font-medium text-sm">Edit</a>
                        <form method="POST" action="{{ path('request_delete', {id: req.id}) }}" class="inline" onsubmit="return confirm('Are you sure?')">
                            <button class="text-red-600 hover:text-red-700 font-medium text-sm">Delete</button>
                        </form>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-600 dark:text-slate-400">
                        {% if req.duration %}
                            {{ req.duration }} Days
                        {% else %}
                            <span class="text-slate-400">Not set</span>
                        {% endif %}
                    </td>
                    <td class="px-6 py-4 text-right space-x-3">
                    {# The New Requirements Button #}
                        <a href="{{ path('requirement_manage', {id: req.id}) }}" 
                            class="inline-flex items-center px-3 py-1.5 bg-slate-100 hover:bg-slate-200 dark:bg-slate-800 dark:hover:bg-slate-700 text-slate-700 dark:text-slate-200 text-xs font-bold rounded-lg transition-colors">
                            <svg class="w-3.5 h-3.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path></svg>
                                Requirements
                        </a>                

                    </td>
                    <td class="px-6 py-4 text-right">
                        <div class="flex items-center justify-end gap-2">
                            {# COMPACT START SERVICE BUTTON (triggers AI matchmaking) #}
                            <form method="POST"
                                  action="{{ path('request_start_service', {id: req.id}) }}"
                                  class="inline"
                                  onsubmit="return confirm('Start AI matchmaking for this service request?');">
                                <button type="submit"
                                        class="flex items-center justify-center w-16 h-7 bg-emerald-600 hover:bg-emerald-700 text-white text-[10px] font-bold rounded uppercase tracking-tighter shadow-sm transition-all whitespace-nowrap">
                                    Start
                                </button>
                            </form>
                        </div>
                    </td>
                    <td class="px-6 py-4 text-right">
                        <div class="flex items-center justify-end gap-2">
                            {# Changed to a button with data-id and a class #}
                            <button 
                                data-id="{{ req.id }}"
                                data-title="{{ req.title }}"
                                data-description="{{ req.description }}"
                                class="ai-generate-btn flex items-center justify-center w-12 h-6 bg-emerald-600 hover:bg-emerald-700 text-white text-[10px] font-bold rounded uppercase tracking-tighter shadow-sm transition-all whitespace-nowrap"
                            >
                                generate
                            </button>
                        </div>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="5" class="px-6 py-12 text-center text-slate-500 dark:text-slate-400">
                        <div class="flex flex-col items-center">
                            <svg class="w-12 h-12 mb-4 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                            </svg>
                            <p>No service requests found. Click the button above to start.</p>
                        </div>
                    </td>
                </tr>
{% endfor %}
