{% extends 'layout_app.html.twig' %}

{% block main %}

<div class="max-w-4xl mx-auto">

    {# Breadcrumb #}
    <div class="mb-6">
        <a href="{{ path('request_list') }}" class="inline-flex items-center text-sm text-slate-500 hover:text-emerald-600 transition-colors">
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
            Back to Marketplace
        </a>
    </div>

    <div class="mb-8">
        <h1 class="text-2xl font-bold text-slate-900 dark:text-white">Edit Service Request</h1>
        <p class="text-slate-500">Updating: <span class="font-medium text-emerald-600">{{ serviceRequest.title }}</span></p>
    </div>

    <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl shadow-sm">
        <form method="POST" class="p-6 lg:p-8 space-y-6">
            
            {# Title #}
            <div>
                <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">Service Title</label>
                <input type="text" name="title" value="{{ serviceRequest.title }}" required 
                    class="w-full px-4 py-2 bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-lg dark:text-white outline-none focus:ring-2 focus:ring-emerald-500">
            </div>
                {# Category #}
            <div>
                <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">Service Category</label>
                <select name="category_id" required class="w-full px-4 py-2 bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-lg dark:text-white">
                    {% for category in categories %}
                        <option value="{{ category.id }}" 
                            {{ serviceRequest.category and serviceRequest.category.id == category.id ? 'selected' : '' }}>
                            {{ category.name }}
                        </option>
                    {% endfor %}
                </select>
            </div>

            {# Budget Range + Status Row (The Upgrade) #}
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-start">
                
                {# Dual Slider Column #}
                <div class="md:col-span-2 space-y-4">
                    <label class="block text-sm font-medium text-slate-700 dark:text-slate-300">Budget Range (€)</label>
                    
                    <div class="relative h-10 flex items-center">
                        <div class="absolute h-2 w-full bg-slate-200 dark:bg-slate-800 rounded-lg"></div>
                        
                        {# Pre-filled with Entity Data #}
                        <input type="range" id="range-min" min="100" max="10000" value="{{ serviceRequest.budgetMin }}" step="10"
                            class="absolute w-full h-2 appearance-none bg-transparent pointer-events-none cursor-pointer z-30">
                        
                        <input type="range" id="range-max" min="0" max="10000" value="{{ serviceRequest.budgetMax }}" step="10"
                            class="absolute w-full h-2 appearance-none bg-transparent pointer-events-none cursor-pointer z-30">
                    </div>

                    {# Interactive Number Inputs #}
                    <div class="grid grid-cols-2 gap-4">
                        <div class="bg-slate-50 dark:bg-slate-950 p-3 rounded-lg border border-slate-200 dark:border-slate-800">
                            <label class="text-[10px] uppercase tracking-wider text-slate-500 block mb-1">Min Budget</label>
                            <div class="flex items-center text-emerald-600 dark:text-emerald-400">
                                <input type="number" name="budget_min" id="input-min" value="{{ serviceRequest.budgetMin }}" 
                                    class="w-full bg-transparent font-bold text-lg outline-none border-none p-0 focus:ring-0">
                                <span class="font-bold text-lg">€</span>
                            </div>
                        </div>
                        <div class="bg-slate-50 dark:bg-slate-950 p-3 rounded-lg border border-slate-200 dark:border-slate-800">
                            <label class="text-[10px] uppercase tracking-wider text-slate-500 block mb-1">Max Budget</label>
                            <div class="flex items-center text-emerald-600 dark:text-emerald-400">
                                <input type="number" name="budget_max" id="input-max" value="{{ serviceRequest.budgetMax }}" 
                                    class="w-full bg-transparent font-bold text-lg outline-none border-none p-0 focus:ring-0">
                                <span class="font-bold text-lg">€</span>
                            </div>
                        </div>
                    </div>
                </div>

                {# Status Column #}
                <div>
                    <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">Freelancer Level</label>
                    <select name="level" class="w-full px-4 py-2 bg-white text-slate-900 dark:bg-slate-800 dark:text-white border border-slate-200 dark:border-slate-700 rounded-lg outline-none focus:ring-2 focus:ring-emerald-500">
                        <option value="ENTRY" {{ serviceRequest.level|upper == 'ENTRY' ? 'selected' : '' }}>Entry Level</option>
                        <option value="INTERMEDIATE" {{ serviceRequest.level|upper == 'INTERMEDIATE' ? 'selected' : '' }}>Intermediate</option>
                        <option value="EXPERT" {{ serviceRequest.level|upper == 'EXPERT' ? 'selected' : '' }}>Expert</option>
                        <option value="SPECIALIST" {{ serviceRequest.level|upper == 'SPECIALIST' ? 'selected' : '' }}>Specialist</option>
                    </select>
                </div>
            </div>
            <div>
                <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">Project Duration</label>
                <div class="relative flex items-center">
                    <input type="number" 
                        name="duration" 
                        value="{{ serviceRequest.duration }}" 
                        placeholder="e.g. 5"
                        class="w-full px-4 py-2 bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-lg dark:text-white outline-none focus:ring-2 focus:ring-emerald-500">
                    <span class="absolute right-4 text-slate-400 text-sm pointer-events-none">Days</span>
                </div>
            </div>
            {# Description #}
            <div>
                <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">Detailed Description</label>
                <textarea name="description" rows="5" class="w-full px-4 py-2 bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-lg dark:text-white outline-none focus:ring-2 focus:ring-emerald-500">{{ serviceRequest.description }}</textarea>
            </div>

            <div class="flex items-center justify-end gap-4 pt-4 border-t border-slate-100 dark:border-slate-800">
                <a href="{{ path('request_list') }}" class="text-slate-500 hover:text-slate-700 dark:hover:text-white">Cancel</a>
                <button type="submit" class="px-6 py-2 bg-emerald-600 hover:bg-emerald-700 text-white font-semibold rounded-lg shadow-md transition-all">Update Request</button>
            </div>
        </form>
    </div>

    {# Danger Zone #}
    <div class="mt-8 bg-red-50/50 dark:bg-red-900/10 border border-red-100 dark:border-red-900/30 rounded-xl p-6">
        <div class="flex items-center justify-between">
            <div>
                <h3 class="text-red-800 dark:text-red-400 font-semibold">Delete Request</h3>
                <p class="text-red-600/70 dark:text-red-400/60 text-sm">This action cannot be undone.</p>
            </div>
            <form method="POST" action="{{ path('request_delete', {id: serviceRequest.id}) }}" onsubmit="return confirm('Delete this request?')">
                <button class="px-4 py-2 bg-white dark:bg-slate-900 border border-red-200 dark:border-red-800 text-red-600 hover:bg-red-600 hover:text-white rounded-lg text-sm font-medium transition-all">
                    Delete
                </button>
            </form>
        </div>
    </div>
</div>

<script>
    const rangeMin = document.getElementById('range-min');
    const rangeMax = document.getElementById('range-max');
    const inputMin = document.getElementById('input-min');
    const inputMax = document.getElementById('input-max');

    function updateFromRange() {
        let minVal = parseInt(rangeMin.value);
        let maxVal = parseInt(rangeMax.value);
        if (minVal >= maxVal) {
            rangeMin.value = maxVal - 10;
            minVal = maxVal - 10;
        }
        inputMin.value = minVal;
        inputMax.value = maxVal;
    }

    function updateFromInput() {
        let minVal = parseInt(inputMin.value);
        let maxVal = parseInt(inputMax.value);
        if (minVal >= maxVal) { minVal = maxVal - 1; inputMin.value = minVal; }
        if (minVal < 0) { minVal = 0; inputMin.value = 0; }
        if (maxVal > 10000) { maxVal = 10000; inputMax.value = 10000; }
        rangeMin.value = minVal;
        rangeMax.value = maxVal;
    }

    rangeMin.addEventListener('input', updateFromRange);
    rangeMax.addEventListener('input', updateFromRange);
    inputMin.addEventListener('change', updateFromInput);
    inputMax.addEventListener('change', updateFromInput);
</script>

<style>
    /* Gray Arrows Style */
    input[type=range]::-webkit-slider-thumb {
        -webkit-appearance: none;
        appearance: none;
        width: 18px;
        height: 22px;
        background-color: #64748b;
        clip-path: polygon(0% 0%, 100% 0%, 100% 60%, 50% 100%, 0% 60%);
        cursor: pointer;
        pointer-events: auto;
        margin-top: -2px; 
    }
    input[type=range]::-moz-range-thumb {
        width: 18px;
        height: 22px;
        background-color: #64748b;
        clip-path: polygon(0% 0%, 100% 0%, 100% 60%, 50% 100%, 0% 60%);
        cursor: pointer;
        pointer-events: auto;
        border: none;
    }
    input[type=range] { pointer-events: none; }
    input::-webkit-outer-spin-button, input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
</style>
{% endblock %}