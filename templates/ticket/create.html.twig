{% extends 'layout_app.html.twig' %}

{% block title %}Create Support Ticket{% endblock %}

{% block main %}
<div class="max-w-4xl mx-auto space-y-6">
    <!-- Header -->
    <div class="bg-gradient-to-br from-white to-slate-50 dark:from-slate-900 dark:to-slate-800 rounded-xl border border-slate-200 dark:border-slate-700 shadow-lg p-6">
        <div class="flex items-center justify-between">
            <div class="flex items-center gap-4">
                <div class="w-14 h-14 rounded-xl bg-gradient-to-br from-emerald-600 to-teal-600 flex items-center justify-center shadow-lg">

                    <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"/>
                    </svg>
                </div>
                <div>
                    <h1 class="text-2xl font-bold text-slate-900 dark:text-white">Create Support Ticket</h1>
                    <p class="text-sm text-slate-600 dark:text-slate-400 mt-1">Submit a new support request</p>
                </div>
            </div>
            <a href="{{ path('ticket_list') }}" class="inline-flex items-center gap-2 px-4 py-2 bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 text-slate-700 dark:text-slate-200 rounded-lg font-medium transition-all">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
                </svg>
                Back
            </a>
        </div>
    </div>

    <!-- Form -->
    <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 shadow-lg overflow-hidden">
        <div class="bg-gradient-to-r from-emerald-600 to-teal-600 px-6 py-4">

            <h2 class="text-lg font-bold text-white flex items-center gap-2">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                </svg>
                Ticket Information
            </h2>
        </div>

        <div class="p-6">
            {{ form_start(form, {'attr': {'class': 'space-y-6', 'novalidate': 'novalidate', 'data-validate': 'ticket-create'}}) }}

                <div class="bg-slate-50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700 rounded-lg p-5">
                    <div class="flex items-center gap-2 mb-3">
                        <svg class="w-5 h-5 text-teal-600 dark:text-teal-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">

                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/>
                        </svg>
                        {{ form_label(form.category, 'Category', {'label_attr': {'class': 'text-sm font-semibold text-slate-700 dark:text-slate-300'}}) }}
                    </div>
                    {{ form_widget(form.category, {'attr': {'class': 'block w-full rounded-lg border-slate-300 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-100 shadow-sm focus:border-teal-500 focus:ring-2 focus:ring-teal-500 transition-all'}}) }}

                    {{ form_errors(form.category) }}
                    <p class="mt-2 text-xs text-slate-500 dark:text-slate-400">Select the most relevant category for your issue</p>
                </div>

                <div class="bg-slate-50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700 rounded-lg p-5">
                    <div class="flex items-center gap-2 mb-3">
                        <svg class="w-5 h-5 text-emerald-600 dark:text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">

                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 20l4-16m2 16l4-16M6 9h14M4 15h14"/>
                        </svg>
                        {{ form_label(form.subject, 'Subject', {'label_attr': {'class': 'text-sm font-semibold text-slate-700 dark:text-slate-300'}}) }}
                    </div>
                    {{ form_widget(form.subject, {'attr': {'class': 'block w-full rounded-lg border-slate-300 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-100 shadow-sm focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500 transition-all', 'placeholder': 'Brief summary of your issue'}}) }}

                    {{ form_errors(form.subject) }}
                    <p class="mt-2 text-xs text-slate-500 dark:text-slate-400">5-255 characters - Provide a clear and concise subject</p>
                </div>

                <div class="bg-slate-50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700 rounded-lg p-5">
                    <div class="flex items-center gap-2 mb-3">
                        <svg class="w-5 h-5 text-amber-600 dark:text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
                        </svg>
                        {{ form_label(form.priority, 'Priority', {'label_attr': {'class': 'text-sm font-semibold text-slate-700 dark:text-slate-300'}}) }}
                    </div>
                    {{ form_widget(form.priority, {'attr': {'class': 'block w-full rounded-lg border-slate-300 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-100 shadow-sm focus:border-amber-500 focus:ring-2 focus:ring-amber-500 transition-all'}}) }}
                    {{ form_errors(form.priority) }}
                    <p class="mt-2 text-xs text-slate-500 dark:text-slate-400">How urgent is this issue?</p>
                </div>

                <div class="bg-slate-50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700 rounded-lg p-5">
                    <div class="flex items-center gap-2 mb-3">
                        <svg class="w-5 h-5 text-teal-600 dark:text-teal-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">

                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/>
                        </svg>
                        {{ form_label(form.message, 'Description', {'label_attr': {'class': 'text-sm font-semibold text-slate-700 dark:text-slate-300'}}) }}
                    </div>
                    {{ form_widget(form.message, {'attr': {'class': 'block w-full rounded-lg border-slate-300 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-100 shadow-sm focus:border-teal-500 focus:ring-2 focus:ring-teal-500 transition-all resize-none', 'rows': 6, 'placeholder': 'Describe your issue in detail...'}}) }}

                    {{ form_errors(form.message) }}
                    <p class="mt-2 text-xs text-slate-500 dark:text-slate-400">Minimum 10 characters - The more details you provide, the faster we can help</p>
                </div>

                <div class="bg-slate-50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700 rounded-lg p-5">
                    <div class="flex items-center gap-2 mb-3">
                        <svg class="w-5 h-5 text-emerald-600 dark:text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13"/>
                        </svg>
                        {{ form_label(form.attachment, 'Attachment (optional)', {'label_attr': {'class': 'text-sm font-semibold text-slate-700 dark:text-slate-300'}}) }}
                    </div>
                    {{ form_widget(form.attachment, {'attr': {'class': 'block w-full text-sm text-slate-500 dark:text-slate-300 file:mr-4 file:py-2.5 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-gradient-to-r file:from-emerald-50 file:to-teal-50 file:text-emerald-700 hover:file:from-emerald-100 hover:file:to-teal-100 file:transition-all file:cursor-pointer dark:file:from-emerald-900/50 dark:file:to-teal-900/50 dark:file:text-emerald-300'}}) }}

                    {{ form_errors(form.attachment) }}
                    <p class="mt-2 text-xs text-slate-500 dark:text-slate-400">Max 10MB - Allowed: images, PDFs, Word docs, ZIP/RAR</p>
                </div>

                {{ form_widget(form._token) }}

                <div class="flex items-center justify-end gap-3 pt-6 border-t border-slate-200 dark:border-slate-800">
                    <a href="{{ path('ticket_list') }}" class="inline-flex items-center gap-2 px-6 py-2.5 bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 text-slate-700 dark:text-slate-200 rounded-lg font-medium transition-all">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                        </svg>
                        Cancel
                    </a>
                    <button type="submit" class="inline-flex items-center gap-2 px-6 py-2.5 bg-gradient-to-r from-emerald-600 to-teal-600 hover:from-emerald-700 hover:to-teal-700 text-white rounded-lg font-semibold transition-all shadow-lg shadow-emerald-500/30 hover:shadow-emerald-500/50">

                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
                        </svg>
                        Create Ticket
                    </button>
                </div>

            {{ form_end(form, {'render_rest': false}) }}
        </div>
    </div>

    <!-- Help Section -->
    <div class="bg-gradient-to-br from-emerald-50 to-teal-50 dark:from-emerald-900/20 dark:to-teal-900/20 rounded-xl border border-emerald-200 dark:border-emerald-800 p-6">
        <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-emerald-500 to-teal-500 flex items-center justify-center flex-shrink-0">

                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
            </div>
            <div>
                <h3 class="text-sm font-semibold text-slate-900 dark:text-white mb-2">Need Help?</h3>
                <p class="text-sm text-slate-600 dark:text-slate-400">Our support team typically responds within 24 hours. For urgent issues, select "High" or "Critical" priority.</p>
            </div>
        </div>
    </div>
</div>
{% endblock %}
