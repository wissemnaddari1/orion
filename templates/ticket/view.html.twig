{% extends 'layout_app.html.twig' %}

{% block title %}Ticket #{{ ticket.id }} - {{ ticket.subject }}{% endblock %}

{% block main %}
<div class="max-w-6xl mx-auto space-y-6">
    {# Ticket Header #}
    <div class="bg-gradient-to-br from-white to-slate-50 dark:from-slate-900 dark:to-slate-800 rounded-xl border border-slate-200 dark:border-slate-700 shadow-lg p-6">
        <div class="flex items-start justify-between mb-4">
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-emerald-600 to-teal-600 flex items-center justify-center shadow-lg">
                    <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"/>
                    </svg>
                </div>
                <div>
                    <h1 class="text-2xl font-bold text-slate-900 dark:text-white">{{ ticket.subject }}</h1>
                    <p class="text-sm text-slate-600 dark:text-slate-400 mt-1 flex items-center gap-2">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                        </svg>
                        Created {{ ticket.createdAt|date('Y-m-d H:i') }} by {{ ticket.createdBy.firstName ~ ' ' ~ ticket.createdBy.lastName }}
                    </p>
                </div>
            </div>
            <div class="flex flex-wrap gap-2 justify-end">
                {% if ticket.status == 'OPEN' %}
                    <span class="px-3 py-1.5 text-xs font-bold rounded-lg bg-gradient-to-r from-emerald-500 to-emerald-600 text-white shadow-sm">OPEN</span>
                {% elseif ticket.status == 'IN_PROGRESS' %}
                    <span class="px-3 py-1.5 text-xs font-bold rounded-lg bg-gradient-to-r from-yellow-500 to-amber-600 text-white shadow-sm">IN PROGRESS</span>
                {% elseif ticket.status == 'WAITING_USER' %}
                    <span class="px-3 py-1.5 text-xs font-bold rounded-lg bg-gradient-to-r from-teal-500 to-pink-600 text-white shadow-sm">WAITING USER</span>
                {% elseif ticket.status == 'CLOSED' %}
                    <span class="px-3 py-1.5 text-xs font-bold rounded-lg bg-gradient-to-r from-slate-500 to-slate-600 text-white shadow-sm">CLOSED</span>
                {% endif %}

                {% if ticket.priority == 'LOW' %}
                    <span class="px-3 py-1.5 text-xs font-bold rounded-lg bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400 border border-green-300 dark:border-green-800">LOW</span>
                {% elseif ticket.priority == 'MEDIUM' %}
                    <span class="px-3 py-1.5 text-xs font-bold rounded-lg bg-yellow-100 dark:bg-yellow-900/30 text-yellow-700 dark:text-yellow-400 border border-yellow-300 dark:border-yellow-800">MEDIUM</span>
                {% elseif ticket.priority == 'HIGH' %}
                    <span class="px-3 py-1.5 text-xs font-bold rounded-lg bg-red-100 dark:bg-red-900/30 text-red-700 dark:text-red-400 border border-red-300 dark:border-red-800">HIGH</span>
                {% endif %}
                <a href="{{ path('client_dashboard') }}" class="px-3 py-1.5 text-xs font-semibold rounded-lg bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 text-slate-700 dark:text-slate-200 transition-all">
                    ÔåÉ Back
                </a>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-6 pt-6 border-t border-slate-200 dark:border-slate-700">
            <div class="flex items-center gap-3 bg-white dark:bg-slate-900 rounded-lg p-3 border border-slate-200 dark:border-slate-800">
                <div class="w-8 h-8 rounded-lg bg-teal-100 dark:bg-teal-900/30 flex items-center justify-center">
                    <svg class="w-5 h-5 text-emerald-600 dark:text-teal-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/>
                    </svg>
                </div>
                <div>
                    <span class="text-xs font-medium text-slate-500 dark:text-slate-400">Category</span>
                    <p class="text-sm font-semibold text-slate-900 dark:text-white">{{ ticket.category.name }}</p>
                </div>
            </div>
            <div class="flex items-center gap-3 bg-white dark:bg-slate-900 rounded-lg p-3 border border-slate-200 dark:border-slate-800">
                <div class="w-8 h-8 rounded-lg bg-teal-100 dark:bg-teal-900/30 flex items-center justify-center">
                    <svg class="w-5 h-5 text-teal-600 dark:text-teal-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/>
                    </svg>
                </div>
                <div>
                    <span class="text-xs font-medium text-slate-500 dark:text-slate-400">Messages</span>
                    <p class="text-sm font-semibold text-slate-900 dark:text-white">{{ ticket.messageCount }}</p>
                </div>
            </div>
        </div>
    </div>

    {# Closed Ticket Alert - Show prominently if closed #}
    {% if ticket.status == 'CLOSED' %}
        <div class="bg-gradient-to-r from-slate-50 to-slate-100 dark:from-slate-800 dark:to-slate-900 border-2 border-slate-400 dark:border-slate-600 rounded-xl shadow-lg p-6">
            <div class="flex items-start gap-4">
                <div class="flex-shrink-0 w-14 h-14 rounded-xl bg-gradient-to-br from-slate-500 to-slate-700 flex items-center justify-center shadow-lg">
                    <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                </div>
                <div class="flex-1">
                    <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-2">­ƒöÆ This Ticket is Closed</h3>
                    <p class="text-sm text-slate-700 dark:text-slate-300 mb-4">
                        This ticket has been marked as resolved by our support team. 
                        <strong>You cannot send new replies to closed tickets.</strong>
                    </p>
                    {% if satisfactionForm %}
                        <div class="bg-emerald-50 dark:bg-emerald-900/20 border-l-4 border-emerald-500 rounded-lg p-4 mt-4">
                            <div class="flex items-center justify-between">
                                <div class="flex items-center gap-3">
                                    <svg class="w-6 h-6 text-emerald-600 dark:text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>
                                    </svg>
                                    <div>
                                        <p class="font-bold text-emerald-900 dark:text-emerald-100">How satisfied are you with the resolution?</p>
                                        <p class="text-xs text-emerald-700 dark:text-emerald-300 mt-0.5">Your feedback helps us improve our support!</p>
                                    </div>
                                </div>
                                <button onclick="openRatingModal()" class="inline-flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-emerald-600 to-teal-600 hover:from-emerald-700 hover:to-teal-700 text-white rounded-xl font-bold transition-all shadow-lg shadow-emerald-500/30 hover:shadow-emerald-500/50 transform hover:scale-105">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>
                                    </svg>
                                    Rate Now Ô¡É
                                </button>
                            </div>
                        </div>
                    {% endif %}
                    {% if ticket.closedAt %}
                        <p class="text-xs text-slate-500 dark:text-slate-400 mt-3">
                            <svg class="w-4 h-4 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                            </svg>
                            Closed on {{ ticket.closedAt|date('F d, Y \a\t H:i') }}
                        </p>
                    {% endif %}
                </div>
            </div>
        </div>
    {% endif %}

    {# Messages - Chat Style #}
    <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 shadow-lg overflow-hidden">
        <div class="bg-gradient-to-r from-emerald-600 to-teal-600 px-6 py-4">
            <h2 class="text-lg font-bold text-white flex items-center gap-2">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z"/>
                </svg>
                Conversation
            </h2>
        </div>

        <div class="p-6 space-y-4 max-h-[600px] overflow-y-auto bg-gradient-to-b from-slate-50/50 to-white dark:from-slate-900/50 dark:to-slate-900">
            {% for message in messages %}
                {% if message.senderRole == 'ADMIN' %}
                    {# Support message - left aligned #}
                    <div class="flex items-start gap-3 animate-slide-in-left">
                        <div class="w-10 h-10 rounded-full bg-gradient-to-br from-emerald-500 to-teal-600 flex items-center justify-center flex-shrink-0 shadow-lg">
                            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"/>
                            </svg>
                        </div>
                        <div class="flex-1 max-w-2xl">
                            <div class="bg-gradient-to-br from-emerald-50 to-teal-50 dark:from-emerald-900/30 dark:to-teal-900/30 rounded-2xl rounded-tl-sm border border-emerald-200 dark:border-emerald-800 p-4 shadow-sm">
                                <div class="flex items-center justify-between mb-2">
                                    <div class="flex items-center gap-2">
                                        <span class="text-sm font-bold text-emerald-900 dark:text-emerald-300">Support Team</span>
                                        <span class="px-2 py-0.5 text-xs font-bold rounded-full bg-emerald-500 text-white">ADMIN</span>
                                    </div>
                                    <span class="text-xs text-slate-500 dark:text-slate-400">{{ message.createdAt|date('H:i') }}</span>
                                </div>
                                <div class="text-sm text-slate-800 dark:text-slate-200 whitespace-pre-line leading-relaxed">{{ message.message }}</div>
                                {% if message.fileName %}
                                    <div class="mt-3 pt-3 border-t border-emerald-200 dark:border-emerald-800">
                                        {% set fileExtension = message.fileName|split('.')|last|lower %}
                                        {% if fileExtension in ['jpg', 'jpeg', 'png', 'gif', 'webp', 'svg'] %}
                                            <a href="{{ message.filePath }}" target="_blank" class="block group">
                                                <img src="{{ message.filePath }}" alt="{{ message.fileName }}" class="max-w-full max-h-64 rounded-lg border border-emerald-200 dark:border-emerald-700 group-hover:opacity-90 transition-opacity">
                                                <span class="text-xs text-emerald-600 dark:text-emerald-400 mt-2 inline-block">{{ message.fileName }} ({{ (message.fileSize / 1024)|round(2) }} KB)</span>
                                            </a>
                                        {% else %}
                                            <a href="{{ message.filePath }}" target="_blank" class="inline-flex items-center gap-2 text-sm text-emerald-700 dark:text-emerald-300 hover:text-emerald-900 dark:hover:text-emerald-100 font-medium">
                                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13"/>
                                                </svg>
                                                {{ message.fileName }} <span class="text-xs">({{ (message.fileSize / 1024)|round(2) }} KB)</span>
                                            </a>
                                        {% endif %}
                                    </div>
                                {% endif %}
                            </div>
                            <p class="text-xs text-slate-400 dark:text-slate-500 mt-1 ml-3">{{ message.createdAt|date('M d, Y') }}</p>
                        </div>
                    </div>
                {% else %}
                    {# User message - right aligned #}
                    <div class="flex items-start gap-3 justify-end animate-slide-in-right">
                        <div class="flex-1 max-w-2xl">
                            <div class="bg-gradient-to-br from-emerald-500 to-teal-600 rounded-2xl rounded-tr-sm p-4 shadow-md ml-auto">
                                <div class="flex items-center justify-between mb-2">
                                    <span class="text-xs text-emerald-100">{{ message.createdAt|date('H:i') }}</span>
                                    <span class="text-sm font-bold text-white">{{ message.sender.firstName ~ ' ' ~ message.sender.lastName }}</span>
                                </div>
                                <div class="text-sm text-white whitespace-pre-line leading-relaxed">{{ message.message }}</div>
                                {% if message.fileName %}
                                    <div class="mt-3 pt-3 border-t border-emerald-400">
                                        {% set fileExtension = message.fileName|split('.')|last|lower %}
                                        {% if fileExtension in ['jpg', 'jpeg', 'png', 'gif', 'webp', 'svg'] %}
                                            <a href="{{ message.filePath }}" target="_blank" class="block group">
                                                <img src="{{ message.filePath }}" alt="{{ message.fileName }}" class="max-w-full max-h-64 rounded-lg border border-emerald-400 group-hover:opacity-90 transition-opacity">
                                                <span class="text-xs text-white opacity-90 mt-2 inline-block">{{ message.fileName }} ({{ (message.fileSize / 1024)|round(2) }} KB)</span>
                                            </a>
                                        {% else %}
                                            <a href="{{ message.filePath }}" target="_blank" class="inline-flex items-center gap-2 text-sm text-white hover:text-emerald-50 font-medium">
                                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13"/>
                                                </svg>
                                                {{ message.fileName }} <span class="text-xs opacity-90">({{ (message.fileSize / 1024)|round(2) }} KB)</span>
                                            </a>
                                        {% endif %}
                                    </div>
                                {% endif %}
                            </div>
                            <p class="text-xs text-slate-400 dark:text-slate-500 mt-1 mr-3 text-right">{{ message.createdAt|date('M d, Y') }}{% if message.isEdited %} ÔÇó Edited{% endif %}</p>
                        </div>
                        <div class="w-10 h-10 rounded-full bg-gradient-to-br from-emerald-500 to-teal-600 flex items-center justify-center flex-shrink-0 shadow-lg">
                            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                            </svg>
                        </div>
                    </div>
                {% endif %}
            {% endfor %}
        </div>
    </div>

    {# Reply Form #}
    {% if ticket.status != 'CLOSED' %}
        <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 shadow-lg overflow-hidden">
            <div class="bg-gradient-to-r from-emerald-600 to-teal-600 px-6 py-4">
                <h2 class="text-lg font-bold text-white flex items-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6"/>
                    </svg>
                    Add Reply
                </h2>
            </div>
            <div class="p-6">
                {{ form_start(replyForm, {'action': path('ticket_reply', {'id': ticket.id}), 'attr': {'class': 'space-y-5', 'novalidate': 'novalidate', 'data-validate': 'ticket-reply'}}) }}
                    <div class="bg-slate-50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700 rounded-lg p-5">
                        {{ form_widget(replyForm.message, {'attr': {'class': 'block w-full rounded-lg border-slate-300 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-100 shadow-sm focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500 transition-all resize-none', 'rows': 4, 'placeholder': 'Type your reply...'}}) }}
                        {{ form_errors(replyForm.message) }}
                        <div id="moderation-error" class="hidden mt-3 p-4 rounded-lg bg-red-50 dark:bg-red-900/20 border border-red-300 dark:border-red-700 animate-shake">
                            <div class="flex items-center gap-3">
                                <div class="flex-shrink-0 w-10 h-10 rounded-full bg-red-100 dark:bg-red-900/40 flex items-center justify-center">
                                    <svg class="w-6 h-6 text-red-600 dark:text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.732 16.5c-.77.833.192 2.5 1.732 2.5z"/>
                                    </svg>
                                </div>
                                <div>
                                    <p class="font-semibold text-red-800 dark:text-red-300">Message Blocked</p>
                                    <p id="moderation-error-text" class="text-sm text-red-700 dark:text-red-400 mt-0.5">Your message contains inappropriate content and cannot be sent. Please revise your message.</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="bg-slate-50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700 rounded-lg p-5">
                        <div class="flex items-center gap-2 mb-3">
                            <svg class="w-5 h-5 text-teal-600 dark:text-teal-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13"/>
                            </svg>
                            {{ form_label(replyForm.attachment, 'Attachment (optional)', {'label_attr': {'class': 'text-sm font-semibold text-slate-700 dark:text-slate-300'}}) }}
                        </div>
                        {{ form_widget(replyForm.attachment, {'attr': {'class': 'block w-full text-sm text-slate-500 dark:text-slate-300 file:mr-4 file:py-2.5 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-gradient-to-r file:from-emerald-50 file:to-teal-50 file:text-emerald-700 hover:file:from-emerald-100 hover:file:to-teal-100 file:transition-all file:cursor-pointer dark:file:from-emerald-900/50 dark:file:to-teal-900/50 dark:file:text-emerald-300'}}) }}
                        {{ form_errors(replyForm.attachment) }}
                    </div>

                    {{ form_widget(replyForm._token) }}

                    <div class="flex justify-end">
                        <button type="submit" class="inline-flex items-center gap-2 px-6 py-2.5 bg-gradient-to-r from-emerald-600 to-teal-600 hover:from-emerald-700 hover:to-teal-700 text-white rounded-lg font-semibold transition-all shadow-lg shadow-emerald-500/30 hover:shadow-emerald-500/50">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
                            </svg>
                            Send Reply
                        </button>
                    </div>
                {{ form_end(replyForm, {'render_rest': false}) }}
            </div>
        </div>
    {% else %}
        {# Ticket is closed - Show prominent warning instead of reply form #}
        <div class="bg-white dark:bg-slate-900 rounded-xl border-2 border-slate-300 dark:border-slate-700 shadow-lg overflow-hidden">
            <div class="bg-gradient-to-r from-slate-500 to-slate-700 px-6 py-4">
                <h2 class="text-lg font-bold text-white flex items-center gap-2">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
                    </svg>
                    Ticket Locked - No New Replies
                </h2>
            </div>
            <div class="p-8 text-center">
                <div class="w-20 h-20 mx-auto mb-4 rounded-full bg-slate-100 dark:bg-slate-800 flex items-center justify-center">
                    <svg class="w-12 h-12 text-slate-600 dark:text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                </div>
                <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-2">This Ticket is Closed</h3>
                <p class="text-slate-600 dark:text-slate-400 mb-4 max-w-md mx-auto">
                    This ticket has been resolved and marked as closed by our support team. 
                    <strong class="text-slate-900 dark:text-white">You cannot add new replies to closed tickets.</strong>
                </p>
                <div class="bg-slate-50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700 rounded-lg p-4 max-w-md mx-auto">
                    <p class="text-sm text-slate-700 dark:text-slate-300">
                        <svg class="w-5 h-5 inline text-emerald-600 dark:text-emerald-400 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                        <strong>Need more help?</strong> Please create a new ticket from the support panel.
                    </p>
                </div>
            </div>
        </div>
    {% endif %}

    {# Satisfaction Rating Modal #}
    {% if satisfactionForm %}
        <div id="rating-modal" class="fixed inset-0 bg-black bg-opacity-60 z-50 flex items-center justify-center p-4" style="display: none;">
            <div class="bg-white dark:bg-slate-900 rounded-2xl shadow-2xl max-w-lg w-full transform transition-all">
                {# Modal Header #}
                <div class="bg-gradient-to-r from-emerald-600 to-teal-600 px-6 py-5 rounded-t-2xl">
                    <div class="flex items-center justify-between">
                        <h2 class="text-xl font-bold text-white flex items-center gap-3">
                            <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>
                            </svg>
                            How satisfied are you?
                        </h2>
                        <button type="button" onclick="closeRatingModal()" class="text-white hover:text-emerald-100 transition-colors">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                            </svg>
                        </button>
                    </div>
                </div>

                {# Modal Body #}
                <div class="p-6 dark:text-slate-100">
                    <p class="text-slate-600 dark:text-slate-400 mb-6 text-center">We'd love to hear about your support experience!</p>

                    <form id="satisfaction-rating-form" class="space-y-6" data-ticket-id="{{ ticket.id }}" novalidate>
                        
                        {# Star Rating Widget #}
                        <div class="text-center">
                            <label class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-4">Rate your experience</label>
                            <div class="flex gap-3 justify-center mb-2" id="star-rating-widget">
                                {% for i in 1..5 %}
                                    <svg class="w-14 h-14 cursor-pointer transition-all transform hover:scale-110 star-icon text-slate-300 dark:text-slate-600 hover:text-yellow-400" data-rating="{{ i }}" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>
                                    </svg>
                                {% endfor %}
                            </div>
                            <p id="rating-text" class="text-sm font-semibold text-slate-600 dark:text-slate-400 min-h-[24px]"></p>
                            <input type="hidden" name="satisfaction_rating_type[satisfactionRating]" id="rating-input" value="">
                        </div>

                        {# Comment Box #}
                        <div class="bg-slate-50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700 rounded-xl p-5">
                            <label for="comment-input" class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-3">Tell us more (optional)</label>
                            <textarea name="satisfaction_rating_type[satisfactionComment]" id="comment-input" rows="4" placeholder="Share your thoughts about the support you received..." class="block w-full rounded-lg border-slate-300 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-100 shadow-sm focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500 transition-all resize-none"></textarea>
                        </div>

                        {# Action Buttons #}
                        <div class="flex gap-3 pt-4">
                            <button type="button" onclick="remindLater()" class="flex-1 inline-flex items-center justify-center gap-2 px-5 py-3 bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 text-slate-700 dark:text-slate-200 rounded-xl font-semibold transition-all border border-slate-300 dark:border-slate-700">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                </svg>
                                Remind Me Later
                            </button>
                            <button type="button" id="submit-rating-btn" disabled class="flex-1 inline-flex items-center justify-center gap-2 px-5 py-3 bg-gradient-to-r from-emerald-600 to-teal-600 hover:from-emerald-700 hover:to-teal-700 text-white rounded-xl font-bold transition-all shadow-lg shadow-emerald-500/30 hover:shadow-emerald-500/50 disabled:opacity-50 disabled:cursor-not-allowed disabled:shadow-none">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                                </svg>
                                Submit Rating
                            </button>
                        </div>
                        
                        {# CSRF Token #}
                        <input type="hidden" name="_token" value="{{ csrf_token('satisfaction_rating') }}">
                    </form>
                </div>
            </div>
        </div>
    {% endif %}

    {# Display rating if already submitted #}
    {% if ticket.status == 'CLOSED' and ticket.satisfactionRating %}
        <div class="bg-gradient-to-br from-emerald-50 to-teal-50 dark:from-emerald-900/20 dark:to-teal-900/20 rounded-xl border border-emerald-200 dark:border-emerald-800 p-6">
            <div class="flex items-center justify-between">
                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-emerald-500 to-teal-500 flex items-center justify-center shadow-lg">
                        <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                        </svg>
                    </div>
                    <div>
                        <p class="font-bold text-lg text-emerald-900 dark:text-emerald-100">Thank you for your feedback!</p>
                        <p class="text-sm text-emerald-700 dark:text-emerald-300 flex items-center gap-2 mt-1">
                            You rated this ticket:
                            <span class="inline-flex items-center gap-1">
                                {% for i in 1..5 %}
                                    <svg class="w-5 h-5 {{ i <= ticket.satisfactionRating ? 'text-yellow-400' : 'text-slate-300' }}" fill="currentColor" viewBox="0 0 24 24">
                                        <path d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>
                                    </svg>
                                {% endfor %}
                                <span class="font-bold ml-1">({{ ticket.satisfactionRating }}/5)</span>
                            </span>
                        </p>
                    </div>
                </div>
            </div>
            {% if ticket.satisfactionComment %}
                <div class="mt-4 pt-4 border-t border-emerald-200 dark:border-emerald-700">
                    <p class="text-sm text-slate-600 dark:text-slate-400 italic">"{{ ticket.satisfactionComment }}"</p>
                </div>
            {% endif %}
        </div>
    {% endif %}
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
{% if satisfactionForm %}
<script>
document.addEventListener('DOMContentLoaded', function() {
    const modal = document.getElementById('rating-modal');
    const ratingInput = document.getElementById('rating-input');
    const submitBtn = document.getElementById('submit-rating-btn');
    const ratingText = document.getElementById('rating-text');
    const stars = document.querySelectorAll('.star-icon');
    let selectedRating = 0;

    const ratingLabels = {
        1: 'Ô¡É Poor',
        2: 'Ô¡ÉÔ¡É Fair',
        3: 'Ô¡ÉÔ¡ÉÔ¡É Good',
        4: 'Ô¡ÉÔ¡ÉÔ¡ÉÔ¡É Very Good',
        5: 'Ô¡ÉÔ¡ÉÔ¡ÉÔ¡ÉÔ¡É Excellent!'
    };

    // Star click handler
    stars.forEach(star => {
        star.addEventListener('click', function() {
            selectedRating = parseInt(this.dataset.rating);
            ratingInput.value = selectedRating;
            submitBtn.disabled = false;
            updateStars(selectedRating);
            ratingText.textContent = ratingLabels[selectedRating];
        });

        // Hover effect
        star.addEventListener('mouseenter', function() {
            const rating = parseInt(this.dataset.rating);
            updateStars(rating);
        });
    });

    // Reset on mouse leave
    document.getElementById('star-rating-widget').addEventListener('mouseleave', function() {
        updateStars(selectedRating);
    });

    function updateStars(rating) {
        stars.forEach((star, index) => {
            if (index < rating) {
                star.classList.remove('text-slate-300', 'dark:text-slate-600');
                star.classList.add('text-yellow-400');
                star.setAttribute('fill', 'currentColor');
            } else {
                star.classList.remove('text-yellow-400');
                star.classList.add('text-slate-300', 'dark:text-slate-600');
                star.setAttribute('fill', 'none');
            }
        });
    }

    // Handle form submission via AJAX - use click event on button instead of form submit
    const ratingForm = document.getElementById('satisfaction-rating-form');
    if (ratingForm && submitBtn) {
        // Prevent form from submitting normally
        ratingForm.addEventListener('submit', function(e) {
            e.preventDefault();
            e.stopImmediatePropagation();
            return false;
        });
        
        // Handle button click
        submitBtn.addEventListener('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            
            // Validate rating is selected
            const ratingValue = ratingInput.value;
            if (!ratingValue || ratingValue < 1 || ratingValue > 5) {
                alert('Please select a rating (1-5 stars)');
                return false;
            }
            
            // Disable submit button
            submitBtn.disabled = true;
            const originalText = submitBtn.innerHTML;
            submitBtn.innerHTML = `
                <svg class="w-5 h-5 animate-spin" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
                <span>Submitting...</span>
            `;
            
            // Prepare form data as JSON
            const commentValue = document.getElementById('comment-input').value.trim();
            const csrfToken = document.querySelector('input[name="_token"]').value;
            const ticketId = ratingForm.getAttribute('data-ticket-id');
            
            console.log('Submitting rating via AJAX...', {ticketId, rating: ratingValue, comment: commentValue});
            
            // Send AJAX request with JSON
            fetch(`/ticket/${ticketId}/satisfaction`, {
                method: 'POST',
                body: JSON.stringify({
                    rating: parseInt(ratingValue),
                    comment: commentValue,
                    _token: csrfToken
                }),
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                }
            })
            .then(async response => {
                console.log('Response status:', response.status);
                const text = await response.text();
                console.log('Response body:', text);
                
                if (!response.ok) {
                    let errorMsg = 'Server error';
                    try {
                        const errorData = JSON.parse(text);
                        errorMsg = errorData.error || errorMsg;
                    } catch(e) {
                        errorMsg = text || errorMsg;
                    }
                    throw new Error(errorMsg);
                }
                
                return JSON.parse(text);
            })
            .then(data => {
                if (data.success) {
                    // Show success message in modal
                    modal.innerHTML = `
                        <div class="bg-white dark:bg-slate-900 rounded-2xl shadow-2xl max-w-lg w-full p-8 text-center animate-fade-in">
                            <div class="w-20 h-20 mx-auto mb-4 rounded-full bg-gradient-to-br from-green-500 to-emerald-600 flex items-center justify-center shadow-lg transform scale-0 animate-pop">
                                <svg class="w-12 h-12 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                                </svg>
                            </div>
                            <h3 class="text-2xl font-bold text-slate-900 dark:text-white mb-2">­ƒÄë Thank You!</h3>
                            <p class="text-slate-600 dark:text-slate-400 mb-4">Your feedback has been recorded successfully.</p>
                            <div class="flex gap-2 justify-center items-center text-yellow-400 mb-6">
                                ${'Ô¡É'.repeat(data.rating || 5)}
                            </div>
                            <button onclick="location.reload()" class="px-8 py-3 bg-gradient-to-r from-emerald-600 to-teal-600 hover:from-emerald-700 hover:to-teal-700 text-white rounded-xl font-bold transition-all shadow-lg hover:shadow-xl transform hover:scale-105">
                                Close & Refresh
                            </button>
                        </div>
                    `;
                    
                    // Add fade-in animation styles
                    const style = document.createElement('style');
                    style.textContent = `
                        @keyframes fade-in {from {opacity: 0;} to {opacity: 1;}}
                        @keyframes pop {from {transform: scale(0);} to {transform: scale(1);}}
                        .animate-fade-in {animation: fade-in 0.3s ease-out;}
                        .animate-pop {animation: pop 0.5s ease-out 0.2s forwards;}
                    `;
                    document.head.appendChild(style);
                } else {
                    throw new Error(data.error || 'Failed to submit rating');
                }
            })
            .catch(error => {
                console.error('Error:', error);
                
                // Show error in modal
                const errorDiv = document.createElement('div');
                errorDiv.className = 'bg-red-50 dark:bg-red-900/20 border-l-4 border-red-500 p-4 rounded-lg mb-4';
                errorDiv.innerHTML = `
                    <div class="flex items-center gap-2">
                        <svg class="w-5 h-5 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                        <p class="text-red-700 dark:text-red-400 font-medium">Failed to submit rating. Please try again.</p>
                    </div>
                `;
                
                ratingForm.insertBefore(errorDiv, ratingForm.firstChild);
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalText;
                
                // Remove error after 5 seconds
                setTimeout(() => errorDiv.remove(), 5000);
            });
            
            return false;
        });
    }

    // Show modal automatically if showRatingModal is true
    {% if showRatingModal %}
        setTimeout(() => {
            openRatingModal();
        }, 2000); // Show after 2 seconds
    {% endif %}

    // Close modal on ESC key
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && modal.style.display !== 'none') {
            closeRatingModal();
        }
    });

    // Close modal when clicking outside
    modal.addEventListener('click', function(e) {
        if (e.target === modal) {
            closeRatingModal();
        }
    });
});

function openRatingModal() {
    const modal = document.getElementById('rating-modal');
    if (modal) {
        modal.style.display = 'flex';
        document.body.style.overflow = 'hidden';
    }
}

function closeRatingModal() {
    const modal = document.getElementById('rating-modal');
    if (modal) {
        modal.style.display = 'none';
        document.body.style.overflow = 'auto';
    }
}

function remindLater() {
    // Set cookie to not show modal for 24 hours
    const expiryDate = new Date();
    expiryDate.setTime(expiryDate.getTime() + (24 * 60 * 60 * 1000)); // 24 hours
    document.cookie = `rating_reminded_{{ ticket.id }}=1; expires=${expiryDate.toUTCString()}; path=/`;
    closeRatingModal();
}
</script>
{% endif %}

<script>
document.addEventListener('DOMContentLoaded', function() {
    const replyForm = document.querySelector('form[data-validate="ticket-reply"]');
    if (!replyForm) return;
    
    const textarea = replyForm.querySelector('textarea');
    const errorBox = document.getElementById('moderation-error');
    const errorText = document.getElementById('moderation-error-text');
    const submitBtn = replyForm.querySelector('button[type="submit"]');
    
    replyForm.addEventListener('submit', function(e) {
        e.preventDefault();
        
        // Hide previous error
        if (errorBox) {
            errorBox.classList.add('hidden');
            errorBox.classList.remove('animate-shake');
        }
        if (textarea) {
            textarea.classList.remove('border-red-500', 'ring-2', 'ring-red-300');
        }
        
        // Disable button, show loading
        const originalBtnHTML = submitBtn.innerHTML;
        submitBtn.disabled = true;
        submitBtn.innerHTML = `
            <svg class="w-5 h-5 animate-spin" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
            Sending...
        `;
        
        // Send via AJAX
        const formData = new FormData(replyForm);
        
        fetch(replyForm.action, {
            method: 'POST',
            body: formData,
            headers: {
                'X-Requested-With': 'XMLHttpRequest'
            }
        })
        .then(async response => {
            const data = await response.json().catch(() => null);
            
            if (!response.ok || (data && data.success === false)) {
                // Show inline error
                const errorMessage = (data && (data.error || data.message)) || 'Your message contains inappropriate content and cannot be sent. Please revise your message.';
                
                if (errorBox) {
                    errorText.textContent = errorMessage;
                    errorBox.classList.remove('hidden');
                    // Trigger shake animation
                    void errorBox.offsetWidth;
                    errorBox.classList.add('animate-shake');
                }
                if (textarea) {
                    textarea.classList.add('border-red-500', 'ring-2', 'ring-red-300');
                    textarea.focus();
                }
                
                // Re-enable button
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalBtnHTML;
                return;
            }
            
            // Success ÔÇö reload page to show the new message
            window.location.reload();
        })
        .catch(error => {
            console.error('Error:', error);
            // On network errors, submit normally
            replyForm.removeEventListener('submit', arguments.callee);
            replyForm.submit();
        });
    });
    
    // Clear error when user starts typing
    if (textarea) {
        textarea.addEventListener('input', function() {
            if (errorBox && !errorBox.classList.contains('hidden')) {
                errorBox.classList.add('hidden');
                textarea.classList.remove('border-red-500', 'ring-2', 'ring-red-300');
            }
        });
    }
});
</script>

<style>
@keyframes shake {
    0%, 100% { transform: translateX(0); }
    10%, 30%, 50%, 70%, 90% { transform: translateX(-4px); }
    20%, 40%, 60%, 80% { transform: translateX(4px); }
}
.animate-shake {
    animation: shake 0.5s ease-in-out;
}
</style>
{% endblock %}
